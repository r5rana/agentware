#!/usr/bin/env python3
"""agentware — deterministic CLI toolkit for an agentware workspace.

The LLM decides WHAT to do; this toolkit does it correctly. It is the ONLY
writer of structured data (the knowledge index.json, FEATURES.md, learning
files).

agentware ships ZERO personal data. The knowledge base lives at a user-chosen
directory OUTSIDE this repo, resolved (in order) from:

  1. the AGENTWARE_KNOWLEDGE_DIR environment variable, then
  2. the AGENTWARE_KNOWLEDGE_DIR=... line in ~/.agentware/config.env, then
  3. (legacy) the same line in <repo>/.agentware/config.env

Run `scripts/agentware init --knowledge-dir <path>` once to create the
directory structure, seed an empty index, and write the config file. Every
other knowledge command resolves the directory automatically. All paths stored
in the index are RELATIVE to the knowledge directory so the index stays
portable.
"""

import argparse
import copy
import datetime
import glob
import json
import math
import os
import re
import shutil
import subprocess
import sys
import threading
import time
from collections import OrderedDict

# --- Repo + knowledge-dir resolution ----------------------------------------
# Repo root = the parent of the scripts/ dir that holds this file. Computed from
# __file__ so the toolkit works regardless of the caller's cwd.
REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
# The config pointer lives in the user's HOME by default so the orchestrator
# package itself stays pristine (read-only) across projects. A repo-local config
# is honoured as a legacy/override fallback. `init` always writes HOME_CONFIG.
HOME_CONFIG = os.path.join(os.path.expanduser("~"), ".agentware", "config.env")
REPO_CONFIG = os.path.join(REPO_ROOT, ".agentware", "config.env")
CONFIG_PATHS = (HOME_CONFIG, REPO_CONFIG)
CONFIG_KEY = "AGENTWARE_KNOWLEDGE_DIR"

# KB auto-commit+push setting (feature 260625-kb-autocommit-default). Resolution
# precedence: the AGENTWARE_KB_AUTOCOMMIT env var -> config.env -> default ON.
# The resolved value is '1' (on) or '0' (off); the loop still only ACTS when the
# KB is a git work tree with an upstream (a non-tracked KB stays a clean no-op).
AUTOCOMMIT_KEY = "AGENTWARE_KB_AUTOCOMMIT"
AUTOCOMMIT_DEFAULT = "1"
_AUTOCOMMIT_OFF_TOKENS = ("0", "off", "no", "false", "disable", "disabled")
_AUTOCOMMIT_ON_TOKENS = ("1", "on", "yes", "true", "enable", "enabled")

# Retrieval mode setting (feature 260625-semantic-retrieval-benchmark, Phase 3).
# Resolution precedence: AGENTWARE_RETRIEVAL_MODE env -> config.env -> default
# 'deterministic' (Mode A: pure-stdlib BM25 (+ACR), zero-install, byte-identical
# forever). 'semantic' (Mode B) adds a LOCAL embedding model (hybrid BM25+embed
# via RRF). Mode B is OPT-IN and requires a local model; if that model is absent
# the EFFECTIVE mode gracefully falls back to 'deterministic' with a notice
# (never crash, never silently mislead). The CONFIGURED value is what the
# operator chose; the EFFECTIVE value is what actually runs given model presence.
RETRIEVAL_MODE_KEY = "AGENTWARE_RETRIEVAL_MODE"
RETRIEVAL_MODE_DETERMINISTIC = "deterministic"
RETRIEVAL_MODE_SEMANTIC = "semantic"
RETRIEVAL_MODE_DEFAULT = RETRIEVAL_MODE_DETERMINISTIC
# Accept friendly aliases (A/B etc.) so the onboarding prompt + CLI are forgiving.
_RETRIEVAL_MODE_DETERMINISTIC_TOKENS = (
    "deterministic", "a", "bm25", "default", "det", "modea", "mode-a")
_RETRIEVAL_MODE_SEMANTIC_TOKENS = (
    "semantic", "b", "embed", "hybrid", "local", "modeb", "mode-b")

# Workspace KB mode (feature 260625-team-mode-onboarding-fork). DISTINCT from the
# retrieval mode above: this records whether the operator runs a SOLO local KB
# ('power') or a SHARED git KB with per-user provenance ('team'). Named
# AGENTWARE_KB_MODE / --set-kb-mode / --kb-mode-only to avoid colliding with the
# pre-existing retrieval `--set-mode` (deterministic|semantic). Resolution
# precedence: AGENTWARE_KB_MODE env -> config.env -> default 'power' (today's
# solo behavior, byte-unchanged). This setting steers ONBOARDING only; it changes
# no ranking math (INV-1).
KB_MODE_KEY = "AGENTWARE_KB_MODE"
KB_MODE_POWER = "power"
KB_MODE_TEAM = "team"
KB_MODE_DEFAULT = KB_MODE_POWER
_KB_MODE_POWER_TOKENS = ("power", "p", "solo", "local", "personal", "default")
_KB_MODE_TEAM_TOKENS = ("team", "t", "shared", "git", "group")

# Per-user provenance handle (feature 260625-team-mode-onboarding-fork). In a
# SHARED (team) KB many humans write to one index, so each writer stamps their
# OWN handle as the entry `author` — distinct from the KB-wide `**Handle**:` in
# MAIN.md (the _operator_handle default). Resolution precedence:
# AGENTWARE_USER_HANDLE env -> config.env -> None (fall back to _operator_handle).
# Stored ONLY in ~/.agentware/config.env + external-KB frontmatter, NEVER in the
# package (R-LOC-03).
USER_HANDLE_KEY = "AGENTWARE_USER_HANDLE"

# Pluggable LOCAL embedder backend (feature 260625-semantic-retrieval-benchmark,
# Phase 3.2). Mode B (semantic) needs a LOCAL embedding model. The backend is
# OPTIONAL and NEVER hard-imported: it is resolved from a runtime config string
# and loaded via importlib (see load_embedder), so this script's static-import
# surface stays stdlib-only (C-dep guard / INV-6) and Mode A keeps running with
# nothing installed. AGENTWARE_EMBEDDER_BACKEND is either a dotted module name
# (importable on sys.path) or a filesystem path to a .py file exposing the
# contract `get_embedder(model=None) -> Embedder` where Embedder.embed(texts)
# returns fixed-dim deterministic vectors. Unset => no semantic backend (the
# zero-install default). AGENTWARE_EMBED_MODEL is the model id passed to the
# backend factory (e.g. the reference Ollama backend's `nomic-embed-text`).
EMBEDDER_BACKEND_KEY = "AGENTWARE_EMBEDDER_BACKEND"
EMBED_MODEL_KEY = "AGENTWARE_EMBED_MODEL"
EMBED_MODEL_DEFAULT = "nomic-embed-text"

# Dream mode (feature 260627-dream-mode, Phase 1): a scheduled, idle-gated,
# unattended DETERMINISTIC KB-maintenance cycle that moves all size-scaling
# maintenance OFF the interactive hot path. Resolution precedence mirrors the
# other SETTINGS_AW flags: AGENTWARE_DREAM env -> config.env -> default OFF.
# Dream is OPT-IN: it ships disabled and runs NOTHING until the operator enables
# it (default '0'). A typo never silently enables it (lenient parse => None =>
# fall through to the safe OFF default). The resolved value is '1' (on)/'0' (off).
DREAM_KEY = "AGENTWARE_DREAM"
DREAM_DEFAULT = "0"
_DREAM_OFF_TOKENS = ("0", "off", "no", "false", "disable", "disabled")
_DREAM_ON_TOKENS = ("1", "on", "yes", "true", "enable", "enabled")

# Dream schedule (feature 260627-dream-mode): the nightly run time the scheduler
# installer (Task 10) wires into launchd/cron. Either a nightly "HH:MM" 24h token
# or a 5-field cron expression. Default UNSET (None) — no schedule until the
# operator sets one. Resolution: AGENTWARE_DREAM_SCHEDULE env -> config.env -> None.
DREAM_SCHEDULE_KEY = "AGENTWARE_DREAM_SCHEDULE"

# Dream concurrency + idle-gate tunables (feature 260627-dream-mode, Task 3).
# The dream lockfile lives under the KB `.cache/` dir — ALREADY gitignored by
# `_ensure_kb_gitignore` so step f (kb-git commit) never stages it. It holds the
# owning pid + a monotonic-ish wall timestamp; a lock is reclaimable when its pid
# is dead OR its timestamp is older than DREAM_LOCK_TTL_SEC (a crashed dream must
# never wedge the next one forever). DREAM_SESSION_TTL_SEC bounds how recently a
# loop's live-stream.log must have been touched to count the feature as a LIVE
# session (the PostToolUse hook appends a line per tool call, so an active loop
# keeps it fresh). DREAM_LOAD_FACTOR gates on 1-min loadavg per CPU so a dream
# never competes with a busy machine.
DREAM_LOCK_REL = os.path.join(".cache", "dream.lock")
DREAM_LOCK_TTL_SEC = 1800       # 30 min: > a full cycle (audit --with-tests ~6m)
DREAM_SESSION_TTL_SEC = 900     # 15 min of live-stream silence => loop is idle/gone
DREAM_LOAD_FACTOR = 1.0         # skip when 1-min loadavg > ncpu * factor
DREAM_NICE_INCREMENT = 10       # lower priority so the cycle never competes

# Knowledge-dir-relative locations (joined with the resolved knowledge dir).
INDEX_REL = "index.json"
LEARNINGS_REL = "learnings"
DECISIONS_REL = "decisions"
FEATURES_REL = "FEATURES.md"
SENTINEL_REL = ".initialized"

# Derived Mode-B vector cache (Phase 4.1): gitignored, regenerable, NEVER source
# of truth — like index.json. Per pinned-model JSON under `.cache/vectors/`,
# keyed by content fingerprint, written ONLY by `index rebuild` (sole writer,
# INV-2). Absence => graceful fallback to Mode A.
VECTOR_CACHE_DIR_REL = os.path.join(".cache", "vectors")
VECTOR_CACHE_VERSION = 1

# Derived BM25 postings cache (feature 260625-kb-cached-inverted-index): a
# gitignored, regenerable inverted index — NEVER source of truth, exactly like
# index.json / the vector cache. A single JSON file under `.cache/`, written ONLY
# by `index rebuild` (rebuild_kb, the sole writer, INV-2). Lets a query touch the
# postings for its query terms (O(Σ df(query-term))) instead of re-tokenizing the
# whole corpus + recomputing df/avgdl every query (O(N·doc_len)). Absence /
# corruption / version- or fingerprint-mismatch => recall silently falls back to
# the live scan, so correctness NEVER depends on the cache being present (INV-1
# byte-identity is enforced by a guard test, not assumed).
BM25_CACHE_REL = os.path.join(".cache", "bm25-postings.json")
BM25_CACHE_VERSION = 1
LOGS_SESSIONS_REL = os.path.join("logs", "sessions")
GITIGNORE_REL = ".gitignore"

# The KB .gitignore `init` scaffolds. `logs/` holds full session transcripts and
# `.loop/` holds ephemeral per-feature loop state (iteration counters, .done,
# live-stream.log); both are local-only run state. With KB autocommit ON by
# default, every run would otherwise commit+push them to the remote (bloat + an
# unwanted disclosure for a security-first operator). Ignoring + untracking them
# keeps autocommit to KNOWLEDGE only (learnings, index, scorecard, MAIN).
KB_GITIGNORE_MARKER = "logs/"
# Required rules an existing KB's .gitignore must contain — compared normalized
# (stripped, trailing-slash removed) and appended if missing by _ensure_kb_gitignore.
KB_GITIGNORE_REQUIRED = ("logs", ".loop", ".cache")
KB_GITIGNORE_CONTENT = (
    "# agentware knowledge base — ignored paths (scaffolded by `agentware init`)\n"
    "# Session transcripts/logs are local-only: NEVER committed or pushed. KB\n"
    "# autocommit only ever versions knowledge (learnings, index, scorecard, MAIN).\n"
    "logs/\n"
    "\n"
    "# Ephemeral per-feature loop state (iteration counters, .done, live-stream.log).\n"
    "# Local-only run state — never committed/pushed, like logs/.\n"
    ".loop/\n"
    "\n"
    "# Derived, regenerable caches (Mode-B vector cache, future postings cache).\n"
    "# Rebuilt only by `index rebuild`; never source of truth — like index.json.\n"
    ".cache/\n"
    "\n"
    "# OS / editor / tooling noise\n"
    ".DS_Store\n"
    "__pycache__/\n"
)

# Indexed knowledge categories scaffolded by `init` inside the knowledge dir.
KNOWLEDGE_SUBDIRS = ("learnings", "projects", "configurations", "prompts",
                     "references", "skills")

# Non-indexed dirs `init` also scaffolds in the knowledge dir: per-feature work
# artifacts (plans/worklogs/state) and append-only session logs. These hold the
# operator's project work + audit trail OUTSIDE the orchestrator package so the
# package stays read-only across projects.
NON_INDEXED_DIRS = ("work", "logs", os.path.join("logs", "sessions"))

# Single source of truth for knowledge categories. The index holds the USER's
# knowledge only — framework artifacts (skills, steering, the toolkit) ship with
# the repo and are documented in README/FEATURES, not in the per-user index.
CATEGORIES = (
    "learnings",
    "decisions",
    "projects",
    "configurations",
    "prompts",
    "references",
    "skills",
)

# Files that are intentionally NEVER indexed (structural / generated). `index
# sync` must not report these as gaps, otherwise the report is pure noise.
SYNC_EXCLUDE_BASENAMES = ("MAIN.md", "FEATURES.md", "README.md")

# Maps a knowledge subdir to the canonical category + id prefix `index sync
# --fix` assigns to a newly discovered file.
SYNC_CATEGORY_RULES = (
    ("learnings/", "learnings", "learn"),
    ("decisions/", "decisions", "decide"),
    ("projects/", "projects", "project"),
    ("configurations/", "configurations", "config"),
    ("prompts/", "prompts", "prompt"),
    ("references/", "references", "ref"),
    ("skills/", "skills", "skill"),
)

# --- Steering (Deterministic Steering Format) lint config --------------------
# These operate on the IN-REPO always-loaded steering, which is framework and
# ships with the clone — unrelated to the external knowledge dir.

# Allowed directive verbs for Deterministic Steering Format (DSF-2).
DSF_VERBS = ("MUST", "NEVER", "ALWAYS", "RUN", "ASK", "STOP", "READ", "IF")

# Banned hedge words for always-loaded steering (DSF-5).
DSF_BANNED_WORDS = (
    "should", "try", "consider", "ideally", "generally",
    "usually", "maybe", "prefer", "when possible", "as needed",
)

# Total character budget for always-loaded steering (DSF-budget).
STEERING_CHAR_BUDGET = 25000

# Always-loaded steering set under Claude Code: `CLAUDE.md` is auto-loaded and
# imports `@AGENTS.md` plus the files in `steering/`. The linter lints all of
# them so the always-on layer can never drift out of the Deterministic Steering
# Format. (The `@`-import lines in CLAUDE.md are bare paths, not bullets, so they
# are not treated as rules.)
STEERING_EXPLICIT = ("CLAUDE.md", "AGENTS.md")
STEERING_GLOB = os.path.join(REPO_ROOT, "steering", "*.md")

# DSF-6: every rule bullet carries a stable rule ID like R-KB-01.
DSF_RULE_ID_RE = re.compile(r"R-[A-Z]+-\d+")
# A lintable rule line is a markdown bullet (`-` or `*`). Numbered lists,
# headings, tables, blockquotes, code fences and prose are NOT rules.
DSF_BULLET_RE = re.compile(r"^\s*[-*]\s+(.+)$")

# Required fields every index entry must carry.
REQUIRED_FIELDS = ("id", "title", "category", "path", "tags", "summary")


# --- Knowledge-dir resolution ------------------------------------------------
def resolve_knowledge_dir():
    """Resolve the knowledge directory, or return None if unconfigured.

    Precedence: AGENTWARE_KNOWLEDGE_DIR env var, then the config.env file.
    Always returns an absolute, user-expanded path.
    """
    env = os.environ.get(CONFIG_KEY)
    if env and env.strip():
        return os.path.abspath(os.path.expanduser(env.strip()))
    for cfg in CONFIG_PATHS:
        if not os.path.isfile(cfg):
            continue
        try:
            with open(cfg, "r", encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if line.startswith("#") or "=" not in line:
                        continue
                    key, _, val = line.partition("=")
                    if key.strip() == CONFIG_KEY:
                        val = val.strip().strip('"').strip("'")
                        if val:
                            return os.path.abspath(os.path.expanduser(val))
        except OSError:
            continue
    return None


def _read_config_key(key):
    """Read KEY=VALUE from the first config.env that defines it (None if absent).

    Mirrors resolve_knowledge_dir's file precedence (HOME then REPO). Values may
    be quoted; surrounding quotes are stripped.
    """
    for cfg in CONFIG_PATHS:
        if not os.path.isfile(cfg):
            continue
        try:
            with open(cfg, "r", encoding="utf-8") as f:
                for line in f:
                    s = line.strip()
                    if s.startswith("#") or "=" not in s:
                        continue
                    k, _, val = s.partition("=")
                    if k.strip() == key:
                        return val.strip().strip('"').strip("'")
        except OSError:
            continue
    return None


def _parse_autocommit(raw):
    """Map a raw setting to '1'/'0', or None if empty/unset.

    Honors the "anything that isn't an explicit off-token is ON" contract so an
    unrecognized non-empty value never silently disables autocommit.
    """
    if raw is None:
        return None
    v = raw.strip().strip('"').strip("'").lower()
    if not v:
        return None
    return "0" if v in _AUTOCOMMIT_OFF_TOKENS else "1"


def _parse_autocommit_strict(raw):
    """Strict parse for `config --set-autocommit`: only recognized tokens.

    Returns '1'/'0' for known on/off tokens, else None (caller errors out).
    """
    v = (raw or "").strip().strip('"').strip("'").lower()
    if v in _AUTOCOMMIT_OFF_TOKENS:
        return "0"
    if v in _AUTOCOMMIT_ON_TOKENS:
        return "1"
    return None


def resolve_kb_autocommit():
    """Resolve the effective KB-autocommit setting as '1' (on) or '0' (off).

    Precedence: AGENTWARE_KB_AUTOCOMMIT env var -> config.env -> default ON.
    This is the SINGLE source of truth read by agentware.sh
    (`config --kb-autocommit-only`).
    """
    env = _parse_autocommit(os.environ.get(AUTOCOMMIT_KEY))
    if env is not None:
        return env
    cfg = _parse_autocommit(_read_config_key(AUTOCOMMIT_KEY))
    if cfg is not None:
        return cfg
    return AUTOCOMMIT_DEFAULT


def _parse_retrieval_mode(raw):
    """Map a raw setting to 'deterministic'/'semantic', or None if empty/unset.

    Unrecognized non-empty values return None (the caller falls through to the
    next precedence tier, ultimately the safe 'deterministic' default) — a typo
    never silently activates the opt-in semantic mode.
    """
    if raw is None:
        return None
    v = raw.strip().strip('"').strip("'").lower()
    if not v:
        return None
    if v in _RETRIEVAL_MODE_SEMANTIC_TOKENS:
        return RETRIEVAL_MODE_SEMANTIC
    if v in _RETRIEVAL_MODE_DETERMINISTIC_TOKENS:
        return RETRIEVAL_MODE_DETERMINISTIC
    return None


def _parse_retrieval_mode_strict(raw):
    """Strict parse for `config --set-mode`/`--set-retrieval`: recognized tokens only.

    Maps the SETTINGS_AW retrieval alias too: `bm25` -> deterministic (Mode A),
    `semantic` -> semantic (Mode B), both already in the token sets above.
    """
    v = (raw or "").strip().strip('"').strip("'").lower()
    if v in _RETRIEVAL_MODE_SEMANTIC_TOKENS:
        return RETRIEVAL_MODE_SEMANTIC
    if v in _RETRIEVAL_MODE_DETERMINISTIC_TOKENS:
        return RETRIEVAL_MODE_DETERMINISTIC
    return None


def _parse_embedder_backend_strict(raw):
    """Strict parse for `config --set-embedder`: a non-empty backend spec.

    SETTINGS_AW (260627-semantic-embedding-settings) writer-side validator. The
    spec is either a dotted module name (e.g. `agentware_embedder_fastembed`,
    importable with scripts/ on sys.path) or a filesystem path to a .py backend.
    We only enforce non-emptiness + single-token-ness here (no whitespace); the
    actual contract is enforced lazily by `load_embedder` (any bad spec -> None ->
    graceful Mode-A fallback, never a crash). Returns the cleaned spec or None.
    """
    v = (raw or "").strip().strip('"').strip("'")
    if not v or any(c.isspace() for c in v):
        return None
    return v


def _parse_embed_model_strict(raw):
    """Strict parse for `config --set-embed-model`: a non-empty model id.

    SETTINGS_AW writer-side validator. The id is passed verbatim to the backend
    factory (e.g. the pinned HuggingFace id `BAAI/bge-small-en-v1.5`). We only
    enforce non-emptiness + no internal whitespace; the backend interprets it.
    Returns the cleaned id or None.
    """
    v = (raw or "").strip().strip('"').strip("'")
    if not v or any(c.isspace() for c in v):
        return None
    return v


def resolve_retrieval_mode():
    """Resolve the CONFIGURED retrieval mode ('deterministic' | 'semantic').

    Precedence: AGENTWARE_RETRIEVAL_MODE env -> config.env -> default
    'deterministic'. This is what the operator CHOSE. The EFFECTIVE mode (what
    actually runs) additionally requires a local model when 'semantic' — see
    resolve_effective_retrieval_mode().
    """
    env = _parse_retrieval_mode(os.environ.get(RETRIEVAL_MODE_KEY))
    if env is not None:
        return env
    cfg = _parse_retrieval_mode(_read_config_key(RETRIEVAL_MODE_KEY))
    if cfg is not None:
        return cfg
    return RETRIEVAL_MODE_DEFAULT


def _parse_kb_mode(raw):
    """Map a raw setting to 'power'/'team', or None if empty/unrecognized.

    An unrecognized non-empty value returns None so the caller falls through to
    the next precedence tier (ultimately the safe 'power' default) — a typo never
    silently flips a solo operator into team semantics.
    """
    if raw is None:
        return None
    v = raw.strip().strip('"').strip("'").lower()
    if not v:
        return None
    if v in _KB_MODE_TEAM_TOKENS:
        return KB_MODE_TEAM
    if v in _KB_MODE_POWER_TOKENS:
        return KB_MODE_POWER
    return None


def _parse_kb_mode_strict(raw):
    """Strict parse for `config --set-kb-mode`: only recognized tokens, else None."""
    v = (raw or "").strip().strip('"').strip("'").lower()
    if v in _KB_MODE_TEAM_TOKENS:
        return KB_MODE_TEAM
    if v in _KB_MODE_POWER_TOKENS:
        return KB_MODE_POWER
    return None


def resolve_kb_mode():
    """Resolve the configured workspace KB mode ('power' | 'team').

    Precedence: AGENTWARE_KB_MODE env -> config.env -> default 'power'. Steers
    onboarding only; never touches ranking (INV-1).
    """
    env = _parse_kb_mode(os.environ.get(KB_MODE_KEY))
    if env is not None:
        return env
    cfg = _parse_kb_mode(_read_config_key(KB_MODE_KEY))
    if cfg is not None:
        return cfg
    return KB_MODE_DEFAULT


def _parse_dream(raw):
    """Map a raw dream setting to '1'/'0', or None if empty/unrecognized.

    Lenient (precedence-tier) parse: an unrecognized non-empty value returns None
    so the caller falls through to the next tier (ultimately the safe OFF
    default) — a typo never silently ENABLES the unattended cycle.
    """
    if raw is None:
        return None
    v = raw.strip().strip('"').strip("'").lower()
    if not v:
        return None
    if v in _DREAM_OFF_TOKENS:
        return "0"
    if v in _DREAM_ON_TOKENS:
        return "1"
    return None


def _parse_dream_strict(raw):
    """Strict parse for `config --set-dream`: only recognized on/off tokens."""
    v = (raw or "").strip().strip('"').strip("'").lower()
    if v in _DREAM_OFF_TOKENS:
        return "0"
    if v in _DREAM_ON_TOKENS:
        return "1"
    return None


def resolve_dream():
    """Resolve the effective dream setting as '1' (on) or '0' (off).

    Precedence: AGENTWARE_DREAM env -> config.env -> default OFF. Read per-run
    (no daemon); the scheduler/installer + the `dream` command consult this.
    """
    env = _parse_dream(os.environ.get(DREAM_KEY))
    if env is not None:
        return env
    cfg = _parse_dream(_read_config_key(DREAM_KEY))
    if cfg is not None:
        return cfg
    return DREAM_DEFAULT


def _parse_dream_schedule_strict(raw):
    """Strict parse/normalize for `config --set-dream-schedule`.

    Accepts either a nightly 24h "HH:MM" token (normalized to zero-padded
    "HH:MM") or a 5-field cron expression (each field limited to digits and the
    cron metacharacters `* / , -`). Returns the normalized token, or None for an
    empty/invalid value (the caller errors out). Deterministic + stdlib-only.
    """
    v = (raw or "").strip().strip('"').strip("'")
    if not v:
        return None
    m = re.match(r"^([01]?\d|2[0-3]):([0-5]\d)$", v)
    if m:
        return "%02d:%02d" % (int(m.group(1)), int(m.group(2)))
    fields = v.split()
    if len(fields) == 5 and all(re.match(r"^[\d*/,\-]+$", f) for f in fields):
        return " ".join(fields)
    return None


def resolve_dream_schedule():
    """Resolve the configured dream schedule token, or None if unset.

    Precedence: AGENTWARE_DREAM_SCHEDULE env -> config.env -> None (unset). The
    value is re-validated through the strict parser so a hand-edited config typo
    degrades to 'unset' rather than propagating a malformed token to the scheduler.
    """
    env = os.environ.get(DREAM_SCHEDULE_KEY)
    if env is not None and env.strip():
        norm = _parse_dream_schedule_strict(env)
        if norm is not None:
            return norm
    cfg = _read_config_key(DREAM_SCHEDULE_KEY)
    if cfg is not None and cfg.strip():
        norm = _parse_dream_schedule_strict(cfg)
        if norm is not None:
            return norm
    return None


# --- Dream idle-gate + concurrency-lock primitives (260627-dream-mode, Task 3) -
# All deterministic + stdlib-only. Wall-clock + pid are INJECTABLE (now=, pid=)
# so the gate/lock logic is unit-testable without real processes or sleeping.

def _pid_alive(pid):
    """True if `pid` names a live process (best-effort, POSIX `kill -0`).

    A None/<=0 pid is never alive. EPERM means the pid exists but is owned by
    another user — still ALIVE (we must not reclaim its lock). ESRCH => dead.
    On platforms without os.kill semantics, default to ALIVE (never steal a lock
    we cannot prove is dead).
    """
    if not pid or pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return True
    return True


def is_session_active(kdir, now=None, ttl=DREAM_SESSION_TTL_SEC):
    """Return the name of a LIVE agentware loop feature, or None if all idle.

    The loop keeps PER-FEATURE state under `work/<feature>/.loop` (agentware.sh
    STATE_DIR): a `.done` sentinel marks a finished feature, and `live-stream.log`
    is appended to on every tool call so an ACTIVE loop keeps its mtime fresh. A
    feature counts as live when `.done` is ABSENT and `live-stream.log` (or the
    `.iteration` counter) was touched within `ttl` seconds. Scans ALL features
    (loop state is per-feature, not global) and returns the first live one found
    (sorted for determinism) so the result is a stable, testable signal.
    """
    if not kdir:
        return None
    now = time.time() if now is None else now
    work = os.path.join(kdir, "work")
    if not os.path.isdir(work):
        return None
    for loop_dir in sorted(glob.glob(os.path.join(work, "*", ".loop"))):
        if os.path.isfile(os.path.join(loop_dir, ".done")):
            continue
        fresh = False
        for marker in ("live-stream.log", ".iteration"):
            p = os.path.join(loop_dir, marker)
            try:
                if now - os.path.getmtime(p) <= ttl:
                    fresh = True
                    break
            except OSError:
                continue
        if fresh:
            return os.path.basename(os.path.dirname(loop_dir))
    return None


def _load_is_high(threshold=None, ncpu=None):
    """(is_high, load1, threshold): is the 1-min loadavg above the per-CPU bound?

    Uses os.getloadavg (stdlib, POSIX). Where it is unavailable (e.g. some
    Windows), load is unknowable => NEVER block (returns is_high=False). The
    threshold defaults to ncpu * DREAM_LOAD_FACTOR.
    """
    if ncpu is None:
        ncpu = os.cpu_count() or 1
    if threshold is None:
        threshold = ncpu * DREAM_LOAD_FACTOR
    try:
        load1 = os.getloadavg()[0]
    except (OSError, AttributeError):
        return (False, None, threshold)
    return (load1 > threshold, load1, threshold)


def dream_gate_reason(kdir, force=False, now=None, load=None):
    """Pure idle-gate decision: a SKIP reason string when busy, else None.

    `force` bypasses the IDLE checks (an operator's manual run) but NEVER the
    concurrency lock (handled separately by dream_acquire_lock). `load` may be
    injected as a (is_high, load1, threshold) tuple for testing; otherwise it is
    sampled live. Returns None when the cycle may proceed.
    """
    if force:
        return None
    feature = is_session_active(kdir, now=now)
    if feature:
        return ("a loop session is active (feature %r) — deferring so the dream "
                "never competes with interactive work" % feature)
    is_high, load1, threshold = _load_is_high() if load is None else load
    if is_high:
        return ("system load is high (1-min loadavg %.2f > %.2f) — deferring the "
                "dream to stay off the hot path" % (load1, threshold))
    return None


def _dream_lock_path(kdir):
    return os.path.join(kdir, DREAM_LOCK_REL)


def _read_dream_lock(path):
    """Return the lock record dict ({'pid':int,'ts':float}) or None if absent/garbage."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            rec = json.load(f)
        if isinstance(rec, dict):
            return rec
    except (OSError, ValueError):
        pass
    return None


def dream_acquire_lock(kdir, now=None, ttl=DREAM_LOCK_TTL_SEC, pid=None):
    """Acquire the dream lock; True on success, False if another LIVE dream holds it.

    The lock is a JSON {pid, ts} file under the gitignored KB `.cache/`. A held
    lock is RECLAIMED (stolen) when its owner pid is dead OR its ts is older than
    `ttl` (a crashed dream must never wedge the next). Otherwise acquisition
    fails. Best-effort + deterministic given injected now/pid. Returns False on a
    write error (never crash the caller).
    """
    if not kdir:
        return False
    now = time.time() if now is None else now
    pid = os.getpid() if pid is None else pid
    path = _dream_lock_path(kdir)
    existing = _read_dream_lock(path)
    if existing is not None:
        opid = existing.get("pid")
        ots = existing.get("ts")
        live_pid = _pid_alive(opid) and opid != pid
        fresh = isinstance(ots, (int, float)) and (now - ots) < ttl
        if live_pid and fresh:
            return False  # another live, non-stale dream holds it
        # else: dead-pid OR expired-mtime => reclaim below
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        tmp = "%s.tmp.%d" % (path, pid)
        with open(tmp, "w", encoding="utf-8") as f:
            json.dump({"pid": pid, "ts": now}, f, sort_keys=True)
        os.replace(tmp, path)
    except OSError:
        return False
    return True


def dream_release_lock(kdir, pid=None):
    """Release the dream lock IFF we own it (pid match). No-op otherwise.

    Never raises: a missing/foreign lock just returns without error so the
    try/finally cleanup in the dream command is always safe.
    """
    if not kdir:
        return
    pid = os.getpid() if pid is None else pid
    path = _dream_lock_path(kdir)
    rec = _read_dream_lock(path)
    if rec is not None and rec.get("pid") not in (pid, None):
        return  # owned by another live dream; do not remove it
    try:
        os.remove(path)
    except OSError:
        pass


def _dream_lower_priority(increment=DREAM_NICE_INCREMENT):
    """Best-effort lower this process's scheduling priority (os.nice). Returns the
    new niceness or None where unsupported. Never raises (a failed nice must not
    abort the cycle)."""
    try:
        return os.nice(increment)
    except (OSError, AttributeError):
        return None


def _normalize_user_handle(raw):
    """Sanitize a per-user handle into a safe single config token, or None.

    Strips surrounding quotes/whitespace, collapses internal whitespace to '-'
    (so a multi-word handle can't corrupt the `KEY=VALUE` config line), and drops
    characters outside a conservative `[A-Za-z0-9._-]` allowlist. Returns None for
    an empty/all-stripped result so the caller can reject it.
    """
    if raw is None:
        return None
    v = raw.strip().strip('"').strip("'").strip()
    if not v:
        return None
    v = re.sub(r"\s+", "-", v)
    v = re.sub(r"[^A-Za-z0-9._-]", "", v)
    # Require at least one alphanumeric: a handle that collapses to only
    # separators (e.g. "!!! @@@" -> "-") is not a usable provenance handle.
    if not re.search(r"[A-Za-z0-9]", v):
        return None
    return v


def resolve_user_handle():
    """Resolve the per-user provenance handle, or None if unset.

    Precedence: AGENTWARE_USER_HANDLE env -> config.env -> None. None means the
    writer falls back to _operator_handle(kdir) — byte-identical to pre-team
    behavior.
    """
    env = _normalize_user_handle(os.environ.get(USER_HANDLE_KEY))
    if env:
        return env
    cfg = _normalize_user_handle(_read_config_key(USER_HANDLE_KEY))
    if cfg:
        return cfg
    return None


def resolve_embedder_backend():
    """Resolve the configured LOCAL embedder backend spec, or None.

    Precedence: AGENTWARE_EMBEDDER_BACKEND env -> config.env -> None. An unset
    spec means NO semantic backend, so Mode A stays the zero-install default.
    The spec is either a dotted module name (importable on sys.path) or a
    filesystem path to a .py file satisfying the embedder contract (see
    load_embedder).
    """
    env = os.environ.get(EMBEDDER_BACKEND_KEY)
    if env and env.strip():
        return env.strip()
    cfg = _read_config_key(EMBEDDER_BACKEND_KEY)
    if cfg and cfg.strip():
        return cfg.strip()
    return None


def resolve_embed_model():
    """Resolve the embedding model id (env -> config.env -> default).

    Passed to the backend factory. The default names the reference Ollama
    backend's `nomic-embed-text`; other backends interpret it as they see fit.
    """
    env = os.environ.get(EMBED_MODEL_KEY)
    if env and env.strip():
        return env.strip()
    cfg = _read_config_key(EMBED_MODEL_KEY)
    if cfg and cfg.strip():
        return cfg.strip()
    return EMBED_MODEL_DEFAULT


# Lazy cache of loaded embedder instances, keyed by (spec, model). A failed load
# is memoized as _EMBEDDER_SENTINEL so a broken/absent backend is probed once,
# not on every recall. _reset_embedder_cache() clears it (test/config-change seam).
_EMBEDDER_SENTINEL = object()
_EMBEDDER_CACHE = {}


def _load_embedder_module(spec):
    """Dynamically import the backend module from a dotted name OR a .py path.

    Uses importlib (stdlib) with a RUNTIME string, so NO static `import` of the
    optional backend ever appears in this file — the stdlib-only static-import
    guard (INV-6) stays green and Mode A keeps running with nothing installed.
    Returns the loaded module or raises (the caller converts any failure to a
    graceful None).
    """
    import importlib  # stdlib, lazy
    looks_like_path = (
        spec.endswith(".py") or (os.sep in spec) or spec.startswith(".")
        or spec.startswith("~") or os.path.isfile(os.path.expanduser(spec)))
    if looks_like_path:
        import importlib.util  # stdlib, lazy
        path = os.path.abspath(os.path.expanduser(spec))
        modname = "agentware_embedder_" + re.sub(
            r"[^0-9A-Za-z_]", "_", os.path.basename(path))
        loader_spec = importlib.util.spec_from_file_location(modname, path)
        if loader_spec is None or loader_spec.loader is None:
            raise ImportError("cannot load embedder backend from %r" % spec)
        module = importlib.util.module_from_spec(loader_spec)
        loader_spec.loader.exec_module(module)
        return module
    return importlib.import_module(spec)


def load_embedder(backend=None, model=None):
    """Lazily load the configured LOCAL embedder, or None if unavailable.

    Contract — the backend module MUST expose a factory::

        get_embedder(model=None) -> Embedder

    where Embedder satisfies::

        embed(texts: list[str]) -> list[list[float]]   # fixed-dim, deterministic
        dim: int                                       # optional

    Determinism (INV-1, Mode B): a backend must return the SAME vector for the
    SAME input (pinned model + rounded floats); RRF later fuses on integer ranks.

    NEVER hard-imports the backend: the spec is a runtime config string loaded
    via importlib, so this script's static-import surface stays stdlib-only
    (C-dep guard / INV-6) and Mode A runs with nothing installed. ANY failure
    (unset spec, missing module, bad contract, import/exec error) returns None —
    the caller gracefully falls back to deterministic Mode A and NEVER crashes.
    """
    spec = backend if backend is not None else resolve_embedder_backend()
    if not spec:
        return None
    mdl = model if model is not None else resolve_embed_model()
    key = (spec, mdl)
    if key in _EMBEDDER_CACHE:
        cached = _EMBEDDER_CACHE[key]
        return None if cached is _EMBEDDER_SENTINEL else cached
    embedder = None
    try:
        module = _load_embedder_module(spec)
        factory = getattr(module, "get_embedder", None)
        if not callable(factory):
            raise AttributeError(
                "embedder backend %r exposes no get_embedder(model=...) factory"
                % spec)
        candidate = factory(model=mdl)
        if candidate is None or not callable(getattr(candidate, "embed", None)):
            raise TypeError(
                "embedder backend %r did not return an object with .embed()"
                % spec)
        embedder = candidate
    except Exception:
        # Graceful: a broken/absent backend NEVER crashes the CLI; Mode A is
        # always available. (We intentionally swallow the cause here; callers
        # surface a user-facing fallback notice via resolve_effective_*.)
        embedder = None
    _EMBEDDER_CACHE[key] = embedder if embedder is not None else _EMBEDDER_SENTINEL
    return embedder


def _reset_embedder_cache():
    """Clear the lazy embedder cache (test/seam hook for config changes)."""
    _EMBEDDER_CACHE.clear()


# --- Derived vector cache (Phase 4.1) ----------------------------------------
# A regenerable, gitignored artifact (like index.json / postings) holding one
# embedding per indexed entry, keyed by a content fingerprint + pinned model id.
# Sole writer is `index rebuild` (cmd_index_rebuild -> rebuild_vector_cache);
# NEVER written lazily inside recall/eval (INV-2 read-only). Missing/corrupt/
# stale/model-mismatch => graceful fallback to Mode A — the cache is an
# optimization, never a correctness dependency. Determinism (INV-1, Mode B):
# given a pinned model + identical corpus, delete+rebuild yields byte-identical
# vectors and a byte-identical cache file (sorted keys, embedder-rounded floats).


def _model_slug(model):
    """Filesystem-safe slug for a model id (used in the cache filename)."""
    return re.sub(r"[^0-9A-Za-z._-]", "_", (model or "default").strip()) or "default"


def vector_cache_path(kdir, model):
    """Absolute path to the per-model vector cache JSON under `.cache/vectors/`."""
    return os.path.join(kdir, VECTOR_CACHE_DIR_REL, _model_slug(model) + ".json")


def _corpus_fingerprint(doc_text):
    """Stable content fingerprint for one corpus document (sha256 hex).

    Keying vectors by this lets `index rebuild` re-embed ONLY content-changed
    entries (incremental) while reusing unchanged ones byte-for-byte.
    """
    import hashlib  # stdlib, lazy
    return hashlib.sha256((doc_text or "").encode("utf-8")).hexdigest()


def load_vector_cache(kdir, model):
    """Load the derived vector cache for `model`, or None if unusable.

    Graceful by contract: a missing file, corrupt JSON, version mismatch, or a
    model mismatch ALL return None so the caller falls back to Mode A. Never
    raises, never mutates. Returns a dict::

        {"version", "model", "dim", "vectors": {id: {"fp", "v": [floats]}}}
    """
    path = vector_cache_path(kdir, model)
    try:
        with open(path, "r", encoding="utf-8") as f:
            cache = json.load(f)
    except (OSError, ValueError):
        return None
    if not isinstance(cache, dict):
        return None
    if cache.get("version") != VECTOR_CACHE_VERSION:
        return None
    if cache.get("model") != model:
        return None
    if not isinstance(cache.get("vectors"), dict):
        return None
    return cache


def build_vector_cache(kdir, data, embedder, model):
    """Embed + persist corpus vectors for `model` (the `index rebuild` writer).

    Incremental: reuses any existing cached vector whose entry id + content
    fingerprint are unchanged, and embeds ONLY the changed/new entries (one
    batched `embedder.embed(...)` call). Writes the cache deterministically
    (sorted keys) so delete+rebuild is byte-identical given a pinned model.
    Returns a stats dict: {embedded, reused, total, dim, model, path}.
    """
    corpus = build_corpus(kdir, data)
    prev = load_vector_cache(kdir, model) or {}
    prev_vectors = prev.get("vectors") or {}

    # Decide per entry: reuse (fingerprint unchanged) vs. (re)embed.
    plan = []          # [(id, fp, reused_vector_or_None)]
    to_embed_idx = []  # positions in `plan` needing embedding
    to_embed_txt = []
    for entry, doc_text in corpus:
        eid = entry.get("id")
        if eid is None:
            continue
        fp = _corpus_fingerprint(doc_text)
        cached = prev_vectors.get(eid)
        if isinstance(cached, dict) and cached.get("fp") == fp \
                and isinstance(cached.get("v"), list):
            plan.append((eid, fp, list(cached["v"])))
        else:
            plan.append((eid, fp, None))
            to_embed_idx.append(len(plan) - 1)
            to_embed_txt.append(doc_text)

    embedded = 0
    if to_embed_txt:
        vectors = embedder.embed(to_embed_txt)
        if len(vectors) != len(to_embed_txt):
            raise ValueError(
                "embedder returned %d vectors for %d inputs"
                % (len(vectors), len(to_embed_txt)))
        for pos, vec in zip(to_embed_idx, vectors):
            eid, fp, _ = plan[pos]
            plan[pos] = (eid, fp, list(vec))
            embedded += 1

    out_vectors = {}
    dim = 0
    for eid, fp, vec in plan:
        if vec is None:
            continue
        if dim == 0:
            dim = len(vec)
        elif len(vec) != dim:
            raise ValueError(
                "vector dim drift for %r: %d != %d" % (eid, len(vec), dim))
        out_vectors[eid] = {"fp": fp, "v": vec}

    cache = {
        "version": VECTOR_CACHE_VERSION,
        "model": model,
        "dim": dim,
        "vectors": out_vectors,
    }
    path = vector_cache_path(kdir, model)
    os.makedirs(os.path.dirname(path), exist_ok=True)
    # Deterministic, byte-identical output: sorted keys + embedder-rounded floats.
    with open(path, "w", encoding="utf-8") as f:
        json.dump(cache, f, ensure_ascii=False, indent=2, sort_keys=True)
        f.write("\n")
    return {"embedded": embedded, "reused": len(plan) - embedded,
            "total": len(plan), "dim": dim, "model": model, "path": path}


def rebuild_vector_cache(kdir, data=None):
    """Rebuild the derived vector cache iff a LOCAL embedder is configured.

    The Mode-B half of `index rebuild`. No backend configured/loadable => a
    no-op returning {"status": "skipped"} (nothing written; Mode A unchanged,
    zero-install default holds). Never raises on a missing backend; an embedder
    runtime error is surfaced as {"status": "error"} so the index rebuild itself
    is never blocked by an optional, regenerable cache.
    """
    embedder = load_embedder()
    if embedder is None:
        return {"status": "skipped",
                "reason": "no local embedding backend configured"}
    model = resolve_embed_model()
    if data is None:
        data, err = load_index(kdir)
        if err is not None:
            return {"status": "error", "reason": err}
    # Guarantee the derived cache is gitignored BEFORE it is ever materialized,
    # so a Mode-B rebuild can never make `.cache/` committable (best-effort).
    try:
        _ensure_kb_gitignore(kdir)
    except OSError:
        pass
    try:
        stats = build_vector_cache(kdir, data, embedder, model)
    except Exception as exc:  # optional cache must never block index rebuild
        return {"status": "error", "reason": str(exc), "model": model}
    stats["status"] = "built"
    return stats


def semantic_embedder_available():
    """True iff a LOCAL embedding backend is configured AND loadable (Mode B).

    Probes the optional, lazily-imported backend via load_embedder(): True only
    when AGENTWARE_EMBEDDER_BACKEND points at a module satisfying the embedder
    contract. Unset/missing/broken backend -> False, so a 'semantic'
    configuration gracefully falls back to 'deterministic' (Mode A). NEVER
    hard-imports an optional backend: the static-import surface of this script
    stays stdlib-only (C-dep guard) so Mode A runs with nothing installed.
    """
    return load_embedder() is not None


def resolve_effective_retrieval_mode():
    """Resolve the mode that will ACTUALLY run, honoring local-model availability.

    Returns (mode, fell_back, notice):
      - configured 'deterministic'            -> ('deterministic', False, '')
      - configured 'semantic' + model present -> ('semantic',      False, '')
      - configured 'semantic' + NO model      -> ('deterministic', True,  notice)

    Mode A is always available with nothing installed (the zero-install default
    invariant); Mode B is opt-in and inert until a local model exists.
    """
    configured = resolve_retrieval_mode()
    if configured == RETRIEVAL_MODE_SEMANTIC and not semantic_embedder_available():
        notice = (
            "retrieval_mode=semantic requested but no local embedding model is "
            "available; falling back to deterministic (Mode A / BM25). Install a "
            "local model and rebuild the vector cache to enable semantic retrieval.")
        return RETRIEVAL_MODE_DETERMINISTIC, True, notice
    return configured, False, ""


def require_knowledge_dir():
    """Resolve the knowledge dir or print a uniform error and return None."""
    kdir = resolve_knowledge_dir()
    if not kdir:
        sys.stderr.write(
            "agentware: knowledge directory is not configured.\n"
            "  Run: scripts/agentware init --knowledge-dir <path>\n"
            "  Or set the AGENTWARE_KNOWLEDGE_DIR environment variable.\n")
        return None
    if not os.path.isdir(kdir):
        sys.stderr.write(
            "agentware: configured knowledge directory does not exist: %s\n"
            "  Run: scripts/agentware init --knowledge-dir %s\n" % (kdir, kdir))
        return None
    return kdir


def index_path(kdir):
    return os.path.join(kdir, INDEX_REL)


def features_path(kdir):
    return os.path.join(kdir, FEATURES_REL)


def learnings_dir(kdir):
    return os.path.join(kdir, LEARNINGS_REL)


def decisions_dir(kdir):
    return os.path.join(kdir, DECISIONS_REL)


# --- Shared index helpers ----------------------------------------------------
def load_index(kdir):
    """Load <kdir>/index.json. Returns (data, error)."""
    path = index_path(kdir)
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except FileNotFoundError:
        return None, "index file not found: %s (run 'agentware init')" % path
    except json.JSONDecodeError as exc:
        return None, "invalid JSON in %s: %s" % (path, exc)
    return data, None


def save_index(kdir, data):
    """Write <kdir>/index.json canonically (2-space indent, trailing newline)."""
    with open(index_path(kdir), "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
        f.write("\n")


def _today():
    import datetime
    return datetime.date.today().isoformat()


def _is_valid_date(s):
    """True iff `s` is a strict YYYY-MM-DD calendar date (stdlib only)."""
    if not isinstance(s, str):
        return False
    import datetime
    try:
        datetime.date.fromisoformat(s)
    except ValueError:
        return False
    # fromisoformat is lenient about some forms across versions; pin the shape.
    return bool(re.match(r"^\d{4}-\d{2}-\d{2}$", s))


def entry_last_verified(entry):
    """Effective freshness date for an entry.

    Back-compat: entries without an explicit `last_verified` are treated as
    `last_verified == created` (R-FAIL-08 freshness without a forced migration).
    """
    if not isinstance(entry, dict):
        return None
    lv = entry.get("last_verified")
    if isinstance(lv, str) and lv:
        return lv
    return entry.get("created")


# --- ACR: Authority/Confidence Re-ranking prior (provenance + freshness) -----
# A deterministic, gentle, bounded per-entry multiplier blended onto BM25
# relevance (`final = bm25_relevance × acr(entry, as_of)`). Pure stdlib, no
# LLM/RNG/network: acr is a pure function of `(entry, as_of)` so at a FIXED
# `as_of` the ranking is byte-identical across runs (INV-1). `as_of` is an
# EXPLICIT parameter (never a hidden wall-clock) so determinism is preserved;
# it defaults to today only at the CLI boundary and is PINNED in tests/eval.
#
# All constants below are tunable starting points (the win gate in Phase 3
# treats MARGIN/H/FLOOR/source-weights/alpha as parameters).
ACR_SOURCE_WEIGHTS = {"user": 1.0, "agent": 0.9, "imported": 0.8}
# Unattributed/legacy entries (no `source` frontmatter) are treated as
# agent-authored — a gentle middle weight, never the top "user" tier.
ACR_DEFAULT_SOURCE_WEIGHT = 0.9
ACR_HALF_LIFE_DAYS = 90          # confidence half-life: freshness halves every H days
ACR_FRESHNESS_FLOOR = 0.85       # a still-true old fact is never buried below this


def source_weight(source):
    """Provenance prior for an entry's `source`. user > agent > imported.

    Unknown/missing/empty source falls back to ACR_DEFAULT_SOURCE_WEIGHT so
    legacy entries are never harshly penalized. Deterministic, stdlib-only.
    """
    if isinstance(source, str):
        key = source.strip().lower()
        if key in ACR_SOURCE_WEIGHTS:
            return ACR_SOURCE_WEIGHTS[key]
    return ACR_DEFAULT_SOURCE_WEIGHT


def freshness(last_verified, as_of, half_life=ACR_HALF_LIFE_DAYS,
              floor=ACR_FRESHNESS_FLOOR):
    """Read-time half-life decay of confidence, gently floored.

    `freshness = max(floor, 0.5 ** (age_days / half_life))` where
    `age_days = max(0, as_of - last_verified)`. A future `last_verified`
    (negative age) is clamped to age 0 → 1.0 (never boosts above fresh). An
    unknown/invalid `last_verified` returns `floor` (treated as oldest, but
    only the gentle floor penalty). Pure function of the two dates; no clock.
    """
    import datetime
    if not _is_valid_date(as_of):
        raise ValueError("as_of must be a YYYY-MM-DD date, got %r" % (as_of,))
    if not _is_valid_date(last_verified):
        return floor
    lv = datetime.date.fromisoformat(last_verified)
    now = datetime.date.fromisoformat(as_of)
    age_days = (now - lv).days
    if age_days <= 0:
        return 1.0
    return max(floor, 0.5 ** (age_days / float(half_life)))


def acr(entry, as_of):
    """Authority/Confidence prior = source_weight × freshness, in [floor*0.8, 1.0].

    Pure, deterministic, bounded. Reuses `entry_last_verified` (which falls back
    to `created`) for the freshness date — no second freshness accessor. Never
    mutates `entry` (INV-2). `as_of` is explicit and required.
    """
    if not isinstance(entry, dict):
        raise ValueError("acr expects an entry dict, got %r" % (type(entry),))
    sw = source_weight(entry.get("source"))
    fr = freshness(entry_last_verified(entry), as_of)
    return sw * fr


def date_age_days(date_str, as_of):
    """Age in whole days of `date_str` as-of `as_of`, clamped ≥0.

    Pure function of two YYYY-MM-DD dates (no clock). A future date (negative
    age) clamps to 0. Returns None when either date is invalid/missing — used
    by the age-stratified slice in the ACR win gate, NOT by ranking, so an
    unknown answer date simply drops out of the stratum rather than skewing it.
    """
    if not _is_valid_date(as_of) or not _is_valid_date(date_str):
        return None
    import datetime
    age = (datetime.date.fromisoformat(as_of)
           - datetime.date.fromisoformat(date_str)).days
    return max(0, age)


def answer_age_days(entries_by_id, expected_ids, as_of):
    """Representative age (days) of a gold query's correct answer, as-of `as_of`.

    For the age-stratified no-regression guard (Phase 3.2): split gold queries
    into OLD-answer vs RECENT-answer strata. When a query has several correct
    answers we take the OLDEST present one (max age) so a query counts as
    OLD-stratum if ANY of its correct answers is old — the conservative choice
    that catches ACR "winning" only by burying still-true old facts. Returns
    None when no expected entry resolves to a valid date (excluded from slices).
    """
    ages = []
    for eid in expected_ids:
        entry = entries_by_id.get(eid)
        if not isinstance(entry, dict):
            continue
        age = date_age_days(entry_last_verified(entry), as_of)
        if age is not None:
            ages.append(age)
    return max(ages) if ages else None


def _entry_key(entry):
    return (entry.get("category") or "", entry.get("id") or "")


def insert_entry_sorted(entries, entry):
    """Insert `entry` at its (category, id) sorted slot (insertion-only)."""
    key = _entry_key(entry)
    for i, existing in enumerate(entries):
        if _entry_key(existing) > key:
            entries.insert(i, entry)
            return
    entries.append(entry)


def add_tags_to_map(tags_map, entry_id, tag_list):
    for t in tag_list:
        bucket = tags_map.get(t)
        if bucket is None:
            tags_map[t] = [entry_id]
        elif entry_id not in bucket:
            bucket.append(entry_id)


def remove_tags_from_map(tags_map, entry_id):
    for t in list(tags_map.keys()):
        bucket = tags_map.get(t)
        if isinstance(bucket, list) and entry_id in bucket:
            bucket[:] = [i for i in bucket if i != entry_id]
            if not bucket:
                del tags_map[t]


def parse_tags(raw):
    out = []
    for part in (raw or "").split(","):
        t = part.strip()
        if t and t not in out:
            out.append(t)
    return out


def validate_index(kdir, data):
    """Return a list of error strings for the index data (empty == valid).

    All entry paths are interpreted RELATIVE to the knowledge dir.
    """
    errors = []
    if not isinstance(data, dict):
        return ["index root is not a JSON object"]

    entries = data.get("entries")
    tags = data.get("tags")
    if not isinstance(entries, list):
        errors.append("'entries' is missing or not a list")
        entries = []
    if not isinstance(tags, dict):
        errors.append("'tags' is missing or not an object")
        tags = {}

    seen_ids = {}
    seen_paths = {}

    for i, entry in enumerate(entries):
        if not isinstance(entry, dict):
            errors.append("entry #%d is not an object" % i)
            continue
        eid = entry.get("id")
        label = eid if eid else "#%d" % i

        for field in REQUIRED_FIELDS:
            if field not in entry:
                errors.append("entry '%s' missing required field '%s'" % (label, field))

        cat = entry.get("category")
        if cat is not None and cat not in CATEGORIES:
            errors.append("entry '%s' has invalid category '%s'" % (label, cat))

        path = entry.get("path")
        if path:
            if not os.path.exists(os.path.join(kdir, path)):
                errors.append("entry '%s' path does not exist: %s" % (label, path))
            if path in seen_paths:
                errors.append("duplicate path '%s' (entries '%s' and '%s')"
                              % (path, seen_paths[path], label))
            else:
                seen_paths[path] = label

        if eid:
            if eid in seen_ids:
                errors.append("duplicate id '%s'" % eid)
            else:
                seen_ids[eid] = entry

        etags = entry.get("tags")
        if etags is not None and not isinstance(etags, list):
            errors.append("entry '%s' tags is not a list" % label)

        # Optional `last_verified` (freshness). Back-compat: absent is fine
        # (treated as == created). When present it MUST be a YYYY-MM-DD date.
        lv = entry.get("last_verified")
        if lv is not None and not _is_valid_date(lv):
            errors.append("entry '%s' last_verified is not YYYY-MM-DD: %r"
                          % (label, lv))

    # Tag map bidirectional consistency: entry.tags -> tags map.
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        eid = entry.get("id")
        etags = entry.get("tags")
        if not isinstance(etags, list):
            continue
        for t in etags:
            ids = tags.get(t)
            if not isinstance(ids, list) or eid not in ids:
                errors.append("tag map missing id '%s' under tag '%s'" % (eid, t))

    # Tag map bidirectional consistency: tags map -> entry.tags.
    for t, ids in tags.items():
        if not isinstance(ids, list):
            errors.append("tag '%s' is not a list" % t)
            continue
        if len(ids) == 0:
            errors.append("tag '%s' has an empty entry list" % t)
        for eid in ids:
            entry = seen_ids.get(eid)
            if entry is None:
                errors.append("tag '%s' references unknown id '%s'" % (t, eid))
            elif t not in (entry.get("tags") or []):
                errors.append("entry '%s' does not list tag '%s' (back-ref mismatch)"
                              % (eid, t))

    return errors


def _do_add(kdir, data, eid, title, category, path, tag_list, summary,
            created=None, last_verified=None):
    """Shared add core. Validates BEFORE mutating; returns (entry, error)."""
    entries = data.setdefault("entries", [])
    tags_map = data.setdefault("tags", {})

    if category not in CATEGORIES:
        return None, "invalid category '%s' (allowed: %s)" % (
            category, ", ".join(CATEGORIES))
    if not os.path.exists(os.path.join(kdir, path)):
        return None, "path does not exist (relative to knowledge dir): %s" % path
    if any(e.get("id") == eid for e in entries):
        return None, "duplicate id '%s'" % eid
    if any(e.get("path") == path for e in entries):
        return None, "path already indexed: %s" % path
    if created is not None and not _is_valid_date(created):
        return None, "created is not YYYY-MM-DD: %r" % created
    if last_verified is not None and not _is_valid_date(last_verified):
        return None, "last_verified is not YYYY-MM-DD: %r" % last_verified

    entry = {
        "id": eid,
        "title": title,
        "category": category,
        "path": path,
        "tags": tag_list,
        "created": created or _today(),
        "summary": summary,
    }
    # Optional freshness field: store ONLY when explicitly provided so the 36
    # legacy entries stay byte-stable (absent == created via entry_last_verified).
    if last_verified is not None:
        entry["last_verified"] = last_verified
    insert_entry_sorted(entries, entry)
    add_tags_to_map(tags_map, eid, tag_list)
    return entry, None


def indexed_paths(data):
    return {e.get("path") for e in (data.get("entries") or [])
            if isinstance(e, dict) and e.get("path")}


def _is_sync_candidate(path):
    """True if `path` (knowledge-dir-relative) is an indexable *.md gap."""
    p = path.replace(os.sep, "/")
    base = os.path.basename(p)
    parts = p.split("/")
    if base in SYNC_EXCLUDE_BASENAMES:
        return False
    if "templates" in parts:
        return False
    # Section roster `<section>/index.md` (exactly 2 parts) is a human roster.
    if base == "index.md" and len(parts) == 2:
        return False
    return True


def scan_unindexed(kdir, data):
    """Return sorted unindexed indexable *.md files (knowledge-dir-relative)."""
    have = indexed_paths(data)
    found = []
    for sub in KNOWLEDGE_SUBDIRS:
        d = os.path.join(kdir, sub)
        if not os.path.isdir(d):
            continue
        for root, _dirs, files in os.walk(d):
            for fn in files:
                if not fn.endswith(".md"):
                    continue
                rel = os.path.relpath(os.path.join(root, fn), kdir).replace(os.sep, "/")
                if rel in have:
                    continue
                if _is_sync_candidate(rel):
                    found.append(rel)
    return sorted(set(found))


def _infer_category(path):
    p = path.replace(os.sep, "/")
    for prefix, category, _id_prefix in SYNC_CATEGORY_RULES:
        if p.startswith(prefix):
            return category
    return "references"


def _suggest_id(path):
    p = path.replace(os.sep, "/")
    category = _infer_category(p)
    id_prefix = "ref"
    for prefix, cat, ip in SYNC_CATEGORY_RULES:
        if cat == category:
            id_prefix = ip
            break
    stem = p[:-3] if p.endswith(".md") else p
    base = os.path.basename(stem)
    if base in ("SKILL", "index"):
        base = os.path.basename(os.path.dirname(stem))
    slug = re.sub(r"[^a-z0-9]+", "-", base.lower()).strip("-")
    return "%s-%s" % (id_prefix, slug)


def _suggest_title(path):
    eid = _suggest_id(path)
    parts = eid.split("-")[1:] or eid.split("-")
    return " ".join(w.capitalize() for w in parts)


# --- init / config -----------------------------------------------------------
_CONFIG_HEADER = (
    "# agentware config — machine-specific, points at this operator's",
    "# EXTERNAL knowledge base so the orchestrator package stays read-only.",
)


def _set_config_value(key, value):
    """Upsert KEY=VALUE in HOME_CONFIG, preserving every other line.

    Creates the file (with the standard header) if absent. Replaces the FIRST
    existing definition of KEY and drops any later duplicates, so the setting is
    written exactly once. Kept in HOME (not the repo) so the package stays pristine.
    """
    os.makedirs(os.path.dirname(HOME_CONFIG), exist_ok=True)
    if os.path.isfile(HOME_CONFIG):
        with open(HOME_CONFIG, "r", encoding="utf-8") as f:
            lines = f.read().splitlines()
    else:
        lines = list(_CONFIG_HEADER)
    out, replaced = [], False
    for line in lines:
        s = line.strip()
        if not s.startswith("#") and "=" in s and s.partition("=")[0].strip() == key:
            if not replaced:
                out.append("%s=%s" % (key, value))
                replaced = True
            # else: drop the duplicate definition
        else:
            out.append(line)
    if not replaced:
        out.append("%s=%s" % (key, value))
    with open(HOME_CONFIG, "w", encoding="utf-8") as f:
        f.write("\n".join(out) + "\n")


def _write_config(kdir):
    """Pin the knowledge dir in ~/.agentware/config.env (preserving other keys).

    Kept in HOME (not the repo) so the orchestrator package stays pristine.
    """
    _set_config_value(CONFIG_KEY, kdir)


def _ensure_kb_gitignore(kdir):
    """Ensure the KB `.gitignore` exists and ignores local-only run state.

    Ignored: `logs/` (session transcripts) and `.loop/` (ephemeral per-feature
    loop state — iteration counters, .done, live-stream.log). Both are local-only
    and must never be committed/pushed.

    Idempotent: creates the file with the standard content if absent; if a
    `.gitignore` already exists but is missing a required rule (`logs/` or
    `.loop/`), appends the missing one(s) — so a KB scaffolded before a rule was
    added still gets it. Returns 'created' | 'appended' | 'kept'.
    """
    path = os.path.join(kdir, GITIGNORE_REL)
    if not os.path.exists(path):
        with open(path, "w", encoding="utf-8") as f:
            f.write(KB_GITIGNORE_CONTENT)
        return "created"
    with open(path, "r", encoding="utf-8") as f:
        existing = f.read()
    # Normalize each line (strip whitespace + trailing slash) so a bare `logs/`
    # or `.loop/` rule is recognized regardless of surrounding formatting.
    present = set(ln.strip().rstrip("/") for ln in existing.splitlines())
    missing = [rule for rule in KB_GITIGNORE_REQUIRED if rule not in present]
    if not missing:
        return "kept"
    sep = "" if existing.endswith("\n") or existing == "" else "\n"
    with open(path, "a", encoding="utf-8") as f:
        f.write(sep + "\n# Local-only run state (added by agentware).\n"
                + "".join(rule + "/\n" for rule in missing))
    return "appended"


def cmd_init(args):
    """Scaffold the external knowledge dir + seed an empty index + write config.

    Idempotent: re-running against an existing dir leaves entries intact and
    only fills in any missing structure. Does NOT write the .initialized
    sentinel — onboarding writes that after the interview.
    """
    kdir = os.path.abspath(os.path.expanduser(args.knowledge_dir))
    as_json = getattr(args, "format", "text") == "json"

    # KNOWLEDGE_SUBDIRS are indexed knowledge categories; NON_INDEXED_DIRS are
    # the operator's work artifacts (plans/worklogs) and append-only logs that
    # the orchestrator writes here INSTEAD of into the package.
    created_dirs = []
    for sub in ("",) + KNOWLEDGE_SUBDIRS + NON_INDEXED_DIRS:
        d = os.path.join(kdir, sub) if sub else kdir
        if not os.path.isdir(d):
            os.makedirs(d, exist_ok=True)
            created_dirs.append(d)

    # Seed an empty valid index only if absent (never clobber real data).
    ipath = index_path(kdir)
    seeded = False
    if not os.path.exists(ipath):
        save_index(kdir, {"entries": [], "tags": {}})
        seeded = True

    # Drop a category roster placeholder so each subdir is browsable.
    for sub in KNOWLEDGE_SUBDIRS:
        roster = os.path.join(kdir, sub, "index.md")
        if not os.path.exists(roster):
            with open(roster, "w", encoding="utf-8") as f:
                f.write("# %s\n\n_Index of %s. Entries are registered in "
                        "`../index.json` via `scripts/agentware`._\n"
                        % (sub.capitalize(), sub))

    # Install the entry templates INTO the operator's dir so their working
    # instance is self-contained and they never have to reach back into the
    # package to scaffold a learning / project / skill entry.
    installed_templates = []
    src_templates = os.path.join(REPO_ROOT, "templates")
    dst_templates = os.path.join(kdir, "templates")
    if os.path.isdir(src_templates):
        os.makedirs(dst_templates, exist_ok=True)
        for fn in sorted(os.listdir(src_templates)):
            if not fn.endswith(".md"):
                continue
            dst = os.path.join(dst_templates, fn)
            if not os.path.exists(dst):
                shutil.copyfile(os.path.join(src_templates, fn), dst)
                installed_templates.append(fn)

    # Scaffold the KB .gitignore so transcripts (logs/) are never committed/pushed
    # once autocommit is ON by default.
    gitignore_action = _ensure_kb_gitignore(kdir)

    _write_config(kdir)

    if as_json:
        json.dump({"ok": True, "knowledge_dir": kdir, "seeded_index": seeded,
                   "created_dirs": created_dirs, "installed_templates": installed_templates,
                   "gitignore": gitignore_action, "config": HOME_CONFIG},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("INITIALIZED knowledge dir: %s" % kdir)
        print("  index:  %s%s" % (ipath, " (seeded)" if seeded else " (kept)"))
        print("  config: %s" % HOME_CONFIG)
        print("  work:   %s/work/<feature>/   logs: %s/logs/" % (kdir, kdir))
        print("  .gitignore: %s (logs/ + .loop/ excluded — transcripts & loop "
              "state never committed)" % gitignore_action)
        if installed_templates:
            print("  templates installed: %s" % ", ".join(installed_templates))
        print("Next: run onboarding (.claude/skills/onboarding/SKILL.md) to "
              "personalize MAIN.md and write the .initialized sentinel.")
    return 0


def cmd_config(args):
    """Show resolved config; optionally set/print the KB-autocommit setting.

    Exit 1 if the knowledge dir is unconfigured (for the default/dir views).
    `--set-autocommit` and `--kb-autocommit-only` never require a knowledge dir.
    """
    as_json = getattr(args, "format", "text") == "json"

    # --set-autocommit on|off: persist to ~/.agentware/config.env, then report.
    set_val = getattr(args, "set_autocommit", None)
    if set_val is not None:
        norm = _parse_autocommit_strict(set_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-autocommit value %r (use on|off|1|0|yes|no)\n"
                % set_val)
            return 2
        _set_config_value(AUTOCOMMIT_KEY, norm)
        if as_json:
            json.dump({"ok": True, "kb_autocommit": norm, "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (KB autocommit %s)"
                  % (AUTOCOMMIT_KEY, norm, HOME_CONFIG,
                     "ON" if norm == "1" else "OFF"))
        return 0

    # --set-mode deterministic|semantic: persist to ~/.agentware/config.env, then
    # report (incl. any graceful fallback when semantic has no local model yet).
    mode_val = getattr(args, "set_mode", None)
    if mode_val is not None:
        norm = _parse_retrieval_mode_strict(mode_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-mode value %r (use deterministic|semantic)\n"
                % mode_val)
            return 2
        _set_config_value(RETRIEVAL_MODE_KEY, norm)
        eff, fell_back, notice = resolve_effective_retrieval_mode()
        if as_json:
            json.dump({"ok": True, "retrieval_mode": norm, "effective_mode": eff,
                       "fell_back": fell_back, "notice": notice,
                       "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (retrieval mode %s)"
                  % (RETRIEVAL_MODE_KEY, norm, HOME_CONFIG, norm))
            if fell_back:
                print("Notice: %s" % notice)
        return 0

    # --- SETTINGS_AW (260627-semantic-embedding-settings) -------------------
    # The single, config-backed, EXTENSIBLE settings layer recall/eval consult to
    # pick the active retrieval strategy. Each setter mirrors the EXACT
    # `_set_config_value` + strict-token-parse + echo pattern of `--set-mode`, so a
    # FUTURE feature flag slots in via the identical get/set pattern (extensibility
    # contract). All persisted to ~/.agentware/config.env; env still overrides
    # per-run; the change takes effect on the NEXT recall/eval (config is read
    # per-run — no daemon, no restart). Schema documented in docs/GUIDE.md.

    # --set-retrieval bm25|semantic: friendly ALIAS for `--set-mode
    # deterministic|semantic` (writes the SAME RETRIEVAL_MODE_KEY).
    retrieval_val = getattr(args, "set_retrieval", None)
    if retrieval_val is not None:
        norm = _parse_retrieval_mode_strict(retrieval_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-retrieval value %r (use bm25|semantic)\n"
                % retrieval_val)
            return 2
        _set_config_value(RETRIEVAL_MODE_KEY, norm)
        eff, fell_back, notice = resolve_effective_retrieval_mode()
        alias = "bm25" if norm == RETRIEVAL_MODE_DETERMINISTIC else "semantic"
        if as_json:
            json.dump({"ok": True, "retrieval": alias, "retrieval_mode": norm,
                       "effective_mode": eff, "fell_back": fell_back,
                       "notice": notice, "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (retrieval %s)"
                  % (RETRIEVAL_MODE_KEY, norm, HOME_CONFIG, alias))
            if fell_back:
                print("Notice: %s" % notice)
        return 0

    # --set-embedder <dotted-name|path>: persist the LOCAL embedder backend spec.
    embedder_val = getattr(args, "set_embedder", None)
    if embedder_val is not None:
        norm = _parse_embedder_backend_strict(embedder_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-embedder value %r (use a dotted module "
                "name or a path to a .py backend, no whitespace)\n" % embedder_val)
            return 2
        _set_config_value(EMBEDDER_BACKEND_KEY, norm)
        _reset_embedder_cache()
        if as_json:
            json.dump({"ok": True, "embedder_backend": norm,
                       "semantic_embedder_available": semantic_embedder_available(),
                       "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (local embedder backend)"
                  % (EMBEDDER_BACKEND_KEY, norm, HOME_CONFIG))
        return 0

    # --set-embed-model <hf-id>: persist the embedding model id.
    embed_model_val = getattr(args, "set_embed_model", None)
    if embed_model_val is not None:
        norm = _parse_embed_model_strict(embed_model_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-embed-model value %r (use a non-empty "
                "model id, no whitespace)\n" % embed_model_val)
            return 2
        _set_config_value(EMBED_MODEL_KEY, norm)
        _reset_embedder_cache()
        if as_json:
            json.dump({"ok": True, "embed_model": norm, "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (embedding model id)"
                  % (EMBED_MODEL_KEY, norm, HOME_CONFIG))
        return 0

    # --embedder-only / --embed-model-only: bare resolved values for shell consumers.
    if getattr(args, "embedder_only", False):
        spec = resolve_embedder_backend()
        if spec:
            print(spec)
        return 0
    if getattr(args, "embed_model_only", False):
        print(resolve_embed_model())
        return 0

    # --set-kb-mode power|team: persist the WORKSPACE mode (distinct from the
    # retrieval --set-mode above) to ~/.agentware/config.env, then report.
    kb_mode_val = getattr(args, "set_kb_mode", None)
    if kb_mode_val is not None:
        norm = _parse_kb_mode_strict(kb_mode_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-kb-mode value %r (use power|team)\n"
                % kb_mode_val)
            return 2
        _set_config_value(KB_MODE_KEY, norm)
        if as_json:
            json.dump({"ok": True, "kb_mode": norm, "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (workspace KB mode %s)"
                  % (KB_MODE_KEY, norm, HOME_CONFIG, norm))
        return 0

    # --set-dream on|off: persist the dream-mode opt-in (feature 260627-dream-mode)
    # to ~/.agentware/config.env, then report. Default OFF; env overrides per-run.
    dream_val = getattr(args, "set_dream", None)
    if dream_val is not None:
        norm = _parse_dream_strict(dream_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-dream value %r (use on|off|1|0|yes|no)\n"
                % dream_val)
            return 2
        _set_config_value(DREAM_KEY, norm)
        if as_json:
            json.dump({"ok": True, "dream": norm, "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (dream mode %s)"
                  % (DREAM_KEY, norm, HOME_CONFIG,
                     "ON" if norm == "1" else "OFF"))
        return 0

    # --set-dream-schedule <HH:MM|cron>: persist the nightly dream schedule token
    # the installer wires into launchd/cron. Invalid tokens are rejected.
    dream_sched_val = getattr(args, "set_dream_schedule", None)
    if dream_sched_val is not None:
        norm = _parse_dream_schedule_strict(dream_sched_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-dream-schedule value %r (use a nightly "
                "HH:MM 24h token or a 5-field cron expression)\n" % dream_sched_val)
            return 2
        _set_config_value(DREAM_SCHEDULE_KEY, norm)
        if as_json:
            json.dump({"ok": True, "dream_schedule": norm, "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (dream schedule)"
                  % (DREAM_SCHEDULE_KEY, norm, HOME_CONFIG))
        return 0

    # --set-user-handle <h>: persist the per-user provenance handle. Sanitized to
    # a safe single token; an all-invalid handle is rejected (no config corruption).
    handle_val = getattr(args, "set_user_handle", None)
    if handle_val is not None:
        norm = _normalize_user_handle(handle_val)
        if not norm:
            sys.stderr.write(
                "agentware: invalid --set-user-handle value %r "
                "(must contain at least one of A-Z a-z 0-9 . _ -)\n" % handle_val)
            return 2
        _set_config_value(USER_HANDLE_KEY, norm)
        if as_json:
            json.dump({"ok": True, "user_handle": norm, "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (per-user provenance handle)"
                  % (USER_HANDLE_KEY, norm, HOME_CONFIG))
        return 0

    # --kb-mode-only: bare resolved workspace mode for shell consumers (onboarding).
    if getattr(args, "kb_mode_only", False):
        print(resolve_kb_mode())
        return 0

    # --dream-only: bare resolved dream setting (on/off) for shell consumers
    # (the scheduler installer + the `dream` idle-gate). Default OFF.
    if getattr(args, "dream_only", False):
        print("on" if resolve_dream() == "1" else "off")
        return 0

    # --dream-schedule-only: bare resolved dream schedule token (empty if unset).
    if getattr(args, "dream_schedule_only", False):
        sched = resolve_dream_schedule()
        if sched:
            print(sched)
        return 0

    # --user-handle-only: bare resolved per-user handle (empty if unset).
    if getattr(args, "user_handle_only", False):
        h = resolve_user_handle()
        if h:
            print(h)
        return 0

    # --record-onboarding: append one onboarding event to <kdir>/logs/metrics.jsonl
    # (Rule-7 observability; gitignored, best-effort). Onboarding calls this on
    # completion so the dashboard can chart mode adoption.
    if getattr(args, "record_onboarding", False):
        kdir = resolve_knowledge_dir()
        if not kdir:
            sys.stderr.write("agentware: no knowledge dir configured\n")
            return 1
        mode = resolve_kb_mode()
        handle = resolve_user_handle()
        wrote = emit_onboarding_metric(kdir, mode, handle)
        if as_json:
            json.dump({"ok": wrote, "event": "onboarding", "mode": mode,
                       "user_handle": handle}, sys.stdout, ensure_ascii=False,
                      indent=2)
            sys.stdout.write("\n")
        else:
            print("Recorded onboarding event (mode=%s, user_handle=%s) -> "
                  "%s/logs/metrics.jsonl" % (mode, handle or "<unset>", kdir))
        return 0

    # --retrieval-mode-only: bare EFFECTIVE mode for shell consumers (the loop /
    # Phase 7 wiring). Any fallback notice goes to stderr so stdout stays a clean
    # single token for capture.
    if getattr(args, "retrieval_mode_only", False):
        eff, fell_back, notice = resolve_effective_retrieval_mode()
        print(eff)
        if fell_back:
            sys.stderr.write("agentware: %s\n" % notice)
        return 0

    # --kb-autocommit-only: bare resolved setting for shell consumers (the loop).
    if getattr(args, "kb_autocommit_only", False):
        print(resolve_kb_autocommit())
        return 0

    kdir = resolve_knowledge_dir()
    autocommit = resolve_kb_autocommit()
    retrieval_mode = resolve_retrieval_mode()
    eff_mode, mode_fell_back, _mode_notice = resolve_effective_retrieval_mode()
    kb_mode = resolve_kb_mode()
    user_handle = resolve_user_handle()
    dream = resolve_dream()
    dream_schedule = resolve_dream_schedule()
    initialized = bool(kdir) and os.path.isfile(os.path.join(kdir, SENTINEL_REL))
    if as_json:
        json.dump({"knowledge_dir": kdir, "configured": bool(kdir),
                   "initialized": initialized, "kb_autocommit": autocommit,
                   "retrieval_mode": retrieval_mode,
                   "effective_retrieval_mode": eff_mode,
                   "kb_mode": kb_mode, "user_handle": user_handle,
                   "dream": dream, "dream_schedule": dream_schedule,
                   "embedder_backend": resolve_embedder_backend(),
                   "embed_model": resolve_embed_model(),
                   "semantic_embedder_available": semantic_embedder_available()},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return 0 if kdir else 1
    if getattr(args, "knowledge_dir_only", False):
        # Bare path for shell consumers (hooks). Empty output if unconfigured.
        if kdir:
            print(kdir)
        return 0 if kdir else 1
    mode_line = "retrieval_mode: %s" % retrieval_mode
    if mode_fell_back:
        mode_line += " (effective: %s — no local model)" % eff_mode
    handle_line = "user_handle:   %s" % (user_handle or "<unset>")
    dream_line = "dream:         %s" % ("on" if dream == "1" else "off")
    dream_sched_line = "dream_sched:   %s" % (dream_schedule or "<unset>")
    # SETTINGS_AW surfacing (semantic backend choice): only meaningful in Mode B.
    embedder_line = "embedder:      %s" % (resolve_embedder_backend() or "<unset>")
    embed_model_line = "embed_model:   %s" % resolve_embed_model()
    if kdir:
        print("knowledge_dir: %s" % kdir)
        print("initialized:   %s" % ("yes" if initialized else "no"))
        print("kb_autocommit: %s" % ("on" if autocommit == "1" else "off"))
        print(mode_line)
        print(embedder_line)
        print(embed_model_line)
        print("kb_mode:       %s" % kb_mode)
        print(handle_line)
        print(dream_line)
        print(dream_sched_line)
        return 0
    print("knowledge_dir: <unconfigured>")
    print("kb_autocommit: %s" % ("on" if autocommit == "1" else "off"))
    print(mode_line)
    print(embedder_line)
    print(embed_model_line)
    print("kb_mode:       %s" % kb_mode)
    print(handle_line)
    print(dream_line)
    print(dream_sched_line)
    return 1


# --- index / query / learn / features / worklog ------------------------------
def cmd_index_add(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    entry, add_err = _do_add(
        kdir, data, args.id, args.title, args.category, args.path,
        parse_tags(args.tags), args.summary, args.created,
        getattr(args, "last_verified", None))
    if add_err is not None:
        sys.stderr.write("agentware: %s\n" % add_err)
        return 1

    # Ensure the registered (pre-existing) file is frontmatter-complete: if it
    # lacks a frontmatter block, prepend one built from the entry + defaults so
    # the file remains the rebuildable source of truth (C-1). Never overwrite an
    # existing block (idempotent); never edit the body.
    backfilled = ensure_entry_frontmatter(kdir, entry)

    save_index(kdir, data)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "added": entry, "frontmatter_backfilled": backfilled},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("ADDED entry '%s' (category=%s, path=%s)%s"
              % (args.id, args.category, args.path,
                 " [frontmatter backfilled]" if backfilled else ""))
    return 0


def cmd_index_remove(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    entries = data.setdefault("entries", [])
    tags_map = data.setdefault("tags", {})
    match = next((e for e in entries if e.get("id") == args.id), None)
    if match is None:
        sys.stderr.write("agentware: id not found: %s\n" % args.id)
        return 1

    entries[:] = [e for e in entries if e.get("id") != args.id]
    remove_tags_from_map(tags_map, args.id)
    save_index(kdir, data)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "removed": match}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("REMOVED entry '%s' (file on disk left untouched)" % args.id)
    return 0


def cmd_index_validate(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    errors = [err] if err is not None else validate_index(kdir, data)
    ok = len(errors) == 0
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": ok, "errors": errors}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        if ok:
            print("VALIDATION PASSED: index.json is consistent.")
        else:
            print("VALIDATION FAILED (%d error(s)):" % len(errors))
            for e in errors:
                print(" -", e)
    return 0 if ok else 1


def cmd_index_sync(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    candidates = scan_unindexed(kdir, data)
    as_json = getattr(args, "format", "text") == "json"

    if not args.fix:
        report = [{"path": p, "suggested_id": _suggest_id(p),
                   "suggested_category": _infer_category(p)} for p in candidates]
        if as_json:
            json.dump({"unindexed": report, "count": len(report)},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            if not report:
                print("SYNC: no unindexed *.md files in the knowledge dir.")
            else:
                print("SYNC: %d unindexed *.md file(s) (dry-run; pass --fix):"
                      % len(report))
                for r in report:
                    print("  %s  ->  id=%s category=%s"
                          % (r["path"], r["suggested_id"], r["suggested_category"]))
        return 0

    added, failures = [], []
    interactive = sys.stdin.isatty()
    for path in candidates:
        category = _infer_category(path)
        eid = _suggest_id(path)
        title = _suggest_title(path)
        if interactive:
            tags_in = input("tags for %s (comma-sep) [%s]: " % (path, category)).strip() \
                or category
            summary_in = input("summary for %s [%s]: " % (path, title)).strip() \
                or title
        else:
            tags_in = category
            summary_in = title
        entry, add_err = _do_add(
            kdir, data, eid, title, category, path, parse_tags(tags_in), summary_in)
        if add_err is not None:
            failures.append({"path": path, "error": add_err})
        else:
            added.append(entry)

    if added:
        save_index(kdir, data)
    if as_json:
        json.dump({"ok": not failures, "added": added, "failures": failures},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        for e in added:
            print("ADDED entry '%s' (category=%s, path=%s)"
                  % (e["id"], e["category"], e["path"]))
        for f in failures:
            sys.stderr.write("agentware: could not add %s: %s\n"
                             % (f["path"], f["error"]))
        if not added and not failures:
            print("SYNC: nothing to fix; all *.md files already indexed.")
    return 1 if failures else 0


def cmd_index_migrate(args):
    """One-time backfill: prepend frontmatter to every indexed entry file.

    Bootstraps the rebuildable source of truth (C-1): each entry's `.md` gets a
    frontmatter block derived from its `index.json` row + defaults
    (author=operator handle, source=agent, last_verified=created). PREPEND only —
    bodies are never edited. Idempotent: a file that already carries frontmatter
    is skipped, so re-running is a no-op (reports 0 changed).
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    author = _operator_handle(kdir)
    migrated, skipped, missing = [], [], []
    for entry in data.get("entries") or []:
        if not isinstance(entry, dict):
            continue
        rel = entry.get("path")
        if not rel or not os.path.exists(os.path.join(kdir, rel)):
            missing.append(rel)
            continue
        if ensure_entry_frontmatter(kdir, entry, author=author,
                                    source=DEFAULT_ENTRY_SOURCE):
            migrated.append(rel)
        else:
            skipped.append(rel)

    as_json = getattr(args, "format", "text") == "json"
    if as_json:
        json.dump({"ok": not missing, "migrated": migrated, "skipped": skipped,
                   "missing": missing, "migrated_count": len(migrated),
                   "skipped_count": len(skipped)},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("MIGRATE: %d file(s) gained frontmatter, %d already had it."
              % (len(migrated), len(skipped)))
        for p in migrated:
            print("  + %s" % p)
        for p in missing:
            sys.stderr.write("agentware: indexed path missing on disk: %s\n" % p)
    return 1 if missing else 0


def scan_entry_files(kdir):
    """All indexable entry *.md paths (knowledge-dir-relative), sorted.

    Same candidate rule as `index sync` (2-part `<section>/index.md` rosters and
    structural files are excluded), but WITHOUT the already-indexed filter — this
    is the full set of files `index rebuild` derives the index from.
    """
    found = []
    for sub in KNOWLEDGE_SUBDIRS:
        d = os.path.join(kdir, sub)
        if not os.path.isdir(d):
            continue
        for root, _dirs, files in os.walk(d):
            for fn in files:
                if not fn.endswith(".md"):
                    continue
                rel = os.path.relpath(os.path.join(root, fn), kdir).replace(os.sep, "/")
                if _is_sync_candidate(rel):
                    found.append(rel)
    return sorted(set(found))


def build_index_from_frontmatter(kdir):
    """Reconstruct the index dict from per-entry frontmatter alone.

    Returns (data, errors). Deterministic: entries are (category, id)-sorted and
    the tags map is rebuilt from that stable order, so identical inputs yield
    byte-identical output (C-2). `path` is derived from each file's location;
    every other column comes from its frontmatter (C-1).
    """
    entries, errors = [], []
    for rel in scan_entry_files(kdir):
        fm = read_entry_frontmatter(os.path.join(kdir, rel))
        eid = fm.get("id")
        if not eid:
            errors.append("missing frontmatter id (un-migrated?): %s" % rel)
            continue
        category = fm.get("category") or _infer_category(rel)
        created = fm.get("created") or _today()
        row = {
            "id": eid,
            "title": fm.get("title") or "",
            "category": category,
            "path": rel,
            "tags": list(fm.get("tags") or []),
            "created": created,
            "summary": fm.get("summary") or "",
            "last_verified": fm.get("last_verified") or created,
        }
        # Derived graph column: include `relates` ONLY when the entry declares
        # edges, so a relates-free KB rebuilds to a byte-identical index.json
        # (backward-compatible). Tokens are already normalized by the parser.
        rel = list(fm.get("relates") or [])
        if rel:
            row["relates"] = rel
        insert_entry_sorted(entries, row)
    tags_map = {}
    for e in entries:
        add_tags_to_map(tags_map, e["id"], e["tags"])
    return {"entries": entries, "tags": tags_map}, errors


def _roster_link(sub, rel_path):
    """Subdir-relative link target for a roster row (e.g. projects/x/index.md -> x/index.md)."""
    prefix = sub + "/"
    return rel_path[len(prefix):] if rel_path.startswith(prefix) else rel_path


def _render_roster(sub, entries):
    """Deterministic, derived `<sub>/index.md` roster (regenerated by rebuild)."""
    rows = [e for e in entries if e.get("category") == sub]
    out = ["# %s\n" % sub.capitalize(),
           "> Auto-generated roster — DO NOT edit. Source of truth is each entry's "
           "frontmatter; regenerate with `scripts/agentware index rebuild`.\n"]
    if not rows:
        out.append("_No entries yet._\n")
    else:
        out.append("| Title | Path | Summary |")
        out.append("|-------|------|---------|")
        for e in rows:
            link = _roster_link(sub, e.get("path") or "")
            out.append("| **%s** | [%s](%s) | %s |"
                       % (e.get("title") or "", link, link, e.get("summary") or ""))
        out.append("")
    return "\n".join(out) + "\n"


def rebuild_kb(kdir):
    """Regenerate index.json + rosters + FEATURES.md from frontmatter at `kdir`.

    Path-parameterized core of `index rebuild` so callers (the CLI command AND
    the git-sync push resolver, Task 4.1) can rebuild ANY knowledge dir — e.g. a
    throwaway clone mid-rebase — not just the resolved operator KB. Returns
    `(data, rosters, errors)`: on any frontmatter/validation error `data` is None,
    `errors` is the non-empty reason list, and NOTHING is written (the caller
    decides how to surface the failure). Deterministic + idempotent (C-1/C-2).
    """
    data, errors = build_index_from_frontmatter(kdir)
    if errors:
        return None, [], errors
    verrs = validate_index(kdir, data)
    if verrs:
        return None, [], ["rebuild produced an invalid index: %s" % e
                          for e in verrs]

    save_index(kdir, data)
    # Derived BM25 postings cache: rebuild_kb is its SOLE writer (INV-2 — recall/
    # eval never write it). Pure/stdlib/no-network, so this is safe even on the
    # git-sync throwaway-clone rebuild path. Best-effort: a write failure must
    # never block the index rebuild — the cache is regenerable and recall falls
    # back to the live scan when it is absent. Ensure `.cache/` is gitignored
    # before the cache is ever materialized.
    try:
        _ensure_kb_gitignore(kdir)
        write_bm25_cache(kdir, build_bm25_cache(kdir, data))
    except OSError:
        pass
    rosters = []
    for sub in KNOWLEDGE_SUBDIRS:
        d = os.path.join(kdir, sub)
        if not os.path.isdir(d):
            continue
        with open(os.path.join(d, "index.md"), "w", encoding="utf-8") as f:
            f.write(_render_roster(sub, data["entries"]))
        rosters.append("%s/index.md" % sub)
    with open(features_path(kdir), "w", encoding="utf-8") as f:
        f.write(_render_features(data))
    return data, rosters, []


def cmd_index_rebuild(args):
    """Regenerate index.json + `<sub>/index.md` rosters + FEATURES.md from frontmatter.

    The index is a DERIVED cache: this reconstructs it from the per-entry markdown
    frontmatter alone (C-1), deterministically and idempotently (C-2). It is the
    conflict-safe resolver for the derived files — never hand-edit them (C-3).
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, rosters, errors = rebuild_kb(kdir)
    if errors:
        for e in errors:
            sys.stderr.write("agentware: rebuild: %s\n" % e)
        return 1

    # Mode-B half: rebuild the derived vector cache when a LOCAL embedder is
    # configured (sole writer, INV-2). A no-op when none is installed, so the
    # zero-install Mode-A default is unaffected. `index rebuild` here is the ONLY
    # caller — the git-sync throwaway-clone resolver uses rebuild_kb() directly
    # and never embeds/networks.
    vc = rebuild_vector_cache(kdir, data)

    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "entries": len(data["entries"]),
                   "rosters": rosters, "features": features_path(kdir),
                   "vector_cache": vc},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("REBUILT index.json (%d entries) + %d roster(s) + FEATURES.md "
              "from frontmatter." % (len(data["entries"]), len(rosters)))
        if vc.get("status") == "built":
            print("REBUILT vector cache (model %s): %d embedded, %d reused, "
                  "%d total, dim %d." % (vc.get("model"), vc.get("embedded", 0),
                  vc.get("reused", 0), vc.get("total", 0), vc.get("dim", 0)))
        elif vc.get("status") == "error":
            sys.stderr.write("agentware: vector cache not rebuilt (%s); Mode A "
                             "unaffected.\n" % vc.get("reason"))
    return 0


# --- Attach-existing-repo conformance (feature 260625-team-mode-onboarding-fork) ---
# Team-mode onboarding can ADOPT an existing repo as the shared KB. Before doing
# so it must confirm the repo conforms to the framework layout, or a malformed KB
# would silently break recall/rebuild for the whole team. This check is READ-ONLY
# (INV-2): it inspects structure, validates the index, and confirms `index rebuild`
# would be a parity NO-OP (the committed index.json already equals what its entry
# frontmatter would produce) WITHOUT writing anything. A non-conformant repo is
# refused with a clear reason; the idempotent migration path (cmd_init scaffold)
# can fill missing STRUCTURE.
ATTACH_REQUIRED_DIRS = KNOWLEDGE_SUBDIRS + ("work", "logs")


def _index_parity_errors(committed, rebuilt):
    """Return [] iff `index rebuild` would not CHANGE any committed data.

    Parity is the no-op property: rebuilding from frontmatter must neither drop
    nor alter what the committed index.json already asserts. Rebuild ADDING a
    purely-defaulted field an entry lacked (e.g. `last_verified` == `created`,
    which a fresh `learn` entry omits until the first rebuild) is a benign no-op,
    NOT a divergence — so the check compares the committed entry set + the values
    committed actually carries, and ignores extra defaulted keys rebuild fills in.
    A different entry set, a dropped entry, or a changed committed value FAILS.
    """
    errs = []
    cmap = {e.get("id"): e for e in (committed.get("entries") or [])}
    rmap = {e.get("id"): e for e in (rebuilt.get("entries") or [])}
    only_c = sorted(set(cmap) - set(rmap))
    only_r = sorted(set(rmap) - set(cmap))
    if only_c:
        errs.append("entries in index.json not derivable from frontmatter: %s"
                    % ", ".join(only_c))
    if only_r:
        errs.append("entries derivable from frontmatter but absent from "
                    "index.json: %s" % ", ".join(only_r))
    for eid in sorted(set(cmap) & set(rmap)):
        c, r = cmap[eid], rmap[eid]
        for k, v in c.items():
            if r.get(k) != v:
                errs.append("entry %r field %r diverges: index.json=%r vs "
                            "frontmatter=>%r" % (eid, k, v, r.get(k)))
    return errs


def attach_conformance_report(path):
    """Read-only conformance check for adopting `path` as the KB. (ok, report).

    Checks, in order: (1) expected dirs present (KNOWLEDGE_SUBDIRS + work/ + logs/);
    (2) index.json present and `validate_index` passes; (3) `index rebuild` is a
    parity no-op (the committed index equals what entry frontmatter would rebuild).
    NEVER mutates `path`. `report` carries `missing_dirs`, `index_errors`,
    `parity_errors`, and a human `summary`.
    """
    report = {"path": path, "missing_dirs": [], "index_errors": [],
              "parity_errors": [], "ok": False, "summary": ""}
    if not os.path.isdir(path):
        report["index_errors"] = ["not a directory: %s" % path]
        report["summary"] = "refused: %s is not a directory" % path
        return False, report

    report["missing_dirs"] = [
        d for d in ATTACH_REQUIRED_DIRS
        if not os.path.isdir(os.path.join(path, d))]

    data, err = load_index(path)
    if err is not None:
        report["index_errors"] = [err]
    else:
        report["index_errors"] = validate_index(path, data)
        # Parity: rebuild-from-frontmatter must equal the committed index. Pure,
        # read-only — build_index_from_frontmatter writes nothing.
        rebuilt, rerrs = build_index_from_frontmatter(path)
        if rerrs:
            report["parity_errors"] = rerrs
        else:
            report["parity_errors"] = _index_parity_errors(data, rebuilt)

    report["ok"] = not (report["missing_dirs"] or report["index_errors"]
                        or report["parity_errors"])
    if report["ok"]:
        report["summary"] = "conformant: safe to adopt %s as the shared KB" % path
    else:
        bits = []
        if report["missing_dirs"]:
            bits.append("missing dirs: %s" % ", ".join(report["missing_dirs"]))
        if report["index_errors"]:
            bits.append("index: %s" % "; ".join(report["index_errors"]))
        if report["parity_errors"]:
            bits.append("rebuild parity: %s" % "; ".join(report["parity_errors"]))
        report["summary"] = "refused: " + " | ".join(bits)
    return report["ok"], report


def _attach_migrate_structure(path):
    """Idempotently fill MISSING KB structure (dirs/rosters; seed index if absent).

    Mirrors the dir/roster/index-seed portion of `cmd_init` but writes NO HOME
    config and clobbers nothing existing — so it can repair an attach candidate
    in place. Returns the list of created dirs.
    """
    created = []
    for sub in ("",) + KNOWLEDGE_SUBDIRS + NON_INDEXED_DIRS:
        d = os.path.join(path, sub) if sub else path
        if not os.path.isdir(d):
            os.makedirs(d, exist_ok=True)
            created.append(sub or ".")
    ipath = index_path(path)
    if not os.path.exists(ipath):
        save_index(path, {"entries": [], "tags": {}})
    for sub in KNOWLEDGE_SUBDIRS:
        roster = os.path.join(path, sub, "index.md")
        if not os.path.exists(roster):
            with open(roster, "w", encoding="utf-8") as f:
                f.write("# %s\n\n_Index of %s._\n" % (sub.capitalize(), sub))
    return created


def cmd_attach(args):
    """Validate (and optionally migrate) a candidate repo for adoption as the KB.

    `--migrate` first fills missing STRUCTURE idempotently (never clobbers data),
    then re-validates. Exit 0 iff conformant. Read-only without `--migrate`.
    """
    path = os.path.abspath(os.path.expanduser(args.path))
    migrated = []
    if getattr(args, "migrate", False):
        migrated = _attach_migrate_structure(path)
    ok, report = attach_conformance_report(path)
    report["migrated_dirs"] = migrated
    if getattr(args, "format", "text") == "json":
        json.dump(report, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        if ok:
            print("ATTACH OK: %s" % report["summary"])
        else:
            print("ATTACH REFUSED: %s" % report["summary"])
            if not getattr(args, "migrate", False) and report["missing_dirs"]:
                print("  hint: re-run with --migrate to fill missing structure "
                      "(idempotent; never clobbers data).")
    return 0 if ok else 1


# --- Declared-edge knowledge graph (deterministic, read-only) ----------------
# The graph is a DERIVED artifact reconstructed from each entry's `relates`
# frontmatter by `index rebuild` — never a separate source of truth (INV-2).
# Traversal is pure/stdlib/no-clock/no-network and visits neighbors in a stable
# sorted (type, target) order, so output is byte-identical given the same KB
# (INV-1). Edges are DECLARED by a human/agent — never LLM-extracted.

def build_adjacency(data):
    """Build (forward, reverse) adjacency from `data["entries"]` `relates` edges.

    forward[id] = sorted, de-duplicated [(type, target_id), ...]
    reverse[id] = sorted, de-duplicated [(type, source_id), ...]
    Ordered by (type, target) for determinism (INV-1). Malformed tokens are
    skipped. Pure + read-only — never mutates the KB or index (INV-2).
    """
    forward, reverse = {}, {}
    for e in data.get("entries") or []:
        if not isinstance(e, dict):
            continue
        eid = e.get("id")
        if not eid:
            continue
        for tok in (e.get("relates") or []):
            parsed = _fm_parse_relate_token(tok)
            if parsed is None:
                continue
            etype, target = parsed
            forward.setdefault(eid, []).append((etype, target))
            reverse.setdefault(target, []).append((etype, eid))
    for amap in (forward, reverse):
        for k in list(amap):
            amap[k] = sorted(set(amap[k]))
    return forward, reverse


def _canonical_cycle(cyc):
    """Rotate a cycle to start at its lexically-smallest id (stable form)."""
    i = cyc.index(min(cyc))
    return tuple(cyc[i:] + cyc[:i])


def find_cycles(forward):
    """Return a sorted list of canonical cycles (each a tuple of ids).

    Iterative colored DFS over the sorted forward adjacency — deterministic and
    cycle-safe (no infinite loop). Each distinct cycle (by node set) reported
    once. Pure + read-only (advisory; never mutates anything).
    """
    nodes = sorted(set(forward) | {t for es in forward.values() for (_, t) in es})
    adj = {n: sorted({t for (_, t) in forward.get(n, [])}) for n in nodes}
    color = {n: 0 for n in nodes}  # 0 white, 1 grey (on stack), 2 black
    cycles, seen = [], set()
    for root in nodes:
        if color[root] != 0:
            continue
        color[root] = 1
        stack = [(root, 0)]
        path = [root]
        while stack:
            node, idx = stack[-1]
            nbrs = adj[node]
            if idx < len(nbrs):
                stack[-1] = (node, idx + 1)
                nxt = nbrs[idx]
                if color[nxt] == 0:
                    color[nxt] = 1
                    path.append(nxt)
                    stack.append((nxt, 0))
                elif color[nxt] == 1 and nxt in path:
                    cyc = path[path.index(nxt):]
                    key = frozenset(cyc)
                    if key not in seen:
                        seen.add(key)
                        cycles.append(_canonical_cycle(cyc))
            else:
                color[node] = 2
                stack.pop()
                path.pop()
    return sorted(cycles)


def graph_relation_errors(data):
    """Declared-edge integrity scan. Returns (dangling, unknown_types).

    dangling       = sorted [(source_id, target_id)] where target is not in the
                     index (a `relates` id that does not resolve).
    unknown_types  = sorted [(source_id, token)] whose type is out of vocab.
    Pure + read-only (INV-2); consumed by the graph_integrity audit (Task 8) and
    edge validation (Task 4).
    """
    ids = {e.get("id") for e in (data.get("entries") or [])
           if isinstance(e, dict) and e.get("id")}
    dangling, unknown = [], []
    for e in data.get("entries") or []:
        if not isinstance(e, dict):
            continue
        eid = e.get("id")
        if not eid:
            continue
        for tok in (e.get("relates") or []):
            parsed = _fm_parse_relate_token(tok)
            if parsed is None:
                continue
            etype, target = parsed
            if etype not in RELATION_TYPES:
                unknown.append((eid, tok))
            if target not in ids:
                dangling.append((eid, target))
    return sorted(set(dangling)), sorted(set(unknown))


def graph_health(data):
    """Advisory graph-health counts (Rule-7 observability). Pure + read-only."""
    forward, _reverse = build_adjacency(data)
    dangling, unknown = graph_relation_errors(data)
    cycles = find_cycles(forward)
    edges = sum(len(v) for v in forward.values())
    return {
        "edges": edges,
        "nodes_with_edges": len([k for k in forward if forward[k]]),
        "dangling": len(dangling),
        "unknown_types": len(unknown),
        "cycles": len(cycles),
    }


def graph_traverse(adjacency, start, depth):
    """Deterministic, cycle-safe closure from `start` over `adjacency`.

    depth == 1 -> direct neighbors; depth == 0 -> full transitive closure;
    depth == N -> up to N hops. Neighbors are visited in sorted (type, target)
    order; the returned id list excludes `start` and is in deterministic BFS
    order. A visited-set makes cycles terminate (INV-1 + cycle-safe).
    """
    visited = {start}
    order = []
    frontier = [start]
    level = 0
    while frontier:
        level += 1
        if depth != 0 and level > depth:
            break
        neigh = []
        for node in frontier:
            for (etype, target) in sorted(adjacency.get(node, [])):
                neigh.append((etype, target))
        next_frontier = []
        for (_etype, target) in sorted(neigh):
            if target not in visited:
                visited.add(target)
                order.append(target)
                next_frontier.append(target)
        frontier = sorted(next_frontier)
    return order


def cmd_query(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    entries = data.get("entries") or []
    tags_map = data.get("tags") or {}
    by_id, by_path = {}, {}
    for e in entries:
        if not isinstance(e, dict):
            continue
        eid = e.get("id")
        if eid is not None and eid not in by_id:
            by_id[eid] = e
        path = e.get("path")
        if path is not None and path not in by_path:
            by_path[path] = e

    results = []
    if args.id is not None:
        hit = by_id.get(args.id)
        if hit is not None:
            results = [hit]
    elif args.path is not None:
        hit = by_path.get(args.path)
        if hit is not None:
            results = [hit]
    elif args.tag is not None:
        for eid in tags_map.get(args.tag, []):
            hit = by_id.get(eid)
            if hit is not None:
                results.append(hit)
    elif args.category is not None:
        results = [e for e in entries
                   if isinstance(e, dict) and e.get("category") == args.category]
    elif getattr(args, "depends_on", None) is not None:
        forward, _reverse = build_adjacency(data)
        ids = graph_traverse(forward, args.depends_on, getattr(args, "depth", 1))
        results = [by_id[i] for i in ids if i in by_id]
    elif getattr(args, "impact", None) is not None:
        _forward, reverse = build_adjacency(data)
        ids = graph_traverse(reverse, args.impact, getattr(args, "depth", 1))
        results = [by_id[i] for i in ids if i in by_id]
    elif getattr(args, "relates", None) is not None:
        forward, reverse = build_adjacency(data)
        combined = {}
        for amap in (forward, reverse):
            for k, v in amap.items():
                combined.setdefault(k, []).extend(v)
        for k in list(combined):
            combined[k] = sorted(set(combined[k]))
        ids = graph_traverse(combined, args.relates, getattr(args, "depth", 1))
        results = [by_id[i] for i in ids if i in by_id]

    json.dump(results, sys.stdout, ensure_ascii=False, indent=2)
    sys.stdout.write("\n")
    return 0


def _topic_to_title(topic):
    words = re.split(r"[^a-zA-Z0-9]+", topic)
    return " ".join(w.capitalize() for w in words if w) or topic


# --- Entry frontmatter (machine-readable source of truth) --------------------
# Per-entry `.md` files carry a leading YAML frontmatter block that is the SOURCE
# OF TRUTH for the index. `index.json` is a DERIVED cache (`index rebuild`
# reconstructs it from frontmatter alone). The format is a RESTRICTED,
# deterministic YAML subset (C-5): a block delimited by `---` lines holding flat
# `key: value` scalars plus one inline list (`tags: [a, b]`). Emit + parse are
# hand-rolled, stdlib only — NO PyYAML (preserves the zero-dependency moat).

# Canonical field order in every emitted block. `relates` is LAST and emitted
# ONLY when non-empty (see render_frontmatter) so entries without declared edges
# stay byte-identical to the pre-graph format (backward-compatible).
FRONTMATTER_FIELDS = ("id", "title", "category", "tags", "created",
                      "summary", "author", "source", "last_verified", "relates")
# The index columns derivable from frontmatter (tags handled separately).
_FM_INDEX_SCALARS = ("id", "title", "category", "created", "summary")

# Closed vocabulary of declared relation types for the `relates` graph edges.
# Edges are DECLARED-ONLY (never LLM-extracted): each token is "<type>:<target>"
# where target is another entry id. An out-of-vocab type is parsed/kept but
# flagged by the graph_integrity audit (advisory) — never silently dropped.
RELATION_TYPES = ("depends-on", "blocks", "supersedes", "relates-to")

DEFAULT_ENTRY_SOURCE = "agent"


def _operator_handle(kdir):
    """Best-effort operator handle for the `author` default. Stdlib only.

    Parses `**Handle**:` (then `**Operator**:`) out of the KB MAIN.md. Falls back
    to 'operator' so the writer never blocks on a missing profile.
    """
    try:
        with open(os.path.join(kdir, "MAIN.md"), "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return "operator"
    for pat in (r"\*\*Handle\*\*:\s*([^\s·|]+)", r"\*\*Operator\*\*:\s*([^\s·|]+)"):
        m = re.search(pat, text)
        if m:
            return m.group(1).strip()
    return "operator"


# --- Personal-data leak guard (R-LOC-03) -------------------------------------
# Directories NEVER scanned for operator identity: VCS metadata, the machine-
# local config (it legitimately stores the KB path, which contains HOME),
# spawn/prompt logs, caches, and vendored deps. This mirrors .gitignore so the
# guard only ever inspects what the package actually ships/pushes.
PERSONAL_SCAN_EXCLUDE_DIRS = (
    ".git", ".agentware", ".agentware-logs", "__pycache__",
    ".venv", "node_modules", ".idea", ".vscode",
)
# Generic / fallback handles that are NOT personal data. Scanning for these
# would match framework prose everywhere; "operator" is also the _operator_handle
# fallback. Compared case-insensitively.
_GENERIC_HANDLES = ("operator", "user", "handle", "admin")
# Email-shaped token, used to lift an operator email out of MAIN.md if present.
_EMAIL_RE = re.compile(r"[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}")


def _operator_email(kdir):
    """Best-effort operator email parsed from the KB MAIN.md, or None.

    Reads the LIVE profile at runtime (hardcodes nothing). Returns the first
    email-shaped token found in MAIN.md, else None.
    """
    try:
        with open(os.path.join(kdir, "MAIN.md"), "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return None
    m = _EMAIL_RE.search(text)
    return m.group(0) if m else None


def operator_identity_strings(kdir):
    """Resolve the LIVE operator identity to the set of literal strings whose
    presence in the package tree would be a personal-data leak (R-LOC-03).

    Resolved entirely at runtime — hardcodes nothing — so the package still ships
    zero personal data. Sources: the handle (MAIN.md/config), the email (MAIN.md,
    if present), and the operator HOME path. Generic/fallback handles are dropped
    (they would match framework prose), as are tokens shorter than 3 chars.
    """
    strings = set()
    handle = _operator_handle(kdir)
    if handle and handle.lower() not in _GENERIC_HANDLES:
        strings.add(handle)
    email = _operator_email(kdir)
    if email:
        strings.add(email)
    home = os.path.expanduser("~")
    if home and home not in ("", "/", "~"):
        strings.add(home)
    return {s for s in strings if len(s) >= 3}


def _package_files(root):
    """Yield (abspath, relpath) for the files that make up the package at `root`.

    Prefers `git ls-files` so the guard inspects EXACTLY what the package
    ships/pushes — which naturally excludes machine-local, gitignored files
    (e.g. `.claude/settings.local.json`, `.agentware/`, `.agentware-logs/`,
    caches). Falls back to a pruned filesystem walk when `root` is not a git work
    tree (e.g. the unit-test temp dirs).
    """
    try:
        proc = subprocess.run(
            ["git", "-C", root, "ls-files", "-z"],
            stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        if proc.returncode == 0:
            for rel in proc.stdout.decode("utf-8", "replace").split("\0"):
                if rel:
                    yield os.path.join(root, rel), rel
            return
    except OSError:
        pass
    kdir = resolve_knowledge_dir()
    kdir_abs = os.path.abspath(kdir) if kdir else None
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [
            d for d in dirnames
            if d not in PERSONAL_SCAN_EXCLUDE_DIRS
            and not (kdir_abs and os.path.abspath(
                os.path.join(dirpath, d)) == kdir_abs)
        ]
        for name in filenames:
            fpath = os.path.join(dirpath, name)
            yield fpath, os.path.relpath(fpath, root)


def scan_personal_data(root, needles):
    """Scan the package's files under `root` for any of the literal `needles`.

    Returns a sorted list of human-readable hit strings (empty list == clean).
    Inspects only what the package ships (see `_package_files`) and silently
    skips non-text/binary files (decode errors). Read-only (INV-2).
    """
    needles = [n for n in (needles or []) if n]
    if not needles:
        return []
    hits = []
    for fpath, rel in _package_files(root):
        try:
            with open(fpath, "r", encoding="utf-8") as f:
                lines = f.readlines()
        except (OSError, UnicodeDecodeError):
            continue
        for i, line in enumerate(lines, 1):
            for n in needles:
                if n in line:
                    hits.append(
                        "%s:%d leaks operator identity %r" % (rel, i, n))
    hits.sort()
    return hits


def _fm_needs_quote(s):
    """True iff a scalar string must be double-quoted to survive round-trip."""
    if s == "":
        return True
    if s != s.strip():
        return True
    if s[0] in "\"'[]{}>|*&!#%@`,?:-":
        return True
    # A colon or hash mid-value can change YAML meaning; quote to be safe.
    return ":" in s or "#" in s


def _fm_quote(s):
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def _fm_emit_scalar(value):
    s = "" if value is None else str(value)
    return _fm_quote(s) if _fm_needs_quote(s) else s


def _fm_emit_tag(t):
    t = "" if t is None else str(t)
    if t == "" or t != t.strip() or any(c in t for c in ',[]"\' '):
        return _fm_quote(t)
    return t


def render_frontmatter(fields):
    """Emit the restricted-YAML frontmatter block (including `---` delimiters)."""
    lines = ["---"]
    for k in FRONTMATTER_FIELDS:
        if k == "tags":
            tags = fields.get("tags") or []
            lines.append("tags: [%s]" % ", ".join(_fm_emit_tag(t) for t in tags))
        elif k == "relates":
            # Omit entirely when empty so a no-edge entry is byte-identical to the
            # pre-graph frontmatter format (backward-compatible). Tokens reuse the
            # tags inline-list machinery (`<type>:<target>`; ':' needs no quoting).
            rel = fields.get("relates") or []
            if rel:
                lines.append("relates: [%s]"
                             % ", ".join(_fm_emit_tag(t) for t in rel))
        else:
            lines.append("%s: %s" % (k, _fm_emit_scalar(fields.get(k))))
    lines.append("---")
    return "\n".join(lines) + "\n"


def _fm_parse_scalar(raw):
    raw = raw.strip()
    if len(raw) >= 2 and raw[0] == '"' and raw[-1] == '"':
        return raw[1:-1].replace('\\"', '"').replace("\\\\", "\\")
    return raw


def _fm_split_inline_list(s):
    """Split an inline list body on commas not inside double quotes."""
    parts, buf, in_q, esc = [], [], False, False
    for ch in s:
        if esc:
            buf.append(ch)
            esc = False
            continue
        if ch == "\\" and in_q:
            buf.append(ch)
            esc = True
            continue
        if ch == '"':
            in_q = not in_q
            buf.append(ch)
            continue
        if ch == "," and not in_q:
            parts.append("".join(buf))
            buf = []
            continue
        buf.append(ch)
    parts.append("".join(buf))
    return parts


def _fm_parse_tags(raw):
    raw = raw.strip()
    if raw.startswith("[") and raw.endswith("]"):
        raw = raw[1:-1]
    out = []
    for p in _fm_split_inline_list(raw):
        if p.strip() == "":
            continue
        out.append(_fm_parse_scalar(p))
    return out


def _fm_parse_relate_token(tok):
    """Split a `<type>:<target>` edge token on the FIRST ':'.

    Returns a normalized (type, target) tuple, or None for a malformed/empty
    token (no colon, or an empty type/target side). Deterministic, stdlib only.
    """
    tok = "" if tok is None else str(tok).strip()
    if not tok:
        return None
    type_, sep, target = tok.partition(":")
    type_, target = type_.strip(), target.strip()
    if not sep or not type_ or not target:
        return None
    return (type_, target)


def _fm_parse_relates(raw):
    """Parse the `relates` inline list into normalized `<type>:<target>` tokens.

    Reuses the quote-aware tags splitter. Each token is split on its FIRST ':'
    into (type, target); malformed/empty tokens are dropped deterministically.
    Out-of-vocab types are KEPT (the graph_integrity audit reports them) — only
    structurally-broken tokens are dropped. Order is preserved.
    """
    raw = raw.strip()
    if raw.startswith("[") and raw.endswith("]"):
        raw = raw[1:-1]
    out = []
    for p in _fm_split_inline_list(raw):
        if p.strip() == "":
            continue
        parsed = _fm_parse_relate_token(_fm_parse_scalar(p))
        if parsed is None:
            continue
        out.append("%s:%s" % parsed)
    return out


def split_frontmatter(text):
    """Return (fields_dict_or_None, body_text).

    Recognizes a frontmatter block ONLY when the file's first line is exactly
    `---` and a closing `---` follows. Otherwise returns (None, text) so legacy
    files and bodies that merely contain `---` horizontal rules are untouched.
    """
    lines = text.split("\n")
    if not lines or lines[0].strip() != "---":
        return None, text
    close = None
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            close = i
            break
    if close is None:
        return None, text
    fields = {}
    for ln in lines[1:close]:
        if not ln.strip() or ":" not in ln:
            continue
        key, _, val = ln.partition(":")
        key = key.strip()
        if key == "tags":
            fields["tags"] = _fm_parse_tags(val)
        elif key == "relates":
            fields["relates"] = _fm_parse_relates(val)
        elif key in FRONTMATTER_FIELDS:
            fields[key] = _fm_parse_scalar(val)
    return fields, "\n".join(lines[close + 1:])


def strip_frontmatter(text):
    """Body text with any leading frontmatter block removed (lossless tail)."""
    fields, body = split_frontmatter(text)
    if fields is None:
        return text
    return body.lstrip("\n")


_LEGACY_CREATED_RE = re.compile(r">\s*\*\*Created\*\*:\s*(\S+)")
_LEGACY_CATEGORY_RE = re.compile(r">\s*\*\*Category\*\*:\s*(\S+)")
_LEGACY_TAGS_RE = re.compile(r">\s*\*\*Tags\*\*:\s*(.+)")


def _parse_legacy_header(text):
    """Best-effort extraction from a legacy blockquote-only entry (pre-migration).

    Returns whatever it can (title/created/category/tags) so callers degrade
    gracefully before the one-time migration runs.
    """
    out = {}
    m = re.search(r"^#\s+(.+?)\s*$", text, re.M)
    if m:
        out["title"] = m.group(1).strip()
    m = _LEGACY_CREATED_RE.search(text)
    if m:
        out["created"] = m.group(1).strip()
    m = _LEGACY_CATEGORY_RE.search(text)
    if m:
        out["category"] = m.group(1).strip()
    m = _LEGACY_TAGS_RE.search(text)
    if m:
        tags = re.findall(r"`([^`]+)`", m.group(1))
        if tags:
            out["tags"] = tags
    return out


def read_entry_frontmatter(path):
    """Parse an entry file's frontmatter into a dict (possibly partial).

    If the file carries a real frontmatter block, return its parsed fields.
    Otherwise tolerate a legacy blockquote-only file and return what it can.
    Returns {} on any read error.
    """
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return {}
    fields, _ = split_frontmatter(text)
    if fields is not None:
        return fields
    return _parse_legacy_header(text)


def build_entry_frontmatter(entry, kdir, author=None,
                            source=DEFAULT_ENTRY_SOURCE, last_verified=None):
    """Build the 9-field frontmatter dict for an index entry + defaults."""
    created = entry.get("created") or _today()
    return {
        "id": entry.get("id") or "",
        "title": entry.get("title") or "",
        "category": entry.get("category") or "",
        "tags": list(entry.get("tags") or []),
        "created": created,
        "summary": entry.get("summary") or "",
        "author": author if author is not None else _operator_handle(kdir),
        "source": source,
        "last_verified": last_verified or entry.get("last_verified") or created,
        # Declared graph edges; defaults to [] so a no-edge entry emits no
        # `relates:` line and stays byte-identical to the pre-graph format.
        "relates": list(entry.get("relates") or []),
    }


def ensure_entry_frontmatter(kdir, entry, author=None,
                             source=DEFAULT_ENTRY_SOURCE):
    """Prepend a frontmatter block to `entry`'s file iff it lacks one.

    Idempotent: a file that already carries a frontmatter block is left untouched
    (returns False). PREPEND only — never edits the body. Returns True if it wrote
    a block. The block is derived from the index `entry` row + defaults so the
    file becomes the rebuildable source of truth (C-1, C-3).
    """
    rel = entry.get("path")
    if not rel:
        return False
    abs_path = os.path.join(kdir, rel)
    try:
        with open(abs_path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return False
    existing, _ = split_frontmatter(text)
    if existing is not None:
        return False
    fm = build_entry_frontmatter(entry, kdir, author=author, source=source)
    with open(abs_path, "w", encoding="utf-8") as f:
        f.write(render_frontmatter(fm) + text)
    return True


def _render_learning(fields, body, back_label="Learnings"):
    """Render a learning entry: machine frontmatter + human header + body.

    `fields` is the 9-field frontmatter dict (source of truth); the human
    blockquote header below it is for readability and is regenerated from the
    same fields, so the two never drift. `back_label` names the category roster
    the footer links back to (the `./index.md` path is the same relative roster
    for every category), so `decide` reuses this renderer verbatim.
    """
    tag_list = fields.get("tags") or []
    tags_str = ", ".join("`%s`" % t for t in tag_list) if tag_list else "_(none)_"
    return (
        "%s"
        "# %s\n\n"
        "> **Created**: %s  \n"
        "> **Tags**: %s  \n"
        "> **Category**: %s\n\n"
        "---\n\n"
        "%s\n\n"
        "---\n\n"
        "[← Back to %s](./index.md) | [← Back to Main](../MAIN.md)\n"
        % (render_frontmatter(fields), fields.get("title") or "",
           fields.get("created") or "", tags_str,
           fields.get("category") or "learnings", body.rstrip("\n"), back_label)
    )


def cmd_learn(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    topic = (args.topic or "").strip()
    if not topic:
        sys.stderr.write("agentware: --topic must not be empty\n")
        return 1

    body = sys.stdin.read() if args.content == "-" else args.content
    if not (body or "").strip():
        sys.stderr.write("agentware: --content must not be empty\n")
        return 1

    # Optional provenance passthrough (feature 260625-team-mode-onboarding-fork).
    # Backward-compat invariant: when BOTH are omitted the frontmatter is
    # byte-identical to today — `source` stays DEFAULT_ENTRY_SOURCE and `author`
    # defaults to the per-user handle if configured, else _operator_handle(kdir)
    # (which is exactly today's behavior when no per-user handle is set).
    src = getattr(args, "source", None)
    if src is not None:
        src_norm = src.strip().lower()
        if src_norm not in ACR_SOURCE_WEIGHTS:
            sys.stderr.write(
                "agentware: invalid --source %r (use %s)\n"
                % (src, "|".join(sorted(ACR_SOURCE_WEIGHTS))))
            return 1
        src = src_norm
    else:
        src = DEFAULT_ENTRY_SOURCE
    author = getattr(args, "author", None)
    if author is not None:
        author = _normalize_user_handle(author)
        if not author:
            sys.stderr.write(
                "agentware: invalid --author (must contain at least one of "
                "A-Z a-z 0-9 . _ -)\n")
            return 1
    else:
        author = resolve_user_handle()  # None => build_entry_frontmatter uses _operator_handle

    eid = "learn-%s" % topic
    rel_path = "%s/%s.md" % (LEARNINGS_REL, topic)
    abs_path = os.path.join(kdir, rel_path)
    tag_list = parse_tags(args.tags)
    title = _topic_to_title(topic)
    created = _today()

    entries = data.get("entries") or []
    if any(e.get("id") == eid for e in entries):
        sys.stderr.write("agentware: duplicate id '%s'\n" % eid)
        return 1
    if any(e.get("path") == rel_path for e in entries):
        sys.stderr.write("agentware: path already indexed: %s\n" % rel_path)
        return 1
    if os.path.exists(abs_path):
        sys.stderr.write(
            "agentware: learning file already exists (refusing to overwrite): %s\n"
            % abs_path)
        return 1

    fm = build_entry_frontmatter(
        {"id": eid, "title": title, "category": "learnings", "tags": tag_list,
         "created": created, "summary": args.summary},
        kdir, author=author, source=src)
    os.makedirs(learnings_dir(kdir), exist_ok=True)
    with open(abs_path, "w", encoding="utf-8") as f:
        f.write(_render_learning(fm, body))

    entry, add_err = _do_add(
        kdir, data, eid, title, "learnings", rel_path, tag_list, args.summary, created)
    if add_err is not None:
        try:
            os.remove(abs_path)
        except OSError:
            pass
        sys.stderr.write("agentware: %s\n" % add_err)
        return 1

    save_index(kdir, data)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "learning": entry}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("LEARNED entry '%s' -> %s (registered in index)" % (eid, abs_path))
    return 0


def _render_decision_body(summary, options, choice, rationale, reversible):
    """Compose a decision entry body from its structured fields.

    Mirrors how `learn` takes free-form `--content`, but `decide` enforces the
    accountability fields R-AUTO-03 requires (options, choice, rationale,
    reversibility) so every recorded autonomous decision is auditable.
    """
    return (
        "## Decision\n\n%s\n\n"
        "## Options\n\n%s\n\n"
        "## Choice\n\n%s\n\n"
        "## Rationale\n\n%s\n\n"
        "## Reversibility\n\n%s\n"
        % (summary.strip(), options.strip(), choice.strip(),
           rationale.strip(), reversible.strip())
    )


def cmd_decide(args):
    """Write + register a `decisions/`-category entry (auto-tagged `decision`).

    A near-clone of `cmd_learn` that reuses the same index plumbing (NEVER hand-
    edits index.json) and the same renderer; the only differences are the
    category, the auto `decision` tag, and the structured decision body.
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    topic = (args.topic or "").strip()
    if not topic:
        sys.stderr.write("agentware: --topic must not be empty\n")
        return 1

    eid = "decide-%s" % topic
    rel_path = "%s/%s.md" % (DECISIONS_REL, topic)
    abs_path = os.path.join(kdir, rel_path)
    tag_list = parse_tags(args.tags) if getattr(args, "tags", None) else []
    if "decision" not in tag_list:
        tag_list = ["decision"] + tag_list
    title = _topic_to_title(topic)
    created = _today()

    entries = data.get("entries") or []
    if any(e.get("id") == eid for e in entries):
        sys.stderr.write("agentware: duplicate id '%s'\n" % eid)
        return 1
    if any(e.get("path") == rel_path for e in entries):
        sys.stderr.write("agentware: path already indexed: %s\n" % rel_path)
        return 1
    if os.path.exists(abs_path):
        sys.stderr.write(
            "agentware: decision file already exists (refusing to overwrite): "
            "%s\n" % abs_path)
        return 1

    body = _render_decision_body(args.summary, args.options, args.choice,
                                 args.rationale, args.reversible)
    fm = build_entry_frontmatter(
        {"id": eid, "title": title, "category": "decisions", "tags": tag_list,
         "created": created, "summary": args.summary},
        kdir, source=DEFAULT_ENTRY_SOURCE)
    os.makedirs(decisions_dir(kdir), exist_ok=True)
    with open(abs_path, "w", encoding="utf-8") as f:
        f.write(_render_learning(fm, body, back_label="Decisions"))

    entry, add_err = _do_add(
        kdir, data, eid, title, "decisions", rel_path, tag_list,
        args.summary, created)
    if add_err is not None:
        try:
            os.remove(abs_path)
        except OSError:
            pass
        sys.stderr.write("agentware: %s\n" % add_err)
        return 1

    save_index(kdir, data)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "decision": entry}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("DECISION entry '%s' -> %s (registered in index)" % (eid, abs_path))
    return 0


# --- Ingestion connectors (deterministic, curated capture) -------------------
# `agentware ingest` reads a LOCAL source artifact (a docs dir, or a local
# `gh issue list --json ...` export) and transforms it into CANDIDATE learnings
# via PURE, DETERMINISTIC heuristics — NO LLM, NO network, NO RNG/wall-clock in
# the transform (INV-1). The only clock use is the `created`/`ts` metadata that
# every command stamps, never inside the transform. Candidates go to a staging
# area under `work/ingest-<source>/` (a NON_INDEXED dir, so they NEVER pollute
# the index) and the command is DRY-RUN BY DEFAULT: nothing registers until an
# explicit `--commit` selects a reviewed subset (curated > raw — the noise
# warning, baked in). On `--commit` the selected, non-duplicate candidates are
# registered through the SAME path `cmd_learn` uses
# (`build_entry_frontmatter(source="imported")` -> `_render_learning` ->
# `_do_add` -> `save_index`); the CLI stays the SOLE index writer (R-KB-01).
# Ingestion is READ-ONLY on the source artifact (INV-2).
#
# UNTRUSTED-CONTENT SAFETY (R-SEC-02): ingested text (docs, issue bodies) is
# treated as INERT DATA. It is only ever extracted into candidate string fields;
# it is NEVER parsed as instructions, NEVER eval/exec'd, NEVER shelled out. A
# prompt-injection line in an ingested artifact lands verbatim in a candidate's
# `content` and has no effect on this tool's control flow.

INGEST_SOURCES = ("docs", "github-issues")


def _ingest_first_paragraph(text):
    """First non-empty, non-heading paragraph of a markdown/plain body.

    Pure string scan: skip leading blank lines and ATX `#` headings, then return
    the first contiguous block of non-blank lines joined by single spaces.
    Deterministic; no network/clock. Returns "" when the body has no prose.
    """
    para = []
    for ln in (text or "").replace("\r\n", "\n").split("\n"):
        s = ln.strip()
        if not para:
            if not s or s.startswith("#"):
                continue
            para.append(s)
        else:
            if not s:
                break
            para.append(s)
    return " ".join(para)


def _ingest_first_heading(text):
    """The first ATX `# ` heading text in `text`, or "" if none. Pure."""
    for ln in (text or "").replace("\r\n", "\n").split("\n"):
        m = re.match(r"^#+\s+(.*\S)\s*$", ln.strip())
        if m:
            return m.group(1).strip()
    return ""


def _ingest_candidate(topic, title, summary, tags, content, source_ref,
                      source_kind, extra_tags=None):
    """Build the common candidate dict + clean/dedupe its tag list.

    The candidate model is `{topic, title, summary, tags, content, source_ref,
    source_kind}`. Tags are stripped + de-duplicated (order-preserving) and the
    operator-supplied `extra_tags` (`--tags`) are appended. Pure + deterministic.
    """
    tag_list = []
    for t in list(tags or []) + list(extra_tags or []):
        t = (t or "").strip()
        if t and t not in tag_list:
            tag_list.append(t)
    return {
        "topic": topic,
        "title": title,
        "summary": summary or "",
        "tags": tag_list,
        "content": content or "",
        "source_ref": source_ref or "",
        "source_kind": source_kind,
    }


def _ingest_docs_adapter(path, extra_tags=None):
    """Walk a LOCAL docs dir deterministically -> one candidate per `*.md`.

    READ-ONLY on the source (INV-2). Topic slug derives from the first `#`
    heading (else the filename stem); first paragraph -> summary; the relative
    directory segments -> tags. Returns (candidates, rejected) with each rejected
    item `{source_ref, reason}`. Raises ValueError if `path` is not a directory.
    """
    if not os.path.isdir(path):
        raise ValueError("docs source path is not a directory: %s" % path)
    candidates, rejected, found = [], [], []
    for root, dirs, files in os.walk(path):
        dirs.sort()
        for fn in sorted(files):
            if fn.endswith(".md"):
                found.append(os.path.join(root, fn))
    for abs_path in sorted(found):
        rel = os.path.relpath(abs_path, path).replace(os.sep, "/")
        try:
            with open(abs_path, "r", encoding="utf-8") as f:
                text = f.read()
        except OSError as exc:
            rejected.append({"source_ref": rel, "reason": "read error: %s" % exc})
            continue
        heading = _ingest_first_heading(text)
        stem = os.path.splitext(os.path.basename(rel))[0]
        topic = _slugify(heading) or _slugify(stem)
        title = heading or _topic_to_title(stem)
        seg_tags = [s for s in os.path.dirname(rel).split("/") if s]
        candidates.append(_ingest_candidate(
            topic, title, _ingest_first_paragraph(text), seg_tags, text, rel,
            "docs", extra_tags))
    return candidates, rejected


def _ingest_github_issues_adapter(path, extra_tags=None):
    """Parse a LOCAL `gh issue list --json ...` export -> one candidate/issue.

    Expects a JSON array of issue objects (the `gh issue list --json
    number,title,body,labels,url,state` shape). Tolerates missing optional keys;
    a non-object item or one with no usable title is SKIPPED and reported in
    `rejected` (never silently corrupting output). READ-ONLY on the source.
    Raises ValueError on an unreadable/non-list file.
    """
    try:
        with open(path, "r", encoding="utf-8") as f:
            raw = json.load(f)
    except (OSError, ValueError) as exc:
        raise ValueError("could not read github-issues JSON %s: %s" % (path, exc))
    if not isinstance(raw, list):
        raise ValueError("github-issues JSON must be a list of issues, got %s"
                         % type(raw).__name__)
    candidates, rejected = [], []
    for i, item in enumerate(raw):
        if not isinstance(item, dict):
            rejected.append({"source_ref": "#%d" % i,
                             "reason": "issue item is not an object"})
            continue
        number = item.get("number")
        ref = item.get("url") or (
            "#%s" % number if number is not None else "#%d" % i)
        title = (item.get("title") or "").strip()
        if not title:
            rejected.append({"source_ref": ref, "reason": "issue has no title"})
            continue
        body = item.get("body") or ""
        label_tags = []
        for lab in (item.get("labels") or []):
            name = lab.get("name") if isinstance(lab, dict) else lab
            if name:
                label_tags.append(str(name))
        candidates.append(_ingest_candidate(
            _slugify(title), title, _ingest_first_paragraph(body) or title,
            label_tags, body, ref, "github-issues", extra_tags))
    return candidates, rejected


def _ingest_validate(candidates):
    """Split candidates into (valid, rejected) by the common candidate contract.

    Rejects empty-topic or empty-content candidates deterministically (reported,
    never registered). Pure function.
    """
    valid, rejected = [], []
    for c in candidates:
        if not (c.get("topic") or "").strip():
            rejected.append({"source_ref": c.get("source_ref", ""),
                             "reason": "empty topic (no slug derivable)"})
        elif not (c.get("content") or "").strip():
            rejected.append({"source_ref": c.get("source_ref", ""),
                             "reason": "empty content"})
        else:
            valid.append(c)
    return valid, rejected


def _ingest_fingerprint(text):
    """Stable sha256 of normalized body text for content-level dedup.

    Normalizes whitespace + case so trivially-reformatted duplicates collide.
    Deterministic, stdlib-only.
    """
    import hashlib  # stdlib, lazy
    norm = re.sub(r"\s+", " ", (text or "")).strip().lower()
    return hashlib.sha256(norm.encode("utf-8")).hexdigest()


def _ingest_extract_body(text):
    """Best-effort body of a rendered learning file (for content-fp dedup).

    `_render_learning` wraps the body between the first `---` rule after the
    blockquote header and the trailing `---` footer. Falls back to the whole
    text when the markers are absent. Read-only, pure.
    """
    fields, rest = split_frontmatter(text)
    body = rest if fields is not None else text
    marker = "\n---\n\n"
    i = body.find(marker)
    if i != -1:
        body = body[i + len(marker):]
        j = body.rfind("\n\n---\n")
        if j != -1:
            body = body[:j]
    return body


def _ingest_existing_dedup(kdir, data):
    """Return (existing_ids, existing_fingerprints) for dedup. Read-only (INV-2).

    `existing_ids` is the set of `learn-*` ids already in the index;
    `existing_fingerprints` are content fingerprints of every learning file on
    disk (so a same-content/different-slug import is also caught).
    """
    ids, fps = set(), set()
    for e in (data.get("entries") or []):
        if not isinstance(e, dict) or e.get("category") != "learnings":
            continue
        eid = e.get("id")
        if eid:
            ids.add(eid)
        rel = e.get("path")
        if not rel:
            continue
        try:
            with open(os.path.join(kdir, rel), "r", encoding="utf-8") as f:
                fps.add(_ingest_fingerprint(_ingest_extract_body(f.read())))
        except OSError:
            continue
    return ids, fps


def _ingest_register(kdir, data, candidate):
    """Register ONE candidate as a `source: imported` learning via the SAME path
    `cmd_learn` uses (build_entry_frontmatter -> _render_learning -> _do_add).

    NEVER writes index.json directly (R-KB-01). The `source_ref` provenance is
    appended as a footer so the committed entry carries its origin URL/path.
    Returns (entry, error); on an add error the just-written file is removed.
    """
    topic = candidate["topic"]
    eid = "learn-%s" % topic
    rel_path = "%s/%s.md" % (LEARNINGS_REL, topic)
    abs_path = os.path.join(kdir, rel_path)
    if os.path.exists(abs_path):
        return None, "learning file already exists: %s" % rel_path
    title = candidate["title"] or _topic_to_title(topic)
    summary = candidate["summary"]
    tag_list = candidate["tags"]
    created = _today()
    body = candidate["content"]
    if candidate.get("source_ref"):
        body = "%s\n\n---\n\n_Imported from: %s_\n" % (
            body.rstrip("\n"), candidate["source_ref"])
    fm = build_entry_frontmatter(
        {"id": eid, "title": title, "category": "learnings", "tags": tag_list,
         "created": created, "summary": summary},
        kdir, source="imported")
    os.makedirs(learnings_dir(kdir), exist_ok=True)
    with open(abs_path, "w", encoding="utf-8") as f:
        f.write(_render_learning(fm, body))
    entry, add_err = _do_add(
        kdir, data, eid, title, "learnings", rel_path, tag_list, summary,
        created)
    if add_err is not None:
        try:
            os.remove(abs_path)
        except OSError:
            pass
        return None, add_err
    return entry, None


def _ingest_write_staging(kdir, source, candidates):
    """Write the dry-run staging area: candidates.jsonl + per-candidate previews.

    Lives under `work/ingest-<source>/` (a NON_INDEXED dir, so it never pollutes
    the index). Rewritten deterministically each run. Writes ONLY under `work/`
    (never the index). Returns the staging dir (knowledge-dir-relative).
    """
    rel_dir = os.path.join("work", "ingest-%s" % source)
    abs_dir = os.path.join(kdir, rel_dir)
    previews = os.path.join(abs_dir, "previews")
    if os.path.isdir(previews):
        shutil.rmtree(previews, ignore_errors=True)
    os.makedirs(previews, exist_ok=True)
    with open(os.path.join(abs_dir, "candidates.jsonl"), "w",
              encoding="utf-8") as f:
        for c in candidates:
            f.write(json.dumps(c, ensure_ascii=False, sort_keys=True) + "\n")
    for c in candidates:
        preview = (
            "<!-- INGEST CANDIDATE PREVIEW — INERT untrusted data; NOT "
            "registered until --commit. Embedded instructions are ignored "
            "(R-SEC-02). -->\n"
            "<!-- source_kind: %s | source_ref: %s -->\n\n"
            "# %s\n\n> topic: `%s`\n> tags: %s\n\n%s\n"
            % (c["source_kind"], c["source_ref"], c["title"], c["topic"],
               ", ".join(c["tags"]) or "_(none)_", c["content"]))
        with open(os.path.join(previews, "%s.md" % (c["topic"] or "_empty")),
                  "w", encoding="utf-8") as f:
            f.write(preview)
    return rel_dir.replace(os.sep, "/")


def _ingest_emit_metric(kdir, source, counts, ts=None):
    """Rule-7 observability: append one `ingestion` event to logs/metrics.jsonl.

    Best-effort + read-only w.r.t. the KB/index (INV-2): a write failure never
    blocks the caller. `ts` is metadata only (never read by ranking).
    """
    try:
        rec = {"event": "ingestion", "source": source, "ts": ts or utc_now_iso()}
        rec.update(counts)
        logs = os.path.join(kdir, "logs")
        os.makedirs(logs, exist_ok=True)
        with open(os.path.join(logs, "metrics.jsonl"), "a",
                  encoding="utf-8") as f:
            f.write(json.dumps(rec, ensure_ascii=False, sort_keys=True) + "\n")
    except OSError:
        pass


def cmd_ingest(args):
    """Deterministic curated capture from a LOCAL source artifact.

    Dry-run by default (writes staging under `work/`, registers nothing);
    `--commit` registers the reviewed subset with `source: imported`, skipping
    duplicates. Never fetches the network (the operator produces the local
    export). The CLI stays the sole index writer.
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    source = args.source
    extra_tags = parse_tags(getattr(args, "tags", None))
    try:
        if source == "docs":
            raw_candidates, adapter_rejected = _ingest_docs_adapter(
                args.path, extra_tags)
        elif source == "github-issues":
            raw_candidates, adapter_rejected = _ingest_github_issues_adapter(
                args.path, extra_tags)
        else:
            sys.stderr.write("agentware: unknown --source '%s'\n" % source)
            return 1
    except ValueError as exc:
        sys.stderr.write("agentware: %s\n" % exc)
        return 1

    valid, validate_rejected = _ingest_validate(raw_candidates)
    rejected = adapter_rejected + validate_rejected

    only = None
    if getattr(args, "only", None):
        only = set(t.strip() for t in args.only.split(",") if t.strip())
    selected = [c for c in valid if (only is None or c["topic"] in only)]

    existing_ids, existing_fps = _ingest_existing_dedup(kdir, data)
    do_commit = getattr(args, "commit", False)

    committed_entries, skipped_dup, seen_ids = [], [], set()
    for c in selected:
        eid = "learn-%s" % c["topic"]
        fp = _ingest_fingerprint(c["content"])
        if eid in existing_ids or fp in existing_fps or eid in seen_ids:
            skipped_dup.append({"topic": c["topic"], "id": eid})
            continue
        seen_ids.add(eid)
        if do_commit:
            entry, add_err = _ingest_register(kdir, data, c)
            if add_err is not None:
                skipped_dup.append(
                    {"topic": c["topic"], "id": eid, "error": add_err})
                continue
            committed_entries.append(entry)
            existing_ids.add(eid)
            existing_fps.add(fp)

    if committed_entries:
        save_index(kdir, data)

    staging_rel = _ingest_write_staging(kdir, source, valid)

    counts = {
        "candidates": len(valid),
        "selected": len(selected),
        "committed": len(committed_entries),
        "skipped_dup": len(skipped_dup),
        "rejected": len(rejected),
    }
    _ingest_emit_metric(kdir, source, counts)

    result = dict(counts)
    result.update({
        "source": source,
        "path": args.path,
        "dry_run": not do_commit,
        "staging_dir": staging_rel,
        "committed_ids": [e["id"] for e in committed_entries],
        "skipped": skipped_dup,
        "rejected_items": rejected,
    })
    if getattr(args, "format", "text") == "json":
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        mode = "COMMIT" if do_commit else "DRY-RUN"
        print("INGEST %s [%s] %s" % (mode, source, args.path))
        print("  candidates: %d  selected: %d  committed: %d  "
              "skipped_dup: %d  rejected: %d"
              % (len(valid), len(selected), len(committed_entries),
                 len(skipped_dup), len(rejected)))
        print("  staging: %s" % staging_rel)
        for e in committed_entries:
            print("  + %s" % e["id"])
        for r in rejected:
            print("  ! rejected %s: %s"
                  % (r.get("source_ref"), r.get("reason")))
    return 0


def _render_features(data):
    markdown = "# Knowledge Base — Features & Capabilities\n\n"
    markdown += ("> **NOTICE:** Auto-generated from this knowledge base's "
                 "`index.json` by `scripts/agentware features`. Do not edit "
                 "manually.\n\n")
    categories = {}
    for entry in data.get("entries", []):
        cat = entry.get("category", "uncategorized")
        categories.setdefault(cat, []).append(entry)
    for cat in sorted(categories.keys()):
        pretty_cat = cat.replace("_", " ").title()
        markdown += "## %s\n\n" % pretty_cat
        markdown += "| Title | Path | Summary |\n"
        markdown += "|-------|------|---------|\n"
        for entry in categories[cat]:
            title = entry.get("title", "")
            path = entry.get("path", "")
            summary = entry.get("summary", "")
            markdown += "| **%s** | `[%s](%s)` | %s |\n" % (title, path, path, summary)
        markdown += "\n"
    if not categories:
        markdown += "_No entries yet. Capture knowledge with " \
                    "`scripts/agentware learn ...`._\n"
    return markdown


def cmd_features(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1
    content = _render_features(data)
    with open(features_path(kdir), "w", encoding="utf-8") as f:
        f.write(content)
    if getattr(args, "format", "text") == "json":
        cat_count = len({e.get("category", "uncategorized")
                         for e in data.get("entries", [])})
        json.dump({"ok": True, "path": features_path(kdir),
                   "entries": len(data.get("entries", [])), "categories": cat_count},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("Successfully generated %s" % features_path(kdir))
    return 0


LEARNED_RE = re.compile(r"^\s*>?\s*LEARNED:\s*(.*?)\s*$")
DECISION_RE = re.compile(r"^\s*>?\s*DECISION:\s*(.*?)\s*$")

# Explicit, deterministic promotion reference on a marker line. The canonical
# form is `(Promoted: <id>)`; the bracketed `[promoted -> <id>]` form is the
# decisions convention and is accepted too so both marker families share one
# matcher. The captured `<id>` is resolved EXACTLY against the live index/files
# (no substring fuzz) — this is the primary signal that a marker was promoted.
PROMOTED_RE = re.compile(
    r"(?:\(\s*Promoted:\s*|\[\s*promoted\s*->\s*)([a-z0-9][a-z0-9-]*)", re.I)


def _slugify(text):
    return re.sub(r"[^a-z0-9]+", "-", (text or "").lower()).strip("-")


def promoted_ids(marker_text):
    """Lowercased ids referenced by an explicit promotion marker, in order."""
    return [m.lower() for m in PROMOTED_RE.findall(marker_text or "")]


def _real_ids(stems, id_prefix):
    """Exact-match id set for a category: every stem in both its bare form and
    its prefixed-id form (`learn-<stem>` / `decide-<stem>`)."""
    ids = set()
    for s in stems:
        ids.add(s)
        ids.add(id_prefix + s)
    return ids


def _category_stems(kdir, data, category, id_prefix, subdir):
    """Filename/id stems of every entry in `category` (for promotion checks).

    Generic over the marker family so `> LEARNED:` (learnings) and `> DECISION:`
    (decisions) share one implementation.
    """
    stems = set()
    for e in (data.get("entries") or []):
        if not isinstance(e, dict) or e.get("category") != category:
            continue
        base = os.path.basename(e.get("path") or "")
        if base.endswith(".md"):
            stems.add(base[:-3].lower())
        eid = e.get("id") or ""
        if eid.startswith(id_prefix):
            stems.add(eid[len(id_prefix):].lower())
    d = os.path.join(kdir, subdir)
    if os.path.isdir(d):
        for fn in os.listdir(d):
            if fn.endswith(".md") and fn != "index.md":
                stems.add(fn[:-3].lower())
    return {s for s in stems if s}


def learning_stems(kdir, data):
    return _category_stems(kdir, data, "learnings", "learn-", LEARNINGS_REL)


def decision_stems(kdir, data):
    return _category_stems(kdir, data, "decisions", "decide-", DECISIONS_REL)


def _is_promoted(marker_text, stems, real_ids):
    """A marker is promoted iff:

    * primary — it carries an explicit `(Promoted: <id>)` / `[promoted -> <id>]`
      reference whose id resolves EXACTLY to a real entry (`real_ids`); or
    * fallback (no reference) — its slug EQUALS a learning stem exactly.

    The legacy substring branches (`stem in slug` / `slug in stem`) are gone:
    they produced false positives (short slug inside an unrelated stem) and could
    never be trusted. Pure string/set comparison over on-disk data -> INV-1
    deterministic, INV-2 read-only.
    """
    refs = promoted_ids(marker_text)
    if refs:
        return any(r in real_ids for r in refs)
    slug = _slugify(marker_text)
    if not slug:
        return False
    return any(slug == stem for stem in stems)


def scan_worklog(path, kdir, data):
    """Scan a worklog for unpromoted `> LEARNED:` and `> DECISION:` markers.

    Both families gate completion (R-SI-03 / R-AUTO-05). The combined top-level
    `unpromoted` list keeps the original exit semantics (non-empty -> fail);
    each item carries a `kind` ("learned"|"decision") so callers can label it.
    """
    l_stems = learning_stems(kdir, data)
    d_stems = decision_stems(kdir, data)
    kinds = (
        ("learned", LEARNED_RE, l_stems, _real_ids(l_stems, "learn-")),
        ("decision", DECISION_RE, d_stems, _real_ids(d_stems, "decide-")),
    )
    unpromoted, total = [], 0
    with open(path, "r", encoding="utf-8") as f:
        for lineno, line in enumerate(f, start=1):
            for kind, rx, stems, real_ids in kinds:
                m = rx.match(line)
                if not m:
                    continue
                text = m.group(1).strip()
                if not text:
                    continue
                total += 1
                if not _is_promoted(text, stems, real_ids):
                    unpromoted.append({"line": lineno, "text": text,
                                       "kind": kind})
                break
    return unpromoted, total


def cmd_worklog_scan(args):
    if not os.path.isfile(args.path):
        sys.stderr.write("agentware: worklog not found: %s\n" % args.path)
        return 1
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    unpromoted, total = scan_worklog(args.path, kdir, data)
    ok = len(unpromoted) == 0
    if getattr(args, "format", "text") == "json":
        json.dump({"unpromoted": unpromoted, "total": total},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        if ok:
            print("WORKLOG SCAN PASSED: %d marker(s), all promoted." % total)
        else:
            print("WORKLOG SCAN FAILED: %d of %d marker(s) unpromoted:"
                  % (len(unpromoted), total))
            for item in unpromoted:
                print("  line %d [%s]: %s"
                      % (item["line"], item.get("kind", "learned"), item["text"]))
    return 0 if ok else 1


# --- Audit -------------------------------------------------------------------
def tag_consistency_errors(data):
    errors = []
    entries = data.get("entries") or []
    tags = data.get("tags") or {}
    by_id = {e.get("id"): e for e in entries
             if isinstance(e, dict) and e.get("id")}
    for e in entries:
        if not isinstance(e, dict):
            continue
        eid = e.get("id")
        for t in (e.get("tags") or []):
            ids = tags.get(t)
            if not isinstance(ids, list) or eid not in ids:
                errors.append("tag map missing id '%s' under tag '%s'" % (eid, t))
    for t, ids in tags.items():
        if not isinstance(ids, list):
            errors.append("tag '%s' is not a list" % t)
            continue
        if not ids:
            errors.append("tag '%s' has an empty entry list" % t)
        for eid in ids:
            entry = by_id.get(eid)
            if entry is None:
                errors.append("tag '%s' references unknown id '%s'" % (t, eid))
            elif t not in (entry.get("tags") or []):
                errors.append("entry '%s' missing back-ref for tag '%s'" % (eid, t))
    return errors


def template_conformance_errors(kdir, data):
    errors = []
    ldir = learnings_dir(kdir)
    if os.path.isdir(ldir):
        for fn in sorted(os.listdir(ldir)):
            if not fn.endswith(".md") or fn == "index.md":
                continue
            fp = os.path.join(ldir, fn)
            try:
                with open(fp, "r", encoding="utf-8") as f:
                    text = f.read()
            except OSError as exc:
                errors.append("cannot read %s: %s" % (fp, exc))
                continue
            if not re.search(r"(?m)^#\s+\S", text):
                errors.append("learning '%s' missing H1 title" % fp)

    projects_dir = os.path.join(kdir, "projects")
    if os.path.isdir(projects_dir):
        for name in sorted(os.listdir(projects_dir)):
            d = os.path.join(projects_dir, name)
            if not os.path.isdir(d):
                continue
            fp = os.path.join(d, "index.md")
            if not os.path.isfile(fp):
                errors.append("project '%s' missing index.md" % name)
                continue
            with open(fp, "r", encoding="utf-8") as f:
                text = f.read()
            if not re.search(r"(?m)^#\s+\S", text):
                errors.append("project index '%s' missing H1 title" % fp)
    return errors


def orphaned_learning_errors(kdir, data):
    errors = []
    have = indexed_paths(data)
    ldir = learnings_dir(kdir)
    if os.path.isdir(ldir):
        for fn in sorted(os.listdir(ldir)):
            if not fn.endswith(".md") or fn == "index.md":
                continue
            rel = "%s/%s" % (LEARNINGS_REL, fn)
            if rel not in have:
                errors.append("orphaned learning (on disk, not indexed): %s" % rel)
    return errors


# --- Retrieval & evaluation (deterministic, stdlib-only) ---------------------
# INV-1: ranking is hand-rolled, stdlib-only — NO LLM, NO embeddings, NO network,
# NO wall-clock in scoring. INV-2: read-only — never mutates index.json or KB.
# The tokenizer here is the SINGLE shared tokenizer reused by the BM25 `recall`
# engine (Phase 1) so the baseline (tag) and ranked (bm25) paths stay comparable.

# Fixed, documented tokenizer: lowercase, split on non-alphanumeric runs, no
# stemming (v1). Pure stdlib; deterministic for identical input.
_TOKEN_RE = re.compile(r"[a-z0-9]+")


def tokenize(text):
    """Lowercase + split on non-alphanumeric. Returns a list of tokens."""
    return _TOKEN_RE.findall((text or "").lower())


def estimate_tokens(text):
    """Documented heuristic: ~4 characters per token (context-budget estimate)."""
    return (len(text or "") + 3) // 4


def _read_entry_body(kdir, entry):
    """Read an entry's markdown body (read-only, best-effort). '' on any error.

    Strips any leading machine frontmatter block so the BM25 corpus sees only the
    human body — keeping recall/eval byte-identical to the pre-frontmatter corpus
    (the index already contributes title/summary/tags separately).
    """
    rel = entry.get("path")
    if not rel:
        return ""
    try:
        with open(os.path.join(kdir, rel), "r", encoding="utf-8") as f:
            return strip_frontmatter(f.read())
    except OSError:
        return ""


def _entry_doc_text(kdir, entry):
    """The BM25 corpus document for one entry: title + summary + tags + body.

    Factored out of `build_corpus` so the cache-backed recall path can reconstruct
    the EXACT same doc_text for a surfaced top-k entry (for token estimation)
    without rebuilding the whole corpus — guaranteeing byte-identity by sharing
    this single join (INV-1). Read-only.
    """
    parts = [
        entry.get("title") or "",
        entry.get("summary") or "",
        " ".join(entry.get("tags") or []),
        _read_entry_body(kdir, entry),
    ]
    return "\n".join(parts)


def build_corpus(kdir, data):
    """Return [(entry, doc_text), ...] for every dict entry, in index order.

    doc_text = title + summary + tags + file body. Read-only; this is the shared
    corpus builder for both the tag baseline (footprint) and BM25 recall (Phase 1).
    """
    corpus = []
    for e in data.get("entries") or []:
        if not isinstance(e, dict):
            continue
        corpus.append((e, _entry_doc_text(kdir, e)))
    return corpus


def eval_corpus_fingerprint(corpus):
    """Deterministic whole-corpus fingerprint (sha256 hex) for gate comparability.

    DISTINCT from the per-document `_corpus_fingerprint` (:492, the vector-cache
    key): this hashes the ENTIRE corpus actually scored — the ordered set of
    `(id, doc_text)` pairs — in CANONICAL order (sorted by id) so byte-identical
    corpora hash identically across runs/machines regardless of index order, while
    ANY add/remove/edit of a scored entry changes the hash. Pure: no timestamps,
    no machine state. `corpus` is the `[(entry, doc_text), ...]` list from
    `build_corpus`. This is the seam that makes `eval --gate` reproducible — two
    runs only ever compare absolute scores when they scored the same corpus.
    """
    import hashlib  # stdlib, lazy
    pairs = sorted(
        ((str((e or {}).get("id") or ""), doc or "") for (e, doc) in corpus),
        key=lambda p: p[0])
    h = hashlib.sha256()
    for eid, doc in pairs:
        h.update(eid.encode("utf-8"))
        h.update(b"\x00")
        h.update(doc.encode("utf-8"))
        h.update(b"\x01")
    return h.hexdigest()


def retrieve_tag(kdir, data, query, top_k=None):
    """Baseline strategy: map a free-text query onto the EXACT-tag `query` path.

    Tokenize the query, union the exact-tag hits for each token that is a known
    tag, and rank entries by (# matching query tokens) desc, then `created` desc,
    then `id` asc. Deterministic and tokenizer-stable so the baseline reproduces.
    `kdir` is accepted for a uniform strategy signature (unused here).
    """
    tags_map = data.get("tags") or {}
    by_id = {}
    for e in data.get("entries") or []:
        if isinstance(e, dict) and e.get("id") is not None:
            by_id.setdefault(e.get("id"), e)

    counts = {}
    for tok in set(tokenize(query)):
        for eid in tags_map.get(tok, []):
            counts[eid] = counts.get(eid, 0) + 1

    ranked = list(counts.keys())
    # Stable multi-pass sort, lowest priority first → highest priority last.
    ranked.sort(key=lambda eid: eid)                                      # id asc
    ranked.sort(key=lambda eid: by_id.get(eid, {}).get("created") or "",  # created
                reverse=True)                                            # desc
    ranked.sort(key=lambda eid: counts[eid], reverse=True)               # matches desc
    return ranked if top_k is None else ranked[:top_k]


# --- BM25 deterministic ranking (Phase 1) ------------------------------------
# Fixed, documented Okapi BM25 parameters. Pinned for determinism; identical
# inputs yield byte-identical ordering (INV-1). No embeddings, no network.
_BM25_K1 = 1.5
_BM25_B = 0.75


def _bm25_index(corpus):
    """Build a BM25 index from [(entry, doc_text), ...] in corpus order.

    Returns (docs, df, avgdl): `docs` is [(entry, term_freqs, doc_len), ...] in
    corpus order, `df` maps term -> number of docs containing it, `avgdl` is the
    mean document length in tokens. Pure stdlib; deterministic.
    """
    docs = []
    df = {}
    total_len = 0
    for entry, text in corpus:
        toks = tokenize(text)
        tf = {}
        for t in toks:
            tf[t] = tf.get(t, 0) + 1
        docs.append((entry, tf, len(toks)))
        total_len += len(toks)
        for t in tf:
            df[t] = df.get(t, 0) + 1
    avgdl = (total_len / len(docs)) if docs else 0.0
    return docs, df, avgdl


def bm25_scores(corpus, query_tokens):
    """Return [(entry, score), ...] in corpus order, scored by Okapi BM25.

    idf = ln(1 + (N - df + 0.5)/(df + 0.5)) (always positive). Term contribution
    saturates via k1 and is length-normalized via b. Deterministic for identical
    input; a doc sharing no query term scores exactly 0.0.
    """
    docs, df, avgdl = _bm25_index(corpus)
    n = len(docs)
    q_terms = set(query_tokens)
    idf = {}
    for t in q_terms:
        n_t = df.get(t, 0)
        idf[t] = math.log(1.0 + (n - n_t + 0.5) / (n_t + 0.5))
    results = []
    for entry, tf, dl in docs:
        score = 0.0
        for t in q_terms:
            f = tf.get(t, 0)
            if f == 0:
                continue
            norm = 1.0 - _BM25_B + _BM25_B * (dl / avgdl if avgdl else 0.0)
            denom = f + _BM25_K1 * norm
            score += idf[t] * (f * (_BM25_K1 + 1.0)) / denom
        results.append((entry, score))
    return results


# --- Derived BM25 postings cache (feature 260625-kb-cached-inverted-index) -----
# A persistent inverted index derived from the SAME corpus `build_corpus`/
# `_bm25_index` produce, so the cache-backed scorer is byte-identical to
# `bm25_scores` (INV-1). The cache is a DERIVED artifact (C-1/C-3): regenerable
# from frontmatter+bodies, gitignored, NEVER source of truth, written ONLY by
# `index rebuild`/`rebuild_kb` (INV-2 read-only — recall/eval never write it).
# Missing/corrupt/stale => graceful fallback to the live scan. Schema (byte-stable,
# sorted keys):
#   {version, fingerprint, n, avgdl, k1, b,
#    doc_lens:{id:len}, df:{term:df}, postings:{term:[[id,tf], ...]}}


def bm25_cache_path(kdir):
    """Absolute path to the derived BM25 postings cache JSON under `.cache/`."""
    return os.path.join(kdir, BM25_CACHE_REL)


def build_bm25_cache(kdir, data):
    """Build the (pure) BM25 postings cache dict from the live corpus.

    Derives from the IDENTICAL `build_corpus` + `_bm25_index` the live scorer uses,
    so the persisted df/avgdl/n/doc_lens/postings reproduce `bm25_scores` exactly.
    The `fingerprint` is the deterministic whole-corpus content hash
    (`eval_corpus_fingerprint`) so ANY body/frontmatter/add/remove change
    invalidates the cache. Postings are ordered by doc_id and all dict keys are
    serialized sorted (see `write_bm25_cache`), so two builds over one KB state are
    byte-identical. Read-only.
    """
    corpus = build_corpus(kdir, data)
    docs, df, avgdl = _bm25_index(corpus)
    fingerprint = eval_corpus_fingerprint(corpus)
    doc_lens = {}
    postings = {}
    for entry, tf, dl in docs:
        eid = entry.get("id")
        if eid is None:
            continue
        doc_lens[eid] = dl
        for term, freq in tf.items():
            postings.setdefault(term, []).append([eid, freq])
    for term in postings:
        postings[term].sort(key=lambda p: p[0])  # stable: order by doc_id
    return {
        "version": BM25_CACHE_VERSION,
        "fingerprint": fingerprint,
        "n": len(docs),
        "avgdl": avgdl,
        "k1": _BM25_K1,
        "b": _BM25_B,
        "doc_lens": doc_lens,
        "df": df,
        "postings": postings,
    }


def write_bm25_cache(kdir, cache):
    """Persist the postings cache deterministically (sorted keys, byte-stable).

    The SOLE writer is `rebuild_kb` (`index rebuild`). Creates `.cache/` as needed.
    """
    path = bm25_cache_path(kdir)
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(cache, f, ensure_ascii=False, indent=2, sort_keys=True)
        f.write("\n")
    return path


def load_bm25_cache(kdir):
    """Load the derived postings cache, or None if unusable.

    Graceful by contract: a missing file, corrupt JSON, non-dict payload, or a
    version mismatch ALL return None so the caller falls back to the live scan.
    Never raises, never mutates.
    """
    path = bm25_cache_path(kdir)
    try:
        with open(path, "r", encoding="utf-8") as f:
            cache = json.load(f)
    except (OSError, ValueError):
        return None
    if not isinstance(cache, dict):
        return None
    if cache.get("version") != BM25_CACHE_VERSION:
        return None
    for key in ("fingerprint", "n", "avgdl", "doc_lens", "df", "postings"):
        if key not in cache:
            return None
    if not isinstance(cache.get("postings"), dict) \
            or not isinstance(cache.get("df"), dict) \
            or not isinstance(cache.get("doc_lens"), dict):
        return None
    return cache


def bm25_cache_is_fresh(cache, data, kdir):
    """True iff `cache` matches the LIVE KB content (no staleness/divergence).

    Re-derives the live whole-corpus fingerprint and compares it to the cached
    one. ANY change to a scored entry's body/frontmatter (or an add/remove) flips
    the fingerprint, so a stale cache is never trusted — the caller falls back to
    the live scan, keeping results correct. Read-only.
    """
    if not isinstance(cache, dict):
        return False
    live_fp = eval_corpus_fingerprint(build_corpus(kdir, data))
    return cache.get("fingerprint") == live_fp


def bm25_scores_cached(cache, query_tokens, entries_by_id):
    """Cache-backed BM25 scorer — byte-identical to `bm25_scores` (INV-1).

    Returns [(entry, score), ...] for the docs that share >=1 query term (the same
    positive-score subset `retrieve_bm25` keeps after its `s > 0.0` filter), scored
    by the IDENTICAL Okapi BM25 arithmetic as `bm25_scores`:
      idf = ln(1 + (n - df + 0.5)/(df + 0.5));  per-doc k1/b length-norm.
    Only the query terms' postings are touched (O(Σ df(query-term))), but to keep
    the float SUMMATION bit-for-bit identical to the live path, the per-doc inner
    loop iterates `q_terms = set(query_tokens)` in the SAME set-iteration order as
    `bm25_scores` (built from the same `query_tokens` in the same process) and
    skips f==0 the same way. `n`, `df`, and `avgdl` come from the cache and equal
    the whole-corpus values the live `_bm25_index` computes, so idf matches exactly.
    `entries_by_id` maps doc_id -> entry; docs with no live entry are skipped. Pure.
    """
    df = cache["df"]
    postings = cache["postings"]
    doc_lens = cache["doc_lens"]
    n = cache["n"]
    avgdl = cache["avgdl"]
    q_terms = set(query_tokens)
    idf = {}
    for t in q_terms:
        n_t = df.get(t, 0)
        idf[t] = math.log(1.0 + (n - n_t + 0.5) / (n_t + 0.5))
    # Gather only the candidate docs (those in a query term's postings), with the
    # per-doc tf for the matching query terms.
    tf_by_doc = {}
    for t in q_terms:
        for doc_id, freq in postings.get(t, []):
            tf_by_doc.setdefault(doc_id, {})[t] = freq
    results = []
    for doc_id, tfs in tf_by_doc.items():
        entry = entries_by_id.get(doc_id)
        if entry is None:
            continue
        dl = doc_lens.get(doc_id, 0)
        score = 0.0
        for t in q_terms:  # SAME order as bm25_scores' inner loop (INV-1)
            f = tfs.get(t, 0)
            if f == 0:
                continue
            norm = 1.0 - _BM25_B + _BM25_B * (dl / avgdl if avgdl else 0.0)
            denom = f + _BM25_K1 * norm
            score += idf[t] * (f * (_BM25_K1 + 1.0)) / denom
        results.append((entry, score))
    return results


def bm25_positive_scores(kdir, data, query, category=None):
    """Positive-score BM25 list [(entry, score>0), ...], cache-backed when safe.

    Uses the fresh postings cache (O(query-terms)) iff the cache loads, is fresh,
    AND `category is None`; otherwise the live `build_corpus` + `bm25_scores` scan.
    A category filter is the one case the whole-corpus cache cannot serve: the live
    path recomputes df/avgdl over the FILTERED sub-corpus, so its statistics (and
    thus scores) differ from the whole-corpus cache — category-scoped recall always
    uses the live scan to preserve byte-identity. The returned ordering is
    unsorted; every caller applies the canonical tie-break sort. Read-only (INV-2).
    """
    q_tokens = tokenize(query)
    if category is None:
        cache = load_bm25_cache(kdir)
        if cache is not None and bm25_cache_is_fresh(cache, data, kdir):
            entries_by_id = {}
            for e in data.get("entries") or []:
                if isinstance(e, dict) and e.get("id") is not None:
                    entries_by_id.setdefault(e.get("id"), e)
            return [(e, s) for (e, s)
                    in bm25_scores_cached(cache, q_tokens, entries_by_id)
                    if s > 0.0]
    corpus = build_corpus(kdir, data)
    if category:
        corpus = [(e, t) for (e, t) in corpus if e.get("category") == category]
    return [(e, s) for (e, s) in bm25_scores(corpus, q_tokens) if s > 0.0]


def retrieve_bm25(kdir, data, query, top_k=None):
    """BM25 recall strategy over title+summary+tags+body. Returns ranked ids.

    Deterministic ordering: score desc -> created desc -> id asc. Only entries
    with a positive score (sharing >=1 query term) are returned. Read-only
    (INV-2); no network/LLM/embeddings (INV-1, INV-6).
    """
    scored = bm25_positive_scores(kdir, data, query)
    # Stable multi-pass sort: lowest priority first, highest priority last.
    scored.sort(key=lambda es: es[0].get("id") or "")                       # id asc
    scored.sort(key=lambda es: es[0].get("created") or "", reverse=True)    # created desc
    scored.sort(key=lambda es: es[1], reverse=True)                         # score desc
    ids = [e.get("id") for (e, _s) in scored]
    return ids if top_k is None else ids[:top_k]


def retrieve_bm25_acr(kdir, data, query, as_of, top_k=None):
    """ACR-reranked BM25: `final = bm25_relevance × acr(entry, as_of)`.

    Surfaces the EXACT same set as `retrieve_bm25` — relevance gates: only
    positive-BM25 entries enter, and the acr multiplier is bounded in (0, 1] so it
    can never lift a zero-score (non-matching) entry into the result (C-3). The
    surfaced set is merely RE-ORDERED by the ACR-weighted score under the SAME
    deterministic tie-break (score desc -> created desc -> id asc). acr is a pure
    function of `(entry, as_of)`, so at a FIXED `as_of` the ordering is
    byte-identical across runs (INV-1). Read-only (INV-2); stdlib only, no
    network/LLM/embeddings.
    """
    scored = [(e, s * acr(e, as_of))
              for (e, s) in bm25_positive_scores(kdir, data, query)]
    # Stable multi-pass sort: lowest priority first, highest priority last.
    scored.sort(key=lambda es: es[0].get("id") or "")                       # id asc
    scored.sort(key=lambda es: es[0].get("created") or "", reverse=True)    # created desc
    scored.sort(key=lambda es: es[1], reverse=True)                         # score desc
    ids = [e.get("id") for (e, _s) in scored]
    return ids if top_k is None else ids[:top_k]


# --- Hybrid BM25 + embedding retrieval via RRF (Phase 5.1, Mode B core) -------
# `bm25+embed` fuses the deterministic BM25 lexical ranking with a query-embedding
# COSINE ranking using Reciprocal Rank Fusion (RRF) over 1-based INTEGER ranks, so
# the fusion never touches raw float scores (no float drift; INV-1). Embeddings
# only RANK candidates — they never author memory content (the no-hallucination
# moat). The embedder is the LOCAL, lazily-loaded backend (load_embedder); when it
# is ABSENT or fails, `bm25+embed` degrades GRACEFULLY to plain `bm25` (Mode A),
# so a clone with nothing installed still works. Corpus vectors are reused from the
# derived vector cache (build_vector_cache) by id+fingerprint where present and
# embedded IN-MEMORY otherwise (e.g. the ephemeral LongMemEval session corpora) —
# recall/eval NEVER write the persisted cache (INV-2; `index rebuild` is its sole
# writer). Determinism (Mode B): pinned model + embedder-rounded vectors -> a
# deterministic cosine ranking (cosine rounded to fixed precision) -> integer-rank
# RRF (fused score rounded) -> the SAME canonical tie-break as every other
# strategy. `tag` / `bm25` / `bm25+acr` are UNCHANGED.
_RRF_K = 60          # standard RRF damping constant (over 1-based integer ranks)
_EMBED_POOL = 200    # deep candidate-pool depth taken from EACH ranker before RRF
_COSINE_ROUND = 9    # fixed precision for cosine similarity (determinism guard)
_RRF_ROUND = 12      # fixed precision for the fused RRF score (determinism guard)


def _canonical_sort(scored):
    """In-place canonical tie-break sort of [(entry, score), ...]; returns it.

    score desc -> created desc -> id asc, via a stable multi-pass sort (lowest
    priority first, highest last) — byte-identical to `retrieve_bm25`'s ordering.
    Shared by the id-only `_canonical_rank` and the scored RRF/recall paths so
    every strategy orders identically (INV-1).
    """
    scored.sort(key=lambda es: es[0].get("id") or "")                    # id asc
    scored.sort(key=lambda es: es[0].get("created") or "", reverse=True)  # created
    scored.sort(key=lambda es: es[1], reverse=True)                      # score desc
    return scored


def _canonical_rank(scored):
    """Sort [(entry, score), ...] by the canonical tie-break -> list of ids."""
    return [e.get("id") for (e, _s) in _canonical_sort(scored)]


def _cosine(a, b):
    """Deterministic cosine similarity rounded to fixed precision.

    Returns 0.0 if either vector is missing/empty, dims differ, or either has
    zero norm. Inputs are already embedder-rounded; the fixed-precision round here
    is a belt-and-suspenders determinism guard before ranks are taken (INV-1).
    """
    if not a or not b or len(a) != len(b):
        return 0.0
    dot = na = nb = 0.0
    for x, y in zip(a, b):
        dot += x * y
        na += x * x
        nb += y * y
    if na <= 0.0 or nb <= 0.0:
        return 0.0
    return round(dot / math.sqrt(na * nb), _COSINE_ROUND)


def _embed_corpus_vectors(kdir, corpus, embedder, model):
    """Return {id: vector} for `corpus`, reusing the derived cache where valid.

    Reuses a persisted vector whose entry id + content fingerprint are unchanged
    (the same key build_vector_cache writes), and embeds the rest IN-MEMORY in one
    batched call. NEVER writes the cache (INV-2): the in-memory embeds cover the
    ephemeral LongMemEval session corpora (which have no persisted vectors) and
    any KB entry not yet in the cache. Deterministic given a pinned model.
    """
    cache = load_vector_cache(kdir, model) or {}
    cached_vectors = cache.get("vectors") or {}
    vectors = {}
    to_embed_ids, to_embed_txt = [], []
    for entry, doc_text in corpus:
        eid = entry.get("id")
        if eid is None:
            continue
        fp = _corpus_fingerprint(doc_text)
        hit = cached_vectors.get(eid)
        if isinstance(hit, dict) and hit.get("fp") == fp \
                and isinstance(hit.get("v"), list):
            vectors[eid] = list(hit["v"])
        else:
            to_embed_ids.append(eid)
            to_embed_txt.append(doc_text)
    if to_embed_txt:
        embedded = embedder.embed(to_embed_txt)
        if len(embedded) != len(to_embed_txt):
            raise ValueError(
                "embedder returned %d vectors for %d inputs"
                % (len(embedded), len(to_embed_txt)))
        for eid, vec in zip(to_embed_ids, embedded):
            vectors[eid] = list(vec)
    return vectors


def _rrf_fuse_scored(rankings, data, k=_RRF_K, pool=_EMBED_POOL):
    """Reciprocal Rank Fusion -> [(entry, fused_score), ...] in canonical order.

    score(d) = sum_r 1/(k + rank_r(d)) over each ranker `r`, using 1-based INTEGER
    ranks within the top-`pool` of that ranker (the deep candidate pool). The
    fused float score is rounded (determinism guard) and the canonical tie-break
    (created desc, id asc) resolves exact ties — so identical inputs yield
    byte-identical ordering (INV-1). Returns the scored tuples so callers that
    need the fused score (e.g. `recall`) get it; `_rrf_fuse` drops it to ids.
    """
    by_id = {}
    for e in data.get("entries") or []:
        if isinstance(e, dict) and e.get("id") is not None:
            by_id.setdefault(e.get("id"), e)
    scores = {}
    for ranking in rankings:
        for rank, eid in enumerate(ranking[:pool], start=1):
            scores[eid] = scores.get(eid, 0.0) + 1.0 / (k + rank)
    scored = [(by_id.get(eid, {"id": eid}), round(s, _RRF_ROUND))
              for eid, s in scores.items()]
    return _canonical_sort(scored)


def _rrf_fuse(rankings, data, k=_RRF_K, pool=_EMBED_POOL):
    """RRF of ranked id-lists -> fused ids (canonical order). See `_rrf_fuse_scored`."""
    return [e.get("id") for (e, _s) in _rrf_fuse_scored(rankings, data, k, pool)]


def retrieve_bm25_embed_scored(kdir, data, query, top_k=None, as_of=None):
    """Hybrid Mode-B retrieval -> [(entry, fused_score), ...] in canonical order.

    1. BM25 lexical ranking (positive scores only, canonical tie-break) — this is
       byte-identical to `retrieve_bm25` (Mode A stays the lexical floor).
    2. Embedder gate: load the LOCAL embedder; if ABSENT or it errors, return the
       plain BM25 (entry, score) list (GRACEFUL Mode-A fallback — never crash).
    3. Embedding cosine ranking over the corpus (cached + in-memory vectors).
    4. RRF over 1-based integer ranks of (1) and (3) across a DEEP candidate pool,
       re-sorted under the canonical tie-break; returns the fused score.

    The scored core behind `retrieve_bm25_embed` (ids) AND `recall_ranked`
    (entry+score+doc_text). Embeddings RANK only (no LLM, no authored content; the
    moat). Deterministic given a pinned model + cached vectors. `as_of` is accepted
    for a uniform strategy signature (the embedding signal is date-independent).
    Read-only (INV-2): never writes the persisted vector cache.
    """
    corpus = build_corpus(kdir, data)
    bm25_sorted = _canonical_sort(
        [(e, s) for (e, s) in bm25_scores(corpus, tokenize(query)) if s > 0.0])

    def _fallback():
        return bm25_sorted if top_k is None else bm25_sorted[:top_k]

    embedder = load_embedder()
    if embedder is None:
        return _fallback()

    model = resolve_embed_model()
    try:
        corpus_vectors = _embed_corpus_vectors(kdir, corpus, embedder, model)
        qvecs = embedder.embed([query])
        qvec = qvecs[0] if qvecs else None
    except Exception:
        # Any embedding failure => graceful Mode-A fallback; never crash recall.
        return _fallback()
    if not qvec:
        return _fallback()

    bm25_ranking = [e.get("id") for (e, _s) in bm25_sorted]
    embed_scored = [(e, _cosine(qvec, corpus_vectors.get(e.get("id"))))
                    for (e, _doc) in corpus if e.get("id") in corpus_vectors]
    embed_ranking = _canonical_rank(embed_scored)

    fused = _rrf_fuse_scored([bm25_ranking, embed_ranking], data)
    return fused if top_k is None else fused[:top_k]


def retrieve_bm25_embed(kdir, data, query, top_k=None, as_of=None):
    """Hybrid Mode-B retrieval -> ranked entry ids. See `retrieve_bm25_embed_scored`."""
    return [e.get("id") for (e, _s)
            in retrieve_bm25_embed_scored(kdir, data, query, top_k, as_of)]


def recall_ranked(kdir, data, query, top_k=None, category=None,
                  strategy="bm25", as_of=None):
    """Deterministic ranked recall returning [(entry, score, doc_text), ...].

    `strategy="bm25"` (default) reuses the shared `build_corpus` + `bm25_scores`
    so ordering is byte-identical to `retrieve_bm25`: score desc -> created desc
    -> id asc, positive scores only. `strategy="bm25+acr"` multiplies each BM25
    score by `acr(entry, as_of)` (provenance × freshness prior) and re-sorts under
    the SAME tie-break — same surfaced set (relevance gates; acr ∈ (0,1]), merely
    reordered. `strategy="bm25+embed"` is the Mode-B hybrid (RRF of BM25 + local
    query-embedding cosine), gracefully falling back to plain `bm25` when no local
    embedder is installed — embeddings RANK only (no LLM; the moat). `as_of`
    defaults to today only at this boundary; PIN it for reproducible runs. An
    optional `category` restricts the corpus BEFORE scoring. Read-only (INV-2);
    only `bm25+embed` consults the LOCAL embedder (INV-1, INV-6). `doc_text` is the
    entry's full corpus document (title+summary+tags+body) for token estimation.
    """
    if strategy not in ("bm25", "bm25+acr", "bm25+embed"):
        raise ValueError("unknown recall strategy: %s" % strategy)
    if strategy == "bm25+embed":
        # Restrict the corpus+fusion to `category` BEFORE ranking (mirrors the
        # bm25 path) by passing an entries-filtered view; the hybrid core builds
        # its own corpus + fuses over `sub`, so both stay consistent.
        sub = data
        if category:
            sub = dict(data)
            sub["entries"] = [e for e in (data.get("entries") or [])
                              if e.get("category") == category]
        scored = retrieve_bm25_embed_scored(kdir, sub, query, top_k=top_k,
                                            as_of=as_of)
        text_by_id = {e.get("id"): t for (e, t) in build_corpus(kdir, sub)}
        return [(e, s, text_by_id.get(e.get("id"), "")) for (e, s) in scored]
    # Cache-backed (O(query-terms)) when fresh + uncategorized, else the live scan;
    # bm25_positive_scores guarantees byte-identical scores either way (INV-1).
    scored = bm25_positive_scores(kdir, data, query, category=category)
    if strategy == "bm25+acr":
        if as_of is None:
            as_of = _today()
        scored = [(e, s * acr(e, as_of)) for (e, s) in scored]
    # Stable multi-pass sort: lowest priority first, highest priority last.
    scored.sort(key=lambda es: es[0].get("id") or "")                       # id asc
    scored.sort(key=lambda es: es[0].get("created") or "", reverse=True)    # created desc
    scored.sort(key=lambda es: es[1], reverse=True)                         # score desc
    if top_k is not None:
        scored = scored[:top_k]
    # Reconstruct doc_text for the SURFACED entries only (token estimation), via
    # the shared `_entry_doc_text` join so it is byte-identical to build_corpus.
    return [(e, s, _entry_doc_text(kdir, e)) for (e, s) in scored]


def retrieve(kdir, data, query, strategy, top_k=None, as_of=None):
    """Dispatch to a retrieval strategy. Returns a ranked list of entry ids.

    'tag'      — the legacy exact-tag baseline (available from day one).
    'bm25'     — the deterministic BM25 recall engine (provided by Phase 1 as the
                 module-level `retrieve_bm25`); errors clearly until that lands.
    'bm25+acr' — BM25 relevance re-weighted by the ACR provenance+freshness prior
                 (`final = bm25 × acr(entry, as_of)`). `as_of` defaults to today
                 only here; PIN it (eval/tests) for reproducible, byte-identical
                 ordering (INV-1). Surfaces the SAME set as 'bm25' (relevance
                 gates), merely reordered (C-3 — plain 'bm25' stays untouched).
    'bm25+embed' — hybrid Mode-B retrieval: RRF fusion (integer ranks) of the
                 BM25 ranking + a query-embedding cosine ranking from the LOCAL
                 embedder (rank-only, no LLM). GRACEFULLY falls back to 'bm25'
                 when no local embedder is installed. Deterministic given a pinned
                 model + cached vectors; 'tag'/'bm25'/'bm25+acr' stay UNCHANGED.
    """
    if strategy == "tag":
        return retrieve_tag(kdir, data, query, top_k)
    if strategy == "bm25":
        fn = globals().get("retrieve_bm25")
        if fn is None:
            raise NotImplementedError(
                "the 'bm25' strategy requires the recall engine (Phase 1); "
                "use --strategy tag for the baseline")
        return fn(kdir, data, query, top_k)
    if strategy == "bm25+acr":
        if as_of is None:
            as_of = _today()
        return retrieve_bm25_acr(kdir, data, query, as_of, top_k)
    if strategy == "bm25+embed":
        return retrieve_bm25_embed(kdir, data, query, top_k, as_of=as_of)
    raise ValueError("unknown retrieval strategy: %s" % strategy)


# --- Ranking metrics (hand-computable, exact) --------------------------------
def recall_at_k(ranked, relevant, k):
    """|relevant ∩ top-k| / |relevant|. 0.0 when there are no relevant items."""
    relevant = set(relevant)
    if not relevant:
        return 0.0
    hits = sum(1 for r in ranked[:k] if r in relevant)
    return hits / len(relevant)


def precision_at_k(ranked, relevant, k):
    """|relevant ∩ top-k| / k (standard precision@k; k is the denominator)."""
    if k <= 0:
        return 0.0
    relevant = set(relevant)
    hits = sum(1 for r in ranked[:k] if r in relevant)
    return hits / k


def _dcg(ranked, relevant, k):
    relevant = set(relevant)
    total = 0.0
    for i, r in enumerate(ranked[:k]):
        if r in relevant:
            total += 1.0 / math.log2(i + 2)  # gain 1, discount log2(rank+1)
    return total


def ndcg_at_k(ranked, relevant, k):
    """Binary-gain nDCG@k = DCG@k / ideal-DCG@k. 0.0 when ideal DCG is 0."""
    relevant = set(relevant)
    ideal_hits = min(len(relevant), k)
    idcg = sum(1.0 / math.log2(i + 2) for i in range(ideal_hits))
    if idcg == 0:
        return 0.0
    return _dcg(ranked, relevant, k) / idcg


def reciprocal_rank(ranked, relevant):
    """1 / (rank of first relevant item) over the FULL ranking; 0.0 if none."""
    relevant = set(relevant)
    for i, r in enumerate(ranked):
        if r in relevant:
            return 1.0 / (i + 1)
    return 0.0


def _median(values):
    """Deterministic p50: middle of an odd list, mean of the two middles else."""
    if not values:
        return 0.0
    s = sorted(values)
    n = len(s)
    mid = n // 2
    if n % 2:
        return float(s[mid])
    return (s[mid - 1] + s[mid]) / 2.0


def load_gold(path):
    """Load a gold set: list of {query, expected_ids[]}. Returns (items, error)."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except FileNotFoundError:
        return None, "gold set not found: %s" % path
    except json.JSONDecodeError as exc:
        return None, "invalid JSON in gold set %s: %s" % (path, exc)
    if not isinstance(data, list):
        return None, "gold set must be a JSON list of {query, expected_ids}"
    items = []
    for i, row in enumerate(data):
        if not isinstance(row, dict):
            return None, "gold entry #%d is not an object" % i
        q = row.get("query")
        exp = row.get("expected_ids")
        if not isinstance(q, str) or not q.strip():
            return None, "gold entry #%d missing a non-empty 'query'" % i
        if not isinstance(exp, list) or not exp:
            return None, "gold entry #%d missing a non-empty 'expected_ids' list" % i
        items.append({"query": q, "expected_ids": [str(x) for x in exp]})
    if not items:
        return None, "gold set is empty"
    return items, None


def evaluate(kdir, data, gold, strategy, top_k, as_of=None):
    """Run the gold set through a strategy and compute graded metrics.

    Returns a dict with aggregate `metrics` + `per_query` rows. Read-only.
    Latency uses time.perf_counter and is the ONLY non-deterministic field; the
    ranking itself is deterministic (INV-1). `as_of` is threaded to `retrieve` so
    the `bm25+acr` strategy decays freshness at a PINNED date (reproducible).
    """
    corpus = build_corpus(kdir, data)
    corpus_fp = eval_corpus_fingerprint(corpus)
    docs_by_id = {e.get("id"): doc for e, doc in corpus}
    entries_by_id = {e.get("id"): e for e, doc in corpus}
    as_of_for_age = as_of or _today()
    per_query = []
    recalls, precisions, ndcgs, rrs, latencies, footprints = [], [], [], [], [], []
    for row in gold:
        query = row["query"]
        relevant = set(row["expected_ids"])
        t0 = time.perf_counter()
        ranked = retrieve(kdir, data, query, strategy, top_k=None, as_of=as_of)
        latency_ms = (time.perf_counter() - t0) * 1000.0
        topk = ranked[:top_k]
        rec = recall_at_k(ranked, relevant, top_k)
        prec = precision_at_k(ranked, relevant, top_k)
        nd = ndcg_at_k(ranked, relevant, top_k)
        rr = reciprocal_rank(ranked, relevant)
        footprint = sum(estimate_tokens(docs_by_id.get(eid, "")) for eid in topk)
        recalls.append(rec)
        precisions.append(prec)
        ndcgs.append(nd)
        rrs.append(rr)
        latencies.append(latency_ms)
        footprints.append(footprint)
        per_query.append({
            "query": query,
            "expected_ids": sorted(relevant),
            "ranked": topk,
            "recall_at_k": rec,
            "precision_at_k": prec,
            "ndcg_at_k": nd,
            "reciprocal_rank": rr,
            "latency_ms": latency_ms,
            "context_tokens": footprint,
            # Age (days) of the correct answer as-of the PINNED date — drives the
            # OLD vs RECENT stratum in the ACR win gate (Phase 3.2). Pure
            # date-math, deterministic at a fixed `as_of`; None ⇒ excluded.
            "answer_age_days": answer_age_days(entries_by_id, relevant,
                                               as_of_for_age),
        })
    n = len(gold)
    mean = lambda xs: (sum(xs) / len(xs)) if xs else 0.0
    return {
        "strategy": strategy,
        "top_k": top_k,
        "num_queries": n,
        "corpus_fingerprint": corpus_fp,
        # Number of scored corpus entries (additive, append-only — same seam as
        # corpus_fingerprint). Lets /api/scaling plot Recall@k vs corpus size and
        # compute a meaningful slope. Legacy rows lacking it report N unknown.
        "corpus_size": len(corpus),
        "metrics": {
            "recall_at_k": mean(recalls),
            "precision_at_k": mean(precisions),
            "ndcg_at_k": mean(ndcgs),
            "mrr": mean(rrs),
            "latency_ms_mean": mean(latencies),
            "latency_ms_p50": _median(latencies),
            "context_tokens_mean": mean(footprints),
        },
        "per_query": per_query,
    }


# --- LongMemEval public benchmark scorer (strategy-agnostic, session-level) --
# The COMPARABLE public scorer (LongMemEval-S, arXiv:2410.10813). It reuses the
# EXACT same retrieve()/build_corpus()/metric helpers as the own gold set, so any
# strategy (bm25, bm25+acr, and later bm25+embed) scores identically — no LLM, no
# network, read-only (INV-1/INV-2). The three validity fixes are baked in:
#   1. retrieval unit = SESSION (one corpus entry per haystack session),
#   2. headline k = 5 (Recall@5, to line up with agentmemory's "95.2%"),
#   3. abstention (the official `_abs` question_id suffix) is EXCLUDED from the
#      recall aggregate and reported SEPARATELY (Recall@k is undefined for it).
_LME_DEFAULT_REL = os.path.join(
    "benchmarks", "longmemeval", "longmemeval_s_cleaned.json")
_LME_DET_SAMPLE = 3  # # of questions re-scored to assert byte-identical ordering


def is_longmemeval_abstention(question_id):
    """True for the official LongMemEval abstention questions.

    Abstention questions carry an `_abs` suffix on `question_id` AND a planted
    distractor `answer_session_ids` that IS in the haystack but does not answer
    the question — so Recall@k is undefined for them. Detect by the suffix (the
    official convention), NEVER by "no gold id" (they have one).
    """
    return str(question_id).endswith("_abs")


def longmemeval_session_text(session):
    """Flatten one LongMemEval session (a list of {role, content} turns) to text.

    Joins the substantive `content` of each turn with newlines — that is what
    BM25 (and later the embedder) rank on. Pure + deterministic; tolerant of
    malformed turns (skips non-dict / empty entries).
    """
    parts = []
    for turn in session or []:
        if isinstance(turn, dict):
            content = turn.get("content")
            if content:
                parts.append(str(content))
    return "\n".join(parts)


def longmemeval_corpus_data(session_ids, sessions):
    """Build a synthetic index-`data` dict: ONE entry per haystack session.

    The session is the retrieval unit (validity fix #1). Each entry carries the
    session id and its full flattened text inline (in `summary`), so the EXISTING
    strategy-agnostic retrieve()/build_corpus() path scores it with NO file I/O,
    NO network and NO LLM. Deterministic; read-only (INV-2).
    """
    entries = []
    for sid, sess in zip(session_ids or [], sessions or []):
        entries.append({"id": str(sid),
                        "summary": longmemeval_session_text(sess)})
    return {"entries": entries}


def evaluate_longmemeval(kdir, dataset_path, strategy, top_k, as_of=None,
                         limit=None):
    """Score a retrieval `strategy` on LongMemEval-S at SESSION granularity.

    For every question: build a session-level temp corpus (longmemeval_corpus_data),
    run retrieve(strategy) over it, and score Recall@k / nDCG@k / MRR / precision@k
    on the gold evidence session id(s) (`answer_session_ids`). Aggregates over all
    ANSWERABLE questions and per `question_type` category. Abstention questions
    (`_abs` suffix) are EXCLUDED from the recall aggregate and reported separately
    (count + per-category breakdown) — never crashed on, never silently mis-scored.

    Deterministic given a PINNED `as_of` (INV-1): a cheap re-score of the first
    `_LME_DET_SAMPLE` answerable questions confirms byte-identical ordering and is
    surfaced as `determinism_ok`. Read-only (INV-2); no network/LLM/embeddings.
    `limit` (testing/dev) scores only the first N questions of the file.
    """
    with open(dataset_path, "r", encoding="utf-8") as f:
        items = json.load(f)
    if not isinstance(items, list):
        raise ValueError("longmemeval dataset must be a JSON list of questions")
    if limit is not None:
        items = items[:limit]

    # Whole-corpus fingerprint over the FROZEN dataset actually scored (the
    # `(question_id, canonical-question-json)` pairs). LongMemEval is already
    # drift-free (frozen file), but recording the fingerprint keeps the invariant
    # that EVERY ledger row carries one, and keeps suites comparable only to runs
    # over the identical frozen slice.
    _lme_corpus = [({"id": str(it.get("question_id", i))},
                    json.dumps(it, sort_keys=True, ensure_ascii=False))
                   for i, it in enumerate(items) if isinstance(it, dict)]
    corpus_fp = eval_corpus_fingerprint(_lme_corpus)

    recalls, precisions, ndcgs, rrs, latencies = [], [], [], [], []
    per_cat = {}
    abstention = {"count": 0, "by_category": {}}
    det_ok, det_checked = True, 0

    for it in items:
        if not isinstance(it, dict):
            continue
        qid = it.get("question_id", "")
        category = it.get("question_type") or "unknown"
        if is_longmemeval_abstention(qid):
            abstention["count"] += 1
            abstention["by_category"][category] = (
                abstention["by_category"].get(category, 0) + 1)
            continue
        query = it.get("question") or ""
        synth = longmemeval_corpus_data(
            it.get("haystack_session_ids"), it.get("haystack_sessions"))
        gold = set(str(g) for g in (it.get("answer_session_ids") or []))
        t0 = time.perf_counter()
        ranked = retrieve(kdir, synth, query, strategy, top_k=None, as_of=as_of)
        latency_ms = (time.perf_counter() - t0) * 1000.0
        if det_checked < _LME_DET_SAMPLE:
            ranked2 = retrieve(kdir, synth, query, strategy, top_k=None,
                               as_of=as_of)
            if ranked2[:top_k] != ranked[:top_k]:
                det_ok = False
            det_checked += 1
        rec = recall_at_k(ranked, gold, top_k)
        prec = precision_at_k(ranked, gold, top_k)
        nd = ndcg_at_k(ranked, gold, top_k)
        rr = reciprocal_rank(ranked, gold)
        recalls.append(rec)
        precisions.append(prec)
        ndcgs.append(nd)
        rrs.append(rr)
        latencies.append(latency_ms)
        c = per_cat.setdefault(
            category, {"recalls": [], "precisions": [], "ndcgs": [], "rrs": []})
        c["recalls"].append(rec)
        c["precisions"].append(prec)
        c["ndcgs"].append(nd)
        c["rrs"].append(rr)

    mean = lambda xs: (sum(xs) / len(xs)) if xs else 0.0
    per_category = {}
    for cat in sorted(per_cat):
        c = per_cat[cat]
        per_category[cat] = {
            "num_queries": len(c["recalls"]),
            "recall_at_k": mean(c["recalls"]),
            "precision_at_k": mean(c["precisions"]),
            "ndcg_at_k": mean(c["ndcgs"]),
            "mrr": mean(c["rrs"]),
        }
    return {
        "suite": "longmemeval",
        "strategy": strategy,
        "top_k": top_k,
        "num_queries": len(recalls),
        "corpus_fingerprint": corpus_fp,
        # Scored-corpus entry count (additive; mirrors the own-gold evaluate()
        # seam) so LongMemEval rows also carry corpus_size for /api/scaling.
        "corpus_size": len(_lme_corpus),
        "dataset_path": dataset_path,
        "as_of": as_of,
        "metrics": {
            "recall_at_k": mean(recalls),
            "precision_at_k": mean(precisions),
            "ndcg_at_k": mean(ndcgs),
            "mrr": mean(rrs),
            "latency_ms_mean": mean(latencies),
            "latency_ms_p50": _median(latencies),
        },
        "per_category": per_category,
        "abstention": abstention,
        "determinism_ok": det_ok,
    }


# --- Frozen synthetic gold-fixture suite (Task 6) ----------------------------
# `eval --suite gold-fixture` scores a TINY, VERSIONED, fully SYNTHETIC corpus +
# queries that ship with the package (tests/fixtures/gold_fixture_suite.json) —
# NOT operator data (R-LOC-03). Because the corpus is frozen in the repo, its
# `corpus_fingerprint` is stable, so the absolute-score gate on this suite is
# DRIFT-FREE by construction: it never false-FAILs on live-KB growth (unlike the
# own gold set), giving the framework a reproducible regression gate that is
# independent of any operator knowledge base. It reuses the EXACT same
# evaluate()/retrieve()/build_corpus() path as the own gold set (entries carry
# their text inline in `summary`, so there is no file I/O, network, or LLM).
GOLD_FIXTURE_SUITE = "gold-fixture"
_GOLD_FIXTURE_REL = os.path.join(
    "tests", "fixtures", "gold_fixture_suite.json")


def gold_fixture_path():
    """Absolute path to the frozen gold-fixture file shipped with the package."""
    return os.path.join(REPO_ROOT, _GOLD_FIXTURE_REL)


def load_gold_fixture(path):
    """Load the frozen gold-fixture: returns (entries, gold). Raises ValueError.

    `entries` is the synthetic corpus as index-style dicts (id/title/summary/tags)
    ready for build_corpus; `gold` is the {query, expected_ids[]} list validated by
    the shared load_gold rules. The file is package-shipped synthetic data with NO
    operator content (R-LOC-03). Pure read; deterministic.
    """
    try:
        with open(path, "r", encoding="utf-8") as f:
            doc = json.load(f)
    except FileNotFoundError:
        raise ValueError("gold-fixture not found: %s" % path)
    except json.JSONDecodeError as exc:
        raise ValueError("invalid JSON in gold-fixture %s: %s" % (path, exc))
    if not isinstance(doc, dict):
        raise ValueError("gold-fixture must be a JSON object")
    corpus = doc.get("corpus")
    gold_rows = doc.get("gold")
    if not isinstance(corpus, list) or not corpus:
        raise ValueError("gold-fixture 'corpus' must be a non-empty list")
    entries = []
    seen = set()
    for i, e in enumerate(corpus):
        if not isinstance(e, dict):
            raise ValueError("gold-fixture corpus entry #%d is not an object" % i)
        eid = e.get("id")
        if not isinstance(eid, str) or not eid.strip():
            raise ValueError("gold-fixture corpus entry #%d missing 'id'" % i)
        if eid in seen:
            raise ValueError("gold-fixture corpus has duplicate id %r" % eid)
        seen.add(eid)
        entries.append({
            "id": eid,
            "title": e.get("title") or "",
            "summary": e.get("summary") or "",
            "tags": list(e.get("tags") or []),
        })
    if not isinstance(gold_rows, list) or not gold_rows:
        raise ValueError("gold-fixture 'gold' must be a non-empty list")
    gold = []
    for i, row in enumerate(gold_rows):
        if not isinstance(row, dict):
            raise ValueError("gold-fixture gold entry #%d is not an object" % i)
        q = row.get("query")
        exp = row.get("expected_ids")
        if not isinstance(q, str) or not q.strip():
            raise ValueError("gold-fixture gold entry #%d missing 'query'" % i)
        if not isinstance(exp, list) or not exp:
            raise ValueError(
                "gold-fixture gold entry #%d missing 'expected_ids'" % i)
        for x in exp:
            if str(x) not in seen:
                raise ValueError(
                    "gold-fixture gold entry #%d expects unknown id %r" % (i, x))
        gold.append({"query": q, "expected_ids": [str(x) for x in exp]})
    return entries, gold


def evaluate_gold_fixture(kdir, fixture_path, strategy, top_k, as_of=None):
    """Score `strategy` over the FROZEN synthetic gold-fixture corpus.

    Reuses evaluate() over a synthetic in-memory index (entries carry their text
    inline, so no file I/O, network, or LLM), then tags the result as the
    `gold-fixture` suite. The whole-corpus fingerprint is stable across runs/
    machines (the corpus is frozen in the repo), so the absolute gate on this
    suite is DRIFT-FREE. Determinism (INV-1) is asserted by re-scoring and
    comparing ranked ordering; surfaced as `determinism_ok`. Read-only (INV-2).
    """
    entries, gold = load_gold_fixture(fixture_path)
    synth = {"entries": entries}
    result = evaluate(kdir, synth, gold, strategy, top_k, as_of=as_of)
    # Determinism check (INV-1): re-score and compare the ranked ordering of every
    # query. The fixture is tiny, so a full re-run is cheap. Latency is the only
    # non-deterministic field and is excluded from the comparison.
    again = evaluate(kdir, synth, gold, strategy, top_k, as_of=as_of)
    result["determinism_ok"] = (
        [q["ranked"] for q in result["per_query"]]
        == [q["ranked"] for q in again["per_query"]])
    result["suite"] = GOLD_FIXTURE_SUITE
    result["as_of"] = as_of
    return result


def record_ledger_suite(kdir, data, result):
    """Append one immutable ledger row for a benchmark-suite run (e.g. LongMemEval).

    Mirrors record_ledger but uses the suite's OWN per-run determinism result
    (already computed inside the scorer over the real haystacks) instead of the
    own-gold-set determinism check. Read-only w.r.t. the KB; append-only.
    """
    pass_rate, ran, failed = _record_test_passrate()
    checks = {
        "test_pass_rate": pass_rate,
        "tests_ran": ran,
        "tests_failed": failed,
        "index_validate_ok": not validate_index(kdir, data),
        "determinism_ok": bool(result.get("determinism_ok")),
    }
    row = build_ledger_row(result, git_info(), utc_now_iso(), checks)
    append_ledger_row(os.path.join(kdir, HISTORY_REL), row)
    return row


_ABLATE_METRIC_KEYS = (
    "recall_at_k", "precision_at_k", "ndcg_at_k", "mrr",
    "latency_ms_mean", "latency_ms_p50", "context_tokens_mean",
)


def evaluate_ablation(kdir, data, gold, top_k, baseline="tag", treatment="bm25",
                      as_of=None):
    """Run the SAME gold set through two strategies and report the per-metric lift.

    Proof-of-lift instrument (Phase 3.2): scores the `baseline` and `treatment`
    strategies over identical queries, then reports `treatment - baseline` for
    every headline metric. `as_of` is threaded to both runs so an ACR treatment
    (`bm25+acr`) decays at a PINNED date. Read-only (INV-2); ranking is
    deterministic (INV-1) so the delta is reproducible (latency excepted).
    """
    base = evaluate(kdir, data, gold, baseline, top_k, as_of=as_of)
    treat = evaluate(kdir, data, gold, treatment, top_k, as_of=as_of)
    delta = {}
    for key in _ABLATE_METRIC_KEYS:
        delta[key] = treat["metrics"][key] - base["metrics"][key]
    return {
        "mode": "ablate",
        "top_k": top_k,
        "num_queries": len(gold),
        # Both strategies scored the SAME corpus, so either evaluate() result's
        # fingerprint identifies it (acr-gate rows inherit this for comparability).
        "corpus_fingerprint": base.get("corpus_fingerprint"),
        # Both strategies scored the SAME corpus, so inherit the corpus_size from
        # the baseline evaluate() result (acr-gate rows pick this up too).
        "corpus_size": base.get("corpus_size"),
        "baseline": baseline,
        "treatment": treatment,
        "strategies": {
            baseline: base["metrics"],
            treatment: treat["metrics"],
        },
        "delta": delta,
        "per_query": {
            baseline: base["per_query"],
            treatment: treat["per_query"],
        },
    }


# --- ACR win gate (Phase 3.2): deterministic 5-part decision rule ------------
# `eval --acr-gate` decides whether `bm25+acr` should become the DEFAULT ranking.
# ALL five checks must hold: (1) mean nDCG@k lift >= MARGIN; (2) paired t-test on
# per-query nDCG deltas significant at alpha (|t| >= t_crit, df=n-1); (3) win-rate
# (queries improved > regressed); (4) no-harm guardrails (Recall@k, MRR, p50
# latency, byte-identical determinism); (5) age-stratified no-regression on the
# OLD-answer stratum (ACR must not "win" only by burying still-true old facts).
# Pure stdlib — NO scipy: the t-test uses a critical-value TABLE (not a continuous
# CDF). Deterministic given the ablation result (computed at a PINNED `as_of`) plus
# a determinism flag, so the same inputs always yield the same verdict.
ACR_GATE_MARGIN = 0.01             # min mean nDCG@k lift (treatment - baseline)
ACR_GATE_ALPHA = 0.05              # paired t-test two-tailed significance level
ACR_GATE_RECALL_EPS = 0.0          # Recall@k no-harm slack (treat >= base - eps)
ACR_GATE_MRR_EPS = 0.0             # MRR no-harm slack (treat >= base - eps)
ACR_GATE_LATENCY_BUDGET_MS = 10.0  # p50 latency slack (treat_p50 <= base_p50 + budget)
ACR_GATE_OLD_AGE_DAYS = 90         # answer_age_days >= this => OLD-answer stratum
ACR_GATE_STRATUM_EPS = 1e-9        # OLD-stratum nDCG no-regression slack

# Two-tailed Student-t critical values, keyed by df, for alpha in {0.05, 0.01}.
# For a df BETWEEN tabulated rows we use the largest tabulated df <= our df, which
# is CONSERVATIVE (a smaller df => a larger critical value => a stricter gate).
# A df above the table uses the normal-approx asymptote (df -> inf).
_T_CRIT = {
    0.05: {1: 12.706, 2: 4.303, 3: 3.182, 4: 2.776, 5: 2.571, 6: 2.447,
           7: 2.365, 8: 2.306, 9: 2.262, 10: 2.228, 11: 2.201, 12: 2.179,
           13: 2.160, 14: 2.145, 15: 2.131, 16: 2.120, 17: 2.110, 18: 2.101,
           19: 2.093, 20: 2.086, 21: 2.080, 22: 2.074, 23: 2.069, 24: 2.064,
           25: 2.060, 26: 2.056, 27: 2.052, 28: 2.048, 29: 2.045, 30: 2.042,
           40: 2.021, 50: 2.009, 60: 2.000, 80: 1.990, 100: 1.984, 120: 1.980},
    0.01: {1: 63.657, 2: 9.925, 3: 5.841, 4: 4.604, 5: 4.032, 6: 3.707,
           7: 3.499, 8: 3.355, 9: 3.250, 10: 3.169, 11: 3.106, 12: 3.055,
           13: 3.012, 14: 2.977, 15: 2.947, 16: 2.921, 17: 2.898, 18: 2.878,
           19: 2.861, 20: 2.845, 21: 2.831, 22: 2.819, 23: 2.807, 24: 2.797,
           25: 2.787, 26: 2.779, 27: 2.771, 28: 2.763, 29: 2.756, 30: 2.750,
           40: 2.704, 50: 2.678, 60: 2.660, 80: 2.639, 100: 2.626, 120: 2.617},
}
_T_CRIT_INF = {0.05: 1.960, 0.01: 2.576}


def t_critical(df, alpha=ACR_GATE_ALPHA):
    """Two-tailed Student-t critical value from a table (stdlib, no scipy).

    For a df not tabulated we pick the largest tabulated df <= our df, which is
    CONSERVATIVE (smaller df => larger critical value => harder to pass). A df
    above the table uses the normal-approx asymptote. Raises ValueError for an
    unsupported alpha or df < 1.
    """
    table = _T_CRIT.get(alpha)
    if table is None:
        raise ValueError("t_critical: unsupported alpha %r (have %s)"
                         % (alpha, sorted(_T_CRIT)))
    if df < 1:
        raise ValueError("t_critical: df must be >= 1, got %r" % (df,))
    keys = sorted(table)
    if df > keys[-1]:
        return _T_CRIT_INF[alpha]
    chosen = keys[0]
    for k in keys:
        if k <= df:
            chosen = k
        else:
            break
    return table[chosen]


def paired_t_test(deltas):
    """Paired t-test on per-query deltas (treatment - baseline). Pure stdlib.

    Returns {n, df, mean, sd, se, t}. The t-statistic is mean / (sd / sqrt(n))
    with df = n - 1 and sd the sample (ddof=1) standard deviation. Degenerate
    cases: n < 2 => t = 0, df = 0 (cannot test); sd == 0 => t = 0 when the mean
    is 0, else +/-inf (a perfectly consistent non-zero shift). Deterministic.
    """
    n = len(deltas)
    if n == 0:
        return {"n": 0, "df": 0, "mean": 0.0, "sd": 0.0, "se": 0.0, "t": 0.0}
    mean = sum(deltas) / n
    if n < 2:
        return {"n": n, "df": 0, "mean": mean, "sd": 0.0, "se": 0.0, "t": 0.0}
    var = sum((d - mean) ** 2 for d in deltas) / (n - 1)
    sd = math.sqrt(var)
    se = sd / math.sqrt(n)
    if se == 0.0:
        t = 0.0 if mean == 0.0 else math.copysign(float("inf"), mean)
    else:
        t = mean / se
    return {"n": n, "df": n - 1, "mean": mean, "sd": sd, "se": se, "t": t}


def acr_gate_decision(ablation, margin=ACR_GATE_MARGIN, alpha=ACR_GATE_ALPHA,
                      recall_eps=ACR_GATE_RECALL_EPS, mrr_eps=ACR_GATE_MRR_EPS,
                      latency_budget_ms=ACR_GATE_LATENCY_BUDGET_MS,
                      old_age_days=ACR_GATE_OLD_AGE_DAYS,
                      stratum_eps=ACR_GATE_STRATUM_EPS, determinism_ok=False):
    """Apply the deterministic 5-part ACR win gate to a bm25-vs-bm25+acr ablation.

    `ablation` is an `evaluate_ablation` result (baseline + treatment headline
    metrics + per-query nDCG and `answer_age_days` on each row). ALL five checks
    must hold for `passed`. Pure given (ablation, determinism_ok): the only
    externally-measured input is `determinism_ok` (the bm25+acr twin-run equality
    at the pinned `as_of`), passed in so this stays a pure, table-driven function.
    """
    base_name = ablation.get("baseline")
    treat_name = ablation.get("treatment")
    strategies = ablation.get("strategies", {})
    base_m = strategies.get(base_name, {})
    treat_m = strategies.get(treat_name, {})
    pq = ablation.get("per_query", {})
    base_pq = pq.get(base_name, [])
    treat_pq = pq.get(treat_name, [])

    # Per-query nDCG deltas (aligned by gold order).
    deltas = [t.get("ndcg_at_k", 0.0) - b.get("ndcg_at_k", 0.0)
              for b, t in zip(base_pq, treat_pq)]

    # 1. Primary: mean nDCG@k lift >= margin.
    delta_ndcg = treat_m.get("ndcg_at_k", 0.0) - base_m.get("ndcg_at_k", 0.0)
    primary_ok = delta_ndcg >= margin

    # 2. Significance: paired t-test, lift in the right direction AND |t| >= t_crit.
    tt = paired_t_test(deltas)
    tcrit = t_critical(tt["df"], alpha) if tt["df"] >= 1 else float("inf")
    sig_ok = tt["df"] >= 1 and tt["mean"] > 0.0 and tt["t"] >= tcrit

    # 3. Win-rate (descriptive sign check): improved > regressed.
    improved = sum(1 for d in deltas if d > 0)
    regressed = sum(1 for d in deltas if d < 0)
    ties = sum(1 for d in deltas if d == 0)
    winrate_ok = improved > regressed

    # 4. No-harm guardrails: Recall@k, MRR, p50 latency, determinism.
    recall_ok = (treat_m.get("recall_at_k", 0.0)
                 >= base_m.get("recall_at_k", 0.0) - recall_eps)
    mrr_ok = treat_m.get("mrr", 0.0) >= base_m.get("mrr", 0.0) - mrr_eps
    latency_ok = (treat_m.get("latency_ms_p50", 0.0)
                  <= base_m.get("latency_ms_p50", 0.0) + latency_budget_ms)
    no_harm_ok = recall_ok and mrr_ok and latency_ok and bool(determinism_ok)

    # 5. Age-stratified no-regression on the OLD-answer stratum.
    old_base, old_treat = [], []
    for b, t in zip(base_pq, treat_pq):
        age = b.get("answer_age_days")
        if isinstance(age, (int, float)) and not isinstance(age, bool) \
                and age >= old_age_days:
            old_base.append(b.get("ndcg_at_k", 0.0))
            old_treat.append(t.get("ndcg_at_k", 0.0))
    old_n = len(old_base)
    _mean = lambda xs: (sum(xs) / len(xs)) if xs else 0.0
    old_base_ndcg = _mean(old_base)
    old_treat_ndcg = _mean(old_treat)
    # Vacuously passes when the stratum is empty (recorded via old_count).
    stratum_ok = (old_n == 0) or (old_treat_ndcg >= old_base_ndcg - stratum_eps)

    passed = bool(primary_ok and sig_ok and winrate_ok and no_harm_ok
                  and stratum_ok)
    return {
        "passed": passed,
        "baseline": base_name,
        "treatment": treat_name,
        "params": {"margin": margin, "alpha": alpha, "recall_eps": recall_eps,
                   "mrr_eps": mrr_eps, "latency_budget_ms": latency_budget_ms,
                   "old_age_days": old_age_days, "stratum_eps": stratum_eps},
        "checks": {
            "primary": {"passed": bool(primary_ok), "delta_ndcg": delta_ndcg,
                        "margin": margin},
            "significance": {"passed": bool(sig_ok), "t": tt["t"], "df": tt["df"],
                             "t_crit": tcrit, "mean_delta": tt["mean"],
                             "n": tt["n"], "alpha": alpha},
            "win_rate": {"passed": bool(winrate_ok), "improved": improved,
                         "regressed": regressed, "ties": ties},
            "no_harm": {
                "passed": bool(no_harm_ok),
                "recall": {"passed": bool(recall_ok),
                           "baseline": base_m.get("recall_at_k"),
                           "treatment": treat_m.get("recall_at_k")},
                "mrr": {"passed": bool(mrr_ok), "baseline": base_m.get("mrr"),
                        "treatment": treat_m.get("mrr")},
                "latency_p50": {"passed": bool(latency_ok),
                                "baseline": base_m.get("latency_ms_p50"),
                                "treatment": treat_m.get("latency_ms_p50"),
                                "budget_ms": latency_budget_ms},
                "determinism_ok": bool(determinism_ok),
            },
            "age_stratum": {"passed": bool(stratum_ok), "old_count": old_n,
                            "old_ndcg_baseline": old_base_ndcg,
                            "old_ndcg_treatment": old_treat_ndcg,
                            "recent_count": len(deltas) - old_n,
                            "old_age_days": old_age_days},
        },
    }


# --- Benchmark ledger (Phase 3B.1): append-only, commit + date-stamped ------
# Every package update records ONE immutable row keyed by (commit SHA, UTC run
# timestamp) to <kdir>/benchmarks/history.jsonl. Rows are NEVER edited or
# removed — `--record` only ever opens the file in append mode. SCORECARD.md
# (Phase 3B.3) is the only regenerated, derived view over these rows.

HISTORY_REL = os.path.join("benchmarks", "history.jsonl")
LEDGER_SCHEMA = "agentware-bench/v1"


def _git_capture(argv, env=None):
    """Run a read-only git command in REPO_ROOT; return stripped stdout or ''."""
    try:
        proc = subprocess.run(
            ["git"] + argv, cwd=REPO_ROOT,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True, env=env)
    except OSError:
        return ""
    return proc.stdout.strip() if proc.returncode == 0 else ""


def git_info():
    """Read-only snapshot of HEAD: short SHA, subject, UTC commit date, dirtiness.

    Degrades gracefully (commit='unknown', empty strings) outside a git repo so
    `--record` never fails just because git is missing. Never mutates anything.
    """
    utc_env = dict(os.environ)
    utc_env["TZ"] = "UTC"
    commit = _git_capture(["rev-parse", "--short", "HEAD"]) or "unknown"
    subject = _git_capture(["log", "-1", "--pretty=%s"])
    committed = _git_capture(
        ["log", "-1", "--date=iso-strict-local", "--pretty=%cd"], env=utc_env)
    dirty = bool(_git_capture(["status", "--porcelain"]))
    return {"commit": commit, "subject": subject,
            "committed": committed, "dirty": dirty}


def utc_now_iso():
    """Current UTC timestamp as ISO-8601 'Z' string. Metadata only (not scoring)."""
    return datetime.datetime.now(datetime.timezone.utc).strftime(
        "%Y-%m-%dT%H:%M:%SZ")


def _record_test_passrate():
    """Shell the unittest suite once and return (pass_rate, ran, failed).

    Recursion guard: the unittest suite itself exercises `eval --record`; if we
    are already inside a suite run (AGENTWARE_NESTED_UNITTEST=1) we return
    (None, 0, 0) instead of spawning the suite again. pass_rate is None when not
    measured. Pure stdlib subprocess (INV-6). Read-only.
    """
    if os.environ.get("AGENTWARE_NESTED_UNITTEST") == "1":
        return None, 0, 0
    env = dict(os.environ)
    env["AGENTWARE_NESTED_UNITTEST"] = "1"
    tests_dir = os.path.join(REPO_ROOT, "tests")
    if not os.path.isdir(tests_dir):
        return None, 0, 0
    try:
        proc = subprocess.run(
            [sys.executable, "-m", "unittest", "discover", "-s", "tests"],
            cwd=REPO_ROOT, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True, env=env)
    except OSError:
        return None, 0, 0
    err = proc.stderr or ""
    rm = re.search(r"Ran (\d+) test", err)
    ran = int(rm.group(1)) if rm else 0
    fm = re.search(r"failures=(\d+)", err)
    em = re.search(r"errors=(\d+)", err)
    failed = (int(fm.group(1)) if fm else 0) + (int(em.group(1)) if em else 0)
    if ran == 0:
        return None, 0, 0
    return (ran - failed) / ran, ran, failed


def _determinism_check(kdir, data, gold, top_k):
    """Score the bm25 path twice over the gold set; True iff ranking is identical.

    Operationalizes INV-1 as a recorded boolean: identical inputs -> identical
    ordering. Latency is excluded (the only non-deterministic field). Read-only.
    """
    a = evaluate(kdir, data, gold, "bm25", top_k)["per_query"]
    b = evaluate(kdir, data, gold, "bm25", top_k)["per_query"]
    return [q["ranked"] for q in a] == [q["ranked"] for q in b]


def _determinism_check_at(kdir, data, gold, top_k, strategy, as_of):
    """Twin-run ranking-equality check for `strategy` at a PINNED `as_of` (INV-1).

    Mirrors `_determinism_check` (which fixes strategy=bm25) but parameterized by
    strategy + as_of so the ACR gate can assert `bm25+acr` is byte-identical
    across runs at a fixed date (decay is a pure function of the two dates, no
    clock). Latency excluded (the only non-deterministic field). Read-only.
    """
    a = evaluate(kdir, data, gold, strategy, top_k, as_of=as_of)["per_query"]
    b = evaluate(kdir, data, gold, strategy, top_k, as_of=as_of)["per_query"]
    return [q["ranked"] for q in a] == [q["ranked"] for q in b]


def compute_reliability(recall_at_k, test_pass_rate, index_ok, determinism_ok):
    """Composite 0-100 reliability score (documented formula).

    Weighted blend (weights sum to 1.0): Recall@k 0.40, unittest pass-rate 0.30,
    index validate clean 0.15, determinism check 0.15. When test_pass_rate is
    None (not measured, e.g. nested run) its component is dropped and the
    remaining weights are renormalized so the score stays in [0, 100].
    """
    comps = [(0.40, max(0.0, min(1.0, recall_at_k)))]
    if test_pass_rate is not None:
        comps.append((0.30, max(0.0, min(1.0, test_pass_rate))))
    comps.append((0.15, 1.0 if index_ok else 0.0))
    comps.append((0.15, 1.0 if determinism_ok else 0.0))
    total_w = sum(w for w, _ in comps)
    if total_w <= 0:
        return 0.0
    return round(100.0 * sum(w * v for w, v in comps) / total_w, 2)


def redact_gold_path(gold_path):
    """Reduce an eval gold-set path to a RELATIVE, PII-free form for the ledger.

    The committed `benchmarks/history.jsonl` is public + reproducible, so a row
    must NEVER carry an absolute operator HOME path (R-LOC-03). This is the source
    fix: relativize the gold path against the knowledge dir (its natural root →
    e.g. "benchmarks/recall-gold.json"), falling back to a HOME-relative form,
    then to the bare basename. A final guard drops to the basename if any residual
    operator-identity token survives as a path component. Idempotent: an
    already-relative path is returned unchanged. Applied in the row BUILDERS (the
    single persistence choke-point every recorded row of every mode passes
    through) so the no-leak guarantee is structural, not per-call-site.
    """
    if not gold_path or not os.path.isabs(gold_path):
        return gold_path
    kdir = resolve_knowledge_dir()
    bases = []
    if kdir:
        bases.append(os.path.abspath(kdir))
    home = os.path.expanduser("~")
    if home and home not in ("", "/", "~"):
        bases.append(home)
    rel = None
    for base in bases:
        try:
            cand = os.path.relpath(gold_path, base)
        except ValueError:
            continue
        if cand != os.pardir and not cand.startswith(os.pardir + os.sep):
            rel = cand
            break
    if rel is None:
        rel = os.path.basename(gold_path)
    for needle in operator_identity_strings(kdir):
        if needle and needle in rel:
            rel = os.path.basename(gold_path)
            break
    return rel


def build_ledger_row(result, git_meta, run_ts, checks):
    """Assemble one immutable ledger row from an eval/ablate result. Pure.

    Deterministic given its inputs (the only volatile values — run_ts, latency,
    git state — are injected by the caller), so tests can build + serialize a row
    byte-identically. `checks` carries test_pass_rate / index_validate_ok /
    determinism_ok / tests_ran / tests_failed.
    """
    mode = result.get("mode", "eval")
    if mode == "ablate":
        treatment = result["treatment"]
        metrics = result["strategies"][treatment]
        strategy = treatment
        ablation = {
            "baseline": result["baseline"],
            "treatment": treatment,
            "delta": result["delta"],
        }
    else:
        metrics = result["metrics"]
        strategy = result.get("strategy", "bm25")
        ablation = None
    recall = metrics.get("recall_at_k", 0.0)
    reliability = compute_reliability(
        recall, checks.get("test_pass_rate"),
        checks.get("index_validate_ok", False),
        checks.get("determinism_ok", False))
    return {
        "schema": LEDGER_SCHEMA,
        "run": run_ts,
        "commit": git_meta.get("commit", "unknown"),
        "committed": git_meta.get("committed", ""),
        "subject": git_meta.get("subject", ""),
        "dirty": git_meta.get("dirty", False),
        "mode": mode,
        # `suite` isolates benchmark families in the SAME ledger: None for the
        # own gold set (the historical default), "longmemeval" for the public
        # comparable scorer. The gate only ever compares rows of the same suite
        # (see gate_baseline) so a session-level LongMemEval row never pollutes
        # the gold-set baseline and vice-versa.
        "suite": result.get("suite"),
        "strategy": strategy,
        "top_k": result.get("top_k"),
        "num_queries": result.get("num_queries"),
        # RELATIVE, PII-free gold path (R-LOC-03): the committed ledger is public,
        # so never persist an absolute operator HOME path. See redact_gold_path.
        "gold_path": redact_gold_path(result.get("gold_path")),
        # Deterministic whole-corpus fingerprint of the scored corpus. Additive
        # field (append-only preserved); makes gate comparability corpus-aware so
        # own-gold drift no longer false-FAILs. Legacy rows lack it (treated as a
        # distinct bucket by gate_baseline).
        "corpus_fingerprint": result.get("corpus_fingerprint"),
        # Scored-corpus entry count (additive, append-only, same pattern as
        # corpus_fingerprint). Powers /api/scaling's Recall@k-vs-corpus-size plot;
        # legacy rows lacking it report N unknown.
        "corpus_size": result.get("corpus_size"),
        "metrics": metrics,
        "ablation": ablation,
        "checks": checks,
        "reliability": reliability,
    }


def append_ledger_row(path, row):
    """Append ONE JSON line to the ledger. APPEND-ONLY — never rewrites a row.

    Opens strictly in append mode ('a'), so existing rows are byte-immutable;
    re-recording at the same commit adds a NEW row (distinct run timestamp). Keys
    are sorted so a fixed row serializes byte-identically. Returns the line.
    """
    parent = os.path.dirname(path)
    if parent:
        os.makedirs(parent, exist_ok=True)
    line = json.dumps(row, ensure_ascii=False, sort_keys=True)
    with open(path, "a", encoding="utf-8") as f:
        f.write(line + "\n")
    return line


def record_ledger(kdir, data, gold, gold_path, result, top_k):
    """Gather volatile state (git, UTC ts, test pass-rate, validate, determinism),
    build a row, and append it. Returns the row. Read-only w.r.t. the KB."""
    pass_rate, ran, failed = _record_test_passrate()
    checks = {
        "test_pass_rate": pass_rate,
        "tests_ran": ran,
        "tests_failed": failed,
        "index_validate_ok": not validate_index(kdir, data),
        "determinism_ok": _determinism_check(kdir, data, gold, top_k),
    }
    row = build_ledger_row(result, git_info(), utc_now_iso(), checks)
    append_ledger_row(os.path.join(kdir, HISTORY_REL), row)
    return row


# --- ACR default-flip ledger (Phase 4.1) ------------------------------------
# `eval --acr-gate --record` appends ONE immutable row (mode="acr-gate") that
# captures the full 5-part decision + both strategies' metrics + the per-stratum
# numbers. The recorded `strategy` field IS the resulting agent-facing default
# (`bm25+acr` iff the gate PASSED, else `bm25`). `active_default_strategy(kdir)`
# then reads that ledger so bare `recall` auto-inherits the decision — the flip
# is data-driven (no steering/agent edits) and reproducible (a pure read of the
# immutable ledger; at a fixed ledger + `as_of` recall is byte-identical, INV-1).

ACR_GATE_MODE = "acr-gate"


def build_acr_gate_row(result, decision, git_meta, run_ts, checks):
    """Assemble one immutable `mode="acr-gate"` ledger row. Pure given inputs.

    `strategy` is the DECIDED default (treatment iff the gate passed, else the
    baseline), so `active_default_strategy` can resolve the agent default from a
    single field. The full `decision` is stored verbatim as evidence (deltas,
    t-stat, win-rate, no-harm, per-stratum). Volatile values (run_ts, latency,
    git) are injected by the caller so a fixed decision serializes identically.
    """
    baseline = result["baseline"]
    treatment = result["treatment"]
    metrics = result["strategies"][treatment]
    decided = treatment if decision.get("passed") else baseline
    reliability = compute_reliability(
        metrics.get("recall_at_k", 0.0), checks.get("test_pass_rate"),
        checks.get("index_validate_ok", False),
        checks.get("determinism_ok", False))
    return {
        "schema": LEDGER_SCHEMA,
        "run": run_ts,
        "commit": git_meta.get("commit", "unknown"),
        "committed": git_meta.get("committed", ""),
        "subject": git_meta.get("subject", ""),
        "dirty": git_meta.get("dirty", False),
        "mode": ACR_GATE_MODE,
        "strategy": decided,
        "top_k": result.get("top_k"),
        "num_queries": result.get("num_queries"),
        # RELATIVE, PII-free gold path (R-LOC-03) — see redact_gold_path. Covers
        # the acr-gate row family too, so no recorded row of any mode leaks HOME.
        "gold_path": redact_gold_path(result.get("gold_path")),
        # Whole-corpus fingerprint of the scored corpus (inherited from the
        # ablation result). Keeps acr-gate rows corpus-aware too (Task 3 criterion:
        # EVERY recorded row carries a fingerprint).
        "corpus_fingerprint": result.get("corpus_fingerprint"),
        # Scored-corpus entry count (additive; inherited from the ablation result)
        # so acr-gate rows are corpus-size-aware for /api/scaling too.
        "corpus_size": result.get("corpus_size"),
        "as_of": result.get("as_of"),
        "metrics": metrics,
        "ablation": {
            "baseline": baseline,
            "treatment": treatment,
            "delta": result["delta"],
        },
        "acr_gate": {
            "passed": bool(decision.get("passed")),
            "decided_strategy": decided,
            "params": decision.get("params"),
            "checks": decision.get("checks"),
        },
        "checks": checks,
        "reliability": reliability,
    }


def record_acr_gate(kdir, data, gold, gold_path, result, decision, top_k, as_of):
    """Gather volatile state and append ONE acr-gate row. Read-only w.r.t. the KB.

    Mirrors `record_ledger` but stamps the bm25+acr determinism check at the
    PINNED `as_of` (INV-1) into the row's checks. Returns the appended row.
    """
    pass_rate, ran, failed = _record_test_passrate()
    checks = {
        "test_pass_rate": pass_rate,
        "tests_ran": ran,
        "tests_failed": failed,
        "index_validate_ok": not validate_index(kdir, data),
        "determinism_ok": _determinism_check_at(
            kdir, data, gold, top_k, "bm25+acr", as_of),
    }
    row = build_acr_gate_row(result, decision, git_info(), utc_now_iso(), checks)
    append_ledger_row(os.path.join(kdir, HISTORY_REL), row)
    return row


def active_default_strategy(kdir):
    """Resolve the agent-facing default recall strategy from the ledger.

    Returns "bm25+acr" iff the MOST RECENT recorded ACR-gate decision PASSED;
    otherwise "bm25". No acr-gate row yet (fresh clone, or the live gate FAILED)
    -> "bm25" — the honest, baseline-preserving default. Pure read of the
    append-only ledger (INV-2); deterministic given the ledger state, so bare
    `recall` is byte-identical at a fixed ledger + `as_of` (INV-1). This is the
    auto-flip seam: agents call bare `recall` and inherit the gated default with
    no steering/agent edits.
    """
    rows = _read_ledger(os.path.join(kdir, HISTORY_REL))
    acr_rows = [r for r in rows if r.get("mode") == ACR_GATE_MODE]
    if not acr_rows:
        return "bm25"
    latest = max(acr_rows, key=lambda r: r.get("run") or "")
    gate = latest.get("acr_gate") or {}
    return "bm25+acr" if gate.get("passed") else "bm25"


def active_recall_strategy(kdir):
    """Resolve the bare-`recall` default strategy, honoring `retrieval_mode` (A/B).

    The Phase 7.1 wiring that makes the onboarding-chosen A/B mode actually change
    what bare `recall` (and the loop's `R-CTX-05` recall) ranks with:

      * Mode A (`deterministic`, the DEFAULT): the gated BM25 default from
        `active_default_strategy` (`bm25` / `bm25+acr`). Byte-identical to today —
        Mode A is untouched and works with nothing installed.
      * Mode B (`semantic`) WITH a local embedding model present: `bm25+embed`,
        the Phase 5 hybrid stack (a won LOCAL reranker would layer here in a later
        phase if/when the embed gate passes).
      * Mode B requested with NO local model: fall back to Mode A's default and
        surface a one-line notice. Mode A is the zero-install invariant; Mode B is
        inert until a local model exists (`resolve_effective_retrieval_mode`).

    Returns (strategy, notice). `notice` is '' UNLESS a semantic->deterministic
    fallback happened (kept off stdout by the caller so JSON capture stays clean).
    Pure read (INV-2); deterministic at a fixed ledger + config + model.
    """
    eff_mode, fell_back, notice = resolve_effective_retrieval_mode()
    if eff_mode == RETRIEVAL_MODE_SEMANTIC:
        return "bm25+embed", ""
    # deterministic: either configured Mode A, or Mode B that fell back to A.
    return active_default_strategy(kdir), (notice if fell_back else "")


# --- Regression gate (Phase 3B.2) -------------------------------------------
# `eval --gate [--tolerance T]` compares the current run to the BEST prior
# comparable ledger row (same retrieval strategy) and EXITS NON-ZERO if any
# headline quality metric or the reliability score regresses beyond tolerance.
# This is the INV-7 enforcement: every package update is benchmarked and a
# regression cannot ship. A first-ever run (no comparable history) PASSES and
# seeds the baseline. The gate ALWAYS records (append-only) so the ledger grows
# on every gated run; it reads the prior rows BEFORE appending the new one so the
# fresh row never compares against itself.

# Higher-is-better quality metrics that the gate protects. Latency/ctx-token
# footprint are deliberately NOT gated as hard failures (they are reported and
# trended in the scorecard) so a benign latency jitter never fails a build.
GATE_METRICS = ("recall_at_k", "precision_at_k", "ndcg_at_k", "mrr")


def _read_ledger(path):
    """Read all rows from the append-only ledger; tolerate blanks/bad lines.

    Read-only (INV-2): only ever opens the file for reading. Returns [] when the
    file does not exist (first-ever run).
    """
    rows = []
    if not os.path.isfile(path):
        return rows
    with open(path, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rows.append(json.loads(line))
            except ValueError:
                continue
    return rows


def gate_baseline(rows, strategy, suite=None, corpus_fingerprint=None):
    """Best-seen value per gated metric + reliability among COMPARABLE rows.

    Comparable = rows recorded with the same retrieval `strategy` AND the same
    benchmark `suite` AND the same `corpus_fingerprint` (apples to apples: a bm25
    run is never gated against a tag-only baseline, a session-level LongMemEval
    row is never gated against an own-gold-set row even when both are
    strategy="bm25", AND an own-gold run is never gated against a row scored over
    a DIFFERENT corpus). `suite=None` selects the historical own-gold-set rows
    (which carry no/None suite).

    The `corpus_fingerprint` filter is what makes own-gold gating REPRODUCIBLE:
    the live operator KB grows over time, so a row recorded against a smaller
    corpus has a different fingerprint and is NOT comparable to a run over the
    grown corpus -> the gate seeds a fresh baseline and PASSES instead of
    false-failing on corpus drift (byte-identical code). Legacy rows recorded
    before fingerprinting carry no `corpus_fingerprint` (None) and so form their
    own distinct bucket -> they never gate a new fingerprinted run. Callers that
    omit `corpus_fingerprint` (None) match only rows whose fingerprint is also
    None (legacy semantics preserved).

    The baseline is the MAX of each metric across all prior comparable rows, so a
    run can never silently drop below any earlier peak. Returns None when there
    is no comparable history (first-ever run for this strategy+suite+corpus ->
    seeds + passes).
    """
    comparable = [r for r in rows
                  if r.get("strategy") == strategy and r.get("suite") == suite
                  and r.get("corpus_fingerprint") == corpus_fingerprint]
    if not comparable:
        return None
    base = {}
    for key in GATE_METRICS:
        vals = [r.get("metrics", {}).get(key) for r in comparable]
        vals = [v for v in vals if isinstance(v, (int, float))]
        if vals:
            base[key] = max(vals)
    rels = [r.get("reliability") for r in comparable
            if isinstance(r.get("reliability"), (int, float))]
    if rels:
        base["reliability"] = max(rels)
    return base


def evaluate_gate(metrics, reliability, baseline, tolerance):
    """Decide pass/fail vs a baseline. Returns (passed, regressions).

    Each gated metric must stay within `tolerance` of the best prior value
    (current >= best - tolerance). Reliability is a 0-100 score, so its
    allowance is `tolerance * 100` points. `baseline is None` => first run =>
    pass with no regressions (caller marks it seeded). `regressions` is a list of
    (metric, baseline_value, current_value) for every metric that dropped too far.
    """
    if baseline is None:
        return True, []
    regressions = []
    for key in GATE_METRICS:
        if key not in baseline:
            continue
        cur = metrics.get(key)
        if not isinstance(cur, (int, float)):
            continue
        if cur < baseline[key] - tolerance:
            regressions.append((key, baseline[key], cur))
    if "reliability" in baseline and isinstance(reliability, (int, float)):
        if reliability < baseline["reliability"] - tolerance * 100.0:
            regressions.append(
                ("reliability", baseline["reliability"], reliability))
    return (len(regressions) == 0), regressions


def _record_and_gate(args, kdir, data, gold, gold_path, result):
    """Apply --record / --gate to a computed eval result.

    --gate implies --record (every gated run appends an immutable row). Reads the
    prior ledger BEFORE appending so the new row never compares against itself.
    Returns (recorded_or_None, gate_or_None); attaches `recorded`/`gate` to
    `result` for the JSON output.
    """
    want_gate = getattr(args, "gate", False)
    if not (getattr(args, "record", False) or want_gate):
        return None, None
    ledger_path = os.path.join(kdir, HISTORY_REL)
    prior_rows = _read_ledger(ledger_path) if want_gate else None
    recorded = record_ledger(kdir, data, gold, gold_path, result, args.top_k)
    result["recorded"] = {
        "path": ledger_path, "commit": recorded["commit"],
        "run": recorded["run"], "reliability": recorded["reliability"],
    }
    gate = None
    if want_gate:
        baseline = gate_baseline(prior_rows, recorded["strategy"],
                                 recorded.get("suite"),
                                 recorded.get("corpus_fingerprint"))
        passed, regressions = evaluate_gate(
            recorded["metrics"], recorded["reliability"],
            baseline, args.tolerance)
        gate = {
            "passed": passed,
            "tolerance": args.tolerance,
            "strategy": recorded["strategy"],
            "seeded": baseline is None,
            "baseline": baseline,
            "regressions": [
                {"metric": m, "baseline": b, "current": c}
                for m, b, c in regressions
            ],
        }
        result["gate"] = gate
    return recorded, gate


def _gate_exit(gate, ab=None):
    """Exit code for a gate result: non-zero (1) only on a real regression.

    When an A/B result is supplied (`eval --gate --ab`), a real A/B FAIL also
    forces exit 1 — the clean-HEAD vs working-tree comparison is an independent
    regression signal layered on top of the absolute baseline gate.
    """
    code = 0 if (gate is None or gate["passed"]) else 1
    if ab is not None and not ab["passed"]:
        code = 1
    return code


def _print_gate(gate):
    """Human-readable gate verdict for text format."""
    if gate is None:
        return
    if gate["seeded"]:
        print("  gate: PASS (seeded baseline; no prior %s history)"
              % gate["strategy"])
        return
    if gate["passed"]:
        print("  gate: PASS (no regression beyond tolerance %.4f)"
              % gate["tolerance"])
        return
    print("  gate: FAIL (regression beyond tolerance %.4f)" % gate["tolerance"])
    for r in gate["regressions"]:
        print("    %-16s best=%.4f  current=%.4f  drop=%.4f" % (
            r["metric"], r["baseline"], r["current"],
            r["baseline"] - r["current"]))


# --- Clean-HEAD vs working-tree A/B gate (Task 5) ----------------------------
# `eval --gate --ab` isolates THIS diff's recall effect from live-KB corpus
# drift BY CONSTRUCTION: it scores the working-tree CLI and the git-HEAD CLI over
# the SAME live corpus and PASSES iff working >= head - tolerance. The HEAD CLI
# is extracted to a temp file via `git show HEAD:scripts/agentware` (read-only —
# never the work tree or index, INV-2); the temp file is always cleaned up. When
# git/HEAD is unavailable it cannot prove a regression, so it PASSES with
# available=False — mirroring gate_baseline's seed-on-empty semantics so the A/B
# mode can never itself be a hard false-failure. This is exactly the R-PKG-05
# question ("is THIS diff responsible for the drop?") as a deterministic check.

def _ab_verdict(working, head, tolerance):
    """Pure A/B decision: (passed, delta). PASS iff working >= head - tolerance."""
    delta = working - head
    return (working >= head - tolerance), delta


def _extract_head_cli():
    """Extract HEAD's scripts/agentware to a temp file. Read-only (INV-2).

    Returns (temp_path, head_commit) or (None, None) when git/HEAD/the blob is
    unavailable. Writes ONLY to a temp file — never the work tree or the index.
    Caller is responsible for unlinking the returned path.
    """
    head_commit = _git_capture(["rev-parse", "--short", "HEAD"])
    if not head_commit:
        return None, None
    blob = _git_capture(["show", "HEAD:scripts/agentware"])
    if not blob:
        return None, None
    import tempfile
    fd, path = tempfile.mkstemp(prefix="agentware-head-", suffix=".py")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(blob)
            f.write("\n")
    except OSError:
        try:
            os.unlink(path)
        except OSError:
            pass
        return None, None
    return path, head_commit


def _ab_head_recall(head_path, kdir, strategy, top_k, as_of, gold_path):
    """Score the HEAD CLI's plain eval over the SAME corpus; return recall_at_k.

    Runs the extracted HEAD script as a subprocess (a plain read-only eval — NO
    --record/--gate, so the ledger is untouched), pinning AGENTWARE_KNOWLEDGE_DIR
    so it scores the IDENTICAL live corpus regardless of the temp file's location.
    Returns the float recall_at_k, or None if the HEAD run produced none.
    """
    env = dict(os.environ)
    env["AGENTWARE_KNOWLEDGE_DIR"] = kdir
    argv = [sys.executable, head_path, "eval",
            "--strategy", strategy, "--top-k", str(top_k),
            "--as-of", as_of, "--gold", gold_path, "--format", "json"]
    try:
        proc = subprocess.run(
            argv, cwd=REPO_ROOT,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True, env=env)
    except OSError:
        return None
    if proc.returncode != 0:
        return None
    try:
        payload = json.loads(proc.stdout)
    except ValueError:
        return None
    recall = (payload.get("metrics") or {}).get("recall_at_k")
    return recall if isinstance(recall, (int, float)) else None


def run_ab_gate(args, kdir, result, gold_path):
    """Clean-HEAD vs working-tree A/B over the SAME corpus (read-only).

    Attaches `result["ab"]` and returns it. PASS iff working >= head - tolerance.
    An unavailable HEAD/git (or a HEAD run that yields no recall) PASSES with
    available=False — it cannot prove this diff caused a regression.
    """
    working = (result.get("metrics") or {}).get("recall_at_k")
    tolerance = args.tolerance
    strategy = result.get("strategy") or getattr(args, "strategy", "bm25")
    top_k = result.get("top_k") or args.top_k
    as_of = result.get("as_of") or _today()
    head_path, head_commit = _extract_head_cli()
    if head_path is None:
        ab = {"available": False, "passed": True,
              "reason": "git HEAD scripts/agentware unavailable",
              "working": working, "head": None, "delta": None,
              "tolerance": tolerance, "head_commit": None, "strategy": strategy}
        result["ab"] = ab
        return ab
    try:
        head = _ab_head_recall(head_path, kdir, strategy, top_k, as_of, gold_path)
    finally:
        try:
            os.unlink(head_path)
        except OSError:
            pass
    if head is None or working is None:
        ab = {"available": False, "passed": True,
              "reason": "HEAD eval produced no recall score",
              "working": working, "head": head, "delta": None,
              "tolerance": tolerance, "head_commit": head_commit,
              "strategy": strategy}
        result["ab"] = ab
        return ab
    passed, delta = _ab_verdict(working, head, tolerance)
    ab = {"available": True, "passed": passed,
          "working": working, "head": head, "delta": delta,
          "tolerance": tolerance, "head_commit": head_commit,
          "strategy": strategy}
    result["ab"] = ab
    return ab


def _print_ab(ab):
    """Human-readable A/B verdict for text format."""
    if ab is None:
        return
    if not ab.get("available", True):
        print("  ab: PASS (clean-HEAD A/B unavailable: %s)"
              % ab.get("reason", "n/a"))
        return
    print("  ab: %s  working=%.4f  head=%.4f  delta=%+.4f  tol=%.4f  head=%s" % (
        "PASS" if ab["passed"] else "FAIL",
        ab["working"], ab["head"], ab["delta"], ab["tolerance"],
        ab.get("head_commit") or "?"))


# --- Scorecard (Phase 3B.3): derived trend VIEW over the ledger --------------
# `bench scorecard` regenerates <kdir>/benchmarks/SCORECARD.md from the
# append-only history.jsonl: a commit + date stamped trend table (newest run
# first) plus the latest ablation delta. The ledger stays the immutable system
# of record; SCORECARD.md is the only regenerated, human-readable VIEW. Pure
# given its rows (no wall-clock, no git) so the same ledger always renders the
# same markdown.

SCORECARD_REL = os.path.join("benchmarks", "SCORECARD.md")

_SCORECARD_COLS = ("Run (UTC)", "Commit", "Committed (UTC)", "Strategy", "Mode",
                   "Recall@5", "nDCG@5", "MRR", "p50 ms", "ctx-tok",
                   "Reliability")


def _fmt_cell(value, fmt):
    """Format a numeric ledger cell, or an em-dash when missing/non-numeric."""
    return (fmt % value) if isinstance(value, (int, float)) else "—"


def render_scorecard(rows):
    """Render the append-only ledger rows as a Markdown trend table (newest run
    first) plus the latest ablation delta. Pure: deterministic given `rows`, so
    it is a faithful VIEW over the immutable ledger. Returns the markdown text.
    """
    head = "# agentware Recall / Benchmark Scorecard\n"
    intro = (
        "> Derived VIEW over the append-only benchmark ledger "
        "(`benchmarks/history.jsonl`). Regenerate with "
        "`scripts/agentware bench scorecard`. Newest run first; the ledger "
        "itself is immutable (one row per commit + run-timestamp).\n")
    if not rows:
        return "%s\n%s\n_No benchmark runs recorded yet._\n" % (head, intro)
    ordered = sorted(rows, key=lambda r: r.get("run", ""), reverse=True)
    lines = [head, intro, ""]
    lines.append("| " + " | ".join(_SCORECARD_COLS) + " |")
    lines.append("| " + " | ".join("---" for _ in _SCORECARD_COLS) + " |")
    for r in ordered:
        m = r.get("metrics", {}) or {}
        cells = [
            r.get("run") or "—",
            "`%s`" % (r.get("commit") or "—"),
            r.get("committed") or "—",
            r.get("strategy") or "—",
            r.get("mode") or "—",
            _fmt_cell(m.get("recall_at_k"), "%.4f"),
            _fmt_cell(m.get("ndcg_at_k"), "%.4f"),
            _fmt_cell(m.get("mrr"), "%.4f"),
            _fmt_cell(m.get("latency_ms_p50"), "%.3f"),
            _fmt_cell(m.get("context_tokens_mean"), "%.1f"),
            _fmt_cell(r.get("reliability"), "%.2f"),
        ]
        lines.append("| " + " | ".join(cells) + " |")
    abl_rows = [r for r in ordered if r.get("ablation")]
    if abl_rows:
        a = abl_rows[0]
        abl = a["ablation"]
        delta = abl.get("delta", {}) or {}
        lines.append("")
        lines.append(
            "## Latest ablation delta (%s vs %s) — commit `%s`, run %s"
            % (abl.get("treatment", "?"), abl.get("baseline", "?"),
               a.get("commit", "?"), a.get("run", "?")))
        lines.append("")
        lines.append("| Metric | Delta |")
        lines.append("| --- | --- |")
        for label, key in (("Recall@k", "recall_at_k"),
                           ("Precision@k", "precision_at_k"),
                           ("nDCG@k", "ndcg_at_k"), ("MRR", "mrr")):
            v = delta.get(key)
            cell = ("%+.4f" % v) if isinstance(v, (int, float)) else "—"
            lines.append("| %s | %s |" % (label, cell))
    return "\n".join(lines) + "\n"


def write_scorecard(kdir):
    """Read the ledger and (over)write SCORECARD.md as a derived VIEW. Returns
    (path, row_count). The ledger is read-only here; only the derived markdown
    view is regenerated."""
    rows = _read_ledger(os.path.join(kdir, HISTORY_REL))
    text = render_scorecard(rows)
    path = os.path.join(kdir, SCORECARD_REL)
    parent = os.path.dirname(path)
    if parent:
        os.makedirs(parent, exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write(text)
    return path, len(rows)


def cmd_bench(args):
    """`bench scorecard` regenerates benchmarks/SCORECARD.md from history.jsonl."""
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    path, n = write_scorecard(kdir)
    print("bench scorecard: wrote %s (%d ledger row%s)" % (
        path, n, "" if n == 1 else "s"))
    return 0


def redact_ledger_gold_paths(ledger_path):
    """The ONLY sanctioned mutation of the append-only ledger (`:3556` exception):
    rewrite ONLY the `gold_path` field of each row to its RELATIVE, PII-free form
    (`redact_gold_path`), preserving every other field value AND row order
    byte-for-byte.

    Redacting personal data is the documented EXCEPTION to append-only — metric
    values, reliability, fingerprints and ordering are NEVER touched. A row whose
    `gold_path` does not change keeps its ORIGINAL bytes verbatim; only a row that
    actually leaks is re-serialized (sorted keys, matching `append_ledger_row`).
    Un-parseable / blank lines are passed through untouched. Returns
    (total_rows, changed_rows). Resolves operator identity via
    `redact_gold_path` → `operator_identity_strings` (no hardcoded HOME).
    """
    if not os.path.isfile(ledger_path):
        return (0, 0)
    with open(ledger_path, encoding="utf-8") as f:
        lines = f.readlines()
    out = []
    total = 0
    changed = 0
    for raw in lines:
        stripped = raw.strip()
        if not stripped:
            out.append(raw)
            continue
        try:
            row = json.loads(stripped)
        except ValueError:
            out.append(raw)  # preserve un-parseable lines verbatim
            continue
        total += 1
        if isinstance(row, dict) and "gold_path" in row:
            new_gp = redact_gold_path(row.get("gold_path"))
            if new_gp != row.get("gold_path"):
                row["gold_path"] = new_gp
                out.append(
                    json.dumps(row, ensure_ascii=False, sort_keys=True) + "\n")
                changed += 1
                continue
        out.append(raw)  # unchanged row → keep original bytes (append-only intact)
    with open(ledger_path, "w", encoding="utf-8") as f:
        f.writelines(out)
    return (total, changed)


def cmd_bench_redact(args):
    """`bench redact` scrubs operator personal data (R-LOC-03) from the committed
    benchmark ledger: it rewrites ONLY the leaking `gold_path` field to its
    relative form, preserving every metric byte-for-byte and row order, then
    regenerates the derived SCORECARD.md beside the ledger.

    Defaults to the live knowledge dir's `benchmarks/history.jsonl`; pass an
    explicit ledger PATH (e.g. the repo's committed `benchmarks/history.jsonl`)
    to scrub that file instead. This is the ONLY sanctioned mutation of the
    append-only ledger and it may touch ONLY `gold_path`.
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    ledger = getattr(args, "path", None) or os.path.join(kdir, HISTORY_REL)
    if not os.path.isfile(ledger):
        print("bench redact: no ledger at %s (nothing to scrub)" % ledger)
        return 0
    total, changed = redact_ledger_gold_paths(ledger)
    # Regenerate the derived scorecard VIEW beside the scrubbed ledger.
    scorecard = os.path.join(
        os.path.dirname(ledger) or ".", os.path.basename(SCORECARD_REL))
    rows = _read_ledger(ledger)
    parent = os.path.dirname(scorecard)
    if parent:
        os.makedirs(parent, exist_ok=True)
    with open(scorecard, "w", encoding="utf-8") as f:
        f.write(render_scorecard(rows))
    print("bench redact: scrubbed %d/%d row gold_path(s) in %s; "
          "regenerated %s" % (changed, total, ledger, scorecard))
    return 0


def _ok(flag):
    """PASS/FAIL token for a boolean check in --acr-gate text output."""
    return "PASS" if flag else "FAIL"


def _print_acr_gate(result, decision, as_of):
    """Human-readable verdict for `eval --acr-gate` (text format)."""
    c = decision["checks"]
    print("eval --acr-gate: %s vs %s  top_k=%d  queries=%d  as_of=%s" % (
        decision["baseline"], decision["treatment"], result["top_k"],
        result["num_queries"], as_of))
    print("  gold: %s" % result.get("gold_path"))
    verdict = "PASS" if decision["passed"] else "FAIL"
    tail = "bm25+acr MAY become the default" if decision["passed"] \
        else "default stays bm25"
    print("  DECISION: %s  (%s)" % (verdict, tail))
    p = c["primary"]
    print("  [%s] primary    : nDCG delta %+.4f  (>= margin %.4f)" % (
        _ok(p["passed"]), p["delta_ndcg"], p["margin"]))
    s = c["significance"]
    print("  [%s] significant: t=%.4f  df=%d  t_crit=%.4f  mean_delta=%+.4f  "
          "(alpha=%.2f)" % (_ok(s["passed"]), s["t"], s["df"], s["t_crit"],
                            s["mean_delta"], s["alpha"]))
    w = c["win_rate"]
    print("  [%s] win-rate   : improved=%d  regressed=%d  ties=%d" % (
        _ok(w["passed"]), w["improved"], w["regressed"], w["ties"]))
    nh = c["no_harm"]
    print("  [%s] no-harm    : recall=%s  mrr=%s  latency_p50=%s  determinism=%s"
          % (_ok(nh["passed"]), _ok(nh["recall"]["passed"]),
             _ok(nh["mrr"]["passed"]), _ok(nh["latency_p50"]["passed"]),
             _ok(nh["determinism_ok"])))
    a = c["age_stratum"]
    print("  [%s] old-stratum: n=%d  base nDCG=%.4f  treat nDCG=%.4f  "
          "(no-regression)" % (_ok(a["passed"]), a["old_count"],
                               a["old_ndcg_baseline"], a["old_ndcg_treatment"]))


def _run_acr_gate(args, kdir, data, gold, gold_path, as_of):
    """Run the bm25-vs-bm25+acr ablation at a PINNED `as_of` and apply the
    deterministic 5-part ACR win gate. Exits non-zero on FAIL.

    Phase 4.1: with `--record`, appends ONE immutable `mode="acr-gate"` row
    (decision + both strategies + deltas + t-stat + per-stratum) to the ledger
    and regenerates SCORECARD.md. The recorded `strategy` field IS the resulting
    agent-facing default — `active_default_strategy` reads it so bare `recall`
    auto-flips iff the gate PASSED (else stays `bm25`). Recording is read-only
    w.r.t. the KB (INV-2). Without `--record` the gate stays a pure read."""
    result = evaluate_ablation(kdir, data, gold, args.top_k,
                               baseline="bm25", treatment="bm25+acr",
                               as_of=as_of)
    result["as_of"] = as_of
    result["gold_path"] = gold_path
    determinism_ok = _determinism_check_at(
        kdir, data, gold, args.top_k, "bm25+acr", as_of)
    decision = acr_gate_decision(
        result,
        margin=getattr(args, "acr_margin", ACR_GATE_MARGIN),
        alpha=getattr(args, "acr_alpha", ACR_GATE_ALPHA),
        determinism_ok=determinism_ok)
    result["acr_gate"] = decision
    decided = "bm25+acr" if decision["passed"] else "bm25"
    if getattr(args, "record", False):
        recorded = record_acr_gate(
            kdir, data, gold, gold_path, result, decision, args.top_k, as_of)
        scorecard_path, _ = write_scorecard(kdir)
        result["recorded"] = {
            "path": os.path.join(kdir, HISTORY_REL),
            "commit": recorded["commit"], "run": recorded["run"],
            "reliability": recorded["reliability"],
            "default_strategy": decided,
            "scorecard": scorecard_path,
        }
    if args.format == "json":
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return 0 if decision["passed"] else 1
    _print_acr_gate(result, decision, as_of)
    if "recorded" in result:
        print("  recorded : %s (run %s, reliability %.2f)" % (
            result["recorded"]["path"], result["recorded"]["run"],
            result["recorded"]["reliability"]))
        print("  default  : bare `recall` now resolves to '%s'" % decided)
    return 0 if decision["passed"] else 1


def _run_longmemeval_suite(args, kdir, data):
    """Run `eval --suite longmemeval`: the strategy-agnostic public scorer.

    Resolves the dataset (default: the CLEANED variant — the comparable baseline),
    scores the requested strategy at SESSION granularity (Recall@k headline k=5,
    nDCG/MRR, per-category, abstention separated), optionally records/gates an
    immutable ledger row, and prints a human or JSON report. Read-only w.r.t. the
    KB except the append-only ledger.
    """
    dataset_path = (getattr(args, "dataset", None)
                    or os.path.join(kdir, _LME_DEFAULT_REL))
    if not os.path.exists(dataset_path):
        sys.stderr.write(
            "agentware: longmemeval dataset not found: %s\n"
            "  acquire it per benchmarks/longmemeval/DATASET.md, or pass "
            "--dataset <path>\n" % dataset_path)
        return 1
    if args.top_k <= 0:
        sys.stderr.write("agentware: --top-k must be a positive integer\n")
        return 1
    as_of = getattr(args, "as_of", None) or _today()
    if not _is_valid_date(as_of):
        sys.stderr.write("agentware: --as-of must be a YYYY-MM-DD date\n")
        return 1
    limit = getattr(args, "limit", None)
    if limit is not None and limit <= 0:
        sys.stderr.write("agentware: --limit must be a positive integer\n")
        return 1

    try:
        result = evaluate_longmemeval(kdir, dataset_path, args.strategy,
                                      args.top_k, as_of=as_of, limit=limit)
    except NotImplementedError as exc:
        sys.stderr.write("agentware: %s\n" % exc)
        return 2
    except (ValueError, OSError, json.JSONDecodeError) as exc:
        sys.stderr.write("agentware: %s\n" % exc)
        return 1
    result["gold_path"] = dataset_path

    want_gate = getattr(args, "gate", False)
    recorded, gate = None, None
    if getattr(args, "record", False) or want_gate:
        ledger_path = os.path.join(kdir, HISTORY_REL)
        prior_rows = _read_ledger(ledger_path) if want_gate else None
        recorded = record_ledger_suite(kdir, data, result)
        result["recorded"] = {
            "path": ledger_path, "commit": recorded["commit"],
            "run": recorded["run"], "reliability": recorded["reliability"],
        }
        if want_gate:
            baseline = gate_baseline(prior_rows, recorded["strategy"],
                                     recorded.get("suite"),
                                     recorded.get("corpus_fingerprint"))
            passed, regressions = evaluate_gate(
                recorded["metrics"], recorded["reliability"], baseline,
                args.tolerance)
            gate = {
                "passed": passed, "tolerance": args.tolerance,
                "strategy": recorded["strategy"], "suite": "longmemeval",
                "seeded": baseline is None, "baseline": baseline,
                "regressions": [
                    {"metric": m, "baseline": b, "current": c}
                    for m, b, c in regressions],
            }
            result["gate"] = gate

    if args.format == "json":
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return _gate_exit(gate)

    m = result["metrics"]
    k = result["top_k"]
    ab = result["abstention"]
    print("eval --suite longmemeval: strategy=%s  top_k=%d  answerable=%d" % (
        result["strategy"], k, result["num_queries"]))
    print("  dataset: %s" % dataset_path)
    print("  as_of  : %s" % result["as_of"])
    print("  Recall@%d     : %.4f" % (k, m["recall_at_k"]))
    print("  Precision@%d  : %.4f" % (k, m["precision_at_k"]))
    print("  nDCG@%d       : %.4f" % (k, m["ndcg_at_k"]))
    print("  MRR           : %.4f" % m["mrr"])
    print("  latency (ms)  : mean=%.3f  p50=%.3f" % (
        m["latency_ms_mean"], m["latency_ms_p50"]))
    print("  determinism   : %s" % ("ok" if result["determinism_ok"] else "FAIL"))
    print("  per-category (Recall@%d / nDCG@%d / MRR / n):" % (k, k))
    for cat in sorted(result["per_category"]):
        c = result["per_category"][cat]
        print("    %-26s R=%.4f  nDCG=%.4f  MRR=%.4f  n=%d" % (
            cat, c["recall_at_k"], c["ndcg_at_k"], c["mrr"], c["num_queries"]))
    print("  abstention (excluded from Recall; reported separately): %d" % (
        ab["count"]))
    for cat in sorted(ab["by_category"]):
        print("    %-26s n=%d" % (cat, ab["by_category"][cat]))
    if recorded is not None:
        print("  recorded: %s  commit=%s  reliability=%.2f  run=%s" % (
            os.path.join(kdir, HISTORY_REL), recorded["commit"],
            recorded["reliability"], recorded["run"]))
    _print_gate(gate)
    return _gate_exit(gate)


def _run_gold_fixture_suite(args, kdir, data):
    """Run `eval --suite gold-fixture`: the frozen synthetic drift-free scorer.

    Scores the requested --strategy over the package-shipped synthetic corpus
    (NO operator data, R-LOC-03). Because the corpus is frozen its
    corpus_fingerprint is stable, so the absolute gate on this suite never
    false-FAILs on live-KB drift. Optionally records/gates an immutable ledger
    row (suite="gold-fixture"). Read-only w.r.t. the KB except the append-only
    ledger.
    """
    if args.top_k <= 0:
        sys.stderr.write("agentware: --top-k must be a positive integer\n")
        return 1
    as_of = getattr(args, "as_of", None) or _today()
    if not _is_valid_date(as_of):
        sys.stderr.write("agentware: --as-of must be a YYYY-MM-DD date\n")
        return 1
    fixture_path = getattr(args, "gold", None) or gold_fixture_path()
    try:
        result = evaluate_gold_fixture(kdir, fixture_path, args.strategy,
                                       args.top_k, as_of=as_of)
    except NotImplementedError as exc:
        sys.stderr.write("agentware: %s\n" % exc)
        return 2
    except ValueError as exc:
        sys.stderr.write("agentware: %s\n" % exc)
        return 1
    result["gold_path"] = fixture_path

    want_gate = getattr(args, "gate", False)
    recorded, gate = None, None
    if getattr(args, "record", False) or want_gate:
        ledger_path = os.path.join(kdir, HISTORY_REL)
        prior_rows = _read_ledger(ledger_path) if want_gate else None
        recorded = record_ledger_suite(kdir, data, result)
        result["recorded"] = {
            "path": ledger_path, "commit": recorded["commit"],
            "run": recorded["run"], "reliability": recorded["reliability"],
        }
        if want_gate:
            baseline = gate_baseline(prior_rows, recorded["strategy"],
                                     recorded.get("suite"),
                                     recorded.get("corpus_fingerprint"))
            passed, regressions = evaluate_gate(
                recorded["metrics"], recorded["reliability"], baseline,
                args.tolerance)
            gate = {
                "passed": passed, "tolerance": args.tolerance,
                "strategy": recorded["strategy"], "suite": GOLD_FIXTURE_SUITE,
                "seeded": baseline is None, "baseline": baseline,
                "regressions": [
                    {"metric": m, "baseline": b, "current": c}
                    for m, b, c in regressions],
            }
            result["gate"] = gate

    if args.format == "json":
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return _gate_exit(gate)

    m = result["metrics"]
    k = result["top_k"]
    print("eval --suite gold-fixture: strategy=%s  top_k=%d  queries=%d" % (
        result["strategy"], k, result["num_queries"]))
    print("  fixture: %s" % fixture_path)
    print("  as_of  : %s" % result["as_of"])
    print("  fingerprint: %s" % result.get("corpus_fingerprint"))
    print("  Recall@%d     : %.4f" % (k, m["recall_at_k"]))
    print("  Precision@%d  : %.4f" % (k, m["precision_at_k"]))
    print("  nDCG@%d       : %.4f" % (k, m["ndcg_at_k"]))
    print("  MRR           : %.4f" % m["mrr"])
    print("  determinism   : %s" % ("ok" if result["determinism_ok"] else "FAIL"))
    if recorded is not None:
        print("  recorded: %s  commit=%s  reliability=%.2f  run=%s" % (
            os.path.join(kdir, HISTORY_REL), recorded["commit"],
            recorded["reliability"], recorded["run"]))
    _print_gate(gate)
    return _gate_exit(gate)


def cmd_eval(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    if getattr(args, "suite", None) == "longmemeval":
        return _run_longmemeval_suite(args, kdir, data)
    if getattr(args, "suite", None) == GOLD_FIXTURE_SUITE:
        return _run_gold_fixture_suite(args, kdir, data)

    gold_path = args.gold or os.path.join(kdir, "benchmarks", "recall-gold.json")
    gold, gerr = load_gold(gold_path)
    if gerr is not None:
        sys.stderr.write("agentware: %s\n" % gerr)
        return 1

    if args.top_k <= 0:
        sys.stderr.write("agentware: --top-k must be a positive integer\n")
        return 1
    as_of = getattr(args, "as_of", None) or _today()
    if not _is_valid_date(as_of):
        sys.stderr.write("agentware: --as-of must be a YYYY-MM-DD date\n")
        return 1

    if getattr(args, "acr_gate", False):
        try:
            return _run_acr_gate(args, kdir, data, gold, gold_path, as_of)
        except NotImplementedError as exc:
            sys.stderr.write("agentware: %s\n" % exc)
            return 2

    if getattr(args, "ablate", False):
        baseline = getattr(args, "baseline", "tag")
        treatment = getattr(args, "treatment", "bm25")
        if baseline == treatment:
            sys.stderr.write(
                "agentware: --baseline and --treatment must differ (got %s)\n"
                % baseline)
            return 1
        try:
            result = evaluate_ablation(kdir, data, gold, args.top_k,
                                       baseline=baseline, treatment=treatment,
                                       as_of=as_of)
            result["as_of"] = as_of
        except NotImplementedError as exc:
            sys.stderr.write("agentware: %s\n" % exc)
            return 2
        result["gold_path"] = gold_path
        recorded, gate = _record_and_gate(args, kdir, data, gold, gold_path, result)
        if args.format == "json":
            json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
            return _gate_exit(gate)
        k = result["top_k"]
        base, treat = result["baseline"], result["treatment"]
        bm, tm = result["strategies"][base], result["strategies"][treat]
        d = result["delta"]
        print("eval --ablate: %s (baseline) vs %s  top_k=%d  queries=%d" % (
            base, treat, k, result["num_queries"]))
        print("  gold: %s" % gold_path)
        labels = [
            ("Recall@%d" % k, "recall_at_k"),
            ("Precision@%d" % k, "precision_at_k"),
            ("nDCG@%d" % k, "ndcg_at_k"),
            ("MRR", "mrr"),
            ("latency_ms_mean", "latency_ms_mean"),
            ("latency_ms_p50", "latency_ms_p50"),
            ("ctx_tokens_mean", "context_tokens_mean"),
        ]
        print("  %-16s %12s %12s %12s" % ("metric", base, treat, "delta"))
        for label, key in labels:
            print("  %-16s %12.4f %12.4f %+12.4f" % (
                label, bm[key], tm[key], d[key]))
        if recorded is not None:
            print("  recorded: %s  commit=%s  reliability=%.2f  run=%s" % (
                os.path.join(kdir, HISTORY_REL), recorded["commit"],
                recorded["reliability"], recorded["run"]))
        _print_gate(gate)
        return _gate_exit(gate)

    try:
        result = evaluate(kdir, data, gold, args.strategy, args.top_k, as_of=as_of)
    except NotImplementedError as exc:
        sys.stderr.write("agentware: %s\n" % exc)
        return 2
    result["gold_path"] = gold_path
    result["as_of"] = as_of
    recorded, gate = _record_and_gate(args, kdir, data, gold, gold_path, result)
    ab = (run_ab_gate(args, kdir, result, gold_path)
          if getattr(args, "ab", False) else None)

    if args.format == "json":
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return _gate_exit(gate, ab)

    m = result["metrics"]
    k = result["top_k"]
    print("eval: strategy=%s  top_k=%d  queries=%d" % (
        result["strategy"], k, result["num_queries"]))
    print("  gold: %s" % gold_path)
    print("  Recall@%d     : %.4f" % (k, m["recall_at_k"]))
    print("  Precision@%d  : %.4f" % (k, m["precision_at_k"]))
    print("  nDCG@%d       : %.4f" % (k, m["ndcg_at_k"]))
    print("  MRR           : %.4f" % m["mrr"])
    print("  latency (ms)  : mean=%.3f  p50=%.3f" % (
        m["latency_ms_mean"], m["latency_ms_p50"]))
    print("  ctx tokens    : mean=%.1f" % m["context_tokens_mean"])
    if recorded is not None:
        print("  recorded: %s  commit=%s  reliability=%.2f  run=%s" % (
            os.path.join(kdir, HISTORY_REL), recorded["commit"],
            recorded["reliability"], recorded["run"]))
    _print_gate(gate)
    _print_ab(ab)
    return _gate_exit(gate, ab)


def build_recall_payload(kdir, data, query, top_k=5, token_budget=1500,
                         category=None, strategy=None, as_of=None):
    """Build the canonical `recall --format json` payload dict. Read-only (INV-2).

    Single source of truth shared by `cmd_recall` and the MCP `recall` tool so
    both surfaces are byte-identical (INV-1): same greedy token-budget walk
    (skip-not-break graceful degradation), same `{id,path,category,score,summary,
    estimated_tokens}` records, same scoring via `recall_ranked`. `strategy=None`
    resolves the gated onboarding A/B default via `active_recall_strategy` exactly
    like bare `recall`; `as_of` defaults to today only at this boundary (PIN it for
    reproducible runs). Returns (payload, mode_notice); the caller decides what to
    do with the notice — cmd_recall writes it to stderr, the MCP tool drops it so
    JSON capture stays clean. Never mutates the KB/index (only reads).
    """
    if not as_of:
        as_of = _today()
    if strategy:
        resolved, mode_notice = strategy, ""
    else:
        resolved, mode_notice = active_recall_strategy(kdir)
    ranked = recall_ranked(kdir, data, query, top_k=top_k,
                           category=category, strategy=resolved, as_of=as_of)
    results = []
    overflow = []
    used = 0
    for entry, score, doc_text in ranked:
        cost = estimate_tokens(doc_text)
        if used + cost > token_budget:
            overflow.append({
                "id": entry.get("id"),
                "path": entry.get("path"),
                "category": entry.get("category"),
                "score": round(score, 6),
                "estimated_tokens": cost,
            })
            continue
        used += cost
        results.append({
            "id": entry.get("id"),
            "path": entry.get("path"),
            "category": entry.get("category"),
            "score": round(score, 6),
            "summary": entry.get("summary") or "",
            "estimated_tokens": cost,
        })
    payload = {
        "query": query,
        "strategy": resolved,
        "as_of": as_of,
        "top_k": top_k,
        "token_budget": token_budget,
        "category": category,
        "context_tokens": used,
        "count": len(results),
        "results": results,
        "overflow": overflow,
        "overflow_count": len(overflow),
    }
    return payload, mode_notice


def cmd_recall(args):
    """Deterministic BM25 ranked retrieval, token-budgeted (replaces MAIN.md dump).

    Returns the highest-ranked entries (id, path, score, summary) trimmed so the
    cumulative estimated token footprint stays <= --token-budget. The greedy pass
    walks ranked order and SKIPS (continue, not break) any entry that would exceed
    the budget, so smaller lower-ranked entries still fill the remaining budget
    (graceful degradation), preserving rank order among included entries (INV-5:
    reduce injected context, never increase it). Each skipped entry is recorded in
    an `overflow` pointer list (id/path/category/score/estimated_tokens — never a
    body) so a count=0 or partial result is actionable instead of a silent miss.
    Read-only (INV-2). --format json emits a stable schema for the loop.
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1
    if args.top_k < 0:
        sys.stderr.write("agentware: --top-k must be >= 0\n")
        return 1
    if args.token_budget < 0:
        sys.stderr.write("agentware: --token-budget must be >= 0\n")
        return 1
    as_of = getattr(args, "as_of", None) or _today()
    if not _is_valid_date(as_of):
        sys.stderr.write("agentware: --as-of must be a YYYY-MM-DD date\n")
        return 1

    # Resolve the ranking strategy + build the canonical payload via the shared
    # builder (single source of truth; the MCP `recall` tool reuses it so both
    # surfaces are byte-identical, INV-1). An explicit --strategy/--acr always
    # wins; otherwise build_recall_payload resolves the gated A/B default.
    explicit_strategy = getattr(args, "strategy", None)
    payload, mode_notice = build_recall_payload(
        kdir, data, args.query, top_k=args.top_k,
        token_budget=args.token_budget, category=args.category,
        strategy=explicit_strategy, as_of=as_of)
    if mode_notice:
        sys.stderr.write("agentware: %s\n" % mode_notice)
    strategy = payload["strategy"]
    results = payload["results"]
    overflow = payload["overflow"]
    used = payload["context_tokens"]

    if args.format == "json":
        json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return 0

    print("recall: query=%r  strategy=%s  top_k=%d  budget=%d  -> %d entr%s (~%d tokens)"
          % (args.query, strategy, args.top_k, args.token_budget, len(results),
             "y" if len(results) == 1 else "ies", used))
    if args.category:
        print("  category: %s" % args.category)
    for r in results:
        print("  [%.4f] %s" % (r["score"], r["id"]))
        print("    %s" % r["path"])
        if r["summary"]:
            print("    %s" % r["summary"])
    if overflow:
        print("  note: %d ranked entr%s exceeded the token budget and %s skipped "
              "(pointers only) — inspect with `agentware query --id <id>`:"
              % (len(overflow), "y" if len(overflow) == 1 else "ies",
                 "was" if len(overflow) == 1 else "were"))
        for o in overflow:
            print("    [%.4f] %s (~%d tokens) %s"
                  % (o["score"], o["id"], o["estimated_tokens"], o["path"]))
    return 0


# --- metrics (execution observability over session transcripts) -------------
# Token-usage keys live at message.usage on assistant lines. We sum exactly the
# four canonical keys (NOT cache_read/cache_creation) per the transcript format.
_USAGE_KEYS = (
    "input_tokens",
    "output_tokens",
    "cache_creation_input_tokens",
    "cache_read_input_tokens",
)

# The INPUT-side token keys: what is loaded INTO the context window on a turn
# (the prompt + cached prefix). Excludes output_tokens (the generated reply).
# Used for context-window utilization / truncation-risk derivations.
_INPUT_SIDE_KEYS = (
    "input_tokens",
    "cache_creation_input_tokens",
    "cache_read_input_tokens",
)

# Context-tax tuning. The model context window (tokens) the peak single-turn
# input-side total is measured against, and the utilization fraction past which
# a turn is flagged truncation-risk. Both configurable via `metrics
# --context-window N`; defaults match a 200K-token Claude window.
_DEFAULT_CONTEXT_WINDOW = 200_000
_CONTEXT_WINDOW_1M = 1_000_000
_TRUNCATION_RISK_THRESHOLD = 0.9


def _model_context_window(model):
    """The context-window size (tokens) for a model id. Claude 4-family models run
    with the 1M-token context beta in this harness — a single-turn peak input of
    >900k tokens is ONLY reachable with the 1M window, so measuring those turns
    against 200k yields a nonsensical >400% utilization and a permanent false
    'truncation risk'. Default to 200k for anything unrecognized."""
    m = (model or "").lower()
    if "[1m]" in m or "-1m" in m or "1m" in m.split("-")[-1:]:
        return _CONTEXT_WINDOW_1M
    if re.search(r"claude-(?:opus|sonnet|haiku)-(?:[4-9]|\d{2,})", m):
        return _CONTEXT_WINDOW_1M
    return _DEFAULT_CONTEXT_WINDOW


def _context_window_for_rows(rows):
    """The largest context window across the models present in `rows` (so peak
    utilization is measured against the real ceiling the run actually had)."""
    win = _DEFAULT_CONTEXT_WINDOW
    for r in rows:
        for model in (r.get("models") or {}):
            win = max(win, _model_context_window(model))
    return win

# --- Loop-health / runaway-detection thresholds (Task 30) --------------------
# The most-cited autonomous-agent failure modes (dead loops, runaway token burn,
# context-window overflow, no-progress) mapped to deterministic thresholds. All
# read-only derivations; thresholds are configurable per call.
#   DUP: the same (tool, args) repeated >= this many times is a dead-loop signal
#        (maps to R-FAIL-04 "never repeat an identical failing action").
#   NOPROGRESS_K: tasks_remaining flat (and > 0) across >= this many consecutive
#        MAIN iterations is a stuck-loop signal.
#   MAXITER_WARN: iterations-used / max past this fraction (run not completed) is
#        an at-risk "nearing the cap" signal; >= 1.0 is critical.
#   CONTEXT_WARN: context-window utilization past this fraction is at-risk;
#        truncation_risk (>= _TRUNCATION_RISK_THRESHOLD) is critical.
# A genuine dead-loop is the SAME (tool, args) repeated MANY times within one
# session. Normal iterative work legitimately re-reads/re-edits a file several
# times, so the 'critical' bar is set well above that (12); the at-risk warn tier
# (derived as threshold//2+1 = 7) catches the 7-11 range worth a glance.
_LOOP_HEALTH_DUP_THRESHOLD = 12
_LOOP_HEALTH_NOPROGRESS_K = 3
_LOOP_HEALTH_MAXITER_WARN = 0.8
_LOOP_HEALTH_CONTEXT_WARN = 0.75

# Default price table ($ per 1,000,000 tokens), keyed by a model-id SUBSTRING.
# Lookup picks the LONGEST matching key (most specific) so e.g.
# "claude-opus-4-20250514" matches "claude-opus-4" over "claude". Fully
# configurable via `metrics --prices <file.json>` (a JSON object of the same
# shape) so no real cost number is hard-coded into behaviour. The cost math is
# PURE: cost = sum(tokens_of_type * price_of_type) / 1e6 — no collection added.
_DEFAULT_PRICES = {
    "claude-opus-4": {
        "input": 15.0, "output": 75.0,
        "cache_creation_input_tokens": 18.75, "cache_read_input_tokens": 1.5},
    "claude-sonnet-4": {
        "input": 3.0, "output": 15.0,
        "cache_creation_input_tokens": 3.75, "cache_read_input_tokens": 0.3},
    "claude-haiku-4": {
        "input": 1.0, "output": 5.0,
        "cache_creation_input_tokens": 1.25, "cache_read_input_tokens": 0.1},
    "claude-3-5-haiku": {
        "input": 0.8, "output": 4.0,
        "cache_creation_input_tokens": 1.0, "cache_read_input_tokens": 0.08},
    "claude-3-5-sonnet": {
        "input": 3.0, "output": 15.0,
        "cache_creation_input_tokens": 3.75, "cache_read_input_tokens": 0.3},
    "default": {
        "input": 3.0, "output": 15.0,
        "cache_creation_input_tokens": 3.75, "cache_read_input_tokens": 0.3},
}

# Maps each token-usage key to its price-table component.
_PRICE_COMPONENT = {
    "input_tokens": "input",
    "output_tokens": "output",
    "cache_creation_input_tokens": "cache_creation_input_tokens",
    "cache_read_input_tokens": "cache_read_input_tokens",
}

# A feature work dir reference inside a transcript: work/<YYMMDD-name>.
_FEATURE_RE = re.compile(r"work/(\d{6}-[A-Za-z0-9][A-Za-z0-9_-]*)")
# A plan.md authored under a feature dir — the authoritative "a plan now exists"
# signal that promotes a planner session from anonymous to feature-named.
_PLAN_PATH_RE = re.compile(
    r"work/(\d{6}-[A-Za-z0-9][A-Za-z0-9_-]*)/plan\.md")
# Planning ARTIFACTS — writing/editing these is planning, not execution. Anything
# else a session edits (source code, configs, READMEs, the package) is EXECUTION.
_PLAN_DOC_RE = re.compile(
    r"work/\d{6}-[A-Za-z0-9][A-Za-z0-9_-]*/(?:plan|design)\.md$")
# Promise emitted by the agent itself (completion signal). Matched in assistant
# OUTPUT text only (not the instruction chrome that also mentions the tag).
_PROMISE_RE = re.compile(r"<promise>[^<]+</promise>")

# Cost-anomaly tuning: a day is flagged when its cost exceeds the trailing
# median of all PRIOR days by this factor, once enough history exists.
_COST_ANOMALY_FACTOR = 2.0
_COST_ANOMALY_MIN_HISTORY = 3

# Session STAGE classification (pure, documented transcript heuristic).
# Stages: plan, work, loop-pre, loop-main, loop-post, unknown.
#  - LOOP sessions are authoritative: agentware.sh exports
#    `AGENTWARE_STAGE=loop-{pre,main,post}` (Task 6/7) and that marker, when it
#    appears anywhere in the transcript, WINS — the loop knows its own phase.
#  - INTERACTIVE sessions are classified by counting discriminating signals:
#    plan-authoring sessions invoke the planner / the `plan new|add-task` CLI;
#    execution sessions run `plan set-status`, emit a completion `</promise>`,
#    or scan the worklog. Whichever side has MORE distinct hits wins; a tie or
#    no hits is `unknown` (never guess).
# The agent-NAME tokens are deliberately omitted from the signal sets because a
# harness agent-type listing can mention BOTH names in any session; the CLI/verb
# signals below only fire on an action that one role actually performs.
_STAGE_LOOP_RE = re.compile(r"AGENTWARE_STAGE=(loop-(?:pre|main|post))")
# Plan/work signals must be ACTIONS one role performs — NOT harness chrome. The
# `/agentware-plan` skill name is listed in the available-skills reminder that
# recurs on many message lines of EVERY session, so counting it inflated stage_plan
# and misclassified long execution sessions (no promise/worklog that turn) as
# "plan". Use only the planner's actual CLI verbs; execution verbs stay as-is.
_STAGE_PLAN_SIGNALS = ("/agentware-plan", "plan new", "plan add-task")
_STAGE_WORK_SIGNALS = ("plan set-status", "</promise>", "worklog scan",
                       "scripts/agentware learn")


def classify_stage(loop_stage, plan_hits, work_hits):
    """Pure stage label from the accumulated signals (documented heuristic).

    The loop's own AGENTWARE_STAGE marker is authoritative. Otherwise EXECUTION
    wins ties and presence: a session that emitted ANY execution verb (completion
    promise, `plan set-status`, worklog scan, a `learn` write) actually executed,
    so it is "work" even if the planner skill name also appears (that name recurs
    in the available-skills reminder on many lines and must never, on its own,
    label a long execution session as "plan"). Only a session with planner signals
    and NO execution signal is "plan"."""
    if loop_stage:
        return loop_stage
    if work_hits > 0:
        return "work"
    if plan_hits > 0:
        return "plan"
    return "unknown"


def _price_for(model, prices):
    """Return the price entry for a model id (longest substring match wins)."""
    best_key, best_len = None, -1
    for key in prices:
        if key == "default":
            continue
        if key in (model or "") and len(key) > best_len:
            best_key, best_len = key, len(key)
    if best_key is not None:
        return prices[best_key]
    return prices.get("default", _DEFAULT_PRICES["default"])


def _usage_cost(usage, price):
    """Pure cost ($) for a usage dict under a price entry ($ per 1M tokens)."""
    total = 0.0
    for k in _USAGE_KEYS:
        comp = _PRICE_COMPONENT[k]
        total += usage.get(k, 0) * float(price.get(comp, 0.0))
    return total / 1_000_000.0


def _cache_read_ratio(usage):
    """cache_read / total INPUT-side tokens (input + cache_creation + cache_read).

    Returns 0.0 when there is no input-side traffic (never divides by zero)."""
    total_in = (usage.get("input_tokens", 0)
                + usage.get("cache_creation_input_tokens", 0)
                + usage.get("cache_read_input_tokens", 0))
    if total_in <= 0:
        return 0.0
    return round(usage.get("cache_read_input_tokens", 0) / total_in, 6)


def _median(values):
    """Pure median of a numeric list (empty -> 0.0). Deterministic."""
    if not values:
        return 0.0
    s = sorted(values)
    n = len(s)
    mid = n // 2
    if n % 2 == 1:
        return float(s[mid])
    return (s[mid - 1] + s[mid]) / 2.0


def _dominant_feature(feature_counts):
    """The most-referenced feature in a transcript (tie-break: lexical)."""
    if not feature_counts:
        return None
    return sorted(feature_counts.items(), key=lambda kv: (-kv[1], kv[0]))[0][0]


def logs_sessions_dir(kdir):
    return os.path.join(kdir, LOGS_SESSIONS_REL)


def _parse_iso(ts):
    """Parse an ISO-8601 timestamp (tolerating a trailing 'Z') to a datetime.

    Returns None on anything unparseable so a single malformed line can never
    crash the parser (transcripts mix control lines that lack timestamps)."""
    if not isinstance(ts, str) or not ts:
        return None
    import datetime
    try:
        return datetime.datetime.fromisoformat(ts.replace("Z", "+00:00"))
    except ValueError:
        return None


def _empty_usage():
    return {k: 0 for k in _USAGE_KEYS}


def aggregate_jsonl(path):
    """Aggregate ONE JSONL transcript file (read-only).

    Returns a dict with: turns (count of assistant lines), usage (summed token
    keys), tools (tool_use name -> count), tool_calls (total), ts_first/ts_last
    (raw ISO strings among lines that HAVE a timestamp), lines (parsed),
    malformed (count of unparseable lines). Tolerates missing files, malformed
    JSON, and lines whose `type` is not assistant/user.
    """
    agg = {
        "turns": 0,
        "usage": _empty_usage(),
        "peak_input_tokens": 0,  # max single-turn input-side total (context fill)
        "models": {},          # model_id -> usage dict (ALL usage attributed)
        "features": {},        # feature name -> MENTION count (work/<feature> anywhere)
        # ACTION attribution: features referenced inside a tool_use INPUT (a file
        # the agent edited, a command it ran). This is what the session actually
        # OPERATED on — immune to injected context (MAIN.md/FEATURES.md/recall
        # listings) that mention features the session never touched. The pillars
        # attribute by this, not by passive mentions.
        "action_features": {}, # feature name -> action count (tool inputs only)
        "plan_authored": {},   # feature -> True if a work/<f>/plan.md was written
        "code_edits": 0,       # Edit/Write to a NON-planning file = execution work
        "planner_spawned": False,  # a Task(subagent_type=agentware-planner) fired
        "executor_spawned": False, # a Task(subagent_type=agentware-execution) fired
        "promise_emitted": False,  # the agent emitted a <promise>…</promise> (done)
        "loop_stage": None,    # loop-{pre,main,post} from AGENTWARE_STAGE marker
        "stage_plan": 0,       # distinct plan-authoring signal lines
        "stage_work": 0,       # distinct execution signal lines
        "tools": {},
        "tool_calls": 0,
        "ts_first": None,
        "ts_last": None,
        "_first_dt": None,
        "_last_dt": None,
        "lines": 0,
        "malformed": 0,
    }
    try:
        f = open(path, "r", encoding="utf-8")
    except (FileNotFoundError, IsADirectoryError, OSError):
        return agg
    with f:
        for raw in f:
            raw = raw.strip()
            if not raw:
                continue
            agg["lines"] += 1
            for feat in _FEATURE_RE.findall(raw):
                agg["features"][feat] = agg["features"].get(feat, 0) + 1
            if agg["loop_stage"] is None:
                sm = _STAGE_LOOP_RE.search(raw)
                if sm:
                    agg["loop_stage"] = sm.group(1)
            if any(sig in raw for sig in _STAGE_PLAN_SIGNALS):
                agg["stage_plan"] += 1
            if any(sig in raw for sig in _STAGE_WORK_SIGNALS):
                agg["stage_work"] += 1
            try:
                obj = json.loads(raw)
            except (ValueError, TypeError):
                agg["malformed"] += 1
                continue
            if not isinstance(obj, dict):
                agg["malformed"] += 1
                continue

            dt = _parse_iso(obj.get("timestamp"))
            if dt is not None:
                if agg["_first_dt"] is None or dt < agg["_first_dt"]:
                    agg["_first_dt"] = dt
                    agg["ts_first"] = obj.get("timestamp")
                if agg["_last_dt"] is None or dt > agg["_last_dt"]:
                    agg["_last_dt"] = dt
                    agg["ts_last"] = obj.get("timestamp")

            if obj.get("type") != "assistant":
                continue
            agg["turns"] += 1
            message = obj.get("message")
            if not isinstance(message, dict):
                continue
            usage = message.get("usage")
            if isinstance(usage, dict):
                model = message.get("model")
                if not isinstance(model, str) or not model:
                    model = "unknown"
                per_model = agg["models"].get(model)
                if per_model is None:
                    per_model = _empty_usage()
                    agg["models"][model] = per_model
                for k in _USAGE_KEYS:
                    v = usage.get(k)
                    if isinstance(v, (int, float)) and not isinstance(v, bool):
                        agg["usage"][k] += int(v)
                        per_model[k] += int(v)
                # Per-turn input-side total = what was loaded into the context
                # window on this turn; the MAX across turns is the peak fill, the
                # signal behind context-window-overflow / silent truncation.
                turn_in = 0
                for k in _INPUT_SIDE_KEYS:
                    v = usage.get(k)
                    if isinstance(v, (int, float)) and not isinstance(v, bool):
                        turn_in += int(v)
                if turn_in > agg["peak_input_tokens"]:
                    agg["peak_input_tokens"] = turn_in
            content = message.get("content")
            if isinstance(content, list):
                for item in content:
                    if not isinstance(item, dict):
                        continue
                    itype = item.get("type")
                    if itype == "text":
                        # The agent emitting a completion promise (its OWN output)
                        # is the authoritative "this run finished" signal.
                        txt = item.get("text")
                        if isinstance(txt, str) and _PROMISE_RE.search(txt):
                            agg["promise_emitted"] = True
                        continue
                    if itype != "tool_use":
                        continue
                    name = item.get("name") or "<unknown>"
                    agg["tools"][name] = agg["tools"].get(name, 0) + 1
                    agg["tool_calls"] += 1
                    inp = item.get("input")
                    inp_text = inp if isinstance(inp, str) else json.dumps(inp)
                    # ACTION feature attribution: features named inside a tool
                    # INPUT (an edited file path, a command operating on work/<f>).
                    for feat in _FEATURE_RE.findall(inp_text or ""):
                        agg["action_features"][feat] = \
                            agg["action_features"].get(feat, 0) + 1
                    fp = inp.get("file_path") if isinstance(inp, dict) else None
                    if isinstance(fp, str) and name in (
                            "Write", "Edit", "MultiEdit", "NotebookEdit"):
                        if _PLAN_DOC_RE.search(fp):
                            # A planning artifact (plan.md / design.md). A FULL Write
                            # of plan.md is plan AUTHORSHIP; Edits are status/marker
                            # maintenance and do NOT count as either authoring or
                            # execution. Either way it is NOT a code edit.
                            if name == "Write":
                                pm = _PLAN_PATH_RE.search(fp)
                                if pm:
                                    agg["plan_authored"][pm.group(1)] = True
                        else:
                            # Editing/writing ANY non-planning file is EXECUTION.
                            # This is what separates a planner (writes a plan and
                            # hands off) from a worker (edits code) — even when the
                            # same session did both, heavy code editing makes it a
                            # worker, not a planner.
                            agg["code_edits"] += 1
                    sub = inp.get("subagent_type") if isinstance(inp, dict) \
                        else None
                    if sub == "agentware-planner":
                        agg["planner_spawned"] = True
                    elif sub == "agentware-execution":
                        agg["executor_spawned"] = True
    return agg


def _merge_usage(into, other):
    for k in _USAGE_KEYS:
        into[k] += other.get(k, 0)


def _merge_tools(into, other):
    for name, count in other.items():
        into[name] = into.get(name, 0) + count


def _merge_models(into, other):
    """Fold a per-model usage dict (model_id -> usage) into another."""
    for model, usage in other.items():
        dest = into.get(model)
        if dest is None:
            dest = _empty_usage()
            into[model] = dest
        _merge_usage(dest, usage)


def _duration_seconds(first_dt, last_dt):
    if first_dt is None or last_dt is None:
        return 0.0
    return max(0.0, (last_dt - first_dt).total_seconds())


# =============================================================================
# Read cache (perf: collapse the O(features × sessions × file) loop hot path)
# =============================================================================
# The dashboard's loop endpoints re-derive per-feature loop state by scanning
# EVERY session transcript ONCE PER FEATURE (collect_sessions/derive_trace are
# called per feature; loop-health calls them 3× per feature). On a real KB
# (37 features × 341 sessions × up to 6 MB each ≈ 13 GB of re-parsing) this
# blows past 90 s. We memoize the expensive per-file derivations keyed by the
# source file's (mtime_ns, size) so the SECOND..Nth read is O(1) and the cache
# AUTO-INVALIDATES the instant a file changes (live-run correctness). Pure
# read-only acceleration: identical inputs → identical outputs, so every loop
# endpoint stays BYTE-IDENTICAL to the pre-cache baseline. Thread-safe (the
# dashboard is a ThreadingHTTPServer) and bounded (LRU) so memory can't grow
# without limit. The CLI stays the sole index writer; this adds no writer.

_READ_CACHE_LOCK = threading.Lock()
_READ_CACHE = OrderedDict()       # cache_key -> (file_key_tuple, value)
_READ_CACHE_MAX = 4096            # bounded LRU; evicts least-recently-used
_CACHE_MISS = object()


def _file_key(path):
    """A change-detecting identity for `path`: (mtime_ns, size), or None when the
    file is absent/unstatable. Any edit (append, rewrite) changes mtime or size,
    so a stale cache entry can never be served for a changed file."""
    try:
        st = os.stat(path)
    except OSError:
        return None
    return (st.st_mtime_ns, st.st_size)


def _multi_file_key(paths):
    """Composite change-key over several files (e.g. a session's live+main)."""
    return tuple(_file_key(p) for p in paths)


def _cached_by_key(cache_id, file_key, compute):
    """Return compute() memoized under (cache_id) and validated by file_key.

    A cache HIT requires the same recorded file_key (so a changed file misses and
    re-computes). `file_key` of None (missing file) is NOT cached — compute() runs
    every time so a file appearing later is picked up immediately. Thread-safe +
    LRU-bounded."""
    if file_key is None:
        return compute()
    with _READ_CACHE_LOCK:
        hit = _READ_CACHE.get(cache_id)
        if hit is not None and hit[0] == file_key:
            _READ_CACHE.move_to_end(cache_id)
            return hit[1]
    value = compute()
    with _READ_CACHE_LOCK:
        _READ_CACHE[cache_id] = (file_key, value)
        _READ_CACHE.move_to_end(cache_id)
        while len(_READ_CACHE) > _READ_CACHE_MAX:
            _READ_CACHE.popitem(last=False)
    return value


def _reset_read_cache():
    """Clear the read cache (used by tests for isolation; harmless in prod)."""
    with _READ_CACHE_LOCK:
        _READ_CACHE.clear()


def _cached_text(path):
    """Memoized full-text read of `path` (mtime/size-keyed), or None when absent.
    Used by the substring feature-match so a transcript is read from disk ONCE
    per request instead of once per feature."""
    fk = _file_key(path)

    def _compute():
        try:
            with open(path, "r", encoding="utf-8", errors="replace") as f:
                return f.read()
        except (FileNotFoundError, IsADirectoryError, OSError):
            return None
    return _cached_by_key(("text", path), fk, _compute)


def parse_session(session_dir):
    """Parse one session directory into a metrics row (read-only).

    Memoized by main.jsonl's (mtime_ns, size): re-parsing a 6 MB transcript once
    per feature is the loop endpoints' dominant cost. Returns a DEEP COPY so
    callers that mutate the row (e.g. apply_pricing adds cost fields in place)
    can never corrupt the cached canonical row. Live-run correct: main.jsonl
    changes every turn, which changes the key and invalidates the entry."""
    main_path = os.path.join(session_dir, "main.jsonl")
    if not os.path.isfile(main_path):
        return None
    fk = _file_key(main_path)
    row = _cached_by_key(("parse_session", os.path.abspath(session_dir)), fk,
                         lambda: _parse_session_uncached(session_dir))
    return copy.deepcopy(row) if row is not None else None


def _parse_session_uncached(session_dir):
    """Parse one session directory into a metrics row (read-only).

    Wall time is computed from main.jsonl's first->last timestamped line only.
    Token + tool totals fold in subagents/*.jsonl. subagent_count is the number
    of subagent transcript files. Returns None if there is no main.jsonl.
    """
    main_path = os.path.join(session_dir, "main.jsonl")
    if not os.path.isfile(main_path):
        return None
    main = aggregate_jsonl(main_path)

    usage = _empty_usage()
    _merge_usage(usage, main["usage"])
    models = {}
    _merge_models(models, main["models"])
    tools = dict(main["tools"])
    tool_calls = main["tool_calls"]
    turns = main["turns"]
    # Peak single-turn context fill: max across the main loop AND each subagent
    # (every agent has its OWN window, so the peak is a max, never a sum).
    peak_input = main["peak_input_tokens"]

    sub_dir = os.path.join(session_dir, "subagents")
    subagent_files = []
    if os.path.isdir(sub_dir):
        subagent_files = sorted(
            n for n in os.listdir(sub_dir) if n.endswith(".jsonl"))
    sub_usage = _empty_usage()
    sub_tools = {}
    sub_turns = 0
    # Identity signals fold the subagents in too (the planner/executor run AS
    # subagents, so their plan-authoring / action features live there).
    action_features = dict(main["action_features"])
    plan_authored = dict(main["plan_authored"])
    code_edits = main["code_edits"]
    planner_spawned = main["planner_spawned"]
    executor_spawned = main["executor_spawned"]
    promise_emitted = main["promise_emitted"]
    for name in subagent_files:
        sa = aggregate_jsonl(os.path.join(sub_dir, name))
        _merge_usage(usage, sa["usage"])
        _merge_usage(sub_usage, sa["usage"])
        _merge_models(models, sa["models"])
        _merge_tools(tools, sa["tools"])
        _merge_tools(sub_tools, sa["tools"])
        tool_calls += sa["tool_calls"]
        turns += sa["turns"]
        sub_turns += sa["turns"]
        if sa["peak_input_tokens"] > peak_input:
            peak_input = sa["peak_input_tokens"]
        for f, c in sa["action_features"].items():
            action_features[f] = action_features.get(f, 0) + c
        plan_authored.update(sa["plan_authored"])
        code_edits += sa["code_edits"]
        planner_spawned = planner_spawned or sa["planner_spawned"]
        executor_spawned = executor_spawned or sa["executor_spawned"]
        promise_emitted = promise_emitted or sa["promise_emitted"]

    duration = _duration_seconds(main["_first_dt"], main["_last_dt"])
    total_tokens = sum(usage[k] for k in _USAGE_KEYS)
    start = main["ts_first"]
    # ACTION-based feature attribution (what the session actually edited/ran),
    # falling back to a mention only when the session took no feature-scoped
    # action. This is immune to the injected MAIN.md/FEATURES.md context that
    # names features the session never touched (the "everything is tokto" bug).
    action_feature = _dominant_feature(action_features)
    feature = action_feature or _dominant_feature(main["features"])
    # Stage uses main.jsonl signals only (subagents inherit the parent's stage).
    stage = classify_stage(main["loop_stage"], main["stage_plan"],
                           main["stage_work"])
    return {
        "session_id": os.path.basename(session_dir.rstrip(os.sep)),
        "turns": turns,
        "stage": stage,
        "main_turns": main["turns"],
        "subagent_turns": sub_turns,
        "start": start,
        "end": main["ts_last"],
        "date": (start[:10] if isinstance(start, str) and start else None),
        "feature": feature,
        "action_feature": action_feature,
        "duration_seconds": round(duration, 3),
        "tokens": usage,
        "total_tokens": total_tokens,
        "peak_input_tokens": peak_input,
        "subagent_tokens": sub_usage,
        "models": {m: dict(u) for m, u in models.items()},
        "cache_read_ratio": _cache_read_ratio(usage),
        "tools": tools,
        "tool_calls": tool_calls,
        "subagent_count": len(subagent_files),
        "malformed_lines": main["malformed"],
        # --- identity signals (authoritative, action-based) -------------------
        "plan_authored": sorted(plan_authored.keys()),
        "code_edits": code_edits,
        "planner_spawned": planner_spawned,
        "executor_spawned": executor_spawned,
        "promise_emitted": promise_emitted,
    }


def _session_feature_match(session_dir, feature):
    """True iff the session transcript references the feature (deterministic).

    A session 'belongs to' a feature when its main.jsonl mentions the feature
    work dir (work/<feature>) or the bare feature name. Pure substring scan over
    the raw transcript text — no parsing, fully deterministic. The text read is
    memoized (mtime/size-keyed) so scanning N features re-reads each transcript
    from disk ONCE, not once per feature.
    """
    main_path = os.path.join(session_dir, "main.jsonl")
    text = _cached_text(main_path)
    if text is None:
        return False
    needles = (os.path.join("work", feature), feature)
    return any(n in text for n in needles)


def collect_sessions(kdir, session=None, feature=None, since=None):
    """Collect per-session metric rows, deterministically ordered.

    Filters: --session (exact id), --feature (transcript references feature),
    --since (session start date >= since, YYYY-MM-DD). Ordering is by start
    timestamp then session_id (rows lacking a start sort last) so output is
    byte-stable across runs.
    """
    root = logs_sessions_dir(kdir)
    rows = []
    if not os.path.isdir(root):
        return rows
    for name in sorted(os.listdir(root)):
        sdir = os.path.join(root, name)
        if not os.path.isdir(sdir):
            continue
        if session is not None and name != session:
            continue
        if feature is not None and not _session_feature_match(sdir, feature):
            continue
        row = parse_session(sdir)
        if row is None:
            continue
        if since is not None:
            start = row.get("start") or ""
            # Compare the YYYY-MM-DD date prefix lexically (ISO sorts correctly).
            if start[:10] < since:
                continue
        rows.append(row)
    rows.sort(key=lambda r: (r.get("start") is None, r.get("start") or "",
                             r.get("session_id") or ""))
    return rows


def _group_events_by_feature(all_events):
    """{feature: [events]} from a single full metrics.jsonl read — the in-memory
    equivalent of N _read_metrics_jsonl(feature=f) filtered reads (same order)."""
    out = {}
    for e in all_events:
        out.setdefault(e.get("feature"), []).append(e)
    return out


def _session_matched_features(sdir, features, features_key):
    """Frozenset of `features` whose name is a substring of this session's
    transcript — IDENTICAL membership to _session_feature_match (since 'work/f'
    contains 'f', the bare-name test subsumes it). Memoized by (main.jsonl
    mtime/size, features identity) so the features×sessions substring scan is
    done ONCE per session per request instead of 3× per feature (analytics +
    context-check + dup-check each used to re-scan)."""
    main_path = os.path.join(sdir, "main.jsonl")
    fk = _file_key(main_path)

    def _compute():
        text = _cached_text(main_path)
        if text is None:
            return frozenset()
        return frozenset(f for f in features if f in text)
    return _cached_by_key(("matched_feats", os.path.abspath(sdir), features_key),
                          fk, _compute)


def build_session_index(kdir, features):
    """Read every session ONCE and group it under each feature it references,
    returning {'rows': {feature: [session rows]}, 'dirs': {feature: [(name, dir)]}}.

    Byte-identical to calling collect_sessions(feature=f) and _trace_session_dirs(
    feature=f) for each feature separately (same membership, same ordering), but
    collapses the O(features × sessions × file) hot path to O(sessions × file):
    each transcript is matched + parsed exactly once and fanned out to its
    features. Read-only; safe to share across the bulk loop derivations."""
    root = logs_sessions_dir(kdir)
    features_key = hash(tuple(features))
    rows = {f: [] for f in features}
    dirs = {f: [] for f in features}
    if os.path.isdir(root):
        for name in sorted(os.listdir(root)):
            sdir = os.path.join(root, name)
            if not os.path.isdir(sdir):
                continue
            matched = _session_matched_features(sdir, features, features_key)
            if not matched:
                continue
            row = parse_session(sdir)
            for f in matched:
                dirs[f].append((name, sdir))
                if row is not None:
                    rows[f].append(row)
    for f in features:
        rows[f].sort(key=lambda r: (r.get("start") is None, r.get("start") or "",
                                    r.get("session_id") or ""))
    return {"rows": rows, "dirs": dirs}


def aggregate_metrics(rows):
    """Aggregate per-session rows into feature/global totals."""
    usage = _empty_usage()
    tools = {}
    agg = {
        "session_count": len(rows),
        "turns": 0,
        "tool_calls": 0,
        "subagent_count": 0,
        "duration_seconds": 0.0,
        "tokens": usage,
        "total_tokens": 0,
        "tools": tools,
    }
    for r in rows:
        agg["turns"] += r["turns"]
        agg["tool_calls"] += r["tool_calls"]
        agg["subagent_count"] += r["subagent_count"]
        agg["duration_seconds"] += r["duration_seconds"]
        _merge_usage(usage, r["tokens"])
        _merge_tools(tools, r["tools"])
    agg["duration_seconds"] = round(agg["duration_seconds"], 3)
    agg["total_tokens"] = sum(usage[k] for k in _USAGE_KEYS)
    return agg


# A session counts as ACTIVE when its last activity is within this window — the
# "active planner/worker" signal the dashboard surfaces (best-effort, persisted).
_AGENT_ACTIVE_WINDOW_S = 12 * 60
# Group label for sessions whose feature can't yet be determined (anonymous
# planner before a plan exists, ad-hoc worker not yet tied to a feature).
_UNATTRIBUTED = "(unattributed)"


def _is_noise_session(r):
    """A trivial/empty session that should NOT count as planner/worker activity.

    SessionStart hooks create a session dir + a near-empty main.jsonl even when no
    real work happens; those showed up as bogus '0 turns / 0 tokens / 2s' rows.
    Drop a session with no assistant turn, or with neither tokens nor tool calls."""
    if (r.get("turns", 0) or 0) <= 0:
        return True
    if (r.get("total_tokens", 0) or 0) <= 0 and (r.get("tool_calls", 0) or 0) <= 0:
        return True
    return False


def resolve_session_identity(row):
    """Resolve a session's AGENT IDENTITY per the operator's model (read-only).

    Returns {kind, feature, name, confidence, complete}:
      - kind ∈ {plan, work, loop}.
      - feature: the work feature this session belongs to, or None when it cannot
        yet be determined (anonymous planner before a plan exists; ad-hoc worker
        not yet tied to a feature).
      - name: human display label (the feature, or 'planner <id>' / 'ad-hoc <id>').
      - confidence: 'high' (attributed from an ACTION — a file it edited / plan it
        wrote / loop it ran), 'provisional' (inferred), 'pending' (not determinable
        yet — backfills once an action reveals the feature).
      - complete: did the run reach its natural end? plan authored (planner) /
        promise emitted (worker/loop). False ⇒ stopped or in-progress.

    Identity comes from what the session DID, never from passive mentions of a
    feature in injected context (which is why the old model mislabeled every
    session as 'tokto')."""
    sid = row.get("session_id") or "????????"
    short = sid.split("-")[0][:8]
    stage = row.get("stage") or "unknown"
    af = row.get("action_feature")
    planned = row.get("plan_authored") or []
    planner = bool(row.get("planner_spawned"))
    promise = bool(row.get("promise_emitted"))
    # A session EXECUTED if it edited any non-planning file, spawned the executor,
    # or emitted a completion promise. This is the line between a PLANNER (writes a
    # plan and hands off) and a WORKER (builds the feature) — even when ONE session
    # did both, heavy code editing makes it a worker that ALSO authored its plan,
    # NOT a planner. (A 668-turn / 286M-token build that wrote its plan first is a
    # worker, not a planner.)
    executed = bool(row.get("code_edits", 0)) or \
        bool(row.get("executor_spawned")) or promise

    # 1) LOOP — the orchestrated loop exports AGENTWARE_STAGE=loop-*; a loop ALWAYS
    #    has a plan to follow, so its feature IS known (the feature it operated on).
    if stage.startswith("loop-"):
        feat = af or row.get("feature")
        return {"kind": "loop", "feature": feat,
                "name": feat or ("loop " + short),
                "confidence": "high" if af else "provisional",
                "complete": promise,
                "terminal": "complete" if promise else "ended"}

    # 2) PLANNER — a session that authored a plan (or ran the planner agent) and DID
    #    NOT execute. Authoritative action only, never the polluted classify_stage
    #    'plan' label. A planner with no plan produced yet is ANONYMOUS + INCOMPLETE
    #    (named by session id until a plan exists — exactly the operator's model).
    if not executed:
        if planned:
            return {"kind": "plan", "feature": planned[0], "name": planned[0],
                    "confidence": "high", "complete": True,
                    "terminal": "complete"}
        if planner:
            return {"kind": "plan", "feature": af, "name": af or
                    ("planner " + short),
                    "confidence": "provisional" if af else "pending",
                    "complete": False, "terminal": "incomplete"}

    # 3) WORKER — execution (NON-loop), including a session that authored its plan
    #    and then built it. Named by the feature it edited (the plan it wrote, or
    #    the dominant action feature); anonymous ad-hoc when none is determinable.
    #    'complete' only on an emitted promise, else neutral 'ended'.
    term = "complete" if promise else "ended"
    feat = af or (planned[0] if planned else None)
    if feat:
        return {"kind": "work", "feature": feat, "name": feat,
                "confidence": "high", "complete": promise, "terminal": term}
    return {"kind": "work", "feature": None, "name": "ad-hoc " + short,
            "confidence": "pending", "complete": promise, "terminal": term}


def _agent_session_view(r, identity=None, status=None):
    """Compact, render-ready projection of a session row for the agent panels,
    carrying the resolved identity (name / feature / kind / confidence / status)."""
    ident = identity or resolve_session_identity(r)
    return {
        "session_id": r.get("session_id"),
        "stage": r.get("stage"),
        "kind": ident["kind"],
        "name": ident["name"],
        "feature": ident["feature"],
        "confidence": ident["confidence"],
        "complete": ident["complete"],
        "status": status or ("complete" if ident["complete"] else "stopped"),
        "start": r.get("start"),
        "end": r.get("end"),
        "date": r.get("date"),
        "turns": r.get("turns", 0),
        "main_turns": r.get("main_turns", 0),
        "subagent_turns": r.get("subagent_turns", 0),
        "tool_calls": r.get("tool_calls", 0),
        "subagent_count": r.get("subagent_count", 0),
        "duration_seconds": r.get("duration_seconds", 0.0),
        "total_tokens": r.get("total_tokens", 0),
        "peak_input_tokens": r.get("peak_input_tokens", 0),
        "cache_read_ratio": r.get("cache_read_ratio", 0.0),
        "cost_usd": r.get("cost_usd", 0.0),
        "models": sorted((r.get("models") or {}).keys()),
    }


def derive_agent_activity(kdir, kind, rows=None, now=None):
    """Per-agent (PLAN_AW / WORK_AW) activity rollup (pure, read-only, INV-2).

    Selects sessions whose resolved IDENTITY (resolve_session_identity) is `kind`
    — NOT a passive stage label — and folds them into: an ACTIVE marker (the
    most-recent session within the active window), a chronological history (each
    session carrying its honest name + complete/stopped/active status), cost/token
    /turn aggregates, and per-day + per-feature breakdowns. Loop runs are excluded
    here (they own the LOOP pillar). Noise (empty 0-turn) sessions are dropped.
    Idle-resilient: full history shows with no live run."""
    if rows is None:
        rows = collect_sessions(kdir)

    sel = []
    for r in rows:
        if _is_noise_session(r):
            continue
        ident = resolve_session_identity(r)
        if ident["kind"] != kind:
            continue
        r = dict(r)            # never mutate the cached/shared row
        r["_identity"] = ident
        sel.append(r)

    agg = aggregate_metrics(sel)
    apply_pricing(sel, agg, _DEFAULT_PRICES)  # adds cost_usd onto the COPIES + agg

    ordered = sorted(sel, key=lambda r: (r.get("start") or "",
                                         r.get("session_id") or ""),
                     reverse=True)
    ref = now if now is not None else \
        datetime.datetime.now(datetime.timezone.utc)
    active = False
    active_sid = None
    if ordered:
        last_dt = _parse_iso(ordered[0].get("end") or ordered[0].get("start"))
        if last_dt is not None and \
                (ref - last_dt).total_seconds() <= _AGENT_ACTIVE_WINDOW_S:
            active = True
            active_sid = ordered[0].get("session_id")

    def _status(r):
        if r.get("session_id") == active_sid:
            return "active"
        # complete (done signal) | incomplete (planner w/o plan) | ended (neutral).
        return r["_identity"].get("terminal", "ended")

    by_day = {}
    by_feature = {}
    for r in sel:
        d = r.get("date")
        if d:
            slot = by_day.setdefault(d, {"sessions": 0, "total_tokens": 0,
                                         "cost_usd": 0.0})
            slot["sessions"] += 1
            slot["total_tokens"] += r.get("total_tokens", 0)
            slot["cost_usd"] = round(slot["cost_usd"] + r.get("cost_usd", 0.0), 6)
        f = r["_identity"]["feature"] or _UNATTRIBUTED
        fr = by_feature.setdefault(f, {"sessions": 0, "total_tokens": 0,
                                       "cost_usd": 0.0})
        fr["sessions"] += 1
        fr["total_tokens"] += r.get("total_tokens", 0)
        fr["cost_usd"] = round(fr["cost_usd"] + r.get("cost_usd", 0.0), 6)

    incomplete = sum(1 for r in sel if _status(r) == "incomplete")
    attributed = sum(1 for r in sel if r["_identity"]["feature"])
    latest = ordered[0] if ordered else None

    return {
        "kind": kind,
        "active": active,
        "active_session": (_agent_session_view(latest, latest["_identity"],
                                               _status(latest))
                           if latest else None),
        "session_count": len(sel),
        "attributed_count": attributed,
        "incomplete_count": incomplete,
        "aggregate": {
            "total_tokens": agg.get("total_tokens", 0),
            "cost_usd": agg.get("cost_usd", 0.0),
            "turns": agg.get("turns", 0),
            "tool_calls": agg.get("tool_calls", 0),
            "subagent_count": agg.get("subagent_count", 0),
            "duration_seconds": agg.get("duration_seconds", 0.0),
            "cache_read_ratio": agg.get("cache_read_ratio", 0.0),
            "tokens": agg.get("tokens", _empty_usage()),
        },
        "by_day": by_day,
        "by_feature": by_feature,
        "sessions": [_agent_session_view(r, r["_identity"], _status(r))
                     for r in ordered],
        "features": sorted(k for k in by_feature if k != _UNATTRIBUTED),
    }


def derive_plan_authoring(kdir, rows):
    """The PLANNER's OUTPUT: every plan that was AUTHORED (a full Write of a
    work/<f>/plan.md), attributed by that authoring ACTION — independent of which
    session did it (an inline builder authors a plan inside a worker session, so
    'pure planner sessions' barely exist; the PLANS still do). Each entry carries
    the feature, when it was first authored, the authoring session, and the plan's
    size + completion read live from its plan.md markers. This is the honest
    'planner metrics' an inline-building operator actually has. Read-only."""
    first = {}
    for r in rows:
        sid = r.get("session_id")
        ts = r.get("start") or ""
        for f in (r.get("plan_authored") or []):
            cur = first.get(f)
            if cur is None or ts < cur["authored"]:
                first[f] = {"feature": f, "authored": ts,
                            "authored_session": sid}
    out = []
    for f, p in first.items():
        pm = os.path.join(kdir, "work", f, "plan.md")
        open_n, done_n = (_plan_marker_status_counts(pm)
                          if os.path.isfile(pm) else (0, 0))
        total = open_n + done_n
        if total > 0 and open_n == 0:
            status = "complete"
        elif done_n > 0:
            status = "in_progress"
        else:
            status = "open"
        out.append({
            "feature": f,
            "authored": p["authored"],
            "authored_session": p["authored_session"],
            "tasks_total": total,
            "tasks_done": done_n,
            "complete": total > 0 and open_n == 0,
            "status": status,
        })
    out.sort(key=lambda x: (x["authored"] or "", x["feature"]), reverse=True)
    return out


def derive_agents(kdir):
    """Both agent rollups (PLAN_AW + WORK_AW) from a SINGLE session read (the
    /api/agents payload). Read-only; the panels select their slice. The plan slice
    additionally carries `plans` — the authored-plan OUTPUT (see derive_plan_authoring)
    — which is the meaningful planner view for an operator who plans inline."""
    rows = collect_sessions(kdir)
    plan = derive_agent_activity(kdir, "plan", rows=rows)
    plan["plans"] = derive_plan_authoring(kdir, rows)
    return {
        "plan": plan,
        "work": derive_agent_activity(kdir, "work", rows=rows),
    }


def _cost_record(usage):
    """A rollup bucket seeded from a usage dict (tokens + zeroed cost)."""
    rec = _empty_usage()
    _merge_usage(rec, usage)
    return {
        "tokens": rec,
        "total_tokens": sum(rec[k] for k in _USAGE_KEYS),
        "cost_usd": 0.0,
        "session_count": 0,
        "cache_read_ratio": 0.0,
    }


def _finalize_record(rec):
    rec["cost_usd"] = round(rec["cost_usd"], 6)
    rec["cache_read_ratio"] = _cache_read_ratio(rec["tokens"])


def apply_pricing(rows, agg, prices):
    """Derive PURE cost/cache/model/feature/day rollups onto rows + aggregate.

    Mutates each row in `rows` (adds per-model cost + row cost_usd) and `agg`
    (adds cost_usd, cache_read_ratio, by_model, by_day, by_feature and a
    cost-anomaly flag per day). No collection, no I/O — derived only from the
    already-parsed token usage. Deterministic."""
    by_model = {}
    by_day = {}
    by_feature = {}

    for r in rows:
        row_cost = 0.0
        priced_models = {}
        for model, usage in sorted(r.get("models", {}).items()):
            price = _price_for(model, prices)
            mcost = _usage_cost(usage, price)
            row_cost += mcost
            priced_models[model] = {
                "tokens": dict(usage),
                "total_tokens": sum(usage.get(k, 0) for k in _USAGE_KEYS),
                "cost_usd": round(mcost, 6),
            }
            # by_model rollup
            mr = by_model.get(model)
            if mr is None:
                mr = _cost_record(_empty_usage())
                by_model[model] = mr
            _merge_usage(mr["tokens"], usage)
            mr["total_tokens"] = sum(mr["tokens"][k] for k in _USAGE_KEYS)
            mr["cost_usd"] += mcost
        # If a row had usage but no per-model breakdown (no model on lines),
        # price the whole row under the default entry so cost is never under-counted.
        if not r.get("models") and r.get("total_tokens"):
            row_cost += _usage_cost(r["tokens"], _price_for("", prices))
        r["models"] = priced_models
        r["cost_usd"] = round(row_cost, 6)

        date = r.get("date")
        if date:
            dr = by_day.get(date)
            if dr is None:
                dr = _cost_record(_empty_usage())
                by_day[date] = dr
            _merge_usage(dr["tokens"], r["tokens"])
            dr["cost_usd"] += row_cost
            dr["session_count"] += 1

        feat = r.get("feature") or "unknown"
        fr = by_feature.get(feat)
        if fr is None:
            fr = _cost_record(_empty_usage())
            by_feature[feat] = fr
        _merge_usage(fr["tokens"], r["tokens"])
        fr["cost_usd"] += row_cost
        fr["session_count"] += 1

    for rec in by_model.values():
        _finalize_record(rec)
    for rec in by_day.values():
        _finalize_record(rec)
    for rec in by_feature.values():
        _finalize_record(rec)

    # Cost-anomaly: walk days chronologically; flag a day whose cost exceeds the
    # trailing median of all PRIOR days by the configured factor.
    anomaly_dates = []
    history = []
    for date in sorted(by_day):
        cost = by_day[date]["cost_usd"]
        flagged = False
        if len(history) >= _COST_ANOMALY_MIN_HISTORY:
            med = _median(history)
            flagged = bool(med > 0 and cost > med * _COST_ANOMALY_FACTOR)
        by_day[date]["cost_anomaly"] = flagged
        if flagged:
            anomaly_dates.append(date)
        history.append(cost)

    agg["cost_usd"] = round(sum(r["cost_usd"] for r in rows), 6)
    agg["cache_read_ratio"] = _cache_read_ratio(agg["tokens"])
    agg["by_model"] = by_model
    agg["by_day"] = by_day
    agg["by_feature"] = by_feature
    agg["cost_anomaly_dates"] = anomaly_dates


def load_price_table(path):
    """Load + validate a JSON price table; returns (prices, error_or_None)."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except (OSError, ValueError) as e:
        return None, "could not read price table %s: %s" % (path, e)
    if not isinstance(data, dict) or not data:
        return None, "price table must be a non-empty JSON object"
    for model, entry in data.items():
        if not isinstance(entry, dict):
            return None, "price entry for %r must be an object" % model
    if "default" not in data:
        # merge over defaults so a partial table still prices unknown models
        merged = dict(_DEFAULT_PRICES)
        merged.update(data)
        return merged, None
    return data, None


def derive_plan_size(plan_path):
    """Read-only plan-authoring size metrics from a plan.md (pure parse).

    Returns {tasks, phases, accept, bytes, promise} or None when the plan is
    unreadable. NEVER writes — observation only (INV-2).
      - tasks:   well-formed task markers (`_PLAN_TASK_LINE_RE`, any status)
      - phases:  distinct MAJOR groups among phased `**N.M**` markers
                 (0 for a flat plan with no phasing)
      - accept:  `- [ ]` acceptance-criteria checkboxes under the
                 '## Acceptance criteria' heading
      - bytes:   plan.md size in bytes
      - promise: a `<promise>…</promise>` token is present
    """
    try:
        with open(plan_path, "rb") as f:
            data = f.read()
    except (OSError, ValueError):
        return None
    text = data.decode("utf-8", "replace")
    lines = text.splitlines()
    tasks = 0
    majors = []
    for ln in lines:
        m = _PLAN_TASK_LINE_RE.match(ln)
        if not m:
            continue
        tasks += 1
        parts = _parse_task_number(m.group(2))
        if len(parts) > 1 and parts[0] not in majors:
            majors.append(parts[0])
    accept = 0
    in_accept = False
    for ln in lines:
        hm = _PLAN_HEADING_RE.match(ln)
        if hm:
            in_accept = "acceptance" in hm.group(1).lower()
            continue
        if in_accept and _PLAN_CHECKBOX_RE.match(ln):
            accept += 1
    return {
        "tasks": tasks,
        "phases": len(majors),
        "accept": accept,
        "bytes": len(data),
        "promise": bool(_PLAN_PROMISE_RE.search(text)),
    }


def derive_authoring(rows):
    """Attribute plan-authoring wall-time + tokens to plan-stage sessions.

    Sums wall time + total tokens over the rows classified `stage == 'plan'`
    (pure, derived from already-parsed session rows). Returns
    {wall_s, tokens, session_count, sessions}.
    """
    wall = 0.0
    tokens = 0
    sessions = []
    for r in rows:
        if r.get("stage") == "plan":
            wall += r.get("duration_seconds", 0.0)
            tokens += r.get("total_tokens", 0)
            sessions.append(r.get("session_id"))
    return {
        "wall_s": round(wall, 3),
        "tokens": tokens,
        "session_count": len(sessions),
        "sessions": sessions,
    }


def _cache_read_per_turn(cache_read, turns):
    """Avg cache-read (re-injected context) tokens per assistant turn (pure)."""
    if turns <= 0:
        return 0.0
    return round(cache_read / turns, 3)


def derive_context_tax(rows, kdir, window=None,
                       threshold=_TRUNCATION_RISK_THRESHOLD):
    """Read-only context-tax derivations (INV-2 — derives, never writes).

    The "context tax" is the silent overhead of re-injecting context every turn
    and the risk of overflowing the model window as the KB/loop grows:
      - cache_read_per_turn: cache_read_input_tokens / turns — the avg context
        re-read per assistant turn (overall + a per-day series).
      - injected_tokens: estimate_tokens over the CURRENT MAIN.md — the
        SessionStart-injected footprint that grows with the KB (snapshot value;
        absent MAIN.md -> 0).
      - context_window_pct / truncation_risk: the PEAK single-turn input-side
        token total vs a configurable model `window` size, flagged past
        `threshold` — the documented failure where a long loop fills the window
        and silently truncates.
    Annotates each row in `rows` with cache_read_per_turn + context_window_pct +
    truncation_risk, and returns the aggregate context_tax block (incl. by_day).
    """
    if not window or window <= 0:
        # Auto-detect the real ceiling from the models in scope (1M for Claude 4
        # family) so utilization isn't measured against a wrong 200k window.
        window = _context_window_for_rows(rows)

    # Current MAIN.md footprint (snapshot; missing/unreadable -> 0). Read-only.
    injected_tokens = 0
    main_md_bytes = 0
    try:
        with open(os.path.join(kdir, "MAIN.md"), "rb") as f:
            data = f.read()
        main_md_bytes = len(data)
        injected_tokens = estimate_tokens(data.decode("utf-8", "replace"))
    except (OSError, ValueError):
        pass

    def _pct(peak):
        return round(peak / window, 6) if window else 0.0

    by_day = {}
    total_turns = 0
    total_cache_read = 0
    peak_overall = 0
    for r in rows:
        turns = r.get("turns", 0) or 0
        cr = r.get("tokens", {}).get("cache_read_input_tokens", 0)
        peak = r.get("peak_input_tokens", 0) or 0
        total_turns += turns
        total_cache_read += cr
        if peak > peak_overall:
            peak_overall = peak
        # Annotate the row (additive; existing keys untouched).
        r["cache_read_per_turn"] = _cache_read_per_turn(cr, turns)
        r["context_window_pct"] = _pct(peak)
        r["truncation_risk"] = bool(_pct(peak) >= threshold)
        date = r.get("date")
        if date:
            d = by_day.get(date)
            if d is None:
                d = {"turns": 0, "cache_read_input_tokens": 0,
                     "peak_input_tokens": 0}
                by_day[date] = d
            d["turns"] += turns
            d["cache_read_input_tokens"] += cr
            if peak > d["peak_input_tokens"]:
                d["peak_input_tokens"] = peak
    for d in by_day.values():
        d["cache_read_per_turn"] = _cache_read_per_turn(
            d["cache_read_input_tokens"], d["turns"])
        d["context_window_pct"] = _pct(d["peak_input_tokens"])
        d["truncation_risk"] = bool(d["context_window_pct"] >= threshold)

    return {
        "injected_tokens": injected_tokens,
        "main_md_bytes": main_md_bytes,
        "cache_read_per_turn": _cache_read_per_turn(total_cache_read,
                                                    total_turns),
        "context_window": window,
        "truncation_threshold": threshold,
        "peak_input_tokens": peak_overall,
        "context_window_pct": _pct(peak_overall),
        "truncation_risk": bool(_pct(peak_overall) >= threshold),
        "by_day": by_day,
    }


# ---- Per-phase / per-iteration cost attribution + terminal run outcome (Task 5)

# Maps a session `stage` tag (Task 3 `classify_stage`) to the loop PHASE bucket it
# is attributed to. The loop runs pre -> main -> post; plan-authoring and ad-hoc
# interactive work get their own buckets; an unclassifiable session is `unknown`.
# This is a PARTITION: every session lands in EXACTLY one phase, so the per-phase
# `total_tokens` SUM reproduces the aggregate session total (no double counting).
_STAGE_TO_PHASE = {
    "loop-pre": "pre",
    "loop-main": "main",
    "loop-post": "post",
    "plan": "plan",
    "work": "work",
    "unknown": "unknown",
}

# The terminal run outcomes a feature loop can end in (agentware.sh):
#   completed         -> the loop signalled done (.done / all markers ✅ / promise)
#   hit_max_iterations-> the main loop reached --max-iterations without completing
#   post_hook_failure -> a post-hook gate (features/index/lint/scan) aborted
#   pre_hook_abort    -> a pre-hook gate (steering/index/plan-lint) aborted the run
_TERMINAL_OUTCOMES = (
    "completed", "hit_max_iterations", "post_hook_failure", "pre_hook_abort",
)


def _phase_for_stage(stage):
    return _STAGE_TO_PHASE.get(stage or "unknown", "unknown")


def derive_phase_costs(rows):
    """Attribute token usage + cost to each loop PHASE (pure, read-only, INV-2).

    Buckets every session row under the phase its `stage` maps to. Because the
    mapping is a partition (each session -> exactly one bucket), summing the
    per-phase `total_tokens` reproduces the aggregate session total EXACTLY — no
    double counting (asserted by tests). Expects `apply_pricing` to have annotated
    each row with `cost_usd` (treated as 0.0 when absent). Returns
    {by_phase: {phase: cost_record + sessions[]}, total_tokens, cost_usd}.
    """
    by_phase = {}
    total_tokens = 0
    total_cost = 0.0
    for r in rows:
        phase = _phase_for_stage(r.get("stage"))
        rec = by_phase.get(phase)
        if rec is None:
            rec = _cost_record(_empty_usage())
            rec["sessions"] = []
            by_phase[phase] = rec
        _merge_usage(rec["tokens"], r.get("tokens", {}))
        rec["total_tokens"] = sum(rec["tokens"][k] for k in _USAGE_KEYS)
        rec["cost_usd"] += r.get("cost_usd", 0.0)
        rec["session_count"] += 1
        sid = r.get("session_id")
        if sid is not None:
            rec["sessions"].append(sid)
        total_tokens += r.get("total_tokens", 0)
        total_cost += r.get("cost_usd", 0.0)
    for rec in by_phase.values():
        _finalize_record(rec)
    return {
        "by_phase": by_phase,
        "total_tokens": total_tokens,
        "cost_usd": round(total_cost, 6),
    }


def _read_metrics_jsonl(kdir, feature=None):
    """Read the append-only loop-emission channel logs/metrics.jsonl (Task 6/7).

    READ-ONLY + tolerant: a missing file yields [], malformed JSON lines are
    skipped, non-dict payloads ignored. Optionally filters to one `feature`. The
    channel does not exist until the Task 6/7 shell emitter lands; until then this
    returns [] so the derivations are forward-compatible (empty, never crashing).
    """
    path = os.path.join(kdir, "logs", "metrics.jsonl")

    def _compute_all():
        out = []
        try:
            with open(path, "r", encoding="utf-8", errors="replace") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        obj = json.loads(line)
                    except ValueError:
                        continue
                    if not isinstance(obj, dict):
                        continue
                    out.append(obj)
        except OSError:
            return []
        return out

    # Parse the whole channel ONCE (mtime/size-keyed), then filter in memory.
    # Previously each of the 37 per-feature calls re-read+re-parsed the entire
    # file; now repeated calls within a request (and across polls) are O(events).
    all_events = _cached_by_key(("metrics_jsonl", path), _file_key(path),
                                _compute_all)
    if feature is None:
        return list(all_events)
    return [e for e in all_events if e.get("feature") == feature]


def derive_iteration_costs(events):
    """Per-iteration loop structure from the metrics.jsonl emission (read-only).

    Groups the per-iteration loop events (those carrying an integer `iteration`)
    into an ordered series with per-phase wall-time + task-burndown signals. Each
    record: {iteration, phases: {phase: wall_s}, phase_wall_s, tasks_remaining,
    tasks_done_delta, self_heal_count}. Returns [] when the emission channel is
    absent (Task 6/7 add it) — forward-compatible, never fabricates per-iteration
    data that the loop has not yet emitted.
    """
    by_it = {}
    order = []
    for e in events:
        # Skip the non-iteration event types (Task 7): task_transition events also
        # carry an integer `iteration` but describe a single task's lifecycle, not
        # the per-iteration loop structure; terminal events have no iteration. Only
        # the Task-6 per-iteration/phase events (no `event` discriminator) fold here.
        if e.get("event") in ("task_transition", "terminal"):
            continue
        it = e.get("iteration")
        if not isinstance(it, int) or isinstance(it, bool):
            continue
        rec = by_it.get(it)
        if rec is None:
            rec = {
                "iteration": it,
                "phases": {},
                "phase_wall_s": 0.0,
                "tasks_remaining": e.get("tasks_remaining"),
                "tasks_done_delta": 0,
                "self_heal_count": e.get("self_heal_count"),
            }
            by_it[it] = rec
            order.append(it)
        phase = e.get("phase") or e.get("stage") or "main"
        wall = e.get("phase_wall_s") or 0.0
        try:
            wall = float(wall)
        except (TypeError, ValueError):
            wall = 0.0
        rec["phases"][phase] = round(rec["phases"].get(phase, 0.0) + wall, 3)
        rec["phase_wall_s"] = round(rec["phase_wall_s"] + wall, 3)
        if isinstance(e.get("tasks_done_delta"), int) and \
                not isinstance(e.get("tasks_done_delta"), bool):
            rec["tasks_done_delta"] += e["tasks_done_delta"]
        if e.get("tasks_remaining") is not None:
            rec["tasks_remaining"] = e.get("tasks_remaining")
        if e.get("self_heal_count") is not None:
            rec["self_heal_count"] = e.get("self_heal_count")
    return [by_it[i] for i in sorted(order)]


def _plan_marker_status_counts(plan_path):
    """Count plan.md task markers by status -> (open, done); open = ⬜/🟡 (pure).

    Reads plan.md with the SAME `_PLAN_TASK_LINE_RE` the linter uses. Returns
    (0, 0) on an unreadable plan. Read-only.
    """
    open_n = 0
    done_n = 0
    try:
        with open(plan_path, "r", encoding="utf-8", errors="replace") as f:
            for ln in f:
                m = _PLAN_TASK_LINE_RE.match(ln)
                if not m:
                    continue
                if m.group(1) == "✅":
                    done_n += 1
                else:
                    open_n += 1
    except OSError:
        return (0, 0)
    return (open_n, done_n)


def derive_outcome(kdir, feature, events=None):
    """Derive a feature's terminal run outcome (read-only, NEVER writes — INV-2).

    Outcome ∈ _TERMINAL_OUTCOMES (plus `unknown` when the artifacts are
    indeterminate). Precedence:
      1. AUTHORITATIVE — the LAST terminal event in logs/metrics.jsonl (Task 7
         appends {feature, outcome, iterations_used, self_heal_count, ...} on loop
         exit). Used verbatim; it is the deterministic source for all four states.
      2. ARTIFACT heuristic over the persisted feature dir — only `completed` is
         asserted with confidence (a `.loop/.done` signal, OR every plan task ✅).
         Anything else stays `unknown` rather than GUESS a failure mode the
         artifacts cannot distinguish (R-FAIL — never guess).
    Returns {outcome, source, iterations_used?, self_heal_count?, signals} or None
    when no feature is in scope.
    """
    if not feature:
        return None
    if events is None:
        events = _read_metrics_jsonl(kdir, feature=feature)
    terminal = [e for e in events
                if e.get("feature") == feature
                and e.get("outcome") in _TERMINAL_OUTCOMES]
    if terminal:
        last = terminal[-1]
        return {
            "outcome": last["outcome"],
            "source": "metrics.jsonl",
            "iterations_used": last.get("iterations_used"),
            "self_heal_count": last.get("self_heal_count"),
            "signals": {"terminal_events": len(terminal)},
        }
    fdir = os.path.join(kdir, "work", feature)
    done_flag = os.path.isfile(os.path.join(fdir, ".loop", ".done"))
    assessment = os.path.isfile(os.path.join(fdir, "assessment.md"))
    open_n, done_n = _plan_marker_status_counts(os.path.join(fdir, "plan.md"))
    signals = {"loop_done": done_flag, "assessment": assessment,
               "open_markers": open_n, "done_markers": done_n}
    if done_flag:
        return {"outcome": "completed", "source": "loop-done", "signals": signals}
    if done_n > 0 and open_n == 0:
        return {"outcome": "completed",
                "source": "assessment" if assessment else "plan-markers",
                "signals": signals}
    return {"outcome": "unknown", "source": "artifacts", "signals": signals}


# --- Loop analytics (Task 28) -------------------------------------------------
# First-class observability over the 3-phase loop — agentware's differentiator.
# ALL derivations below are PURE + READ-ONLY (INV-2): they read only the existing
# append-only logs/metrics.jsonl emission channel (Task 6/7) + the already-parsed
# session rows, never writing anything. Forward-compatible: every field degrades
# to None/[]/{} when the channel has not emitted it yet (never fabricated).

_LOOP_PHASES = ("pre", "main", "post")


def _normalize_phase(phase):
    """`loop-pre`/`loop-main`/`loop-post` (the stage tag) -> bare phase name."""
    if isinstance(phase, str) and phase.startswith("loop-"):
        return phase[len("loop-"):]
    return phase or "main"


def list_loop_features(kdir):
    """Sorted feature dirs under <kdir>/work carrying a plan.md or a .loop/ — the
    unit the loop operates on (read-only directory listing; [] when absent)."""
    work = os.path.join(kdir, "work")
    out = []
    try:
        for name in sorted(os.listdir(work)):
            fdir = os.path.join(work, name)
            if not os.path.isdir(fdir):
                continue
            if os.path.isfile(os.path.join(fdir, "plan.md")) or \
                    os.path.isdir(os.path.join(fdir, ".loop")):
                out.append(name)
    except OSError:
        return []
    return out


def derive_loop_throughput(kdir, events=None):
    """Loop throughput over time: features COMPLETED per day + ISO week, derived
    from the terminal events (outcome == 'completed') across all features. Pure +
    read-only; an empty channel yields empty maps."""
    if events is None:
        events = _read_metrics_jsonl(kdir)
    by_day = {}
    by_week = {}
    for e in events:
        if e.get("event") != "terminal" or e.get("outcome") != "completed":
            continue
        ts = e.get("ts")
        dt = _parse_iso(ts)
        if dt is None or not isinstance(ts, str):
            continue
        day = ts[:10]
        by_day[day] = by_day.get(day, 0) + 1
        iso = dt.isocalendar()
        wk = "%04d-W%02d" % (iso[0], iso[1])
        by_week[wk] = by_week.get(wk, 0) + 1
    return {
        "by_day": by_day,
        "by_week": by_week,
        "completed_total": sum(by_day.values()),
    }


def _loop_analytics_for_feature(kdir, feature, events=None, sessions_rows=None):
    """Per-run loop analytics for ONE feature (pure, read-only). Folds the
    metrics.jsonl emission into: per-phase wall split, iterations-to-completion,
    a tasks-remaining burndown, iteration efficiency, self-heal count,
    max-iteration utilization, pre/post-hook gate outcomes, promise/.done
    latency, and the terminal outcome. Empty channel -> safe zero/None values."""
    if events is None:
        events = _read_metrics_jsonl(kdir, feature=feature)
    outcome = derive_outcome(kdir, feature, events=events)
    terminals = [e for e in events if e.get("event") == "terminal"]
    terminal = terminals[-1] if terminals else {}

    phase_wall = {}
    gates = {"pre": [], "post": []}
    iter_ts = []
    max_seen = None
    # The 3 phases each run their OWN iteration counter (pre 1..3, main 1..N,
    # post 1..3), so their iteration numbers OVERLAP. The burndown is the MAIN
    # loop's tasks-remaining curve, so it folds main-phase events ONLY (keyed by
    # iteration: last remaining seen + summed done-delta); pre/post wall-time is
    # still attributed to phase_wall, and pre/post events drive the gate outcomes.
    main_by_it = {}
    main_order = []
    for e in events:
        if e.get("event") in ("task_transition", "terminal"):
            continue
        phase = _normalize_phase(e.get("phase") or e.get("stage"))
        wall = e.get("phase_wall_s") or 0.0
        try:
            wall = float(wall)
        except (TypeError, ValueError):
            wall = 0.0
        phase_wall[phase] = round(phase_wall.get(phase, 0.0) + wall, 3)
        if isinstance(e.get("ts"), str):
            iter_ts.append(e["ts"])
        m = e.get("max")
        if isinstance(m, int) and not isinstance(m, bool):
            max_seen = m if max_seen is None else max(max_seen, m)
        if phase in ("pre", "post"):
            gates[phase].append({
                "iteration": e.get("iteration"),
                "result": e.get("result"),
                "promise_status": e.get("promise_status"),
                "ts": e.get("ts"),
                "ok": (e.get("promise_status") == "signalled"
                       or e.get("result") == "complete"),
            })
        elif phase == "main":
            it = e.get("iteration")
            if not isinstance(it, int) or isinstance(it, bool):
                continue
            rec = main_by_it.get(it)
            if rec is None:
                rec = {"iteration": it, "tasks_remaining": None,
                       "tasks_done_delta": 0}
                main_by_it[it] = rec
                main_order.append(it)
            if e.get("tasks_remaining") is not None:
                rec["tasks_remaining"] = e.get("tasks_remaining")
            d = e.get("tasks_done_delta")
            if isinstance(d, int) and not isinstance(d, bool):
                rec["tasks_done_delta"] += d
            sh = e.get("self_heal_count")
            if isinstance(sh, int) and not isinstance(sh, bool):
                rec["self_heal_count"] = sh

    # Per-phase TOKEN split from the already-parsed session rows (read-only): the
    # phase a session lands in is its AGENTWARE_STAGE (Task 3/5 classifier).
    # `sessions_rows` (from a shared single-pass index) avoids re-scanning every
    # session per feature; falls back to the per-feature scan when not supplied.
    rows = (sessions_rows if sessions_rows is not None
            else collect_sessions(kdir, feature=feature))
    by_phase = derive_phase_costs(rows)["by_phase"]
    phase_tokens = {ph: by_phase[ph]["total_tokens"] for ph in by_phase}

    iterations = [main_by_it[i] for i in sorted(main_order)]
    burndown = [{
        "iteration": r["iteration"],
        "tasks_remaining": r.get("tasks_remaining"),
        "tasks_done_delta": r.get("tasks_done_delta", 0),
    } for r in iterations]

    tasks_closed = sum((r.get("tasks_done_delta") or 0) for r in iterations)
    n_iters = terminal.get("iterations_used")
    if not isinstance(n_iters, int) or isinstance(n_iters, bool) or n_iters <= 0:
        n_iters = len(iterations)
    iteration_efficiency = round(tasks_closed / n_iters, 3) if n_iters else None

    max_iter = terminal.get("max")
    if not isinstance(max_iter, int) or isinstance(max_iter, bool):
        max_iter = max_seen
    max_util = (round(n_iters / max_iter, 3)
                if (isinstance(max_iter, int) and max_iter and n_iters)
                else None)

    self_heal = terminal.get("self_heal_count")
    if self_heal is None:
        sh = [r.get("self_heal_count") for r in iterations
              if isinstance(r.get("self_heal_count"), int)
              and not isinstance(r.get("self_heal_count"), bool)]
        self_heal = max(sh) if sh else 0

    latency_s = None
    if terminal and iter_ts:
        t0 = _parse_iso(min(iter_ts))
        t1 = _parse_iso(terminal.get("ts"))
        if t0 is not None and t1 is not None:
            latency_s = round((t1 - t0).total_seconds(), 3)

    return {
        "feature": feature,
        "outcome": (outcome or {}).get("outcome", "unknown"),
        "iterations_to_completion": n_iters,
        "max_iterations": max_iter,
        "max_iteration_utilization": max_util,
        "iteration_efficiency": iteration_efficiency,
        "tasks_closed": tasks_closed,
        "tasks_total": terminal.get("tasks_total"),
        "tasks_done": terminal.get("tasks_done"),
        "self_heal_count": self_heal,
        "promise_status": terminal.get("promise_status"),
        "latency_s": latency_s,
        "burndown": burndown,
        "phase_wall_s": phase_wall,
        "phase_tokens": phase_tokens,
        "gates": gates,
        "event_count": len(events),
    }


def derive_loop_analytics(kdir, feature=None):
    """Loop analytics for the Loops dashboard section (pure, read-only, INV-2).

    With a `feature`, returns that single run's analytics dict. Without one,
    returns {features: [per-feature dicts], throughput: {by_day, by_week,
    completed_total}} across every work feature. Never writes; degrades to empty
    structures when the emission channel is absent (forward-compatible)."""
    if feature:
        return _loop_analytics_for_feature(kdir, feature)
    all_events = _read_metrics_jsonl(kdir)
    by_feat = _group_events_by_feature(all_events)
    features = list_loop_features(kdir)
    index = build_session_index(kdir, features)
    feats = [_loop_analytics_for_feature(
                kdir, f, events=by_feat.get(f, []),
                sessions_rows=index["rows"].get(f, []))
             for f in features]
    return {
        "features": feats,
        "throughput": derive_loop_throughput(kdir, events=all_events),
    }


# --- Trace / Run-explorer (Task 29) ------------------------------------------
# Step-level observability — the #1 LLM/agent-observability pain ("see the
# reasoning, not just inputs/outputs"). Builds an ORDERED tool-call step timeline
# (name, args, result, status, timing, best-effort tokens) + marker/decision
# transitions, GROUPED by loop iteration, from logs/sessions/<sid>/{live.jsonl,
# main.jsonl} + the metrics.jsonl emission. PURE + READ-ONLY (INV-2): reads logs
# only, NEVER writes. Forward-compatible: missing logs yield empty groups.


def _trace_io(raw, limit=2000):
    """Normalize a tool I/O field to a bounded STRING for the trace payload.

    The live.jsonl hook stores tool_input/tool_response as JSON STRINGS (already
    truncated to ~1500 chars). Re-serialize parseable JSON deterministically
    (sorted keys) and bound length, returning (text, truncated_bool). Strings
    keep the UI contract simple — the step detail shows truncated tool I/O."""
    if raw is None:
        return "", False
    if isinstance(raw, str):
        try:
            s = json.dumps(json.loads(raw), ensure_ascii=False, sort_keys=True)
        except ValueError:
            s = raw
    else:
        s = json.dumps(raw, ensure_ascii=False, sort_keys=True)
    if len(s) > limit:
        return s[:limit] + " …[truncated]", True
    return s, False


def _main_tooluse_token_shares(main_path):
    """Memoized wrapper (mtime/size-keyed) over the per-step token attribution —
    read once per request instead of once per feature's trace derivation."""
    return _cached_by_key(("tooluse_shares", main_path), _file_key(main_path),
                          lambda: _main_tooluse_token_shares_uncached(main_path))


def _main_tooluse_token_shares_uncached(main_path):
    """Ordered (tool_name, token_share) for each main-agent tool_use in main.jsonl.

    A turn's output_tokens are split EVENLY across the tool_use items it emitted
    (best-effort per-step token attribution). Read-only; [] when the transcript
    is absent/unreadable/malformed."""
    shares = []
    try:
        f = open(main_path, "r", encoding="utf-8", errors="replace")
    except (FileNotFoundError, IsADirectoryError, OSError):
        return shares
    with f:
        for raw in f:
            raw = raw.strip()
            if not raw:
                continue
            try:
                obj = json.loads(raw)
            except ValueError:
                continue
            if not isinstance(obj, dict) or obj.get("type") != "assistant":
                continue
            msg = obj.get("message")
            content = msg.get("content") if isinstance(msg, dict) else None
            if not isinstance(content, list):
                continue
            names = [it.get("name") or "<unknown>" for it in content
                     if isinstance(it, dict) and it.get("type") == "tool_use"]
            if not names:
                continue
            usage = msg.get("usage") if isinstance(msg.get("usage"), dict) else {}
            out = usage.get("output_tokens")
            out = out if isinstance(out, int) and not isinstance(out, bool) else 0
            share = round(out / len(names))
            for nm in names:
                shares.append((nm, share))
    return shares


def _trace_steps_for_session(sdir):
    """Memoized wrapper (keyed on this session's live.jsonl+main.jsonl identity)
    over the step build. derive_trace MUTATES returned steps (sets iteration), so
    return a DEEP COPY to keep the cached canonical steps pristine across the
    per-feature trace calls that loop-health/alerts make repeatedly."""
    keyfiles = (os.path.join(sdir, "live.jsonl"), os.path.join(sdir, "main.jsonl"))
    steps = _cached_by_key(("trace_steps", os.path.abspath(sdir)),
                           _multi_file_key(keyfiles),
                           lambda: _trace_steps_for_session_uncached(sdir))
    return copy.deepcopy(steps)


def _trace_steps_for_session_uncached(sdir):
    """Build a session's ordered tool-call steps (read-only).

    Primary source: live.jsonl (the per-action stream carrying name/args/result/
    status/ts). Falls back to main.jsonl tool_use items when no live stream
    exists (no result/status then). Per-step duration = the next step's ts minus
    this ts (within the session); per-step tokens align best-effort to the
    main.jsonl turn output tokens by ordered name match."""
    live_path = os.path.join(sdir, "live.jsonl")
    main_path = os.path.join(sdir, "main.jsonl")
    shares = _main_tooluse_token_shares(main_path)
    steps = []
    live_rows = []
    try:
        with open(live_path, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                if isinstance(obj, dict):
                    live_rows.append(obj)
    except OSError:
        live_rows = []
    if live_rows:
        for obj in live_rows:
            args, at = _trace_io(obj.get("input"))
            res, rt = _trace_io(obj.get("response"))
            steps.append({
                "ts": obj.get("ts") if isinstance(obj.get("ts"), str) else None,
                "tool": obj.get("tool") or "<unknown>",
                "status": obj.get("status") or "ok",
                "args": args, "args_truncated": at,
                "result": res, "result_truncated": rt,
            })
    else:
        # Fallback: main.jsonl tool_use items (no result/status streamed).
        try:
            f = open(main_path, "r", encoding="utf-8", errors="replace")
        except (FileNotFoundError, IsADirectoryError, OSError):
            f = None
        if f is not None:
            with f:
                for raw in f:
                    raw = raw.strip()
                    if not raw:
                        continue
                    try:
                        obj = json.loads(raw)
                    except ValueError:
                        continue
                    if not isinstance(obj, dict) or \
                            obj.get("type") != "assistant":
                        continue
                    msg = obj.get("message")
                    ts = obj.get("timestamp")
                    ts = ts if isinstance(ts, str) else None
                    content = msg.get("content") if isinstance(msg, dict) else None
                    if not isinstance(content, list):
                        continue
                    for it in content:
                        if isinstance(it, dict) and it.get("type") == "tool_use":
                            args, at = _trace_io(it.get("input"))
                            steps.append({
                                "ts": ts, "tool": it.get("name") or "<unknown>",
                                "status": "ok", "args": args,
                                "args_truncated": at, "result": "",
                                "result_truncated": False,
                            })
    # Per-step tokens: best-effort index+name alignment with main-agent turns.
    for i, st in enumerate(steps):
        st["tokens"] = (shares[i][1]
                        if i < len(shares) and shares[i][0] == st["tool"]
                        else None)
    # Per-step duration within the session (next.ts - this.ts).
    for i, st in enumerate(steps):
        dur = None
        if st["ts"] is not None and i + 1 < len(steps):
            t0 = _parse_iso(st["ts"])
            t1 = _parse_iso(steps[i + 1]["ts"])
            if t0 is not None and t1 is not None:
                d = round((t1 - t0).total_seconds(), 3)
                dur = d if d >= 0 else None
        st["duration_s"] = dur
    return steps


def _trace_session_dirs(kdir, session=None, feature=None):
    """Resolve the session dirs in scope (read-only): a single `session` id, or
    every session whose transcript references `feature`. Sorted by session id."""
    root = logs_sessions_dir(kdir)
    out = []
    if not os.path.isdir(root):
        return out
    if session is not None:
        sdir = os.path.join(root, session)
        if os.path.isdir(sdir):
            out.append((session, sdir))
        return out
    for name in sorted(os.listdir(root)):
        sdir = os.path.join(root, name)
        if not os.path.isdir(sdir):
            continue
        if feature is not None and not _session_feature_match(sdir, feature):
            continue
        out.append((name, sdir))
    return out


def _trace_iteration_windows(events):
    """Sorted [(ts, iteration)] boundaries from the metrics.jsonl MAIN-phase
    events, used to bucket trace steps into loop iterations by timestamp."""
    wins = []
    for e in events:
        if e.get("event") in ("task_transition", "terminal"):
            continue
        if _normalize_phase(e.get("phase") or e.get("stage")) != "main":
            continue
        it = e.get("iteration")
        ts = e.get("ts")
        if isinstance(it, int) and not isinstance(it, bool) \
                and isinstance(ts, str):
            wins.append((ts, it))
    wins.sort(key=lambda w: w[0])
    return wins


def _iteration_for_ts(windows, ts):
    """The iteration of the latest window starting at-or-before ts (None if the
    step predates the first window or has no timestamp)."""
    if not isinstance(ts, str):
        return None
    found = None
    for wts, it in windows:
        if wts <= ts:
            found = it
        else:
            break
    return found


def derive_trace(kdir, session=None, feature=None, max_steps=4000,
                 sess_dirs=None, events=None):
    """Step-level run trace for the Trace/Run-explorer (pure, read-only, INV-2).

    Scope is a single `session` id or a `feature` (all sessions whose transcript
    references it). Returns an ORDERED tool-call step timeline grouped by loop
    iteration, plus per-iteration marker/decision transitions from metrics.jsonl.
    Empty/missing logs yield empty groups (forward-compatible, never crashes).
    Optional `sess_dirs`/`events` (shared single-pass index) skip the per-feature
    session re-scan + metrics re-read when the bulk caller already has them."""
    if sess_dirs is None:
        sess_dirs = _trace_session_dirs(kdir, session=session, feature=feature)
    # Resolve the feature used for iteration/transition grouping.
    grp_feature = feature
    if grp_feature is None and session is not None and sess_dirs:
        row = parse_session(sess_dirs[0][1])
        if row:
            grp_feature = row.get("feature")
    if events is None:
        events = (_read_metrics_jsonl(kdir, feature=grp_feature)
                  if grp_feature else [])
    windows = _trace_iteration_windows(events)
    transitions = [e for e in events if e.get("event") == "task_transition"]

    steps = []
    sessions_meta = []
    for sid, sdir in sess_dirs:
        s_steps = _trace_steps_for_session(sdir)
        for st in s_steps:
            st["session_id"] = sid
        sessions_meta.append({"session_id": sid, "step_count": len(s_steps)})
        steps.extend(s_steps)
    # Deterministic global order: by ts (None last), then session id, then arrival.
    steps.sort(key=lambda s: (s.get("ts") is None, s.get("ts") or "",
                              s.get("session_id") or ""))
    truncated = False
    if len(steps) > max_steps:
        steps = steps[:max_steps]
        truncated = True

    tool_summary = {}
    for i, st in enumerate(steps):
        st["index"] = i
        st["iteration"] = _iteration_for_ts(windows, st.get("ts"))
        tool_summary[st["tool"]] = tool_summary.get(st["tool"], 0) + 1

    groups = {}
    order = []

    def _group(itv):
        if itv not in groups:
            groups[itv] = {"iteration": itv, "steps": [], "transitions": []}
            order.append(itv)
        return groups[itv]

    for st in steps:
        _group(st["iteration"])["steps"].append(st)
    for tr in transitions:
        itv = tr.get("iteration")
        if not isinstance(itv, int) or isinstance(itv, bool):
            itv = None
        _group(itv)["transitions"].append({
            "ts": tr.get("ts"), "task": tr.get("task"),
            "from": tr.get("from"), "to": tr.get("to"),
            "approx": tr.get("approx"),
        })

    iterations = [groups[k] for k in
                  sorted(order, key=lambda k: (k is None,
                                               k if isinstance(k, int) else 0))]
    for g in iterations:
        g["step_count"] = len(g["steps"])

    err_count = sum(1 for s in steps if s.get("status") == "ERR")
    return {
        "scope": "session" if session is not None else "feature",
        "session": session,
        "feature": grp_feature,
        "sessions": sessions_meta,
        "step_count": len(steps),
        "err_count": err_count,
        "tool_summary": tool_summary,
        "truncated": truncated,
        "iterations": iterations,
    }


# --- Loop-health & runaway detection (Task 30) -------------------------------
# The most-cited autonomous-agent pain: dead loops, runaway token burn, context-
# window overflow, and silent no-progress (maps to agentware R-FAIL-04). ALL
# derivations below are PURE + READ-ONLY (INV-2): they fold the existing trace
# (live.jsonl) + loop-analytics (metrics.jsonl) + context-tax (session rows)
# derivations into per-run health signals, never writing anything. Each check
# degrades to an OK/empty result when its source is absent (forward-compatible).

_LOOP_HEALTH_SEVERITY = {"ok": 0, "at_risk": 1, "critical": 2}


def _worst_status(statuses):
    """The most-severe status among an iterable of {ok,at_risk,critical}."""
    worst = "ok"
    for s in statuses:
        if _LOOP_HEALTH_SEVERITY.get(s, 0) > _LOOP_HEALTH_SEVERITY[worst]:
            worst = s
    return worst


def _loop_health_dup_check(kdir, feature, threshold, sess_dirs=None,
                           events=None):
    """Duplicate/repeated tool-call detection — a dead-loop signal (R-FAIL-04).

    Folds the read-only trace steps (live.jsonl per-action stream) into a count
    per (tool, args) signature; the worst offender drives the status. `flagged`
    when the same call repeats >= `threshold` times. Names the offending tool +
    the iteration it recurs in so the badge can point at the stuck step. Optional
    `sess_dirs`/`events` come from the shared single-pass index (avoid re-scan)."""
    # AUTHORITATIVE attribution: count duplicate tool calls only from sessions whose
    # DOMINANT feature is this one. A broad substring match folds the single global
    # outlier session (e.g. "Read repeated 77×" while it discussed many features)
    # into EVERY feature's dup count, making 100% of runs read 'critical'. Filter to
    # dominant-feature sessions; keep the broad set only if the strict filter empties.
    if sess_dirs is not None:
        sess_dirs = [(sid, sdir) for (sid, sdir) in sess_dirs
                     if (parse_session(sdir) or {}).get("feature") == feature]
    tr = derive_trace(kdir, feature=feature, sess_dirs=sess_dirs, events=events)
    # A genuine dead-loop is the SAME (tool, args) repeated within ONE session (or
    # iteration window). Counting across a feature's whole multi-session history
    # inflates normal re-reads/edits into a false 'critical', so scope the signature
    # by session (and iteration when the emission channel provides one). This makes
    # 'critical' actually mean "stuck repeating one call", not "long-lived feature".
    counts = {}
    first_iter = {}
    for grp in tr.get("iterations", []):
        for st in grp.get("steps", []):
            key = (st.get("session_id"), st.get("iteration"),
                   st.get("tool") or "<unknown>", st.get("args") or "")
            counts[key] = counts.get(key, 0) + 1
            if key not in first_iter:
                first_iter[key] = st.get("iteration")
    max_count = 0
    offender = None
    for key, n in counts.items():
        if n > max_count:
            max_count, offender = n, key
    # offender is (session_id, iteration, tool, args); expose tool/iteration.
    offender_tool = offender[2] if offender else None
    warn = max(2, threshold // 2 + 1)
    if max_count >= threshold:
        status = "critical"
    elif max_count >= warn:
        status = "at_risk"
    else:
        status = "ok"
    return {
        "name": "duplicate_tool_calls",
        "status": status,
        "flagged": max_count >= threshold,
        "max_repeat": max_count,
        "threshold": threshold,
        "tool": offender_tool,
        "iteration": first_iter.get(offender) if offender else None,
        "detail": (("tool %r repeated %d times in one session"
                    % (offender_tool, max_count))
                   if (offender and max_count >= warn) else None),
    }


def _longest_flat_run(burndown):
    """Longest run of consecutive MAIN iterations with the SAME (and > 0)
    tasks_remaining — the no-progress signal. Returns (run_len, iteration_at_end)
    where the iteration marks where the flat streak ends. None values break a run.
    """
    best_len = 0
    best_iter = None
    cur_len = 0
    prev = None
    for b in burndown:
        rem = b.get("tasks_remaining")
        if rem is None or rem <= 0:
            cur_len, prev = 0, None
            continue
        if prev is not None and rem == prev:
            cur_len += 1
        else:
            cur_len = 1
        if cur_len > best_len:
            best_len, best_iter = cur_len, b.get("iteration")
        prev = rem
    return best_len, best_iter


def _loop_health_progress_check(la, k, maxiter_warn):
    """No-progress / nearing-max detection from the loop-analytics burndown.

    Critical when the run hit (or is at/over) the iteration cap without
    completing; at-risk when tasks_remaining is flat across >= `k` MAIN
    iterations OR utilization crosses `maxiter_warn` while still running."""
    burndown = la.get("burndown") or []
    outcome = la.get("outcome")
    flat_len, flat_iter = _longest_flat_run(burndown)
    util = la.get("max_iteration_utilization")
    completed = outcome == "completed"
    hit_max = (outcome == "hit_max_iterations"
               or (isinstance(util, (int, float)) and util >= 1.0
                   and not completed))
    flat_stuck = flat_len >= k
    nearing = (isinstance(util, (int, float)) and util >= maxiter_warn
               and not completed)
    if hit_max:
        status = "critical"
    elif flat_stuck or nearing:
        status = "at_risk"
    else:
        status = "ok"
    detail = None
    if flat_stuck:
        detail = ("tasks_remaining flat across %d iterations (at iteration %s)"
                  % (flat_len, flat_iter))
    elif hit_max:
        detail = "run reached the iteration cap without completing"
    elif nearing:
        detail = "nearing the iteration cap (%.0f%% used)" % (util * 100.0)
    return {
        "name": "no_progress",
        "status": status,
        "flagged": status != "ok",
        "flat_run": flat_len,
        "flat_iteration": flat_iter,
        "max_iteration_utilization": util,
        "outcome": outcome,
        "iteration": flat_iter,
        "detail": detail,
    }


def _loop_health_burn_check(kdir, feature, la, budget=None):
    """Token burn-rate per MAIN iteration + a projection to the iteration cap.

    rate = main-phase tokens / iterations-to-completion; projection = rate ×
    max_iterations. When a `budget` is supplied, `flagged`/at-risk fires if the
    projection would exceed it. Read-only (delegates to the loop-analytics phase
    tokens). No budget -> reported but never flagged."""
    main_tokens = (la.get("phase_tokens") or {}).get("main", 0) or 0
    n_iters = la.get("iterations_to_completion") or 0
    rate = round(main_tokens / n_iters, 1) if n_iters else None
    max_iter = la.get("max_iterations")
    projected = (round(rate * max_iter)
                 if (rate is not None and isinstance(max_iter, int)
                     and not isinstance(max_iter, bool)) else None)
    status = "ok"
    detail = None
    if budget and projected is not None:
        if projected >= budget:
            status = "critical"
            detail = ("projected %d tokens exceeds budget %d"
                      % (projected, budget))
        elif projected >= budget * _LOOP_HEALTH_MAXITER_WARN:
            status = "at_risk"
            detail = ("projected %d tokens nearing budget %d"
                      % (projected, budget))
    return {
        "name": "token_burn",
        "status": status,
        "flagged": status != "ok",
        "tokens_per_iteration": rate,
        "main_tokens": main_tokens,
        "iterations": n_iters,
        "projected_total": projected,
        "budget": budget,
        "detail": detail,
    }


def _loop_health_context_check(kdir, feature, window, threshold,
                               sessions_rows=None):
    """Context-window utilization + truncation-risk for a feature's sessions.

    Delegates to the read-only context-tax derivation (peak input-side tokens vs
    a configurable `window`). Critical at truncation_risk (>= `threshold`),
    at-risk past _LOOP_HEALTH_CONTEXT_WARN — the context-overflow failure mode.
    `sessions_rows` (shared single-pass index) avoids the per-feature re-scan."""
    rows = (sessions_rows if sessions_rows is not None
            else collect_sessions(kdir, feature=feature))
    # AUTHORITATIVE attribution: a session counts toward THIS feature's context
    # health only when the feature is its DOMINANT feature (parse_session.feature),
    # not merely a substring of its transcript. Without this, the single global-max
    # session (which mentions many features) leaks its peak into every feature and
    # makes 100% of runs read 'critical'. Fall back to the broad set if the strict
    # filter is empty (so a feature with only substring matches still reports).
    rows = [r for r in rows if r.get("feature") == feature]
    ct = derive_context_tax(rows, kdir, window=window, threshold=threshold)
    pct = ct.get("context_window_pct", 0.0) or 0.0
    risk = bool(ct.get("truncation_risk"))
    if risk:
        status = "critical"
    elif pct >= _LOOP_HEALTH_CONTEXT_WARN:
        status = "at_risk"
    else:
        status = "ok"
    return {
        "name": "context_window",
        "status": status,
        "flagged": risk,
        "context_window_pct": pct,
        "peak_input_tokens": ct.get("peak_input_tokens", 0),
        "context_window": ct.get("context_window", window),
        "truncation_risk": risk,
        "truncation_threshold": ct.get("truncation_threshold", threshold),
        "detail": (("peak input %d tokens = %.0f%% of the %d window"
                    % (ct.get("peak_input_tokens", 0), pct * 100.0,
                       ct.get("context_window", window)))
                   if status != "ok" else None),
    }


def _loop_health_for_feature(kdir, feature, window=None,
                             threshold=_TRUNCATION_RISK_THRESHOLD,
                             dup_threshold=_LOOP_HEALTH_DUP_THRESHOLD,
                             noprogress_k=_LOOP_HEALTH_NOPROGRESS_K,
                             budget=None, index=None, events=None):
    """Per-run loop-health for ONE feature (pure, read-only, INV-2).

    Runs the four runaway-detection checks (duplicate tool calls, no-progress,
    token burn-rate, context-window utilization) and folds them into an overall
    OK/at-risk/critical badge that NAMES the offending tool/iteration. Every
    check degrades to OK when its source channel is absent. A shared single-pass
    `index` (build_session_index) + pre-grouped `events` let the bulk caller
    avoid re-scanning every session 3× per feature; both are optional."""
    # window=None => the context check auto-detects the real model ceiling (1M for
    # Claude 4) rather than forcing a 200k window that mis-reads big sessions.
    sessions_rows = index["rows"].get(feature) if index is not None else None
    sess_dirs = index["dirs"].get(feature) if index is not None else None
    la = _loop_analytics_for_feature(kdir, feature, events=events,
                                     sessions_rows=sessions_rows)
    dup = _loop_health_dup_check(kdir, feature, dup_threshold,
                                 sess_dirs=sess_dirs, events=events)
    progress = _loop_health_progress_check(la, noprogress_k,
                                           _LOOP_HEALTH_MAXITER_WARN)
    burn = _loop_health_burn_check(kdir, feature, la, budget=budget)
    context = _loop_health_context_check(kdir, feature, window, threshold,
                                         sessions_rows=sessions_rows)
    checks = {c["name"]: c for c in (dup, progress, burn, context)}
    status = _worst_status(c["status"] for c in checks.values())
    # The offender that drives the badge: the worst flagged check naming a tool/
    # iteration (dup first — it points at a concrete stuck step), else progress.
    offender = None
    for c in (dup, progress, context, burn):
        if c["flagged"]:
            offender = {"check": c["name"], "tool": c.get("tool"),
                        "iteration": c.get("iteration"), "detail": c.get("detail")}
            break
    flagged = [c["name"] for c in checks.values() if c["flagged"]]
    return {
        "feature": feature,
        "status": status,
        "checks": checks,
        "flagged_checks": flagged,
        "offender": offender,
        "outcome": la.get("outcome"),
    }


def derive_loop_health(kdir, feature=None, window=None,
                       threshold=_TRUNCATION_RISK_THRESHOLD,
                       dup_threshold=_LOOP_HEALTH_DUP_THRESHOLD,
                       noprogress_k=_LOOP_HEALTH_NOPROGRESS_K, budget=None):
    """Loop-health & runaway detection for the Loops + Overview sections (pure,
    read-only, INV-2).

    With a `feature`, returns that single run's health dict (status + per-check
    detail + the offending tool/iteration). Without one, returns
    {features: [...], summary: {ok, at_risk, critical}} across every work feature.
    Never writes; degrades to OK/empty when the emission/log channels are absent.
    """
    if feature:
        return _loop_health_for_feature(
            kdir, feature, window=window, threshold=threshold,
            dup_threshold=dup_threshold, noprogress_k=noprogress_k,
            budget=budget)
    features = list_loop_features(kdir)
    by_feat = _group_events_by_feature(_read_metrics_jsonl(kdir))
    index = build_session_index(kdir, features)
    feats = [_loop_health_for_feature(
        kdir, f, window=window, threshold=threshold,
        dup_threshold=dup_threshold, noprogress_k=noprogress_k, budget=budget,
        index=index, events=by_feat.get(f, []))
        for f in features]
    summary = {"ok": 0, "at_risk": 0, "critical": 0}
    for f in feats:
        summary[f["status"]] = summary.get(f["status"], 0) + 1
    worst = _worst_status(f["status"] for f in feats)
    return {"features": feats, "summary": summary, "status": worst}


# --- Alerts surface (Task 31) ------------------------------------------------
# Symptom-based, severity-ranked alerts derived PURELY (INV-2, read-only) from
# the SAME sources the other panels read — the eval ledger, the cost rollups,
# loop-health, the staleness/conflict report, and the per-feature worklogs. No
# new collection; every alert deep-links to the panel/route that explains it, and
# the ledger SHAs are returned as commit markers so trend charts can correlate a
# metric shift with the commit that caused it (per SRE symptom-based alerting).

# severity -> rank (higher = worse); mirrors _LOOP_HEALTH_SEVERITY's intent but
# spans the three alert severities used across every class.
_ALERT_SEVERITY_RANK = {"info": 0, "warning": 1, "critical": 2}

# Reliability is a 0..100 score; a run-over-run DROP past these (percentage
# points) is a warning, then critical. nDCG is a 0..1 fraction.
_ALERT_RELIABILITY_WARN = 2.0
_ALERT_RELIABILITY_CRIT = 10.0
_ALERT_NDCG_WARN = 0.05
_ALERT_NDCG_CRIT = 0.10

# Retrieval scaling: recall@k SHOULD hold/improve as the corpus grows. A net
# NEGATIVE slope of recall-vs-corpus_size is the degradation symptom to flag.
_ALERT_SCALING_SLOPE_THRESHOLD = 0.0

# Loop-health status -> alert severity for the stuck-loop/runaway class.
_LOOP_STATUS_TO_ALERT = {"critical": "critical", "at_risk": "warning"}

# Frontend routes each alert class deep-links to (must match the panel registry).
_ALERT_DEEP_LINKS = {
    "regression": "/health/quality",
    "scaling": "/memory/scaling",
    "cost": "/cost",
    "loop": "/loops/health",
    "kb_stale": "/health",
    "kb_conflict": "/health",
    "unpromoted": "/loops/outcomes",
}


def _ols_slope(points):
    """Ordinary-least-squares slope over (x, y) numeric points; None if < 2 or
    degenerate. Mirrors the dashboard's /api/scaling slope so the alert and the
    plotted slope agree (read-only, pure)."""
    pts = [(x, y) for (x, y) in points
           if isinstance(x, (int, float)) and not isinstance(x, bool)
           and isinstance(y, (int, float)) and not isinstance(y, bool)]
    n = len(pts)
    if n < 2:
        return None
    sx = sum(x for x, _ in pts)
    sy = sum(y for _, y in pts)
    sxx = sum(x * x for x, _ in pts)
    sxy = sum(x * y for x, y in pts)
    denom = n * sxx - sx * sx
    if denom == 0:
        return None
    return (n * sxy - sx * sy) / denom


def _worst_alert_severity(severities):
    worst = None
    for s in severities:
        if worst is None or \
                _ALERT_SEVERITY_RANK.get(s, 0) > _ALERT_SEVERITY_RANK[worst]:
            worst = s
    return worst


def _alert(category, severity, title, detail, feature=None, extra=None):
    """Build one alert record with a deterministic id + the class deep-link."""
    aid = category if feature is None else "%s:%s" % (category, feature)
    rec = {
        "id": aid,
        "category": category,
        "severity": severity,
        "title": title,
        "detail": detail,
        "feature": feature,
        "deep_link": _ALERT_DEEP_LINKS.get(category),
    }
    if extra:
        rec.update(extra)
    return rec


def _alerts_regression(rows):
    """Reliability + nDCG REGRESSION vs the prior ledger row (E5)."""
    out = []
    if len(rows) < 2:
        return out
    latest, prev = rows[-1], rows[-2]
    lr, pr = latest.get("reliability"), prev.get("reliability")
    if isinstance(lr, (int, float)) and isinstance(pr, (int, float)):
        drop = pr - lr
        if drop >= _ALERT_RELIABILITY_WARN:
            sev = "critical" if drop >= _ALERT_RELIABILITY_CRIT else "warning"
            out.append(_alert(
                "regression", sev, "Reliability regression",
                "reliability fell %.1f pts (%.1f -> %.1f) vs the prior eval"
                % (drop, pr, lr),
                extra={"metric": "reliability", "from": pr, "to": lr,
                       "commit": latest.get("commit"),
                       "prev_commit": prev.get("commit")}))
    ln = (latest.get("metrics") or {}).get("ndcg_at_k")
    pn = (prev.get("metrics") or {}).get("ndcg_at_k")
    if isinstance(ln, (int, float)) and isinstance(pn, (int, float)):
        ndrop = pn - ln
        if ndrop >= _ALERT_NDCG_WARN:
            sev = "critical" if ndrop >= _ALERT_NDCG_CRIT else "warning"
            out.append(_alert(
                "regression", sev, "nDCG regression",
                "nDCG@k fell %.3f (%.3f -> %.3f) vs the prior eval"
                % (ndrop, pn, ln),
                feature=None,
                extra={"metric": "ndcg_at_k", "from": pn, "to": ln,
                       "commit": latest.get("commit"),
                       "prev_commit": prev.get("commit"),
                       "id": "regression:ndcg"}))
    return out


def _alerts_scaling(rows, slope_threshold):
    """Retrieval scaling-slope crossing threshold — recall degrading as the
    corpus grows (E5). Reuses the same OLS the /api/scaling panel plots."""
    xy = []
    for r in rows:
        size = r.get("corpus_size")
        recall = (r.get("metrics") or {}).get("recall_at_k")
        if isinstance(size, (int, float)) and not isinstance(size, bool) \
                and isinstance(recall, (int, float)):
            xy.append((size, recall))
    slope = _ols_slope(xy)
    if slope is None or slope >= slope_threshold:
        return []
    return [_alert(
        "scaling", "warning", "Retrieval scaling degradation",
        "recall@k slope vs corpus size is %.6f (< %.6f) over %d measured runs"
        % (slope, slope_threshold, len(xy)),
        extra={"slope": slope, "measured": len(xy)})]


def _alerts_cost(agg):
    """COST spike vs the trailing median (E5) — reuses the cost-anomaly flag."""
    dates = agg.get("cost_anomaly_dates") or []
    if not dates:
        return []
    return [_alert(
        "cost", "warning", "Cost spike",
        "%d day(s) exceeded the trailing-median cost: %s"
        % (len(dates), ", ".join(dates)),
        extra={"dates": list(dates)})]


def _alerts_loop(kdir):
    """Stuck-loop / runaway-tokens from loop-health (E4 -> E5)."""
    out = []
    health = derive_loop_health(kdir)
    for f in health.get("features", []):
        sev = _LOOP_STATUS_TO_ALERT.get(f.get("status"))
        if not sev:
            continue
        off = f.get("offender") or {}
        detail = off.get("detail") or ", ".join(f.get("flagged_checks") or []) \
            or "loop-health flagged"
        out.append(_alert(
            "loop", sev, "Loop-health: %s" % f.get("status"),
            detail, feature=f.get("feature"),
            extra={"flagged_checks": f.get("flagged_checks") or [],
                   "offender": off or None}))
    return out


def _alerts_kb(kdir, data, max_age_days):
    """Stale + possibly-conflicting KB entries (E5) from the audit report."""
    out = []
    if data is None:
        return out
    report = build_stale_report(kdir, data, max_age_days)
    stale = report.get("stale") or []
    if stale:
        out.append(_alert(
            "kb_stale", "info", "Stale knowledge entries",
            "%d entr%s past the %d-day freshness window"
            % (len(stale), "y" if len(stale) == 1 else "ies", max_age_days),
            extra={"count": len(stale),
                   "ids": [s.get("id") for s in stale]}))
    conflicts = report.get("conflicts") or []
    if conflicts:
        out.append(_alert(
            "kb_conflict", "warning", "Possible duplicate/conflicting entries",
            "%d high-overlap entry pair(s) may duplicate or conflict"
            % len(conflicts),
            extra={"count": len(conflicts), "pairs": conflicts}))
    return out


def _alerts_unpromoted(kdir, data):
    """Unpromoted `> LEARNED:` / `> DECISION:` markers in a FINISHED run's
    worklog (E5) — the completion-gate symptom (R-SI-03 / R-AUTO-05)."""
    out = []
    if data is None:
        return out
    for feature in list_loop_features(kdir):
        outcome = derive_outcome(kdir, feature) or {}
        if outcome.get("outcome") != "completed":
            continue
        wl = os.path.join(kdir, "work", feature, "worklog.md")
        if not os.path.isfile(wl):
            continue
        try:
            unpromoted, _total = scan_worklog(wl, kdir, data)
        except OSError:
            continue
        if not unpromoted:
            continue
        out.append(_alert(
            "unpromoted", "warning", "Unpromoted learnings at finish",
            "%d marker(s) still unpromoted in a completed run" % len(unpromoted),
            feature=feature,
            extra={"count": len(unpromoted),
                   "markers": unpromoted}))
    return out


def derive_alerts(kdir, slope_threshold=_ALERT_SCALING_SLOPE_THRESHOLD,
                  max_age_days=120):
    """Severity-ranked, symptom-based alerts derived read-only (INV-2) from the
    existing telemetry (Task 31): reliability/nDCG regression, retrieval
    scaling-slope, cost spike, stuck-loop/runaway, stale/conflicting KB, and
    unpromoted LEARNED/DECISION at finish. Each alert deep-links to its panel;
    the ledger SHAs are returned as `commit_markers` so trend charts can place
    commit markers aligned to the runs. Never writes; degrades to empty when a
    source channel is absent."""
    rows = _read_ledger(os.path.join(kdir, HISTORY_REL))
    rows_sessions = collect_sessions(kdir)
    agg = aggregate_metrics(rows_sessions)
    apply_pricing(rows_sessions, agg, _DEFAULT_PRICES)
    data, _err = load_index(kdir)

    alerts = []
    alerts += _alerts_regression(rows)
    alerts += _alerts_scaling(rows, slope_threshold)
    alerts += _alerts_cost(agg)
    alerts += _alerts_loop(kdir)
    alerts += _alerts_kb(kdir, data, max_age_days)
    alerts += _alerts_unpromoted(kdir, data)

    # Stable, severity-ranked order (worst first), then by category/id so the
    # output is deterministic across runs (read-only repeatability, INV-2).
    alerts.sort(key=lambda a: (
        -_ALERT_SEVERITY_RANK.get(a["severity"], 0),
        a["category"], str(a["id"])))

    summary = {"critical": 0, "warning": 0, "info": 0}
    for a in alerts:
        summary[a["severity"]] = summary.get(a["severity"], 0) + 1
    worst = _worst_alert_severity(a["severity"] for a in alerts)

    # Commit/deployment markers for the trend charts: one per ledger run, newest
    # last (chronological), carrying the headline metrics for tooltip context.
    commit_markers = [{
        "commit": r.get("commit"),
        "run": r.get("run"),
        "strategy": r.get("strategy"),
        "reliability": r.get("reliability"),
        "recall_at_k": (r.get("metrics") or {}).get("recall_at_k"),
    } for r in rows if r.get("commit")]

    return {
        "alerts": alerts,
        "summary": summary,
        "open_count": len(alerts),
        "status": worst or "ok",
        "commit_markers": commit_markers,
    }


# --- Failure-ladder & error-recovery (Task 32) -------------------------------
# agentware-specific, high value: WHERE runs get stuck (tool ERR rate from the
# live.jsonl per-action stream) and HOW they recovered along the R-FAIL
# escalation ladder — (1) knowledge base -> (2) own reasoning -> (3) change
# inputs -> (4) switch approach -> (5) web search (R-FAIL-01). ALL derivations
# are PURE + READ-ONLY (INV-2): they fold the existing trace (live.jsonl) + the
# per-feature worklog markers + the loop self-heal count, never writing. Each
# signal degrades to a zeroed tally when its source channel is absent.

# The R-FAIL escalation-ladder tiers, in order (R-FAIL-01). The dashboard plots
# WHERE a run climbed the ladder to recover from a tool failure.
_FAIL_LADDER_TIERS = ["kb", "reasoning", "inputs", "switch", "web"]

# Tools that count as a web escalation (ladder tier 5, R-FAIL-06/R-WEB-01).
_FAIL_WEB_TOOLS = {"WebSearch", "WebFetch"}

# Substrings in a tool's input that mark a knowledge-base lookup (ladder tier 1,
# R-FAIL-02): the agent re-queries the KB by the error signature before retrying.
_FAIL_KB_SIGNATURES = ("agentware recall", "agentware query", "agentware audit")


def _fail_step_is_web(step):
    """A step is a web escalation iff its tool is a web-search/fetch tool."""
    return (step.get("tool") or "") in _FAIL_WEB_TOOLS


def _fail_step_is_kb_lookup(step):
    """A step is a KB lookup iff it invokes an agentware recall/query/audit (read
    from the bounded tool-input string the trace already carries)."""
    if (step.get("tool") or "") in _FAIL_WEB_TOOLS:
        return False
    args = step.get("args") or ""
    return any(sig in args for sig in _FAIL_KB_SIGNATURES)


def _classify_recovery(err_step, next_step):
    """Map an ERR step + the action that FOLLOWED it onto an R-FAIL ladder tier.

    The recovery is an OBSERVABLE proxy read from the NEXT tool call (the run's
    actual next action after the failure):
      - a web search/fetch         -> "web"     (tier 5)
      - a KB recall/query/audit    -> "kb"      (tier 1)
      - the SAME tool, CHANGED args -> "inputs" (tier 3, R-FAIL-04)
      - the SAME tool, SAME args    -> "reasoning" (tier 2 — a reasoned re-attempt)
      - a DIFFERENT tool           -> "switch"  (tier 4, R-FAIL-05)
    No next step -> the run ended ON the error (unrecovered) -> None.
    """
    if next_step is None:
        return None
    if _fail_step_is_web(next_step):
        return "web"
    if _fail_step_is_kb_lookup(next_step):
        return "kb"
    if next_step.get("tool") == err_step.get("tool"):
        if (next_step.get("args") or "") != (err_step.get("args") or ""):
            return "inputs"
        return "reasoning"
    return "switch"


def _failure_marker_tally(kdir, feature):
    """Per-kind LEARNED/DECISION tallies (total + unpromoted) from the feature's
    worklog (read-only). Reuses the completion-gate regexes + promotion stems so
    the tally agrees with the worklog-scan gate."""
    out = {"learned": {"total": 0, "unpromoted": 0},
           "decision": {"total": 0, "unpromoted": 0}}
    wl = os.path.join(kdir, "work", feature, "worklog.md")
    if not os.path.isfile(wl):
        return out
    data, _err = load_index(kdir)
    l_stems = learning_stems(kdir, data)
    d_stems = decision_stems(kdir, data)
    kinds = (
        ("learned", LEARNED_RE, l_stems, _real_ids(l_stems, "learn-")),
        ("decision", DECISION_RE, d_stems, _real_ids(d_stems, "decide-")),
    )
    try:
        f = open(wl, "r", encoding="utf-8", errors="replace")
    except OSError:
        return out
    with f:
        for line in f:
            for kind, rx, stems, real_ids in kinds:
                m = rx.match(line)
                if not m:
                    continue
                text = m.group(1).strip()
                if not text:
                    continue
                out[kind]["total"] += 1
                if not _is_promoted(text, stems, real_ids):
                    out[kind]["unpromoted"] += 1
                break
    return out


def derive_failures(kdir, feature):
    """Failure-ladder & error-recovery for one feature (pure, read-only, INV-2).

    Folds the read-only trace (live.jsonl) + the per-feature worklog markers +
    the loop terminal self-heal count into: tool ERR rate (+ per-tool tallies),
    R-FAIL ladder tier usage (kb/reasoning/inputs/switch/web — classified from
    the action that followed each ERR), the web-search escalation count, KB-lookup
    count, self-heal re-engagements, and the DECISION/LEARNED marker tallies.
    Empty/missing logs yield zeroed tallies (forward-compatible, never crashes)."""
    trace = derive_trace(kdir, feature=feature)
    steps = []
    for grp in trace.get("iterations", []):
        steps.extend(grp.get("steps", []))
    # Restore the deterministic GLOBAL order (the trace assigns each step a
    # monotonic `index`) so recovery classification reads the true next action.
    steps.sort(key=lambda s: s.get("index", 0))

    step_count = trace.get("step_count", len(steps))
    err_count = trace.get("err_count",
                          sum(1 for s in steps if s.get("status") == "ERR"))
    err_rate = round(err_count / step_count, 4) if step_count else 0.0

    err_by_tool = {}
    for s in steps:
        if s.get("status") == "ERR":
            t = s.get("tool") or "<unknown>"
            err_by_tool[t] = err_by_tool.get(t, 0) + 1

    ladder = {t: 0 for t in _FAIL_LADDER_TIERS}
    unrecovered = 0
    for i, s in enumerate(steps):
        if s.get("status") != "ERR":
            continue
        nxt = steps[i + 1] if i + 1 < len(steps) else None
        tier = _classify_recovery(s, nxt)
        if tier is None:
            unrecovered += 1
        else:
            ladder[tier] += 1

    web_search_count = sum(1 for s in steps if _fail_step_is_web(s))
    kb_lookup_count = sum(1 for s in steps if _fail_step_is_kb_lookup(s))

    outcome = derive_outcome(kdir, feature) or {}
    self_heal = outcome.get("self_heal_count")
    if not isinstance(self_heal, int) or isinstance(self_heal, bool):
        self_heal = 0

    markers = _failure_marker_tally(kdir, feature)

    return {
        "feature": feature,
        "scope": "feature",
        "step_count": step_count,
        "err_count": err_count,
        "err_rate": err_rate,
        "err_by_tool": err_by_tool,
        "ladder": ladder,
        "ladder_order": list(_FAIL_LADDER_TIERS),
        "unrecovered": unrecovered,
        "web_search_count": web_search_count,
        "kb_lookup_count": kb_lookup_count,
        "self_heal_count": self_heal,
        "markers": markers,
        "tool_summary": trace.get("tool_summary", {}),
        "sessions": trace.get("sessions", []),
    }


def _fmt_duration(seconds):
    seconds = int(round(seconds))
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    if h:
        return "%dh%02dm%02ds" % (h, m, s)
    if m:
        return "%dm%02ds" % (m, s)
    return "%ds" % s


def _print_metrics_text(rows, agg, flt):
    desc = []
    if flt.get("session"):
        desc.append("session=%s" % flt["session"])
    if flt.get("feature"):
        desc.append("feature=%s" % flt["feature"])
    if flt.get("since"):
        desc.append("since=%s" % flt["since"])
    print("metrics: %d session%s%s" % (
        len(rows), "" if len(rows) == 1 else "s",
        ("  (%s)" % ", ".join(desc)) if desc else ""))
    for r in rows:
        print("  %s  turns=%d  tools=%d  subagents=%d  tokens=%d  wall=%s"
              % (r["session_id"], r["turns"], r["tool_calls"],
                 r["subagent_count"], r["total_tokens"],
                 _fmt_duration(r["duration_seconds"])))
        if r["tools"]:
            parts = ", ".join("%s=%d" % (k, r["tools"][k])
                              for k in sorted(r["tools"]))
            print("    tool calls: %s" % parts)
    print("  ----")
    print("  TOTAL  sessions=%d  turns=%d  tools=%d  subagents=%d  tokens=%d  wall=%s"
          % (agg["session_count"], agg["turns"], agg["tool_calls"],
             agg["subagent_count"], agg["total_tokens"],
             _fmt_duration(agg["duration_seconds"])))
    u = agg["tokens"]
    print("    tokens: in=%d out=%d cache_creation=%d cache_read=%d"
          % (u["input_tokens"], u["output_tokens"],
             u["cache_creation_input_tokens"], u["cache_read_input_tokens"]))
    if "cost_usd" in agg:
        print("    cost: $%.4f  cache_read_ratio=%.3f%s"
              % (agg["cost_usd"], agg.get("cache_read_ratio", 0.0),
                 ("  cost_anomalies=%d" % len(agg["cost_anomaly_dates"]))
                 if agg.get("cost_anomaly_dates") else ""))
    if "context_tax" in agg:
        ct = agg["context_tax"]
        print("    context_tax: cache_read/turn=%.1f  injected_tokens=%d  "
              "window_util=%.1f%%%s"
              % (ct["cache_read_per_turn"], ct["injected_tokens"],
                 ct["context_window_pct"] * 100.0,
                 "  TRUNCATION-RISK" if ct["truncation_risk"] else ""))
    if agg.get("outcome"):
        print("    outcome: %s (%s)" % (agg["outcome"]["outcome"],
                                        agg["outcome"]["source"]))
    if "phase_costs" in agg:
        pc = agg["phase_costs"]["by_phase"]
        parts = ", ".join("%s=$%.4f" % (ph, pc[ph]["cost_usd"])
                          for ph in sorted(pc))
        if parts:
            print("    phase_costs: %s" % parts)


DASHBOARD_SERVER = os.path.join(REPO_ROOT, "scripts", "agentware_dashboard.py")


def cmd_dashboard(args):
    """Serve the read-only observability dashboard (localhost-only).

    The HTTP server needs `http.server`, which the toolkit's import guards
    (INV-1/INV-6, tests/test_invariants.py) forbid in this CLI source. So the
    server lives in a SEPARATE sidecar file (`scripts/agentware_dashboard.py`)
    that the guards never scan, and we launch it via subprocess — the same
    pattern as the optional embedder backend. This keeps the toolkit's
    static-import surface stdlib-only while the dashboard still runs.

    The server binds 127.0.0.1 ONLY, serves the built static bundle
    (webui/dist/) through a hardened static handler, and exposes the read-only
    JSON API. It adds NO writer.
    """
    if not os.path.isfile(DASHBOARD_SERVER):
        print("error: dashboard server missing (%s)" % DASHBOARD_SERVER,
              file=sys.stderr)
        return 1
    host = getattr(args, "host", None) or "127.0.0.1"
    dist_dir = os.path.join(REPO_ROOT, "webui", "dist")
    kdir = resolve_knowledge_dir()
    cmd = [sys.executable, DASHBOARD_SERVER,
           "--host", host, "--port", str(args.port), "--dist", dist_dir]
    if kdir:
        cmd += ["--kdir", kdir]
    if getattr(args, "no_open", False):
        cmd.append("--no-open")
    try:
        return subprocess.call(cmd, cwd=REPO_ROOT)
    except KeyboardInterrupt:
        return 0


def cmd_metrics(args):
    """Execution observability over session transcripts (READ-ONLY, INV-2).

    Parses logs/sessions/<sid>/main.jsonl (+ subagents/*.jsonl) for turn counts,
    wall time, token usage, tool-call counts and subagent counts. NEVER touches
    index.json or any KB file."""
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    since = getattr(args, "since", None)
    if since is not None and not _is_valid_date(since):
        sys.stderr.write("agentware: --since must be YYYY-MM-DD\n")
        return 1
    prices = _DEFAULT_PRICES
    price_source = "default"
    prices_path = getattr(args, "prices", None)
    if prices_path:
        prices, perr = load_price_table(prices_path)
        if perr:
            sys.stderr.write("agentware: %s\n" % perr)
            return 1
        price_source = prices_path
    rows = collect_sessions(
        kdir, session=getattr(args, "session", None),
        feature=getattr(args, "feature", None), since=since)
    agg = aggregate_metrics(rows)
    apply_pricing(rows, agg, prices)
    flt = {"session": getattr(args, "session", None),
           "feature": getattr(args, "feature", None), "since": since}

    # Plan-authoring derivations (read-only): attributed authoring time/tokens
    # always; plan-size only when a single feature is in scope (it has a plan.md).
    agg["authoring"] = derive_authoring(rows)
    # Context-tax derivations (read-only): cache-read-per-turn series, the
    # injected MAIN.md footprint, and context-window utilization + truncation risk.
    agg["context_tax"] = derive_context_tax(
        rows, kdir, window=getattr(args, "context_window", None))
    feature = getattr(args, "feature", None)
    plan_meta = derive_plan_size(_plan_path(kdir, feature)) if feature else None

    # Per-phase / per-iteration cost attribution + terminal run outcome (Task 5,
    # read-only). phase_costs partition the session tokens by loop phase (sums ==
    # session totals); iterations + outcome are per-feature: outcome reads the
    # Task 6/7 metrics.jsonl terminal event when present, else falls back to the
    # persisted .loop/plan/assessment artifacts.
    agg["phase_costs"] = derive_phase_costs(rows)
    if feature:
        loop_events = _read_metrics_jsonl(kdir, feature=feature)
        agg["iterations"] = derive_iteration_costs(loop_events)
        agg["outcome"] = derive_outcome(kdir, feature, events=loop_events)

    if args.format == "json":
        payload = {"filter": flt, "session_count": len(rows),
                   "price_source": price_source,
                   "sessions": rows, "aggregate": agg}
        if feature:
            payload["plan"] = plan_meta
        json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return 0 if rows else 1

    if not rows:
        print("metrics: no matching sessions under %s"
              % logs_sessions_dir(kdir))
        return 1
    _print_metrics_text(rows, agg, flt)
    return 0


def _audit_steering_lint_check():
    result = lint_steering()
    details = []
    if not result["budget_ok"]:
        details.append("char budget exceeded: %d > %d" % (
            result["total_chars"], result["char_budget"]))
    for v in result["violations"]:
        details.append("%s %s:%d %s" % (v["rule"], v["file"], v["line"], v["text"]))
    for b in result["banned_words"]:
        details.append("DSF-5 %s:%d banned %r" % (b["file"], b["line"], b["word"]))
    return {
        "name": "steering_lint",
        "ok": result["ok"],
        "details": details or ["DSF-clean: %d/%d chars" % (
            result["total_chars"], result["char_budget"])],
    }


def _audit_tests_check():
    """Shell the stdlib unittest suite and report pass/fail as an audit check.

    Read-only, hermetic: the suite points the CLI at a synthetic temp KB via
    AGENTWARE_KNOWLEDGE_DIR (see tests/_fixtures.py), so it never touches the
    operator KB. subprocess is stdlib, so INV-6 (stdlib-only) holds.
    """
    tests_dir = os.path.join(REPO_ROOT, "tests")
    if not os.path.isdir(tests_dir):
        return {"name": "unittest", "ok": False,
                "details": ["tests/ directory not found at %s" % tests_dir]}
    try:
        proc = subprocess.run(
            [sys.executable, "-m", "unittest", "discover", "-s", "tests"],
            cwd=REPO_ROOT, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True)
    except OSError as exc:
        return {"name": "unittest", "ok": False,
                "details": ["could not launch unittest: %s" % exc]}
    ok = proc.returncode == 0
    lines = [ln for ln in (proc.stderr or "").splitlines() if ln.strip()]
    ran_line = next((ln for ln in lines if ln.startswith("Ran ")), "")
    details = [ran_line.strip() or ("unittest exit %d" % proc.returncode)]
    if not ok:
        details.extend(lines[-12:])
    return {"name": "unittest", "ok": ok, "details": details}


def _audit_gate_check(kdir):
    """Run the benchmark regression gate as the audit's INV-7 enforcement.

    Shells `eval --strategy bm25 --gate --format json` as an isolated subprocess
    (so it measures an honest reliability via its own test pass-rate and stays
    decoupled from this process), then regenerates SCORECARD.md from the freshly
    appended row. FAILS the audit on a beyond-tolerance regression (non-zero
    gate exit). A first-ever run seeds + passes. When no gold set exists yet the
    check is a soft pass (nothing to benchmark). Read-only w.r.t. index.json;
    only appends to the append-only ledger + regenerates the derived scorecard.
    """
    gold = os.path.join(kdir, "benchmarks", "recall-gold.json")
    if not os.path.isfile(gold):
        return {"name": "benchmark_gate", "ok": True,
                "details": ["no gold set at %s; skipped" % gold]}
    env = dict(os.environ)
    env["AGENTWARE_KNOWLEDGE_DIR"] = kdir
    try:
        proc = subprocess.run(
            [sys.executable, os.path.join(REPO_ROOT, "scripts", "agentware"),
             "eval", "--strategy", "bm25", "--gate", "--format", "json"],
            cwd=REPO_ROOT, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True, env=env)
    except OSError as exc:
        return {"name": "benchmark_gate", "ok": False,
                "details": ["could not launch eval --gate: %s" % exc]}
    ok = proc.returncode == 0
    details = []
    try:
        payload = json.loads(proc.stdout)
        g = payload.get("gate", {}) or {}
        rec = payload.get("recorded", {}) or {}
        if g.get("seeded"):
            details.append("seeded baseline (no prior bm25 history)")
        details.append("reliability=%.2f commit=%s tolerance=%.4f" % (
            rec.get("reliability", 0.0), rec.get("commit", "?"),
            g.get("tolerance", 0.0)))
        for r in g.get("regressions", []) or []:
            details.append("REGRESSION %s best=%.4f current=%.4f" % (
                r.get("metric"), r.get("baseline", 0.0), r.get("current", 0.0)))
    except ValueError:
        details.append("eval --gate exit %d" % proc.returncode)
        if not ok:
            details.extend((proc.stderr or "").splitlines()[-6:])
    try:
        write_scorecard(kdir)
    except OSError as exc:
        details.append("scorecard regen failed: %s" % exc)
    return {"name": "benchmark_gate", "ok": ok, "details": details}


def _audit_bm25_cache_check(kdir, data):
    """Cache-integrity guard for the derived BM25 postings cache (Rule 7).

    The cache is an OPTIMIZATION, never a correctness dependency, so ABSENCE is a
    PASS (recall falls back to the live scan). When the cache IS present it must be
    FRESH and derivable — a present-but-stale cache is the silent-divergence risk
    this check surfaces so the dashboard can show cache integrity. Remedy on a FAIL
    is always `scripts/agentware index rebuild` (the sole writer). Read-only.
    """
    cache = load_bm25_cache(kdir)
    if cache is None:
        return {"name": "bm25_cache_health", "ok": True,
                "details": ["absent or unreadable: recall uses the live scan "
                            "(cache is an optimization, not a dependency)"]}
    fresh = bm25_cache_is_fresh(cache, data, kdir)
    return {
        "name": "bm25_cache_health",
        "ok": fresh,
        "details": ["fresh: postings match live KB content (%d term(s), n=%d)"
                    % (len(cache.get("postings") or {}), cache.get("n", 0))]
        if fresh else
        ["STALE: postings cache diverges from live KB content — run "
         "`scripts/agentware index rebuild` to regenerate (recall is still "
         "correct: it ignores a stale cache and falls back to the live scan)"],
    }


def _audit_mode_b_health_check(kdir, data):
    """Mode-B (semantic) health for the dashboard (Rule 7; feature
    260627-semantic-embedding-settings).

    INERT in deterministic mode (the zero-install default) — it returns a PASS and
    never false-alarms users who never opted in. When the CONFIGURED retrieval mode
    is `semantic`, it verifies the two things Mode B needs to actually run:
      1. a LOCAL embedder is loadable (the optional backend is installed), and
      2. the derived vector cache is present AND fresh (every live corpus entry has
         a cached vector whose content fingerprint matches).
    A missing backend or a missing/stale cache is a clear, ACTIONABLE warning
    (FAILs the check) so the operator knows semantic is silently falling back to
    Mode A. Read-only (INV-2): never loads/writes the cache as a side effect beyond
    a read. Maps to the eval-ledger retrieval metrics (Recall@5/nDCG@5/MRR) — no new
    hot-path cost.
    """
    configured = resolve_retrieval_mode()
    if configured != RETRIEVAL_MODE_SEMANTIC:
        return {"name": "mode_b_health", "ok": True,
                "details": ["inert: retrieval_mode=deterministic (Mode A / BM25, "
                            "zero-install default) — no semantic backend required"]}
    problems = []
    if not semantic_embedder_available():
        problems.append(
            "no LOCAL embedder is loadable (set one with `scripts/agentware config "
            "--set-embedder <backend>` and install it, e.g. "
            "`python3 -m pip install fastembed==0.8.0`) — semantic is falling back "
            "to Mode A (BM25)")
    else:
        model = resolve_embed_model()
        cache = load_vector_cache(kdir, model)
        if cache is None:
            problems.append(
                "vector cache for model %r is missing/unreadable — run "
                "`scripts/agentware index rebuild` to build it (recall still works: "
                "it falls back to Mode A until the cache exists)" % model)
        else:
            cached = cache.get("vectors") or {}
            stale = []
            for entry, doc_text in build_corpus(kdir, data):
                eid = entry.get("id")
                if eid is None:
                    continue
                hit = cached.get(eid)
                if not (isinstance(hit, dict)
                        and hit.get("fp") == _corpus_fingerprint(doc_text)):
                    stale.append(eid)
            if stale:
                problems.append(
                    "vector cache is STALE for %d entr(y/ies) (e.g. %s) — run "
                    "`scripts/agentware index rebuild` to regenerate (recall stays "
                    "correct: a stale/missing vector falls back to the BM25 floor)"
                    % (len(stale), ", ".join(sorted(stale)[:5])))
    if problems:
        return {"name": "mode_b_health", "ok": False, "details": problems}
    model = resolve_embed_model()
    cache = load_vector_cache(kdir, model) or {}
    return {"name": "mode_b_health", "ok": True,
            "details": ["healthy: semantic mode active, embedder loadable, vector "
                        "cache fresh (model %s, %d entr(y/ies))"
                        % (model, len(cache.get("vectors") or {}))]}


def provenance_coverage(kdir, data):
    """Return (missing_author_ids, total) over indexed entries (READ-ONLY).

    An entry "has provenance" when its file frontmatter carries a non-empty
    `author`. In a SHARED (team) KB this attributes each learning to the member
    who wrote it; missing-`author` entries are the gap the provenance-mix panel
    surfaces. Stdlib-only, no clock/network. Feature 260625-team-mode-onboarding-fork.
    """
    missing, total = [], 0
    for e in (data.get("entries") or []):
        rel = e.get("path")
        if not rel:
            continue
        total += 1
        fm = read_entry_frontmatter(os.path.join(kdir, rel))
        if not (fm.get("author") or "").strip():
            missing.append(e.get("id") or rel)
    return missing, total


def _audit_provenance_coverage_check(kdir, data):
    """Per-user provenance coverage (Rule 7 observability; advisory in power mode).

    Reports indexed entries whose frontmatter lacks an `author`. In TEAM mode this
    FAILS the check so a shared KB cannot silently lose attribution; in POWER mode
    it is purely INFORMATIONAL (never flips `ok` — a solo KB predating provenance
    is fine). Read-only w.r.t. the KB/index (INV-2).
    """
    missing, total = provenance_coverage(kdir, data)
    mode = resolve_kb_mode()
    ok = (not missing) or (mode != KB_MODE_TEAM)
    if not missing:
        details = ["full coverage: %d/%d indexed entr(y/ies) carry an `author`"
                   % (total, total)]
    else:
        covered = total - len(missing)
        sev = "FAIL (team mode)" if mode == KB_MODE_TEAM else "advisory (power mode)"
        details = ["%s: %d/%d entr(y/ies) missing `author` provenance: %s"
                   % (sev, len(missing), total, ", ".join(sorted(missing)[:20]))]
        if covered:
            details.append("%d/%d already attributed" % (covered, total))
    return {"name": "provenance_coverage", "ok": ok, "details": details}


def emit_onboarding_metric(kdir, mode, user_handle=None, ts=None):
    """Rule-7 observability: append one `onboarding` event to logs/metrics.jsonl.

    Best-effort + read-only w.r.t. the KB/index (INV-2): a write failure never
    blocks onboarding. `logs/` is gitignored, so this never reaches the remote.
    Shape: {ts, event:"onboarding", mode, user_handle}. Feature
    260625-team-mode-onboarding-fork.
    """
    try:
        rec = {"event": "onboarding", "mode": mode,
               "user_handle": user_handle, "ts": ts or utc_now_iso()}
        logs = os.path.join(kdir, "logs")
        os.makedirs(logs, exist_ok=True)
        with open(os.path.join(logs, "metrics.jsonl"), "a",
                  encoding="utf-8") as f:
            f.write(json.dumps(rec, ensure_ascii=False, sort_keys=True) + "\n")
        return True
    except OSError:
        return False


def _audit_personal_data_check(kdir):
    """R-LOC-03 guard: the package must ship ZERO operator personal data.

    Resolves the LIVE operator identity (handle, email, HOME path) at runtime
    and scans the package tree (REPO_ROOT) for those exact strings. Hardcodes
    nothing, so the package still ships zero personal data. FAILS if any leak is
    present. Read-only.
    """
    needles = operator_identity_strings(kdir)
    hits = scan_personal_data(REPO_ROOT, needles)
    return {
        "name": "personal_data",
        "ok": not hits,
        "details": hits or [
            "clean: no operator identity in package tree "
            "(%d needle(s) checked)" % len(needles)],
    }


def _audit_graph_integrity_check(kdir, data):
    """Declared-edge graph health (INV-2 advisory; never auto-mutates).

    Reports DANGLING edges (a `relates` target not in the index) and UNKNOWN
    relation types — both FAIL the check. CYCLES are reported advisory-only and
    do NOT flip `ok` (a cyclic dependency graph is a signal, not corruption). A
    clean/empty KB ⇒ ok:True. Read-only.
    """
    dangling, unknown = graph_relation_errors(data)
    forward, _reverse = build_adjacency(data)
    cycles = find_cycles(forward)
    details = []
    for (eid, target) in dangling:
        details.append("dangling edge: '%s' -> '%s' (target not in index)"
                       % (eid, target))
    for (eid, tok) in unknown:
        details.append("unknown relation type: '%s' declared by '%s' (vocab: %s)"
                       % (tok, eid, ", ".join(RELATION_TYPES)))
    for cyc in cycles:
        details.append("cycle (advisory): %s"
                       % " -> ".join(list(cyc) + [cyc[0]]))
    ok = not dangling and not unknown
    if not details:
        details = ["clean: no dangling edges, unknown types, or cycles"]
    return {"name": "graph_integrity", "ok": ok, "details": details}


def _append_graph_health_metric(kdir, data, ts=None):
    """Rule-7 observability: append one advisory graph_health line to
    `<kdir>/logs/metrics.jsonl` (gitignored, append-only).

    Best-effort + read-only w.r.t. the KB/index (INV-2): a write failure never
    blocks the caller. `ts` is metadata only — passed in, never read by ranking.
    """
    try:
        gh = graph_health(data)
        rec = {"event": "graph_health", "ts": ts or utc_now_iso()}
        rec.update(gh)
        logs = os.path.join(kdir, "logs")
        os.makedirs(logs, exist_ok=True)
        with open(os.path.join(logs, "metrics.jsonl"), "a", encoding="utf-8") as f:
            f.write(json.dumps(rec, ensure_ascii=False, sort_keys=True) + "\n")
    except OSError:
        pass


# --- Freshness & conflict detection (Phase 2.2) ------------------------------
# "Volatile" categories whose facts decay (R-FAIL-08): treat a point-in-time
# value as suspect once its last_verified is older than the staleness window.
VOLATILE_CATEGORIES = ("learnings", "configurations")
# Token-set Jaccard at/above this threshold flags a same-category pair as a
# possible duplicate/conflict. Reporting only; never auto-mutates the KB (INV-2).
_CONFLICT_JACCARD = 0.6


def stale_entries(data, max_age_days, today=None):
    """Return [(entry, age_days), ...] for volatile-category entries whose
    effective last_verified is older than max_age_days.

    Deterministic given `today` (defaults to the system date — reporting only,
    so wall-clock here is fine; INV-1 forbids wall-clock in RANKING, not in this
    advisory freshness report). Entries with no valid date are skipped. Ordering:
    oldest first, then id asc. Read-only (INV-2).
    """
    import datetime
    today = today or _today()
    try:
        today_d = datetime.date.fromisoformat(today)
    except ValueError:
        return []
    out = []
    for e in data.get("entries") or []:
        if not isinstance(e, dict):
            continue
        if (e.get("category") or "") not in VOLATILE_CATEGORIES:
            continue
        lv = entry_last_verified(e)
        if not _is_valid_date(lv):
            continue
        age = (today_d - datetime.date.fromisoformat(lv)).days
        if age > max_age_days:
            out.append((e, age))
    out.sort(key=lambda ea: ea[0].get("id") or "")          # id asc
    out.sort(key=lambda ea: ea[1], reverse=True)            # oldest first
    return out


def conflict_pairs(kdir, data, threshold=_CONFLICT_JACCARD):
    """Return [(entry_a, entry_b, jaccard), ...] for same-category entry pairs
    whose token-set Jaccard >= threshold (possible duplicate/conflict).

    Token sets come from the shared corpus document (title+summary+tags+body)
    via the same tokenizer BM25 uses, so flagging is deterministic and stable.
    Read-only (INV-2); reporting only — never auto-deletes/merges. Ordering:
    highest similarity first, then (id_a, id_b) asc.
    """
    corpus = build_corpus(kdir, data)
    items = [(e, set(tokenize(text))) for (e, text) in corpus]
    pairs = []
    for i in range(len(items)):
        ei, si = items[i]
        if not si:
            continue
        for j in range(i + 1, len(items)):
            ej, sj = items[j]
            if not sj:
                continue
            if (ei.get("category") or "") != (ej.get("category") or ""):
                continue
            union = si | sj
            if not union:
                continue
            jac = len(si & sj) / len(union)
            if jac >= threshold:
                pairs.append((ei, ej, round(jac, 6)))
    pairs.sort(key=lambda p: ((p[0].get("id") or ""), (p[1].get("id") or "")))
    pairs.sort(key=lambda p: p[2], reverse=True)            # most similar first
    return pairs


def build_stale_report(kdir, data, max_age_days):
    """Build the advisory staleness + conflict report dict. Reporting only."""
    stale = stale_entries(data, max_age_days)
    conflicts = conflict_pairs(kdir, data)
    return {
        "max_age_days": max_age_days,
        "volatile_categories": list(VOLATILE_CATEGORIES),
        "stale": [
            {"id": e.get("id"), "category": e.get("category"),
             "path": e.get("path"), "last_verified": entry_last_verified(e),
             "age_days": age}
            for (e, age) in stale
        ],
        "conflicts": [
            {"a": a.get("id"), "b": b.get("id"),
             "category": a.get("category"), "jaccard": jac}
            for (a, b, jac) in conflicts
        ],
    }


def _print_stale_report(report):
    print("STALE REPORT (advisory — reporting only, no mutation):")
    print("  window: last_verified older than %d day(s) in %s" % (
        report["max_age_days"], ", ".join(report["volatile_categories"])))
    if report["stale"]:
        print("  stale entries (%d):" % len(report["stale"]))
        for s in report["stale"]:
            print("    - %s [%s] last_verified=%s age=%dd" % (
                s["id"], s["category"], s["last_verified"], s["age_days"]))
    else:
        print("  stale entries: none")
    if report["conflicts"]:
        print("  possible duplicate/conflict pairs (%d, Jaccard >= %.2f):" % (
            len(report["conflicts"]), _CONFLICT_JACCARD))
        for c in report["conflicts"]:
            print("    - %s <-> %s [%s] jaccard=%.4f" % (
                c["a"], c["b"], c["category"], c["jaccard"]))
    else:
        print("  possible duplicate/conflict pairs: none")


def cmd_audit(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    as_json = getattr(args, "format", "text") == "json"
    data, err = load_index(kdir)
    if err is not None:
        checks = [{"name": "index_validate", "ok": False, "details": [err]}]
    else:
        ve = validate_index(kdir, data)
        un = scan_unindexed(kdir, data)
        te = tag_consistency_errors(data)
        tce = template_conformance_errors(kdir, data)
        oe = orphaned_learning_errors(kdir, data)
        checks = [
            {"name": "index_validate", "ok": not ve, "details": ve},
            {"name": "filesystem_sync", "ok": not un, "details": un},
            {"name": "tag_consistency", "ok": not te, "details": te},
            {"name": "template_conformance", "ok": not tce, "details": tce},
            {"name": "orphaned_learnings", "ok": not oe, "details": oe},
            _audit_steering_lint_check(),
            _audit_personal_data_check(kdir),
            _audit_bm25_cache_check(kdir, data),
            _audit_mode_b_health_check(kdir, data),
            _audit_graph_integrity_check(kdir, data),
            _audit_provenance_coverage_check(kdir, data),
            _audit_dream_health_check(kdir),
        ]
        # Rule-7 observability: advisory graph-health signal (append-only,
        # gitignored, read-only w.r.t. the KB/index).
        _append_graph_health_metric(kdir, data)
    if getattr(args, "with_tests", False):
        checks.append(_audit_tests_check())
        if err is None:
            checks.append(_audit_gate_check(kdir))
    stale_report = None
    if getattr(args, "stale", False) and err is None:
        stale_report = build_stale_report(
            kdir, data, getattr(args, "max_age_days", 120))
    ok = all(c["ok"] for c in checks)
    if as_json:
        payload = {"ok": ok, "checks": checks}
        if stale_report is not None:
            payload["stale_report"] = stale_report
        json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("AUDIT %s (%d check(s)):" % ("PASSED" if ok else "FAILED", len(checks)))
        for c in checks:
            print("  [%s] %s" % ("ok" if c["ok"] else "FAIL", c["name"]))
            if not c["ok"]:
                for d in c["details"]:
                    print("      - %s" % d)
        if stale_report is not None:
            _print_stale_report(stale_report)
    return 0 if ok else 1


# --- Steering DSF lint -------------------------------------------------------
def _steering_files():
    files = []
    for name in STEERING_EXPLICIT:
        p = os.path.join(REPO_ROOT, name)
        if os.path.exists(p):
            files.append(p)
    files.extend(sorted(glob.glob(STEERING_GLOB)))
    return files


def _iter_rule_lines(text):
    lines = text.splitlines()
    in_front = in_code = False
    for i, raw in enumerate(lines, 1):
        stripped = raw.strip()
        if i == 1 and stripped == "---":
            in_front = True
            continue
        if in_front:
            if stripped == "---":
                in_front = False
            continue
        if stripped.startswith("```"):
            in_code = not in_code
            continue
        if in_code:
            continue
        m = DSF_BULLET_RE.match(raw)
        if not m:
            continue
        body = m.group(1).strip()
        if body:
            yield i, body


def _first_token_verb(body):
    first = body.split()[0]
    return first.strip("*_`").rstrip(":.,")


def lint_steering():
    violations, banned_words = [], []
    total_chars = 0
    for path in _steering_files():
        try:
            text = open(path, "r", encoding="utf-8").read()
        except OSError as exc:
            violations.append({"rule": "DSF-read", "file": path,
                               "line": 0, "text": str(exc)})
            continue
        total_chars += len(text)
        for lineno, body in _iter_rule_lines(text):
            verb = _first_token_verb(body)
            if verb not in DSF_VERBS:
                violations.append({"rule": "DSF-2", "file": path, "line": lineno,
                                   "text": body})
            if not DSF_RULE_ID_RE.search(body):
                violations.append({"rule": "DSF-6", "file": path, "line": lineno,
                                   "text": body})
            low = body.lower()
            for w in DSF_BANNED_WORDS:
                if re.search(r"\b" + re.escape(w) + r"\b", low):
                    banned_words.append({"file": path, "line": lineno,
                                         "word": w, "text": body})
    budget_ok = total_chars <= STEERING_CHAR_BUDGET
    ok = (not violations) and (not banned_words) and budget_ok
    return {"ok": ok, "total_chars": total_chars, "char_budget": STEERING_CHAR_BUDGET,
            "budget_ok": budget_ok, "violations": violations,
            "banned_words": banned_words}


def cmd_steering_lint(args):
    result = lint_steering()
    as_json = getattr(args, "format", "text") == "json"
    if as_json:
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("STEERING LINT %s" % ("PASSED" if result["ok"] else "FAILED"))
        print("  chars: %d / %d (budget %s)" % (
            result["total_chars"], result["char_budget"],
            "ok" if result["budget_ok"] else "EXCEEDED"))
        for v in result["violations"]:
            print("  [%s] %s:%d  %s" % (v["rule"], v["file"], v["line"], v["text"]))
        for b in result["banned_words"]:
            print("  [DSF-5] %s:%d  banned %r in: %s" % (
                b["file"], b["line"], b["word"], b["text"]))
    return 0 if result["ok"] else 1


# --- Plan lint (feature 260625-plan-lint-gate) -------------------------------
# Canonical task-marker regex — the SINGLE SOURCE OF TRUTH for "what counts as an
# open task marker" in a feature plan. Its bytes MUST stay byte-identical to the
# `grep -cE '…'` pattern in agentware.sh:open_markers() (pinned by the contract
# test in tests/test_plan_lint.py). This is the POSIX-ERE form exactly as grep
# consumes it; Python's `re` does NOT honour POSIX `[[:class:]]` syntax, so the
# linter derives a Python-usable pattern via _posix_ere_to_python() at load time
# rather than feeding these bytes to re.compile directly.
PLAN_TASK_MARKER_RE = r"^[[:space:]]*-[[:space:]]*(⬜|🟡)[[:space:]]*\*\*[0-9]"


def _posix_ere_to_python(pattern):
    """Deterministically translate the POSIX-ERE classes we use into Python re.

    grep's POSIX bracket classes (`[[:space:]]`, `[[:digit:]]`, `[[:alpha:]]`)
    are not honoured by Python's `re`; translate the ones the canonical marker
    regex uses so the linter and the loop derive from the same source string.
    """
    return (pattern
            .replace("[[:space:]]", r"\s")
            .replace("[[:digit:]]", r"\d")
            .replace("[[:alpha:]]", "[A-Za-z]"))


# Open-marker matcher (⬜/🟡), derived from the canonical constant so it can never
# drift from the loop. Used only to assert the translation round-trips.
_PLAN_OPEN_MARKER_PY = re.compile(_posix_ere_to_python(PLAN_TASK_MARKER_RE))

# Well-formed task marker of ANY status. Extends the open-marker form with the
# done glyph ✅, since a complete plan's tasks are legitimately well-formed and
# must still lint clean (all-✅ plans). Captures the task number, which may be a
# FLAT `**N**` or a PHASED `**N.M**` marker (the documented phased form in
# docs/loop.md, e.g. `**1.1**`, `**1.2**`, `**2.1**`). The loop's grep counter
# (`PLAN_TASK_MARKER_RE`, `\*\*[0-9]`) already matches both, so this re-aligns the
# linter with the loop and with the documented task format.
_PLAN_TASK_LINE_RE = re.compile(r"^\s*-\s*(⬜|🟡|✅)\s*\*\*(\d+(?:\.\d+)?)\*\*")
# Malformed task-like lines we flag with a specific fix hint (R3).
_PLAN_CHECKBOX_RE = re.compile(r"^\s*-\s*\[[ xX]?\]")        # GitHub `- [ ]`
# A lettered TASK ID someone wrote instead of the canonical marker — `- **T1**`,
# `- **T12**`, `- **A3**`: a compact identifier (letters then digits) inside the
# bold, mirroring the `- **N**` shape but with a letter prefix. The trailing
# `\d+` requirement is deliberate: it flags real task-id mistakes WITHOUT
# false-flagging ordinary prose bullets like `- **Note:** …` or
# `- **Foundation first:** …` (a word/phrase, no compact `<letters><digits>**`).
_PLAN_LETTERED_RE = re.compile(r"^\s*-\s*\*\*[A-Za-z]+\d+\*\*")  # `- **T1**`
_PLAN_HEADING_RE = re.compile(r"^##\s+(.*\S)\s*$")
_PLAN_VERIFY_RE = re.compile(r"\*Verify:\*")
_PLAN_VERIFY_NONEMPTY_RE = re.compile(r"\*Verify:\*\s*\S")
_PLAN_PROMISE_RE = re.compile(r"<promise>[A-Z0-9_]+</promise>")

_PLAN_MARKER_HINT = ("expected a well-formed marker like `- ⬜ **N**` "
                     "(emoji ⬜/🟡/✅ + bold digit)")
_PLAN_R7_TOKENS = ("R-KB", "index validate", "learn", "features")
_PLAN_R9_BLOCKING = ("stop and ask", "operator decision required",
                     "await confirmation", "ask the user", "ask the operator")
_PLAN_R9_CARVEOUT = ("r-pkg-03", "r-exec-06", "pre-decided",
                     "proceed deterministically", "deterministic resolution",
                     "carve-out", "carveout")


def _parse_task_number(s):
    """'1' -> (1,); '1.2' -> (1, 2). Tuple form drives the R4 ordering check."""
    return tuple(int(p) for p in s.split("."))


def _check_task_numbering(number_strings):
    """Validate task-number ordering for FLAT or PHASED markers (R4).

    Returns an error message string, or None when the numbering is well-formed.

    - Flat plans (`**1**`, `**2**`, …): numbers must be 1..N, no gaps/dups.
    - Phased plans (`**1.1**`, `**1.2**`, `**2.1**`, …): the MAJOR groups must
      appear contiguously as 1..K, and within each major the MINORS must run
      1..m (so `set-status` / the burndown stay unambiguous). A flat marker is
      not mixed into a phased plan.
    """
    parsed = [_parse_task_number(s) for s in number_strings]
    phased = any(len(p) > 1 for p in parsed)
    if not phased:
        nums = [p[0] for p in parsed]
        expected = list(range(1, len(nums) + 1))
        if nums != expected:
            return ("task numbers must increase monotonically from 1 with no "
                    "gaps or duplicates; found %s, expected %s"
                    % (nums, expected))
        return None
    # Phased: walk the markers, grouping contiguous runs by major number.
    majors_in_order = []
    minors = {}
    for p in parsed:
        if len(p) != 2:
            return ("phased plans must use `**N.M**` markers throughout; found "
                    "a flat marker %r mixed in" % ".".join(map(str, p)))
        major, minor = p
        if not majors_in_order or majors_in_order[-1] != major:
            if major in majors_in_order:
                return ("phased major groups must be contiguous; major %d "
                        "reappears out of order" % major)
            majors_in_order.append(major)
        minors.setdefault(major, []).append(minor)
    if majors_in_order != list(range(1, len(majors_in_order) + 1)):
        return ("phased major numbers must increase from 1 with no gaps; "
                "found %s" % majors_in_order)
    for major in majors_in_order:
        ms = minors[major]
        if ms != list(range(1, len(ms) + 1)):
            return ("phased minors under major %d must run 1..%d with no gaps "
                    "or duplicates; found %s" % (major, len(ms), ms))
    return None


def lint_plan(text, strict=False):
    """Apply the structural plan-format rules R1–R9 to `text`.

    Returns (errors, warnings); each is a list of {rule, line, message}. R1 (file
    existence) is handled by the caller before this runs. Read-only (INV-2): never
    mutates anything. R9 is a warning by default and an error under `strict`.
    """
    errors, warnings = [], []

    def add(bucket, rule, line, message):
        bucket.append({"rule": rule, "line": int(line), "message": message})

    lines = text.splitlines()

    # Locate the required sections (R2) and the Tasks-section line range.
    tasks_start = accept_start = None
    headings = []
    for i, ln in enumerate(lines):
        m = _PLAN_HEADING_RE.match(ln)
        if not m:
            continue
        title = m.group(1).strip().lower()
        headings.append(i)
        if title == "tasks" and tasks_start is None:
            tasks_start = i
        elif title.startswith("acceptance criteria") and accept_start is None:
            accept_start = i

    if tasks_start is None:
        add(errors, "R2", 0, "missing required section '## Tasks'")
    if accept_start is None:
        add(errors, "R2", 0, "missing required section '## Acceptance criteria'")

    # Tasks section spans from just after '## Tasks' to the next '##' heading.
    if tasks_start is not None:
        tasks_end = len(lines)
        for idx in headings:
            if idx > tasks_start:
                tasks_end = idx
                break
        scan_range = range(tasks_start + 1, tasks_end)
    else:
        tasks_end = len(lines)
        scan_range = range(len(lines))

    # Find well-formed markers and malformed task-like lines within Tasks only
    # (so legit `- [ ]` checkboxes under '## Acceptance criteria' are NOT flagged).
    markers = []   # (idx, number-string)  — number is flat "N" or phased "N.M"
    for i in scan_range:
        ln = lines[i]
        m = _PLAN_TASK_LINE_RE.match(ln)
        if m:
            markers.append((i, m.group(2)))
        elif _PLAN_CHECKBOX_RE.match(ln) or _PLAN_LETTERED_RE.match(ln):
            add(errors, "R3", i + 1,
                "malformed task marker: %r — %s" % (ln.strip(), _PLAN_MARKER_HINT))

    # R3 — at least one well-formed marker.
    if not markers:
        add(errors, "R3", (tasks_start or 0) + 1,
            "no well-formed task markers found in '## Tasks' — %s"
            % _PLAN_MARKER_HINT)

    # R4 — task numbers monotonic from 1, no gaps/dups (flat OR phased N.M).
    if markers:
        msg = _check_task_numbering([n for (_, n) in markers])
        if msg:
            add(errors, "R4", markers[0][0] + 1, msg)

    # Build per-task bodies (marker line .. next marker / section end).
    tasks = []
    for k, (idx, num) in enumerate(markers):
        body_end = markers[k + 1][0] if k + 1 < len(markers) else tasks_end
        tasks.append({
            "line": idx + 1, "num": num,
            "body": "\n".join(lines[idx:body_end]),
        })

    # R5 — every task has a `*Verify:*` line.
    for t in tasks:
        if not _PLAN_VERIFY_RE.search(t["body"]):
            add(errors, "R5", t["line"],
                "task %s (line %d) has no `*Verify:*` line (every task must be "
                "independently verifiable — R-VERIFY-01)" % (t["num"], t["line"]))

    # R6 — at least one `[e2e]` task with a non-empty Verify line.
    if tasks and not any("[e2e]" in t["body"]
                         and _PLAN_VERIFY_NONEMPTY_RE.search(t["body"])
                         for t in tasks):
        add(errors, "R6", (tasks_start or 0) + 1,
            "no task carries an `[e2e]` token with a non-empty `*Verify:*` line "
            "(the plan must verify end-to-end before completion)")

    # R7 — at least one task references a knowledge-base update.
    tasks_text = "\n".join(lines[(tasks_start or 0):tasks_end])
    if tasks and not any(tok in tasks_text for tok in _PLAN_R7_TOKENS):
        add(errors, "R7", (tasks_start or 0) + 1,
            "no task references a knowledge-base update (expected one of: "
            "R-KB, `index validate`, `learn`, `features` — R-KB-*/R-SI-02)")

    # R8 — exactly one <promise>CONTENT</promise> tag.
    promises = _PLAN_PROMISE_RE.findall(text)
    if len(promises) != 1:
        add(errors, "R8", 0,
            "expected exactly one <promise>CONTENT</promise> tag, found %d"
            % len(promises))

    # R9 — blocking/interactive phrasing without a deterministic resolution.
    for t in tasks:
        low = t["body"].lower()
        if any(p in low for p in _PLAN_R9_BLOCKING) and \
                not any(c in low for c in _PLAN_R9_CARVEOUT):
            bucket = errors if strict else warnings
            add(bucket, "R9", t["line"],
                "task %s (line %d) uses blocking/interactive phrasing without a "
                "deterministic resolution or a cited R-PKG-03/R-EXEC-06 carve-out "
                "(plans must execute autonomously)" % (t["num"], t["line"]))

    return errors, warnings


def _emit_plan_lint(result, as_json):
    if as_json:
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("PLAN LINT %s" % ("PASSED" if result["ok"] else "FAILED"))
        for e in result["errors"]:
            print("  [%s] line %d: %s" % (e["rule"], e["line"], e["message"]))
        for w in result["warnings"]:
            print("  [warn %s] line %d: %s" % (w["rule"], w["line"], w["message"]))
    return 0 if result["ok"] else 1


def cmd_plan_lint(args):
    path = args.path
    strict = bool(getattr(args, "strict", False))
    as_json = getattr(args, "format", "text") == "json"

    # R1 — the file exists and is readable.
    if not os.path.isfile(path):
        return _emit_plan_lint(
            {"ok": False, "warnings": [],
             "errors": [{"rule": "R1", "line": 0,
                         "message": "plan file not found or not readable: %s"
                                    % path}]}, as_json)
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError as exc:
        return _emit_plan_lint(
            {"ok": False, "warnings": [],
             "errors": [{"rule": "R1", "line": 0,
                         "message": "cannot read plan file %s: %s" % (path, exc)}]},
            as_json)

    errors, warnings = lint_plan(text, strict=strict)
    result = {"ok": len(errors) == 0, "errors": errors, "warnings": warnings}
    return _emit_plan_lint(result, as_json)


# --- Plan authoring (feature 260625-plan-authoring-toolkit) -------------------
# The GENERATION half of the generation/enforcement split: deterministic writers
# that produce lint-passing plan structure BY CONSTRUCTION. The LLM planner
# decides WHAT the tasks are; these commands guarantee the FORM (markers,
# numbering, required sections, the <promise> tag, and the mandatory trailing
# [e2e]+[kb] pair). They reuse the SINGLE marker source-of-truth from the
# lint gate (_PLAN_TASK_LINE_RE, any-status) — no second pattern.

# Maps the CLI status word to the canonical marker glyph.
_PLAN_STATUS_GLYPH = {"todo": "⬜", "wip": "🟡", "done": "✅"}


def _atomic_write(path, text):
    """Write `text` to `path` atomically (temp sibling + os.replace rename).

    The single writer all three emitter commands route through, so a crash mid-
    write can never leave a half-written plan.md.
    """
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = "%s.tmp.%d" % (path, os.getpid())
    try:
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(text)
        os.replace(tmp, path)
    except BaseException:
        try:
            os.remove(tmp)
        except OSError:
            pass
        raise


def _plan_promise(feature):
    """Derive the deterministic <promise> content from a feature name.

    `260625-plan-authoring-toolkit` -> `260625_PLAN_AUTHORING_TOOLKIT_COMPLETE`.
    """
    slug = re.sub(r"[^A-Za-z0-9]+", "_", feature).strip("_").upper()
    return "%s_COMPLETE" % slug


def _plan_path(kdir, feature):
    return os.path.join(kdir, "work", feature, "plan.md")


def _plan_skeleton(feature, title, max_iterations, self_extension):
    """Build the canonical, lint-passing plan skeleton.

    ALWAYS seeds the mandatory trailing pair: a penultimate `[e2e]` task (literal
    token + non-empty Verify -> R6) and a final `[kb]` task embedding an R7 token
    (`index validate`/`learn`/`features` -> R7). There is no flag to omit them.
    """
    warning = ""
    if self_extension:
        warning = (
            "## ‼️ Self-extension warning (read before executing)\n\n"
            "This plan edits agentware **package** files (`R-PKG-01`). Per the "
            "reinterpreted `R-PKG-03`, approving and running this prominently-"
            "warned plan IS the confirmation — the loop RECORDS it and proceeds "
            "(no mid-run stop). Per `R-PKG-04`/`R-PKG-05`, run `scripts/agentware "
            "steering lint` and `scripts/agentware eval --record --gate` after "
            "editing; a reliability-neutral-or-better A/B passes, a pre-existing-"
            "drift FAIL is a recorded `> DECISION:` known-issue, and a genuine "
            "diff-caused regression stops.\n\n---\n\n")
    selfext_line = "YES (`R-PKG-03` record-and-proceed)" if self_extension else "NO"
    return (
        "# Plan — %s\n\n"
        "> Feature: `%s`\n"
        "> Created: %s\n"
        "> Type: %s\n\n"
        "---\n\n"
        "%s"
        "## Context\n\n"
        "_TODO: problem, goal, design, constraints, environment, pitfalls._\n\n"
        "---\n\n"
        "## Tasks\n\n"
        "- ⬜ **1** [e2e] End-to-end verification of the feature.\n"
        "  *Verify:* TODO — exercise the feature end-to-end and capture the outcome.\n"
        "- ⬜ **2** [kb] Knowledge-base update.\n"
        "  Run `scripts/agentware audit --stale`, add a learning via "
        "`scripts/agentware learn`, then `scripts/agentware features`.\n"
        "  *Verify:* `scripts/agentware index validate` exits 0; "
        "`scripts/agentware worklog scan` reports 0 unpromoted markers.\n\n"
        "---\n\n"
        "## Acceptance criteria\n\n"
        "- [ ] TODO: define the verifiable acceptance criteria.\n\n"
        "---\n\n"
        "## Operational\n\n"
        "- **Max iterations:** %d\n"
        "- **Self-extension:** %s\n\n"
        "<promise>%s</promise>\n"
        % (title, feature, _today(),
           "**self-extension (package change)**" if self_extension
           else "feature work",
           warning, int(max_iterations), selfext_line, _plan_promise(feature))
    )


def _plan_renumber(lines):
    """Rewrite ONLY the `**N**` token of each task marker to a monotonic 1..N.

    Uses the any-status matcher so ✅ tasks are renumbered too (never skipped).
    """
    out, n = [], 0
    for ln in lines:
        if _PLAN_TASK_LINE_RE.match(ln):
            n += 1
            ln = re.sub(r"(\*\*)\d+(\*\*)", r"\g<1>%d\g<2>" % n, ln, count=1)
        out.append(ln)
    return out


def _plan_marker_indices(lines):
    """Indices of every task-marker line, in file order."""
    return [i for i, ln in enumerate(lines) if _PLAN_TASK_LINE_RE.match(ln)]


def _load_plan_for_edit(kdir, feature):
    """Read a plan for mutation, refusing if it is missing or fails lint.

    Returns (text, None) on success or (None, error_message). The read-modify-
    write guard: never edit (and so never corrupt) a plan that does not already
    satisfy the structural contract.
    """
    path = _plan_path(kdir, feature)
    if not os.path.isfile(path):
        return None, "no plan at %s (run `plan new %s` first)" % (path, feature)
    with open(path, "r", encoding="utf-8") as f:
        text = f.read()
    errors, _ = lint_plan(text, strict=False)
    if errors:
        return None, ("refusing to edit a plan that fails `plan lint` "
                      "(%d error(s)); fix it first" % len(errors))
    return text, None


def cmd_plan_new(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    path = _plan_path(kdir, args.feature)
    if os.path.exists(path) and not getattr(args, "force", False):
        sys.stderr.write(
            "agentware: plan already exists (use --force to overwrite): %s\n"
            % path)
        return 1
    text = _plan_skeleton(args.feature, args.title,
                          getattr(args, "max_iterations", 30),
                          bool(getattr(args, "self_extension", False)))
    _atomic_write(path, text)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "path": path,
                   "promise": _plan_promise(args.feature)},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("PLAN created '%s' -> %s" % (args.feature, path))
    return 0


def cmd_plan_add_task(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    text, err = _load_plan_for_edit(kdir, args.feature)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1
    lines = text.splitlines()
    markers = _plan_marker_indices(lines)
    # Insert BEFORE the mandatory trailing [e2e]+[kb] pair (the last two tasks).
    # With <2 tasks present the plan is non-canonical; the lint guard above would
    # have caught a missing Tasks section, so fall back to "before the last".
    insert_at = markers[-2] if len(markers) >= 2 else (
        markers[-1] if markers else len(lines))

    tag = ""
    verify = (args.verify or "").strip()
    if getattr(args, "e2e", False):
        tag = "[e2e] "
        verify = verify or "TODO — exercise this end-to-end and capture the outcome."
    elif getattr(args, "kb", False):
        tag = "[kb] "
        verify = verify or "`scripts/agentware index validate` exits 0."
    verify = verify or "TODO — add a verification command for this task."

    block = ["- ⬜ **0** %s%s" % (tag, args.description),
             "  *Verify:* %s" % verify]
    new_lines = lines[:insert_at] + block + lines[insert_at:]
    new_lines = _plan_renumber(new_lines)
    out = "\n".join(new_lines) + ("\n" if text.endswith("\n") else "")
    _atomic_write(_plan_path(kdir, args.feature), out)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "tasks": len(_plan_marker_indices(new_lines))},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("PLAN add-task '%s': %d task(s)"
              % (args.feature, len(_plan_marker_indices(new_lines))))
    return 0


def cmd_plan_set_status(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    glyph = _PLAN_STATUS_GLYPH.get(args.status)
    if glyph is None:
        sys.stderr.write("agentware: status must be todo|wip|done\n")
        return 1
    text, err = _load_plan_for_edit(kdir, args.feature)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1
    lines = text.splitlines()
    target = int(args.number)
    hit = False
    for i, ln in enumerate(lines):
        m = _PLAN_TASK_LINE_RE.match(ln)
        # Toolkit-managed plans use flat `**N**`; phased `**N.M**` markers (which
        # int() cannot parse) are skipped rather than crashing set-status.
        if m and m.group(2).isdigit() and int(m.group(2)) == target:
            lines[i] = re.sub(r"(⬜|🟡|✅)", glyph, ln, count=1)
            hit = True
            break
    if not hit:
        sys.stderr.write("agentware: no task numbered %d in plan\n" % target)
        return 1
    out = "\n".join(lines) + ("\n" if text.endswith("\n") else "")
    _atomic_write(_plan_path(kdir, args.feature), out)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "task": target, "status": args.status},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("PLAN set-status '%s': task %d -> %s"
              % (args.feature, target, args.status))
    return 0


# --- KB git sync -------------------------------------------------------------
# Pure-git helpers for the conflict-safe knowledge-base sync (feature
# 260625-kb-git-sync). NO new dependency: shells the operator's `git` only. All
# helpers operate on an explicit directory so tests can drive throwaway temp
# repos (NEVER the operator's real $KDIR) and never raise on a non-repo dir.

def _git(target, *args, **kwargs):
    """Run `git -C <target> <args>`; return the CompletedProcess.

    Never raises on a non-zero exit (check=False); callers inspect returncode.
    Captures stdout/stderr as text. If the `git` binary is absent the
    FileNotFoundError is surfaced as a synthetic returncode 127 so callers can
    degrade to local-only (C-4) without crashing.
    """
    cmd = ["git", "-C", target] + [str(a) for a in args]
    try:
        return subprocess.run(
            cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            text=True, check=False, **kwargs)
    except FileNotFoundError:
        return subprocess.CompletedProcess(cmd, 127, "", "git: command not found")


def git_is_work_tree(target):
    """True iff `target` is inside a git work tree."""
    cp = _git(target, "rev-parse", "--is-inside-work-tree")
    return cp.returncode == 0 and cp.stdout.strip() == "true"


def git_has_upstream(target):
    """True iff the current branch has a configured upstream tracking branch.

    This is the precise precondition for a fast-forward pull / push: a bare
    remote alone is not enough — the branch must track an upstream (`@{u}`).
    """
    if not git_is_work_tree(target):
        return False
    cp = _git(target, "rev-parse", "--abbrev-ref",
              "--symbolic-full-name", "@{upstream}")
    return cp.returncode == 0 and bool(cp.stdout.strip())


def git_is_clean(target):
    """True iff the work tree has no staged/unstaged/untracked changes."""
    if not git_is_work_tree(target):
        return False
    cp = _git(target, "status", "--porcelain")
    return cp.returncode == 0 and cp.stdout.strip() == ""


def git_status(target):
    """Report the three KB git-state booleans as a dict.

    has_upstream / is_clean are forced False on a non-work-tree so the shape is
    always the same regardless of the target.
    """
    iwt = git_is_work_tree(target)
    return {
        "is_work_tree": iwt,
        "has_upstream": git_has_upstream(target) if iwt else False,
        "is_clean": git_is_clean(target) if iwt else False,
    }


def cmd_kb_git_status(args):
    """Print the KB git-state booleans (is_work_tree / has_upstream / is_clean).

    Targets the resolved knowledge dir by default; `--path` overrides it so the
    loop (and tests) can point at a throwaway repo. NEVER mutates anything.
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1
    st = git_status(target)
    if getattr(args, "format", "text") == "json":
        json.dump(st, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("is_work_tree: %s" % ("yes" if st["is_work_tree"] else "no"))
        print("has_upstream: %s" % ("yes" if st["has_upstream"] else "no"))
        print("is_clean:     %s" % ("yes" if st["is_clean"] else "no"))
    return 0


def git_toplevel(target):
    """Absolute path of `target`'s git work-tree root, or None if not a repo."""
    cp = _git(target, "rev-parse", "--show-toplevel")
    if cp.returncode != 0:
        return None
    top = cp.stdout.strip()
    return os.path.realpath(top) if top else None


def git_changed_paths(target):
    """Repo-relative paths with pending changes (staged, unstaged, untracked).

    Parses `status --porcelain` (machine-stable). Rename entries (`old -> new`)
    contribute the NEW path. Returns a de-duplicated, sorted list.
    """
    cp = _git(target, "status", "--porcelain")
    if cp.returncode != 0:
        return []
    paths = set()
    for line in cp.stdout.splitlines():
        if len(line) < 4:
            continue
        p = line[3:]
        if " -> " in p:  # rename / copy: take the destination
            p = p.split(" -> ", 1)[1]
        p = p.strip().strip('"')
        if p:
            paths.add(p)
    return sorted(paths)


def _sanitize_commit_tag(tag):
    """Lowercase + restrict a commit scope tag to [a-z0-9._-] (collapsed `-`)."""
    tag = (tag or "kb").strip().lower()
    tag = re.sub(r"[^a-z0-9._-]+", "-", tag).strip("-._")
    return tag or "kb"


# Conventional-commit subject the auto-commit must satisfy: feat|chore(scope): msg
COMMIT_MSG_RE = re.compile(r"^(feat|chore)\([a-z0-9._-]+\): .+")

# A commit subject stays one sane line; cap its total length (C-1) and truncate
# with an ellipsis rather than spill the dir list / topic list across the line.
COMMIT_SUBJECT_MAX = 100
# How many knowledge topics to name before collapsing the tail to "+N more".
COMMIT_TOPICS_LIMIT = 5


def kb_changed_knowledge_topics(changed):
    """Knowledge entry 'topics' (basenames) among the changed paths.

    `learnings/<topic>.md` -> `<topic>`; `skills/<topic>/...` or
    `skills/<topic>.md` -> `<topic>`. De-duplicated, sorted, deterministic — used
    to make the autocommit subject name WHAT knowledge changed instead of the
    generic top-level dir list. Pure string ops over the staged diff (no LLM /
    network), so the moat is preserved (feature 260625-autocommit-message-fix).
    """
    seen = set()
    for p in changed:
        parts = p.split("/")
        if len(parts) < 2:
            continue  # top-level file (MAIN.md, index.json) — not a knowledge entry
        topic = None
        if parts[0] == "learnings" and parts[-1].endswith(".md"):
            topic = parts[-1][:-3]
        elif parts[0] == "skills":
            seg = parts[1]
            topic = seg[:-3] if seg.endswith(".md") else seg
        if topic:
            seen.add(topic)
    return sorted(seen)


def _format_topics_label(topics, limit=COMMIT_TOPICS_LIMIT):
    """`learnings: a, b, c` (first `limit`, tail collapsed to `+N more`)."""
    shown = topics[:limit]
    label = ", ".join(shown)
    extra = len(topics) - len(shown)
    if extra > 0:
        label += ", +%d more" % extra
    return "learnings: %s" % label


def _truncate_subject(subject, limit=COMMIT_SUBJECT_MAX):
    """Clamp a commit subject to one sane line ≤ `limit` chars (C-1)."""
    subject = subject.splitlines()[0] if subject else subject
    if len(subject) > limit:
        subject = subject[:limit - 3].rstrip().rstrip(",") + "..."
    return subject


def cmd_kb_git_commit(args):
    """Stage + commit ONLY the knowledge-base repo as one conventional commit.

    Deterministic, opt-in commit discipline (feature 260625-kb-git-sync, Task
    2.1). Scope is the KB repo ONLY (C-3): the helper operates with `git -C
    <target>` against a SEPARATE git repo and refuses if the target's work-tree
    root resolves to the agentware package repo, so the project/package can
    never be staged. No-ops (rc 0) on a non-tracked KB (C-4) or a clean tree.

    Message format is ENFORCED: `feat|chore(<tag>): <summary>`. The tag is
    derived deterministically (caller-supplied --tag, sanitized); when --message
    is omitted a deterministic summary of the changed top-level dirs is built.
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1

    # C-4: degrade to local-only (no failure) when the KB is not a git repo.
    if not git_is_work_tree(target):
        print("kb-git commit: %s is not a git work tree — skipping commit "
              "(local-only)." % target)
        return 0

    # C-3 scope guard: NEVER commit the agentware package repo. The KB is a
    # separate repo; if the target somehow resolves to this package's work-tree
    # root, refuse loudly rather than stage package/project files.
    top = git_toplevel(target)
    pkg_top = git_toplevel(REPO_ROOT)
    if top and pkg_top and top == pkg_top:
        sys.stderr.write(
            "kb-git commit: refusing — target resolves to the agentware "
            "package repo (%s); commits are scoped to the KB repo only "
            "(C-3).\n" % top)
        return 1

    changed = git_changed_paths(target)
    if not changed:
        print("kb-git commit: nothing to commit — work tree clean.")
        return 0

    tag = _sanitize_commit_tag(getattr(args, "tag", None))
    ctype = getattr(args, "type", None) or "chore"
    message = getattr(args, "message", None)
    # Name WHAT knowledge changed (deterministic, from the staged diff). Used as
    # the default summary, or appended as a compact suffix to a caller --message.
    topics = kb_changed_knowledge_topics(changed)
    if not message:
        if topics:
            # Default summary describes the changed knowledge entries...
            message = _format_topics_label(topics)
        else:
            # ...else fall back to the changed top-level dir list (C-2, never empty).
            tops = sorted({p.split("/", 1)[0] for p in changed})
            n = len(changed)
            message = "sync %s (%d file%s)" % (
                ", ".join(tops), n, "" if n == 1 else "s")
    elif topics:
        # A caller-supplied title (e.g. the plan title from agentware.sh) gets a
        # compact knowledge suffix so the subject names BOTH feature + knowledge.
        message = "%s — %s" % (message, _format_topics_label(topics))

    subject = _truncate_subject("%s(%s): %s" % (ctype, tag, message))
    if not COMMIT_MSG_RE.match(subject):
        sys.stderr.write(
            "kb-git commit: refusing — message '%s' does not match "
            "feat|chore(<tag>): <summary>.\n" % subject)
        return 1

    # Stage ONLY this repo (git -C <target> scopes the add to <target>'s repo).
    add = _git(target, "add", "-A")
    if add.returncode != 0:
        sys.stderr.write("kb-git commit: git add failed: %s\n" % add.stderr.strip())
        return 1

    commit = _git(target, "commit", "-m", subject)
    if commit.returncode != 0:
        sys.stderr.write("kb-git commit: git commit failed: %s\n"
                         % (commit.stderr.strip() or commit.stdout.strip()))
        return 1

    head = _git(target, "rev-parse", "HEAD").stdout.strip()
    print("kb-git commit: %s — %s" % (head[:9], subject))
    return 0


def git_pull_ff(target):
    """Fast-forward-only `git pull`; non-interactive (never prompts for input).

    Returns the CompletedProcess. `GIT_TERMINAL_PROMPT=0` makes an offline /
    auth-required fetch fail fast instead of hanging for credentials
    (R-SHELL-01), and `--ff-only` refuses to create a merge commit — a divergent
    upstream is reported as a non-zero exit the caller treats as a graceful skip
    (the push/rebase path, Phase 4, owns real divergence).
    """
    env = dict(os.environ)
    env["GIT_TERMINAL_PROMPT"] = "0"
    return _git(target, "pull", "--ff-only", env=env)


def cmd_kb_git_pull(args):
    """Fast-forward the KB repo from its upstream at a safe point.

    Pull cadence (feature 260625-kb-git-sync, Task 3.1): run at agent start and
    again right before a push. Preconditions — the target is a git work tree
    (C-4), has a configured upstream, and the tree is CLEAN (prior writes must be
    committed first; we NEVER pull onto uncommitted edits). Any unmet
    precondition, an offline fetch, or a non-fast-forward divergence is a
    graceful SKIP (rc 0 + a clear notice) — pulling NEVER blocks work. Beyond the
    fast-forward this mutates nothing.
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1

    # C-4: degrade to local-only (never block) when the KB is not a git repo.
    if not git_is_work_tree(target):
        print("kb-git pull: %s is not a git work tree — skipping pull "
              "(local-only)." % target)
        return 0

    if not git_has_upstream(target):
        print("kb-git pull: no upstream tracking branch — skipping pull "
              "(local-only).")
        return 0

    # Precondition: a clean tree. Prior writes must be committed first so a
    # fast-forward can never clobber or conflict with uncommitted edits.
    if not git_is_clean(target):
        print("kb-git pull: work tree has uncommitted changes — skipping pull "
              "(commit first; never pulling onto uncommitted writes).")
        return 0

    cp = git_pull_ff(target)
    if cp.returncode != 0:
        detail = [l for l in (cp.stderr or "").strip().splitlines() if l.strip()]
        first = detail[0] if detail else "fetch failed"
        print("kb-git pull: skipped — %s (offline or diverged; not blocking "
              "work)." % first)
        return 0

    out_lines = [l for l in (cp.stdout or "").strip().splitlines() if l.strip()]
    summary = out_lines[0] if out_lines else "up to date"
    print("kb-git pull: %s" % summary)
    return 0


def _is_derived_rel(rel):
    """True iff a KB-relative path is a DERIVED file regenerated by `index rebuild`.

    The derived set is exactly `index.json`, `FEATURES.md`, and each
    `<sub>/index.md` roster (sub in KNOWLEDGE_SUBDIRS). These are NEVER merged by
    hand or by an agent (C-1) — conflicts in them are resolved deterministically
    by rebuilding from the union of entry frontmatter.
    """
    rel = rel.strip().strip('"')
    if rel in ("index.json", "FEATURES.md"):
        return True
    parts = rel.split("/")
    return (len(parts) == 2 and parts[1] == "index.md"
            and parts[0] in KNOWLEDGE_SUBDIRS)


def git_unmerged_paths(target):
    """Repo-relative paths currently in a conflicted (unmerged) state, sorted."""
    cp = _git(target, "diff", "--name-only", "--diff-filter=U")
    if cp.returncode != 0:
        return []
    return sorted({l.strip().strip('"') for l in cp.stdout.splitlines()
                   if l.strip()})


def git_rebase_in_progress(target):
    """True iff a rebase is currently paused/in progress in `target`.

    Checks both git rebase backends (merge → `rebase-merge`, am → `rebase-apply`)
    via `rev-parse --git-path`, which respects worktrees. Used by the prose-merge
    path (Phase 5): `kb-git push --on-prose-conflict pause` leaves a rebase in
    progress for the MERGE_PROMPT, and `kb-git merge-continue` only proceeds when
    one is actually in progress.
    """
    for marker in ("rebase-merge", "rebase-apply"):
        cp = _git(target, "rev-parse", "--git-path", marker)
        if cp.returncode != 0:
            continue
        p = cp.stdout.strip()
        if not p:
            continue
        if not os.path.isabs(p):
            p = os.path.join(target, p)
        if os.path.isdir(p):
            return True
    return False


def file_has_conflict_markers(path):
    """True iff `path` still contains git conflict markers (`<<<<<<<`/`>>>>>>>`).

    Only the 7-angle-bracket markers are checked: they never occur in normal
    prose/markdown, so this avoids false positives on a `=======` setext heading
    or horizontal rule. The nothing-lost prose merge (Phase 5) refuses to continue
    a rebase while any reconciled entry file still carries an unresolved marker.
    """
    try:
        with open(path, encoding="utf-8", errors="replace") as f:
            for line in f:
                if line.startswith("<<<<<<<") or line.startswith(">>>>>>>"):
                    return True
    except OSError:
        return False
    return False


def _git_noninteractive_env():
    """Env that makes git fail fast instead of prompting (stdin/editor/creds)."""
    env = dict(os.environ)
    env["GIT_TERMINAL_PROMPT"] = "0"  # never prompt for credentials (R-SHELL-01)
    env["GIT_EDITOR"] = "true"        # never open an editor (rebase --continue)
    return env


def git_push(target):
    """`git push` to the upstream; non-interactive. Returns the CompletedProcess."""
    return _git(target, "push", env=_git_noninteractive_env())


def _push_was_rejected(cp):
    """True iff a non-zero push failed because the upstream moved (non-fast-forward).

    Distinguishes a resolvable rejection (rebase + retry) from an offline / auth /
    network failure (graceful skip, C-4). Matches git's stable wording.
    """
    blob = ((cp.stderr or "") + (cp.stdout or "")).lower()
    return ("rejected" in blob or "non-fast-forward" in blob
            or "fetch first" in blob or "updates were rejected" in blob)


# Distinct return code for a re-push RACE (upstream moved again between our
# resolve and our push). It is recoverable — `kb_git_push_synced` retries the
# whole pull→resolve→push up to a bounded cap (C-2) — so it is kept separate from
# a fail-loud rc 1. Never surfaced to a CLI caller: the wrapper maps an exhausted
# race to a plain rc 1.
RC_REPUSH_RACE = 4


def git_entry_ids_at_ref(target, ref):
    """Set of entry frontmatter IDs present at a git ref's tree, or None.

    Lists the tree at `ref` WITHOUT a checkout (`git ls-tree -r`), keeps only
    indexable entry files (the same `<sub>/…md` candidate rule as
    `scan_entry_files`, minus the `<sub>/index.md` rosters), reads each blob via
    `git show <ref>:<path>`, and parses its frontmatter `id`. Returns None when
    `ref` does not resolve, so the nothing-lost gate can SKIP an unavailable
    parent (e.g. `@{upstream}` during a detached-HEAD rebase) rather than
    mis-count it as empty. Pure git — no new dependency (C-5).
    """
    ls = _git(target, "ls-tree", "-r", "--name-only", ref)
    if ls.returncode != 0:
        return None
    ids = set()
    for rel in ls.stdout.splitlines():
        rel = rel.strip().strip('"')
        if not rel.endswith(".md"):
            continue
        parts = rel.split("/")
        if parts[0] not in KNOWLEDGE_SUBDIRS:
            continue
        if not _is_sync_candidate(rel):
            continue
        show = _git(target, "show", "%s:%s" % (ref, rel))
        if show.returncode != 0:
            continue
        fields, _body = split_frontmatter(show.stdout)
        if fields and fields.get("id"):
            ids.add(fields["id"])
    return ids


def kb_entry_ids(target):
    """Set of entry frontmatter IDs in the WORKING TREE at `target`.

    The same enumeration the index derives from (`scan_entry_files` +
    `read_entry_frontmatter`); used by the nothing-lost gate to compute the
    MERGED entry-ID set after a resolution.
    """
    ids = set()
    for rel in scan_entry_files(target):
        fm = read_entry_frontmatter(os.path.join(target, rel))
        if fm.get("id"):
            ids.add(fm["id"])
    return ids


def kb_nothing_lost_gate(target, parent_refs):
    """Mechanical "nothing lost" gate after a merge resolution (C-2).

    Runs ON the resolved work tree, BEFORE the network push, so a lossy or
    invalid merge is REJECTED before it can reach the remote:

      1. index rebuild → index validate: re-derive the index from frontmatter
         (`build_index_from_frontmatter`, read-only — writes nothing) and validate
         it. Any frontmatter / validation error fails the gate.
      2. entry-ID superset check: the merged entry-ID set MUST be a SUPERSET of
         the UNION of every resolvable parent's entry-ID set. A parent ref that
         does not resolve is skipped (not counted as empty). If any id was dropped
         the gate fails.

    Returns (ok, note). The caller aborts/leaves the rebase and fails loud on a
    False result — no silent loss. Deterministic, no agent, no new dependency.
    """
    data, errors = build_index_from_frontmatter(target)
    if errors:
        return False, ("nothing-lost gate: invalid frontmatter after merge: %s"
                       % "; ".join(errors))
    verrs = validate_index(target, data)
    if verrs:
        return False, ("nothing-lost gate: index invalid after merge: %s"
                       % "; ".join(verrs))

    merged = {e.get("id") for e in data["entries"] if e.get("id")}
    union = set()
    for ref in parent_refs:
        if not ref:
            continue
        pids = git_entry_ids_at_ref(target, ref)
        if pids is None:
            continue  # parent ref unavailable (e.g. detached @{upstream}) — skip
        union |= pids
    dropped = union - merged
    if dropped:
        return False, ("nothing-lost gate: merge would DROP entry id(s): %s — "
                       "merged set is not a superset of the parents (C-2 abort)"
                       % ", ".join(sorted(dropped)))
    return True, ("nothing-lost gate: ok (%d merged id(s) ⊇ %d parent id(s))"
                  % (len(merged), len(union)))


def _git_upstream_name(target):
    """The current branch's upstream ref name (e.g. `origin/main`), or "".

    Resolved while ON the branch (before any rebase detaches HEAD) so the
    nothing-lost gate can reference the upstream parent by a concrete name that
    still resolves mid-rebase.
    """
    cp = _git(target, "rev-parse", "--abbrev-ref",
              "--symbolic-full-name", "@{upstream}")
    return cp.stdout.strip() if cp.returncode == 0 else ""


def kb_git_push_once(target, on_prose_conflict="abort"):
    """One push attempt with deterministic derived-file conflict resolution.

    Returns (rc, note). rc 0 == pushed or a graceful no-op skip (C-4); rc 1 ==
    fail loud; rc 3 == paused on a prose conflict (only when
    `on_prose_conflict == "pause"`) with the rebase LEFT IN PROGRESS for the
    MERGE_PROMPT — `note` is `"PROSE_CONFLICT\n<rel>\n<rel>..."`. The flow:

      1. push → success: done.
      2. push rejected (upstream moved) → `pull --rebase`.
         - rebase clean → push again.
         - rebase conflicts ONLY in derived files → rebuild from the entry union
           (`rebuild_kb`, C-1, NO agent), stage, `rebase --continue`, push.
         - any conflict in a NON-derived (entry) file → same-entry prose case:
           * on_prose_conflict == "abort" (default): `rebase --abort` + fail loud
             rc 1 (preserves the deterministic, agent-free push contract).
           * on_prose_conflict == "pause" (Phase 5): leave the rebase in progress
             and return rc 3 + the conflicted entry-file list, so the loop can
             reconcile them with the curated MERGE_PROMPT (agentware-execution)
             and then run `kb-git merge-continue`. NO agent is invoked here.
      3. push failed for any other reason (offline/auth) → graceful skip (C-4).

    Every conflict RESOLUTION is verified by the nothing-lost gate (C-2) BEFORE
    the resulting commit is pushed: a lossy or invalid merge aborts the rebase
    and fails loud rather than reaching the remote. A re-push race returns
    RC_REPUSH_RACE so `kb_git_push_synced` can retry within a bounded cap.
    """
    # Captured ON the branch (before any rebase detaches HEAD) so the nothing-lost
    # gate can name the upstream parent with a ref that still resolves mid-rebase.
    upstream_name = _git_upstream_name(target)

    push = git_push(target)
    if push.returncode == 0:
        out = (push.stderr or push.stdout or "").strip().splitlines()
        return 0, "pushed%s" % ((" — " + out[-1]) if out else "")

    if not _push_was_rejected(push):
        first = (push.stderr or "push failed").strip().splitlines()
        return 0, "skipped — %s (offline or no access; not blocking work)" % (
            first[0] if first else "push failed")

    # Upstream moved: rebase our local commits on top of it, resolving any
    # derived-file conflicts deterministically.
    env = _git_noninteractive_env()
    rebase = _git(target, "pull", "--rebase", env=env)
    if rebase.returncode == 0:
        push2 = git_push(target)
        if push2.returncode == 0:
            return 0, "pushed (after fast-forward rebase)"
        # A conflict-free rebase replays every commit verbatim (no synthesized
        # content) so there is nothing for the gate to catch; a rejection here is
        # purely a re-push race for the bounded retry.
        return (RC_REPUSH_RACE,
                "push still rejected after clean rebase (re-push race)")

    unmerged = git_unmerged_paths(target)
    if not unmerged:
        _git(target, "rebase", "--abort", env=env)
        first = (rebase.stderr or "rebase failed").strip().splitlines()
        return 1, "rebase failed: %s" % (first[0] if first else "unknown")

    non_derived = [p for p in unmerged if not _is_derived_rel(p)]
    if non_derived:
        # Same-entry prose conflict — the deterministic path stops here (C-1: an
        # agent NEVER merges via this engine). Two dispositions:
        if on_prose_conflict == "pause":
            # Phase 5: leave the rebase in progress for the curated MERGE_PROMPT.
            # The loop reconciles these entry files via agentware-execution, then
            # calls `kb-git merge-continue` (which rebuilds the derived files).
            return 3, "PROSE_CONFLICT\n" + "\n".join(non_derived)
        # Default: abort cleanly and fail loud rather than touch entry files.
        _git(target, "rebase", "--abort", env=env)
        return 1, ("conflict in non-derived file(s) %s — needs prose merge "
                   "(not auto-resolvable here)" % ", ".join(non_derived))

    # All conflicts are in derived files: regenerate them from the union of
    # entry frontmatter (the entry files themselves merged cleanly). NO agent.
    data, _rosters, errors = rebuild_kb(target)
    if errors:
        _git(target, "rebase", "--abort", env=env)
        return 1, "rebuild during merge failed: %s" % "; ".join(errors)

    add = _git(target, "add", "-A")
    if add.returncode != 0:
        _git(target, "rebase", "--abort", env=env)
        return 1, "git add failed during merge: %s" % add.stderr.strip()

    # Nothing-lost gate (C-2): the resolved (mid-rebase) work tree must rebuild to
    # a valid index whose entry-ID set is a superset of BOTH parents. Fail loud +
    # abort the rebase BEFORE the push if anything was dropped — no silent loss.
    ok, gnote = kb_nothing_lost_gate(target, ["ORIG_HEAD", upstream_name])
    if not ok:
        _git(target, "rebase", "--abort", env=env)
        return 1, gnote

    cont = _git(target, "rebase", "--continue", env=env)
    if cont.returncode != 0:
        _git(target, "rebase", "--abort", env=env)
        first = (cont.stderr or "rebase --continue failed").strip().splitlines()
        return 1, "rebase --continue failed: %s" % (first[0] if first else "")

    push3 = git_push(target)
    if push3.returncode == 0:
        return 0, "pushed (derived files auto-resolved via index rebuild)"
    return (RC_REPUSH_RACE,
            "push rejected after deterministic resolve (re-push race)")


def kb_git_push_synced(target, on_prose_conflict="abort", max_retries=3):
    """`kb_git_push_once` wrapped in a bounded pull→resolve→push retry (C-2).

    Each attempt runs a full `kb_git_push_once` (which itself pulls/rebases and
    resolves derived-file conflicts under the nothing-lost gate). When the upstream
    moves AGAIN between our resolve and our push (`RC_REPUSH_RACE`), we retry the
    whole cycle up to `max_retries` times, then FAIL LOUD (rc 1) — never an
    unbounded loop. Any other disposition (pushed rc 0, graceful skip rc 0, prose
    pause rc 3, fail-loud rc 1) returns immediately. The race sentinel is internal
    and is mapped to a plain rc 1 on exhaustion so callers see a normal failure.
    """
    attempts = max(1, max_retries)
    last_note = "no attempt"
    for attempt in range(1, attempts + 1):
        rc, note = kb_git_push_once(target, on_prose_conflict=on_prose_conflict)
        if rc != RC_REPUSH_RACE:
            return rc, note
        last_note = note  # race — pull/resolve/push again on the next iteration
    return 1, ("push failed after %d re-push race retries: %s (upstream keeps "
               "moving — try again)" % (attempts, last_note))


def cmd_kb_git_push(args):
    """Push KB commits to upstream, auto-resolving derived-file conflicts.

    Git-sync push (feature 260625-kb-git-sync, Task 4.1). Preconditions: the
    target is a git work tree (C-4) with a configured upstream, and is NOT the
    agentware package repo (C-3). A push rejected by a moved upstream is resolved
    by rebasing and regenerating the DERIVED files (`index.json`, rosters,
    `FEATURES.md`) from the entry union via `index rebuild` — never by an agent
    (C-1). Offline / no-upstream / non-repo are graceful rc-0 skips (never block).
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1

    # C-4: degrade to local-only (never block) when the KB is not a git repo.
    if not git_is_work_tree(target):
        print("kb-git push: %s is not a git work tree — skipping push "
              "(local-only)." % target)
        return 0

    # C-3 scope guard: NEVER push the agentware package repo.
    top = git_toplevel(target)
    pkg_top = git_toplevel(REPO_ROOT)
    if top and pkg_top and top == pkg_top:
        sys.stderr.write(
            "kb-git push: refusing — target resolves to the agentware package "
            "repo (%s); sync is scoped to the KB repo only (C-3).\n" % top)
        return 1

    if not git_has_upstream(target):
        print("kb-git push: no upstream tracking branch — skipping push "
              "(local-only).")
        return 0

    mode = getattr(args, "on_prose_conflict", "abort")
    retries = getattr(args, "max_retries", 3) or 3
    rc, note = kb_git_push_synced(target, on_prose_conflict=mode,
                                  max_retries=retries)

    if rc == 3 and note.startswith("PROSE_CONFLICT"):
        # Paused on a same-entry prose conflict (Phase 5). Emit the conflicted
        # entry paths on stdout (one per line) so the loop can feed them to the
        # MERGE_PROMPT; the human note goes to stderr. The rebase is LEFT IN
        # PROGRESS — the loop reconciles, then runs `kb-git merge-continue`.
        files = [l for l in note.splitlines()[1:] if l.strip()]
        for f in files:
            print(f)
        sys.stderr.write(
            "kb-git push: prose conflict in %d entry file(s) — rebase left in "
            "progress; reconcile via the MERGE_PROMPT, then run "
            "`kb-git merge-continue`.\n" % len(files))
        return 3

    stream = sys.stdout if rc == 0 else sys.stderr
    stream.write("kb-git push: %s\n" % note)
    return rc


def kb_git_merge_continue(target):
    """Finish a prose-merge rebase after the agent reconciled the entry files.

    Phase 5 second half. Preconditions: a rebase is in progress (left by
    `kb-git push --on-prose-conflict pause`) and the conflicted ENTRY files have
    been reconciled in the work tree (both sides' facts retained, no conflict
    markers). Deterministic, C-1/C-2:

      1. Require a rebase in progress (else nothing to continue).
      2. Refuse if any reconciled entry file still carries conflict markers — the
         prose merge is incomplete (do NOT continue, do NOT abort: the partial
         work is preserved for another reconciliation pass).
      3. Stage the reconciled entry files, then UNCONDITIONALLY rebuild the
         DERIVED files (`index.json`, rosters, `FEATURES.md`) from the entry
         frontmatter union (`rebuild_kb`) — so even if the agent touched a derived
         file it is overwritten with the canonical regenerated content (C-1).
      4. `rebase --continue`, then push.

    Returns (rc, note). rc 0 == pushed; rc 1 == fail loud (the rebase is left in
    place for inspection, never silently aborted).
    """
    env = _git_noninteractive_env()
    if not git_rebase_in_progress(target):
        return 1, "no rebase in progress — nothing to continue"

    unmerged = git_unmerged_paths(target)
    entry_unmerged = [p for p in unmerged if not _is_derived_rel(p)]
    for rel in entry_unmerged:
        if file_has_conflict_markers(os.path.join(target, rel)):
            return 1, ("unresolved conflict markers remain in %s — prose merge "
                       "incomplete (not continuing; rebase left in place)" % rel)

    # Stage the agent-reconciled entry files (C-1: derived files are NEVER
    # hand-merged — they are regenerated below).
    if entry_unmerged:
        add = _git(target, "add", "--", *entry_unmerged)
        if add.returncode != 0:
            return 1, "git add (entry files) failed: %s" % add.stderr.strip()

    # Regenerate the DERIVED files from the reconciled entry union — never merged.
    data, _rosters, errors = rebuild_kb(target)
    if errors:
        return 1, "rebuild after prose merge failed: %s" % "; ".join(errors)

    add2 = _git(target, "add", "-A")
    if add2.returncode != 0:
        return 1, "git add (derived) failed: %s" % add2.stderr.strip()

    # Nothing-lost gate (C-2): the reconciled (mid-rebase) work tree must rebuild
    # to a valid index whose entry-ID set is a superset of BOTH parents. On
    # failure leave the rebase in place (never silently abort — the partial work
    # is preserved for another reconciliation pass) and fail loud BEFORE the push.
    ok, gnote = kb_nothing_lost_gate(target, ["ORIG_HEAD", "@{upstream}"])
    if not ok:
        return 1, gnote

    cont = _git(target, "rebase", "--continue", env=env)
    if cont.returncode != 0:
        first = (cont.stderr or "rebase --continue failed").strip().splitlines()
        return 1, "rebase --continue failed: %s" % (first[0] if first else "")

    push = git_push(target)
    if push.returncode == 0:
        return 0, "pushed (prose conflict reconciled; derived files rebuilt)"
    return 1, "push rejected after prose merge (re-push race)"


def cmd_kb_git_merge_continue(args):
    """Continue a paused prose-merge rebase, then push (feature 260625-kb-git-sync).

    Runs after the curated MERGE_PROMPT reconciled the conflicted entry markdown.
    Same scope guards as push: a non-repo target is a graceful no-op (C-4), and
    the agentware package repo is refused (C-3). The derived files are always
    rebuilt from frontmatter, never hand-merged (C-1).
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1

    # C-4: degrade to local-only (never block) when the KB is not a git repo.
    if not git_is_work_tree(target):
        print("kb-git merge-continue: %s is not a git work tree — nothing to "
              "continue (local-only)." % target)
        return 0

    # C-3 scope guard: NEVER operate on the agentware package repo.
    top = git_toplevel(target)
    pkg_top = git_toplevel(REPO_ROOT)
    if top and pkg_top and top == pkg_top:
        sys.stderr.write(
            "kb-git merge-continue: refusing — target resolves to the agentware "
            "package repo (%s); sync is scoped to the KB repo only (C-3).\n" % top)
        return 1

    rc, note = kb_git_merge_continue(target)
    stream = sys.stdout if rc == 0 else sys.stderr
    stream.write("kb-git merge-continue: %s\n" % note)
    return rc


# --- fanout: parallel-lane orchestration -------------------------------------
# (feature 260626-parallel-worktree-orchestration)
#
# `fanout` makes the parallel-lane workflow repeatable and SAFE. It is pure
# orchestration: it drives git + spawns the EXISTING loop + runs the EXISTING
# gates. It NEVER edits KB entry content and NEVER touches ranking/retrieval
# (the moat is untouched). Two isolations per lane:
#   * a package git worktree on feat/<f>  (code isolation), and
#   * an isolated KB git worktree on kb/<f>, with the loop pinned to it via
#     AGENTWARE_KNOWLEDGE_DIR (the env var that wins config precedence).
# No two lanes share a working tree or a KB. All lane STATE (the registry +
# per-lane env files + the worktrees) lives OUTSIDE both repos under
# ~/.agentware/fanout (override with AGENTWARE_FANOUT_DIR for hermetic tests),
# so neither repo's `git status` is ever perturbed. Stdlib-only (subprocess git);
# no new dependency.

FANOUT_FEATURE_RE = re.compile(r"^[A-Za-z0-9_-]+$")

# Append-only / derived KB files whose concurrent-lane conflicts resolve
# DETERMINISTICALLY (never by LLM): append-only files union-merge; derived files
# are regenerated by `index rebuild` after the merge. `fanout merge-policy`
# installs these as a `.gitattributes` merge=union policy in the KB repo.
FANOUT_MERGE_UNION_PATHS = (
    "benchmarks/history.jsonl",
    "benchmarks/SCORECARD.md",
    "index.json",
    "FEATURES.md",
    "**/index.md",
)
FANOUT_GITATTR_BEGIN = "# >>> agentware fanout merge-policy >>>"
FANOUT_GITATTR_END = "# <<< agentware fanout merge-policy <<<"

# Append-only ledgers (NOT derived — rebuild_kb does not regenerate them). On a
# concurrent-lane merge they conflict at EOF; the merge-queue resolves them
# deterministically by UNION (keep BOTH sides), independent of whether the
# merge=union `.gitattributes` policy happens to be installed/committed.
FANOUT_APPEND_ONLY_PATHS = ("benchmarks/history.jsonl", "benchmarks/SCORECARD.md")

# Default post-merge gates the merge-queue runs after EACH lane merge
# (R-PKG-04 steering lint + R-PKG-05 eval gate + the test suite). Each is a shell
# command run with cwd = the package integration repo and env
# AGENTWARE_KNOWLEDGE_DIR = the integration KB (so `eval --record` writes ledger
# rows into the INTEGRATION KB, never a lane KB). These are operator-default /
# operator-supplied (trusted) commands, so shell=True is acceptable here.
FANOUT_DEFAULT_GATES = (
    "scripts/agentware steering lint",
    "scripts/agentware eval --record --gate",
    "python3 -m unittest discover -s tests",
)


def _fanout_dir():
    """Base state dir for fanout (env-overridable for hermetic tests).

    Default: ~/.agentware/fanout (sibling of config.env). AGENTWARE_FANOUT_DIR
    overrides it so tests never touch the operator's real ~/.agentware state.
    """
    override = os.environ.get("AGENTWARE_FANOUT_DIR")
    if override and override.strip():
        return os.path.abspath(os.path.expanduser(override.strip()))
    return os.path.join(os.path.dirname(HOME_CONFIG), "fanout")


def _fanout_lanes_path():
    return os.path.join(_fanout_dir(), "lanes.json")


def load_lanes():
    """Load the fanout lane registry. Returns (data, error).

    A missing registry is the EMPTY registry (not an error). On success `data`
    is always `{"lanes": {<feature>: <record>}}`.
    """
    path = _fanout_lanes_path()
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except FileNotFoundError:
        return {"lanes": {}}, None
    except (OSError, json.JSONDecodeError) as exc:
        return None, "invalid fanout registry %s: %s" % (path, exc)
    if not isinstance(data, dict) or not isinstance(data.get("lanes"), dict):
        return None, ("malformed fanout registry %s (expected {\"lanes\": {...}})"
                      % path)
    return data, None


def save_lanes(data):
    """Persist the lane registry canonically (atomic, 2-space, sorted, newline)."""
    _atomic_write(
        _fanout_lanes_path(),
        json.dumps(data, indent=2, ensure_ascii=False, sort_keys=True) + "\n")


def _resolve_repo_arg(value, default):
    """Absolute path from an optional --repo/--kb-repo value, else the default."""
    if value:
        return os.path.abspath(os.path.expanduser(value))
    return default


def _fanout_lane_paths(feature, repo, kb_repo):
    """Deterministic per-lane branch names + worktree/env paths."""
    base = _fanout_dir()
    wt_root = os.path.join(base, "worktrees", feature)
    return {
        "feature": feature,
        "repo": repo,
        "kb_repo": kb_repo,
        "feat_branch": "feat/%s" % feature,
        "kb_branch": "kb/%s" % feature,
        "worktree": os.path.join(wt_root, "pkg"),
        "kb_path": os.path.join(wt_root, "kb"),
        "env_file": os.path.join(base, "env", "%s.env" % feature),
    }


def _branch_exists(repo, branch):
    """True iff a local branch ref exists in `repo`."""
    return _git(repo, "rev-parse", "--verify", "--quiet",
                "refs/heads/%s" % branch).returncode == 0


def _fanout_provision_lane(data, lane, base, kb_base, dry):
    """Create one lane's worktrees + env file + registry entry.

    Returns (action, error). action ∈ {created, exists, would-create}; on any
    failure error is a message and action is None. Idempotent and clobber-safe:
    an intact registered lane is a no-op; a pre-existing branch/worktree this
    command does not own is REFUSED rather than overwritten.
    """
    feature = lane["feature"]
    existing = data["lanes"].get(feature)

    # Idempotent: a registered lane whose worktrees still exist is a no-op
    # success — we never clobber/recreate it.
    if existing:
        if (os.path.isdir(existing.get("worktree", "")) and
                os.path.isdir(existing.get("kb_path", ""))):
            return "exists", None
        return None, ("lane already registered but its worktrees are missing; "
                      "run `fanout teardown %s --force` then re-run" % feature)

    repo, kb_repo = lane["repo"], lane["kb_repo"]
    # Clobber guard: refuse a branch/worktree this command did not register.
    for r, b in ((repo, lane["feat_branch"]), (kb_repo, lane["kb_branch"])):
        if _branch_exists(r, b):
            return None, ("branch %s already exists in %s (refusing to clobber)"
                          % (b, r))
    for p in (lane["worktree"], lane["kb_path"]):
        if os.path.exists(p):
            return None, "worktree path already exists: %s (refusing to clobber)" % p

    if dry:
        return "would-create", None

    # Package worktree on feat/<f>.
    cp = _git(repo, "worktree", "add", "-b", lane["feat_branch"],
              lane["worktree"], base)
    if cp.returncode != 0:
        return None, "git worktree add (package) failed: %s" % cp.stderr.strip()

    # KB worktree on kb/<f>. On failure roll back the package worktree so a
    # half-provisioned lane never lingers.
    cp = _git(kb_repo, "worktree", "add", "-b", lane["kb_branch"],
              lane["kb_path"], kb_base)
    if cp.returncode != 0:
        _git(repo, "worktree", "remove", "--force", lane["worktree"])
        _git(repo, "branch", "-D", lane["feat_branch"])
        return None, "git worktree add (KB) failed: %s" % cp.stderr.strip()

    # Per-lane env file pinning AGENTWARE_KNOWLEDGE_DIR to the KB worktree.
    env_text = (
        "# agentware fanout lane env — feature %s\n"
        "# `source` (or `--main-prompt`-pass) this before `./agentware.sh %s`\n"
        "# from the lane's package worktree to pin the isolated KB.\n"
        "AGENTWARE_KNOWLEDGE_DIR=%s\n"
        % (feature, feature, lane["kb_path"]))
    _atomic_write(lane["env_file"], env_text)

    data["lanes"][feature] = {
        "feature": feature,
        "feat_branch": lane["feat_branch"],
        "kb_branch": lane["kb_branch"],
        "worktree": lane["worktree"],
        "kb_path": lane["kb_path"],
        "env_file": lane["env_file"],
        "repo": repo,
        "kb_repo": kb_repo,
        "base": base,
        "merged": False,
    }
    save_lanes(data)
    return "created", None


def _fanout_gitattributes_block():
    """The managed merge=union block (delimited so it can be re-installed idempotently)."""
    lines = [FANOUT_GITATTR_BEGIN]
    lines += ["%s merge=union" % p for p in FANOUT_MERGE_UNION_PATHS]
    lines.append(FANOUT_GITATTR_END)
    return "\n".join(lines)


def _strip_managed_block(text):
    """Remove a prior managed merge-policy block, preserving all other lines."""
    if FANOUT_GITATTR_BEGIN not in text:
        return text
    out, skip = [], False
    for line in text.splitlines():
        if line.strip() == FANOUT_GITATTR_BEGIN:
            skip = True
            continue
        if line.strip() == FANOUT_GITATTR_END:
            skip = False
            continue
        if not skip:
            out.append(line)
    return "\n".join(out)


def _install_merge_policy(kb_repo):
    """Idempotently install the merge=union `.gitattributes` block. Returns (changed, error)."""
    if not git_is_work_tree(kb_repo):
        return False, "%s is not a git work tree" % kb_repo
    path = os.path.join(kb_repo, ".gitattributes")
    existing = ""
    if os.path.isfile(path):
        with open(path, encoding="utf-8") as f:
            existing = f.read()
    stripped = _strip_managed_block(existing)
    parts = []
    if stripped.strip():
        parts.append(stripped.rstrip("\n"))
    parts.append(_fanout_gitattributes_block())
    new_text = "\n".join(parts) + "\n"
    if new_text == existing:
        return False, None
    _atomic_write(path, new_text)
    return True, None


def cmd_fanout_merge_policy(args):
    """Install the idempotent merge=union `.gitattributes` into the KB repo.

    Append-only files (`benchmarks/history.jsonl`, `benchmarks/SCORECARD.md`) and
    derived files (`index.json`, `FEATURES.md`, `<sub>/index.md`) get
    `merge=union`, so concurrent-lane conflicts in them resolve DETERMINISTICALLY
    — never by LLM. Derived files are regenerated post-merge by `index rebuild`
    (the merge-queue), so a union'd-but-stale derived file is always overwritten
    with the canonical union from frontmatter. Idempotent; scoped to the KB repo.
    """
    fmt_json = getattr(args, "format", "text") == "json"
    kb_repo = _resolve_repo_arg(getattr(args, "kb", None),
                                resolve_knowledge_dir())
    if not kb_repo:
        sys.stderr.write("fanout merge-policy: no KB repo (pass --kb or set "
                         "AGENTWARE_KNOWLEDGE_DIR).\n")
        return 1
    changed, err = _install_merge_policy(kb_repo)
    if err:
        sys.stderr.write("fanout merge-policy: %s\n" % err)
        return 1
    path = os.path.join(kb_repo, ".gitattributes")
    if fmt_json:
        json.dump({"kb": kb_repo, "gitattributes": path, "changed": changed,
                   "patterns": list(FANOUT_MERGE_UNION_PATHS)},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("fanout merge-policy: %s %s"
              % ("installed" if changed else "already current", path))
    return 0


def _count_open_plan_markers(plan_path):
    """Count open (⬜/🟡) task markers in a plan.md via the canonical matcher."""
    try:
        with open(plan_path, encoding="utf-8") as f:
            return sum(1 for line in f if _PLAN_OPEN_MARKER_PY.match(line))
    except OSError:
        return None


def _lane_outcome(rec):
    """Read-only inference of a lane's loop outcome.

    The plan referenced a `derive_outcome` that does NOT exist in this codebase
    (R-FAIL-08), so this infers the outcome deterministically from the lane's
    isolated KB worktree — never mutating anything:

      merged      — already integrated by the merge-queue (registry flag).
      missing     — a worktree is gone.
      provisioned — lane exists but its plan.md has not been seeded yet.
      in_progress — open plan markers remain AND no `.loop/.done` sentinel.
      blocked     — finished but the worklog still has unpromoted markers
                    (zero-knowledge-loss not yet satisfied).
      completed   — finished and clean.
    """
    if rec.get("merged"):
        return "merged"
    kb_path = rec.get("kb_path", "")
    worktree = rec.get("worktree", "")
    if not (os.path.isdir(kb_path) and os.path.isdir(worktree)):
        return "missing"
    feature = rec.get("feature", "")
    work_dir = os.path.join(kb_path, "work", feature)
    open_n = _count_open_plan_markers(os.path.join(work_dir, "plan.md"))
    done = os.path.isfile(os.path.join(work_dir, ".loop", ".done"))
    if open_n is None and not done:
        return "provisioned"
    if not (done or open_n == 0):
        return "in_progress"
    # Finished — enforce the zero-knowledge-loss view if a worklog exists.
    worklog = os.path.join(work_dir, "worklog.md")
    if os.path.isfile(worklog):
        data, err = load_index(kb_path)
        if err is None:
            try:
                unpromoted, _total = scan_worklog(worklog, kb_path, data)
                if unpromoted:
                    return "blocked"
            except OSError:
                pass
    return "completed"


def cmd_fanout_list(args):
    """List active lanes with their branch, KB path, and inferred loop outcome."""
    fmt_json = getattr(args, "format", "text") == "json"
    data, err = load_lanes()
    if err:
        sys.stderr.write("fanout list: %s\n" % err)
        return 1
    lanes = []
    for feature in sorted(data["lanes"]):
        rec = data["lanes"][feature]
        lanes.append({
            "feature": feature,
            "feat_branch": rec.get("feat_branch"),
            "kb_branch": rec.get("kb_branch"),
            "kb_path": rec.get("kb_path"),
            "worktree": rec.get("worktree"),
            "merged": bool(rec.get("merged")),
            "outcome": _lane_outcome(rec),
        })
    if fmt_json:
        json.dump({"lanes": lanes}, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        if not lanes:
            print("fanout list: no active lanes.")
        else:
            for l in lanes:
                print("%-28s %-14s %-12s %s"
                      % (l["feature"], l["feat_branch"], l["outcome"],
                         l["kb_path"]))
    return 0


def _is_ancestor(repo, ancestor, descendant):
    """True iff `ancestor` is an ancestor of `descendant` (already-merged check)."""
    return _git(repo, "merge-base", "--is-ancestor",
                ancestor, descendant).returncode == 0


def _ensure_integration_branch(repo, branch, base):
    """Create `branch` from `base` (default HEAD) if absent. Returns (ok, error)."""
    if _branch_exists(repo, branch):
        return True, None
    base_ref = base or "HEAD"
    cp = _git(repo, "branch", branch, base_ref)
    if cp.returncode != 0:
        return False, ("could not create %s from %s in %s: %s"
                       % (branch, base_ref, repo, cp.stderr.strip()))
    return True, None


def _run_gate(cmd, repo, kb_repo):
    """Run one post-merge gate (shell) in `repo` with the integration KB pinned.

    Each gate is an operator-default / operator-supplied (trusted) command, so
    shell=True is acceptable here. AGENTWARE_KNOWLEDGE_DIR is pinned to the
    INTEGRATION KB so `eval --record` writes ledger rows THERE, never into a lane
    KB. Returns (rc, combined_output).
    """
    env = dict(os.environ)
    env["AGENTWARE_KNOWLEDGE_DIR"] = kb_repo
    env["GIT_TERMINAL_PROMPT"] = "0"
    try:
        cp = subprocess.run(cmd, shell=True, cwd=repo, env=env,
                            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                            text=True)
        return cp.returncode, cp.stdout or ""
    except Exception as exc:  # pragma: no cover - defensive
        return 1, str(exc)


def _merge_in_progress(repo):
    """True iff a merge is paused/in progress (MERGE_HEAD exists) in `repo`.

    Distinguishes a merge that STARTED then conflicted (MERGE_HEAD set) from one
    REFUSED before starting (e.g. a dirty work tree → no MERGE_HEAD), so the KB
    integrator never mistakes a refused merge for a clean one (silent-drop guard).
    """
    return _git(repo, "rev-parse", "-q", "--verify", "MERGE_HEAD").returncode == 0


def _union_resolve_conflict(path):
    """Resolve a conflicted append-only file by UNION — keep BOTH sides, drop the
    git conflict markers. The `=======` separator is dropped only INSIDE a conflict
    hunk, so a legitimate `=======` line in normal content is preserved."""
    try:
        with open(path, encoding="utf-8") as f:
            lines = f.readlines()
    except OSError:
        return False
    out, in_conflict = [], False
    for ln in lines:
        s = ln.rstrip("\r\n")
        if s.startswith("<<<<<<<"):
            in_conflict = True
            continue
        if in_conflict and s.startswith("======="):
            continue
        if s.startswith(">>>>>>>"):
            in_conflict = False
            continue
        out.append(ln)
    with open(path, "w", encoding="utf-8") as f:
        f.writelines(out)
    return True


def _lane_repo_args(rec, args, default_repo, default_kb):
    """Effective (repo, kb_repo) for ONE lane: explicit CLI flag wins, else the
    value stored in the lane record at spin-up, else the global default. Makes the
    registry authoritative so a non-default-repo lane works without re-passing the
    flags on every subcommand."""
    repo = _resolve_repo_arg(getattr(args, "repo", None),
                             rec.get("repo") or default_repo)
    kb_repo = _resolve_repo_arg(getattr(args, "kb_repo", None),
                                rec.get("kb_repo") or default_kb)
    return repo, kb_repo


def _lanes_common_repo(reg, order, key, fallback):
    """The single stored repo across the in-scope lanes for `key` (repo|kb_repo),
    or `fallback` when none is stored or they disagree. merge-queue integrates onto
    ONE repo, so a consistent stored value lets the operator omit --repo/--kb-repo."""
    vals = set()
    for f in order:
        v = reg["lanes"].get(f, {}).get(key)
        if v:
            vals.add(os.path.abspath(os.path.expanduser(v)))
    return vals.pop() if len(vals) == 1 else fallback


def _mq_integrate_package(repo, integration, feat_branch):
    """Serially integrate a lane's feat branch into the package integration branch.

    Implemented as a serial `merge --no-ff` INTO integration (NOT a rebase of the
    lane branch): feat/<f> is checked out in the lane's worktree and so cannot be
    rebased from the main repo, and a merge gives the IDENTICAL never-drop +
    halt-on-monolith-conflict semantics WITHOUT a blanket `-X ours/theirs` (the
    exact mode that silently drops a subcommand). Returns (status, detail);
    status ∈ {merged, skipped, conflict, error}. On conflict/error the in-progress
    merge is aborted so the repo is left CLEAN for the operator (R-EXEC-06 handoff).
    """
    if _is_ancestor(repo, feat_branch, integration):
        return "skipped", "already merged"
    co = _git(repo, "checkout", integration)
    if co.returncode != 0:
        return "error", "checkout %s failed: %s" % (integration, co.stderr.strip())
    env = _git_noninteractive_env()
    mg = _git(repo, "merge", "--no-ff", "--no-commit", feat_branch, env=env)
    unmerged = git_unmerged_paths(repo)
    if unmerged:
        _git(repo, "merge", "--abort")
        return "conflict", "conflict in: %s" % ", ".join(unmerged)
    if not _merge_in_progress(repo):
        # No MERGE_HEAD: either "Already up to date" (rc 0 — nothing to do) or a
        # merge REFUSED before it started (rc != 0, e.g. a dirty tree — fail loud).
        if mg.returncode == 0:
            return "skipped", "already up to date"
        return "error", (mg.stderr.strip() or mg.stdout.strip() or "merge refused")
    cm = _git(repo, "commit", "--no-edit",
              "-m", "fanout: integrate %s" % feat_branch, env=env)
    if cm.returncode != 0:
        _git(repo, "merge", "--abort")
        return "error", "commit failed: %s" % cm.stderr.strip()
    return "merged", "ok"


def _mq_integrate_kb(kb_repo, integration, kb_branch):
    """Integrate a lane's KB branch into the KB integration branch.

    Derived/append-only conflicts resolve DETERMINISTICALLY (the merge=union
    `.gitattributes` policy + `index rebuild`, which regenerates index.json /
    rosters / FEATURES.md from the frontmatter UNION — so a union'd-but-stale
    derived file is overwritten with the canonical union). A same-entry PROSE
    conflict (a NON-derived unmerged path) HALTS deterministically — it is
    reserved for the curated prose-merge path and is NEVER auto-resolved here.
    The nothing-lost ID-superset gate runs BEFORE the commit, so a lossy merge is
    rejected. Returns (status, detail); status ∈ {merged, skipped, prose-conflict,
    error}. On halt the in-progress merge is aborted (repo left clean).
    """
    if _is_ancestor(kb_repo, kb_branch, integration):
        return "skipped", "already merged"
    co = _git(kb_repo, "checkout", integration)
    if co.returncode != 0:
        return "error", "checkout %s failed: %s" % (integration, co.stderr.strip())
    parent_integration = _git(kb_repo, "rev-parse", "HEAD").stdout.strip()
    env = _git_noninteractive_env()
    mg = _git(kb_repo, "merge", "--no-ff", "--no-commit", kb_branch, env=env)
    if not _merge_in_progress(kb_repo):
        # No MERGE_HEAD: "Already up to date" (rc 0) OR a merge REFUSED before it
        # started (rc != 0, e.g. a dirty tree). NEVER fall through to commit — that
        # would record a non-merge as "merged" and SILENTLY DROP the lane's KB work.
        if mg.returncode == 0:
            return "skipped", "already up to date"
        _git(kb_repo, "merge", "--abort")
        return "error", (mg.stderr.strip() or mg.stdout.strip() or "merge refused")
    # Deterministically UNION the append-only ledgers (history.jsonl / SCORECARD.md),
    # independent of whether the merge=union `.gitattributes` policy was installed.
    for p in git_unmerged_paths(kb_repo):
        if p in FANOUT_APPEND_ONLY_PATHS:
            if _union_resolve_conflict(os.path.join(kb_repo, p)):
                _git(kb_repo, "add", "--", p)
    # Any remaining NON-derived unmerged path is a same-entry PROSE conflict — halt
    # for the curated prose-merge path (never auto-resolved here).
    non_derived = [p for p in git_unmerged_paths(kb_repo) if not _is_derived_rel(p)]
    if non_derived:
        _git(kb_repo, "merge", "--abort")
        return "prose-conflict", ("same-entry conflict in: %s "
                                  "(reserved for the curated prose-merge path)"
                                  % ", ".join(non_derived))
    data, _rosters, errors = rebuild_kb(kb_repo)
    if errors:
        _git(kb_repo, "merge", "--abort")
        return "error", "index rebuild failed: %s" % "; ".join(errors)
    ok, note = kb_nothing_lost_gate(kb_repo, [parent_integration, kb_branch])
    if not ok:
        _git(kb_repo, "merge", "--abort")
        return "error", note
    _git(kb_repo, "add", "-A")
    cm = _git(kb_repo, "commit", "--no-edit",
              "-m", "fanout: integrate %s" % kb_branch, env=env)
    if cm.returncode != 0:
        _git(kb_repo, "merge", "--abort")
        return "error", "commit failed: %s" % cm.stderr.strip()
    return "merged", note


def _mq_emit(results, fmt_json, halt, msg):
    """Render the merge-queue outcome and return the process exit code."""
    if fmt_json:
        json.dump({"halted": halt, "lanes": results}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        for r in results:
            print("fanout merge-queue: %-26s %-14s %s"
                  % (r["feature"], r["status"], r.get("detail", "")))
    if halt and msg:
        sys.stderr.write(msg + "\n")
    return 1 if halt else 0


def _teardown_blocker(rec, repo, kb_repo, integration, have_kb):
    """Return a refusal reason for an unmerged/dirty lane, else None."""
    for label, path in (("package worktree", rec.get("worktree", "")),
                        ("KB worktree", rec.get("kb_path", ""))):
        if os.path.isdir(path) and git_is_work_tree(path) and not git_is_clean(path):
            return "%s has uncommitted changes" % label
    if not _branch_exists(repo, integration):
        return ("integration branch '%s' does not exist (nothing merged yet)"
                % integration)
    if not _is_ancestor(repo, rec["feat_branch"], integration):
        return "%s is not merged into %s" % (rec["feat_branch"], integration)
    if have_kb and _branch_exists(kb_repo, integration):
        if not _is_ancestor(kb_repo, rec["kb_branch"], integration):
            return "%s is not merged into %s" % (rec["kb_branch"], integration)
    return None


def _remove_worktree(repo, path, force):
    """Remove a worktree (prune stale metadata if its dir is already gone)."""
    if not path or not os.path.exists(path):
        _git(repo, "worktree", "prune")
        return True, None
    cmd = ["worktree", "remove"]
    if force:
        cmd.append("--force")
    cmd.append(path)
    cp = _git(repo, *cmd)
    if cp.returncode != 0:
        return False, cp.stderr.strip()
    return True, None


def cmd_fanout_teardown(args):
    """Remove merged lanes' worktrees + branches; refuse unmerged/dirty lanes.

    Safety (R-GIT-02): without --force a lane is removed ONLY if it is fully merged
    into the integration branch AND its worktrees are clean; otherwise it is
    REFUSED deterministically (non-zero exit + message — an R-EXEC-06 operator
    handoff, never an interactive prompt). Worktrees are removed BEFORE their
    branches (a branch checked out by a live worktree cannot be deleted). NO
    `reset --hard` / force-push is ever run; `branch -D` runs only on a
    confirmed-merged lane (the safety gate proved no commits are lost) or under an
    explicit --force.
    """
    fmt_json = getattr(args, "format", "text") == "json"
    dry = getattr(args, "dry_run", False)
    force = getattr(args, "force", False)
    integration = getattr(args, "integration_branch", None) or "integration"

    reg, err = load_lanes()
    if err:
        sys.stderr.write("fanout teardown: %s\n" % err)
        return 1

    results, rc = [], 0
    for feature in args.features:
        rec = reg["lanes"].get(feature)
        if not rec:
            sys.stderr.write("fanout teardown: unknown lane: %s\n" % feature)
            rc = 1
            results.append({"feature": feature, "status": "error",
                            "detail": "unknown lane"})
            continue

        # Registry is authoritative for this lane's repos (recorded at spin-up);
        # --repo/--kb-repo override only when explicitly passed.
        repo, kb_repo = _lane_repo_args(rec, args, REPO_ROOT,
                                        resolve_knowledge_dir())
        have_kb = bool(kb_repo) and git_is_work_tree(kb_repo)

        if not force:
            reason = _teardown_blocker(rec, repo, kb_repo, integration, have_kb)
            if reason:
                sys.stderr.write("fanout teardown: refusing %s — %s "
                                 "(use --force to override).\n"
                                 % (feature, reason))
                rc = 1
                results.append({"feature": feature, "status": "refused",
                                "detail": reason})
                continue

        if dry:
            results.append({"feature": feature, "status": "would-remove"})
            continue

        ok, derr = _remove_worktree(repo, rec.get("worktree"), force)
        if not ok:
            sys.stderr.write("fanout teardown: %s: package worktree remove "
                             "failed: %s\n" % (feature, derr))
            rc = 1
            results.append({"feature": feature, "status": "error", "detail": derr})
            continue
        if have_kb:
            ok, derr = _remove_worktree(kb_repo, rec.get("kb_path"), force)
            if not ok:
                sys.stderr.write("fanout teardown: %s: KB worktree remove "
                                 "failed: %s\n" % (feature, derr))
                rc = 1
                results.append({"feature": feature, "status": "error",
                                "detail": derr})
                continue

        # Worktrees gone -> the branches are free to delete.
        _git(repo, "branch", "-D", rec["feat_branch"])
        if have_kb:
            _git(kb_repo, "branch", "-D", rec["kb_branch"])

        try:
            os.remove(rec.get("env_file", ""))
        except OSError:
            pass
        del reg["lanes"][feature]
        save_lanes(reg)
        results.append({"feature": feature, "status": "removed"})

    if fmt_json:
        json.dump({"dry_run": dry, "lanes": results}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        for r in results:
            if r["status"] in ("error", "refused"):
                continue
            print("fanout teardown: %s %s" % (r["feature"], r["status"]))
    return rc


def cmd_fanout_merge_queue(args):
    """Serially integrate finished lanes onto an `integration` branch, gated.

    The monolith (`scripts/agentware`) is the serial chokepoint, embraced: lanes
    integrate ONE AT A TIME; on a package conflict the queue HALTS deterministically
    (non-zero + an actionable message naming the lane/branch/region) rather than a
    blanket `-X` that silently drops a feature. After EACH lane's package + KB
    merges succeed it runs the gates (steering lint + eval --record --gate + the
    test suite, by default) against the integration tree; any gate FAIL halts the
    queue. Resumable: already-merged lanes are skipped on re-run.
    """
    fmt_json = getattr(args, "format", "text") == "json"
    dry = getattr(args, "dry_run", False)
    integration = getattr(args, "integration_branch", None) or "integration"
    base = getattr(args, "base", None)
    kb_base = getattr(args, "kb_base", None)
    no_gates = getattr(args, "no_gates", False)
    gates = ([] if no_gates
             else list(getattr(args, "gate", None) or []) or list(FANOUT_DEFAULT_GATES))

    reg, err = load_lanes()
    if err:
        sys.stderr.write("fanout merge-queue: %s\n" % err)
        return 1

    requested = list(getattr(args, "features", None) or [])
    order = requested or sorted(reg["lanes"])
    missing = [f for f in order if f not in reg["lanes"]]
    if missing:
        sys.stderr.write("fanout merge-queue: unknown lane(s): %s\n"
                         % ", ".join(missing))
        return 1

    # Registry is authoritative: prefer the lanes' stored repo/kb_repo (recorded at
    # spin-up) over the global default, unless --repo/--kb-repo explicitly override.
    repo = _resolve_repo_arg(getattr(args, "repo", None),
                             _lanes_common_repo(reg, order, "repo", REPO_ROOT))
    kb_repo = _resolve_repo_arg(getattr(args, "kb_repo", None),
                                _lanes_common_repo(reg, order, "kb_repo",
                                                   resolve_knowledge_dir()))
    if not git_is_work_tree(repo):
        sys.stderr.write("fanout merge-queue: package repo is not a git work "
                         "tree: %s\n" % repo)
        return 1
    have_kb = bool(kb_repo) and git_is_work_tree(kb_repo)

    if dry:
        plan = [{"feature": f, "outcome": _lane_outcome(reg["lanes"][f])}
                for f in order]
        if fmt_json:
            json.dump({"dry_run": True, "integration": integration,
                       "lanes": plan, "gates": gates},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("fanout merge-queue [dry-run]: integration=%s" % integration)
            for p in plan:
                print("  %s (%s)" % (p["feature"], p["outcome"]))
            for g in gates:
                print("  gate: %s" % g)
        return 0

    ok, ierr = _ensure_integration_branch(repo, integration, base)
    if not ok:
        sys.stderr.write("fanout merge-queue: %s\n" % ierr)
        return 1
    if have_kb:
        ok, ierr = _ensure_integration_branch(kb_repo, integration, kb_base)
        if not ok:
            sys.stderr.write("fanout merge-queue: %s\n" % ierr)
            return 1

    results = []
    for feature in order:
        rec = reg["lanes"][feature]
        # Skip ONLY fully-integrated lanes (package + KB + gates all passed in a
        # prior run). Do NOT short-circuit on package ancestry alone — a lane whose
        # package merged but whose KB/gate step halted must be RE-processable; the
        # per-step _is_ancestor guards make the package step an idempotent no-op on
        # resume while the KB step retries and the gates re-run.
        if rec.get("merged"):
            results.append({"feature": feature, "status": "skipped",
                            "detail": "already merged"})
            continue
        outcome = _lane_outcome(rec)
        if outcome != "completed":
            results.append({"feature": feature, "status": "skipped",
                            "detail": "not finished (outcome=%s)" % outcome})
            continue

        # 1) Package monolith — the serial chokepoint.
        pstatus, pdetail = _mq_integrate_package(repo, integration,
                                                 rec["feat_branch"])
        if pstatus in ("conflict", "error"):
            results.append({"feature": feature, "status": "halt-package",
                            "detail": pdetail})
            return _mq_emit(
                results, fmt_json, True,
                "fanout merge-queue HALTED on lane '%s' — package merge %s "
                "(%s).\nResolve the monolith conflict by hand and re-run; the "
                "queue skips already-merged lanes. (NO blanket -X ours/theirs — "
                "that silently drops a subcommand.)" % (feature, pstatus, pdetail))

        # 2) KB — deterministic derived merge + nothing-lost gate.
        if have_kb:
            kstatus, kdetail = _mq_integrate_kb(kb_repo, integration,
                                                rec["kb_branch"])
            if kstatus in ("prose-conflict", "error"):
                results.append({"feature": feature, "status": "halt-kb",
                                "detail": kdetail})
                return _mq_emit(
                    results, fmt_json, True,
                    "fanout merge-queue HALTED on lane '%s' — KB merge %s (%s)."
                    % (feature, kstatus, kdetail))

        # 3) Package gates (R-PKG-04/05 + the test suite) on the integrated tree.
        gate_fail = None
        for g in gates:
            rc, output = _run_gate(g, repo, kb_repo if have_kb else repo)
            if rc != 0:
                gate_fail = (g, rc, output)
                break
        if gate_fail:
            g, grc, output = gate_fail
            tail = "\n".join(output.strip().splitlines()[-8:])
            results.append({"feature": feature, "status": "halt-gate",
                            "detail": "gate %r exited %d" % (g, grc)})
            return _mq_emit(
                results, fmt_json, True,
                "fanout merge-queue HALTED after merging lane '%s' — gate "
                "FAILED:\n  $ %s\n  (exit %d)\n%s\nFix and re-run; already-merged "
                "lanes are skipped." % (feature, g, grc, tail))

        # A gate (e.g. `eval --record`) may have written ledger rows into the
        # integration KB, leaving its tree dirty. Commit those artifacts now so the
        # NEXT lane merges onto a CLEAN tree — a dirty tree would otherwise refuse
        # the next merge (which the silent-drop guard turns into a halt) and the
        # final lane's rows would never be committed.
        if have_kb and git_is_work_tree(kb_repo) and not git_is_clean(kb_repo):
            _git(kb_repo, "add", "-A")
            _git(kb_repo, "commit", "--no-edit",
                 "-m", "fanout: gate artifacts for %s" % feature,
                 env=_git_noninteractive_env())

        rec["merged"] = True
        save_lanes(reg)
        results.append({"feature": feature, "status": "merged", "detail": "ok"})

    return _mq_emit(results, fmt_json, False, None)


def cmd_fanout_spin_up(args):
    """Provision one or more isolated lanes (package + KB worktrees + env file).

    Per feature: a package git worktree on feat/<f> off --base, an isolated KB
    git worktree on kb/<f> off --kb-base, and a per-lane env file pinning
    AGENTWARE_KNOWLEDGE_DIR to the KB worktree. Idempotent (an intact existing
    lane is a no-op), refuses to clobber a branch/worktree it does not own, and
    --dry-run prints the plan and writes nothing.
    """
    fmt_json = getattr(args, "format", "text") == "json"
    dry = getattr(args, "dry_run", False)

    repo = _resolve_repo_arg(getattr(args, "repo", None), REPO_ROOT)
    kb_repo = _resolve_repo_arg(getattr(args, "kb_repo", None),
                                resolve_knowledge_dir())
    if not kb_repo:
        sys.stderr.write("fanout spin-up: no KB repo (pass --kb-repo or set "
                         "AGENTWARE_KNOWLEDGE_DIR).\n")
        return 1
    base = getattr(args, "base", None) or "HEAD"
    kb_base = getattr(args, "kb_base", None) or base

    for label, path in (("package", repo), ("KB", kb_repo)):
        if not git_is_work_tree(path):
            sys.stderr.write("fanout spin-up: %s repo is not a git work tree: "
                             "%s\n" % (label, path))
            return 1

    data, err = load_lanes()
    if err:
        sys.stderr.write("fanout spin-up: %s\n" % err)
        return 1

    results, rc = [], 0
    for feature in args.features:
        if not FANOUT_FEATURE_RE.match(feature):
            sys.stderr.write("fanout spin-up: invalid feature name %r "
                             "(allowed: [A-Za-z0-9_-]).\n" % feature)
            rc = 1
            continue
        lane = _fanout_lane_paths(feature, repo, kb_repo)
        action, lerr = _fanout_provision_lane(data, lane, base, kb_base, dry)
        if lerr:
            sys.stderr.write("fanout spin-up: %s: %s\n" % (feature, lerr))
            rc = 1
            results.append({"feature": feature, "action": "error", "error": lerr})
            continue
        results.append({
            "feature": feature, "action": action,
            "feat_branch": lane["feat_branch"], "kb_branch": lane["kb_branch"],
            "worktree": lane["worktree"], "kb_path": lane["kb_path"],
            "env_file": lane["env_file"],
        })

    if fmt_json:
        json.dump({"dry_run": dry, "lanes": results}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        for r in results:
            if r["action"] == "error":
                continue
            tag = "[dry-run] would create" if dry else r["action"]
            print("fanout spin-up: %s %s" % (r["feature"], tag))
            print("  feat worktree: %s (%s)" % (r["worktree"], r["feat_branch"]))
            print("  kb   worktree: %s (%s)" % (r["kb_path"], r["kb_branch"]))
            print("  env file:      %s" % r["env_file"])
    return rc


# --- Parser construction -----------------------------------------------------
# --- MCP server (read-only Model Context Protocol over the KB, stdio) --------
# A stdlib-only (`json` + `sys`) JSON-RPC 2.0 server speaking the MCP STDIO
# transport: newline-delimited JSON-RPC messages on stdin/stdout (no HTTP, no
# socket, no Content-Length framing — that's the HTTP/SSE transport, which is a
# future, separately-subprocess'd tier; see the plan's non-goals). The server is
# READ-ONLY by construction: it exposes exactly two tools — `recall` and `query`
# — that delegate to the existing read functions (`build_recall_payload` /
# `cmd_query`'s lookup). NO write tool is registered, so the CLI stays the sole
# writer of the index (R-KB-01) and an untrusted client cannot mutate the KB
# (INV-2). Tool-call arguments are untrusted input and are validated (R-SEC-02).
# Because stdio needs no network module, `test_cli_imports_no_network_modules`
# and `test_cli_imports_are_stdlib_only` stay green by construction.

# Pinned MCP protocol version (the widely-supported stable revision). We echo a
# client's requested version when we support it, else degrade to ours.
MCP_PROTOCOL_VERSION = "2024-11-05"
MCP_SUPPORTED_PROTOCOL_VERSIONS = ("2024-11-05", "2025-03-26", "2025-06-18")
MCP_SERVER_NAME = "agentware-kb"
MCP_SERVER_VERSION = "0.1.0"

# Read-only tools exposed over MCP. Schemas MIRROR the `recall`/`query` argparse
# definitions (same names/defaults/enum) so behavior is identical across surfaces.
MCP_RECALL_STRATEGIES = ("bm25", "bm25+acr")
MCP_QUERY_SELECTORS = ("id", "path", "tag", "category")


class _McpInvalidParams(Exception):
    """Raised by a tool when its (untrusted) arguments fail validation -> -32602."""


def _mcp_envelope(req_id, body):
    """Wrap a JSON-RPC 2.0 response, echoing the request id (never generated)."""
    resp = {"jsonrpc": "2.0", "id": req_id}
    resp.update(body)
    return resp


def _mcp_result(req_id, result):
    return _mcp_envelope(req_id, {"result": result})


def _mcp_error(req_id, code, message):
    return _mcp_envelope(req_id, {"error": {"code": code, "message": message}})


def _mcp_tool_definitions():
    """The two read-only tool descriptors with JSON Schemas mirroring the CLI."""
    return [
        {
            "name": "recall",
            "description": (
                "Read-only deterministic BM25 ranked retrieval over the knowledge "
                "base, token-budgeted. Byte-identical to `agentware recall "
                "--format json`. Never mutates the KB."),
            "inputSchema": {
                "type": "object",
                "properties": {
                    "query": {
                        "type": "string",
                        "description": "free-text query to rank KB entries against",
                    },
                    "top_k": {
                        "type": "integer", "minimum": 0, "default": 5,
                        "description": "max entries to return before budgeting",
                    },
                    "token_budget": {
                        "type": "integer", "minimum": 0, "default": 1500,
                        "description": "trim so cumulative est. tokens <= budget",
                    },
                    "category": {
                        "type": "string",
                        "description": "restrict ranking to a single category",
                    },
                    "strategy": {
                        "type": "string", "enum": list(MCP_RECALL_STRATEGIES),
                        "description": "ranking strategy (default: the gated default)",
                    },
                    "as_of": {
                        "type": "string",
                        "description": "YYYY-MM-DD date for ACR freshness decay "
                                       "(default: today; PIN it for reproducible runs)",
                    },
                },
                "required": ["query"],
                "additionalProperties": False,
            },
        },
        {
            "name": "query",
            "description": (
                "Read-only lookup of KB entries by exactly one of id/path/tag/"
                "category. Same records as `agentware query`. Never mutates the KB."),
            "inputSchema": {
                "type": "object",
                "properties": {
                    "id": {"type": "string", "description": "look up a single entry by id"},
                    "path": {"type": "string", "description": "look up a single entry by path"},
                    "tag": {"type": "string", "description": "list all entries carrying a tag"},
                    "category": {"type": "string", "description": "list all entries in a category"},
                },
                "additionalProperties": False,
            },
        },
    ]


def _mcp_require_int(arguments, key, default):
    val = arguments.get(key, default)
    # JSON booleans parse to Python bool (an int subclass) — reject explicitly.
    if isinstance(val, bool) or not isinstance(val, int):
        raise _McpInvalidParams("%r must be an integer" % key)
    if val < 0:
        raise _McpInvalidParams("%r must be >= 0" % key)
    return val


def _mcp_require_str(arguments, key, default=None):
    val = arguments.get(key, default)
    if val is None:
        return None
    if not isinstance(val, str):
        raise _McpInvalidParams("%r must be a string" % key)
    return val


def _mcp_tool_recall(kdir, data, arguments):
    """Validate untrusted args, then build the canonical recall payload (read-only)."""
    query = arguments.get("query")
    if not isinstance(query, str):
        raise _McpInvalidParams("'query' is required and must be a string")
    top_k = _mcp_require_int(arguments, "top_k", 5)
    token_budget = _mcp_require_int(arguments, "token_budget", 1500)
    category = _mcp_require_str(arguments, "category")
    strategy = _mcp_require_str(arguments, "strategy")
    if strategy is not None and strategy not in MCP_RECALL_STRATEGIES:
        raise _McpInvalidParams(
            "'strategy' must be one of %s" % (list(MCP_RECALL_STRATEGIES),))
    as_of = _mcp_require_str(arguments, "as_of")
    if as_of is not None and not _is_valid_date(as_of):
        raise _McpInvalidParams("'as_of' must be a YYYY-MM-DD date")
    payload, _notice = build_recall_payload(
        kdir, data, query, top_k=top_k, token_budget=token_budget,
        category=category, strategy=strategy, as_of=as_of)
    return json.dumps(payload, ensure_ascii=False, indent=2)


def _mcp_query_lookup(data, selector, value):
    """Replicate cmd_query's id/path/tag/category dispatch (read-only). Returns list."""
    entries = data.get("entries") or []
    tags_map = data.get("tags") or {}
    by_id, by_path = {}, {}
    for e in entries:
        if not isinstance(e, dict):
            continue
        eid = e.get("id")
        if eid is not None and eid not in by_id:
            by_id[eid] = e
        path = e.get("path")
        if path is not None and path not in by_path:
            by_path[path] = e
    results = []
    if selector == "id":
        hit = by_id.get(value)
        if hit is not None:
            results = [hit]
    elif selector == "path":
        hit = by_path.get(value)
        if hit is not None:
            results = [hit]
    elif selector == "tag":
        for eid in tags_map.get(value, []):
            hit = by_id.get(eid)
            if hit is not None:
                results.append(hit)
    elif selector == "category":
        results = [e for e in entries
                   if isinstance(e, dict) and e.get("category") == value]
    return results


def _mcp_tool_query(kdir, data, arguments):
    """Validate untrusted args: exactly one selector, then dispatch (read-only)."""
    present = [(k, arguments[k]) for k in MCP_QUERY_SELECTORS if k in arguments]
    if len(present) != 1:
        raise _McpInvalidParams(
            "exactly one of %s must be provided" % (list(MCP_QUERY_SELECTORS),))
    selector, value = present[0]
    if not isinstance(value, str):
        raise _McpInvalidParams("%r must be a string" % selector)
    results = _mcp_query_lookup(data, selector, value)
    return json.dumps(results, ensure_ascii=False, indent=2)


def _mcp_handle_tools_call(req_id, params, kdir, data):
    if not isinstance(params, dict):
        return _mcp_error(req_id, -32602, "params must be an object")
    name = params.get("name")
    arguments = params.get("arguments")
    if arguments is None:
        arguments = {}
    if not isinstance(arguments, dict):
        return _mcp_error(req_id, -32602, "tool arguments must be an object")
    try:
        if name == "recall":
            text = _mcp_tool_recall(kdir, data, arguments)
        elif name == "query":
            text = _mcp_tool_query(kdir, data, arguments)
        else:
            return _mcp_error(req_id, -32602, "unknown tool: %r" % (name,))
    except _McpInvalidParams as e:
        return _mcp_error(req_id, -32602, str(e))
    except Exception as e:  # a tool blew up -> structured error, server stays alive
        return _mcp_error(req_id, -32603, "tool execution error: %s" % e)
    return _mcp_result(req_id, {
        "content": [{"type": "text", "text": text}],
        "isError": False,
    })


def _mcp_initialize(params):
    requested = None
    if isinstance(params, dict):
        requested = params.get("protocolVersion")
    version = requested if requested in MCP_SUPPORTED_PROTOCOL_VERSIONS \
        else MCP_PROTOCOL_VERSION
    return {
        "protocolVersion": version,
        "serverInfo": {"name": MCP_SERVER_NAME, "version": MCP_SERVER_VERSION},
        "capabilities": {"tools": {}},
    }


def handle_mcp_request(req, kdir, data):
    """Handle ONE parsed JSON-RPC request dict. Returns a response dict, or None
    for notifications (no `id`). Read-only over (kdir, data). Pure given inputs —
    request ids are echoed, never generated (no RNG)."""
    if not isinstance(req, dict):
        return _mcp_error(None, -32600, "invalid request: not a JSON object")
    is_notification = "id" not in req
    req_id = req.get("id")
    method = req.get("method")
    if not isinstance(method, str):
        if is_notification:
            return None
        return _mcp_error(req_id, -32600, "invalid request: missing method")
    # Notifications (incl. notifications/initialized) get no response.
    if is_notification or method.startswith("notifications/"):
        return None
    if method == "initialize":
        return _mcp_result(req_id, _mcp_initialize(req.get("params") or {}))
    if method == "tools/list":
        return _mcp_result(req_id, {"tools": _mcp_tool_definitions()})
    if method == "tools/call":
        return _mcp_handle_tools_call(req_id, req.get("params") or {}, kdir, data)
    return _mcp_error(req_id, -32601, "method not found: %s" % method)


def cmd_mcp(args):
    """Serve the read-only KB over MCP stdio (JSON-RPC 2.0, newline-delimited).

    Reads one JSON-RPC message per stdin line, writes one response line per
    non-notification. Malformed JSON -> a parse-error (-32700) envelope with a
    null id. Exits 0 cleanly on stdin EOF (no hang). Read-only: the index is
    loaded ONCE at startup and never written (INV-2).
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1
    out = sys.stdout
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            req = json.loads(line)
        except (ValueError, TypeError):
            resp = _mcp_error(None, -32700, "parse error")
            out.write(json.dumps(resp, ensure_ascii=False) + "\n")
            out.flush()
            continue
        resp = handle_mcp_request(req, kdir, data)
        if resp is not None:
            out.write(json.dumps(resp, ensure_ascii=False) + "\n")
            out.flush()
    return 0


# --- Dream mode (feature 260627-dream-mode, Phase 1) --------------------------
# A scheduled, idle-gated, unattended DETERMINISTIC maintenance cycle ("a dream")
# that moves all size-scaling KB maintenance OFF the interactive hot path. It
# ORCHESTRATES the already-sanctioned writers ONLY (index rebuild / bench redact /
# eval --record / kb-git commit) and adds NO new maintenance logic. stdlib-only,
# non-interactive, default OFF. NO LLM, NO destructive deletes/merges, NO
# auto-promotion (those are Phase 2, behind a future review queue).

# Lockfile + journal live under KB paths ALREADY gitignored by _ensure_kb_gitignore
# (.cache/, logs/), so the git-sync step never stages them. The journal is run-
# state (machine-local), NOT durable knowledge — durable reliability history is
# the tracked eval ledger (benchmarks/history.jsonl). See the Task-8 `> DECISION:`.
DREAM_LOCK_REL = os.path.join(".cache", "dream.lock")
DREAM_JOURNAL_REL = os.path.join("logs", "dream-journal.md")
DREAM_LOCK_TTL_S = 3600          # a held lock older than this is reclaimable (stale)
DREAM_SESSION_TTL_S = 1800       # a .loop whose liveness file is fresher = active
DREAM_LOAD_RATIO = 4.0           # skip when 1-min loadavg > ratio * cpu_count
DREAM_NICE = 10                  # run the cycle at low priority (never compete)
DREAM_STALE_HOURS = 48           # dream_health warns when last dream older than this

# Ordered, fixed cycle (each step idempotent + individually skippable via --steps).
DREAM_STEP_FUNCS = ()  # populated below once the step fns are defined


def dream_active_sessions(kdir, now=None):
    """Return sorted feature names with a LIVE agentware loop session.

    Loop state is PER-FEATURE: agentware.sh keeps `work/<feature>/.loop` with a
    `.done` sentinel + a `live-stream.log` it touches each tool call. A feature is
    LIVE when its `.loop` exists, `.done` is ABSENT, and a liveness file
    (live-stream.log, else .iteration) was modified within DREAM_SESSION_TTL_S.
    Read-only; `now` is overridable for deterministic tests.
    """
    now = now if now is not None else time.time()
    live = []
    work = os.path.join(kdir, "work")
    if not os.path.isdir(work):
        return live
    try:
        feats = sorted(os.listdir(work))
    except OSError:
        return live
    for feat in feats:
        loop = os.path.join(work, feat, ".loop")
        if not os.path.isdir(loop):
            continue
        if os.path.exists(os.path.join(loop, ".done")):
            continue
        mtime = None
        for name in ("live-stream.log", ".iteration"):
            try:
                mtime = os.path.getmtime(os.path.join(loop, name))
                break
            except OSError:
                continue
        if mtime is not None and (now - mtime) <= DREAM_SESSION_TTL_S:
            live.append(feat)
    return live


def is_session_active(kdir, now=None):
    """True iff any agentware loop session is currently live (idle-gate signal)."""
    return bool(dream_active_sessions(kdir, now=now))


def _dream_lock_path(kdir):
    return os.path.join(kdir, DREAM_LOCK_REL)


def _dream_read_lock(path):
    """Parse the dream lockfile into a dict, or None if absent/unreadable."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            rec = json.load(f)
        return rec if isinstance(rec, dict) else None
    except (OSError, ValueError):
        return None


def _dream_pid_alive(pid):
    """True iff `pid` is a live process on this host (signal-0 probe, stdlib)."""
    if not isinstance(pid, int) or pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True   # exists but owned by another user
    except OSError:
        return False
    return True


def dream_lock_is_stale(rec, now=None, ttl=DREAM_LOCK_TTL_S):
    """A lock is STALE (reclaimable) when its pid is dead OR its mtime is older
    than `ttl`. Pure given `rec`; `now` overridable for tests."""
    now = now if now is not None else time.time()
    if not isinstance(rec, dict):
        return True
    if not _dream_pid_alive(rec.get("pid")):
        return True
    ts = rec.get("mtime")
    if not isinstance(ts, (int, float)) or (now - ts) > ttl:
        return True
    return False


def dream_acquire_lock(kdir, now=None, ttl=DREAM_LOCK_TTL_S):
    """Acquire the single-writer dream lock under .cache/ (gitignored).

    Returns (True, path) on success, or (False, reason) when a FRESH lock is held.
    Reclaims a STALE lock (dead pid / expired mtime). Reads the existing lock
    BEFORE writing anything, so a held-lock refusal mutates NOTHING.
    """
    now = now if now is not None else time.time()
    path = _dream_lock_path(kdir)
    existing = _dream_read_lock(path)
    if existing is not None and not dream_lock_is_stale(existing, now=now, ttl=ttl):
        return False, "held by pid %s since %s" % (
            existing.get("pid"), existing.get("mtime"))
    rec = {"pid": os.getpid(), "mtime": now}
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        _ensure_kb_gitignore(kdir)
        with open(path, "w", encoding="utf-8") as f:
            json.dump(rec, f, sort_keys=True)
    except OSError as exc:
        return False, "could not write lockfile: %s" % exc
    return True, path


def dream_release_lock(kdir):
    """Release the dream lock IFF this process owns it (best-effort)."""
    path = _dream_lock_path(kdir)
    rec = _dream_read_lock(path)
    if rec is not None and rec.get("pid") == os.getpid():
        try:
            os.remove(path)
        except OSError:
            pass


def dream_load_skip_reason(load1, ncpu, ratio=DREAM_LOAD_RATIO):
    """SKIP reason string when 1-min loadavg exceeds ratio*ncpu, else None. Pure."""
    if load1 is None or not ncpu:
        return None
    ceiling = ratio * ncpu
    if load1 > ceiling:
        return ("system load high (loadavg1=%.2f > %.2f = %.1f*%d cpu)"
                % (load1, ceiling, ratio, ncpu))
    return None


def dream_idle_skip_reason(kdir, force=False, now=None, load1=None, ncpu=None):
    """Idle-gate decision: a SKIP reason string, or None to proceed.

    With `force=True` the idle signals are bypassed (the concurrency lock still
    applies elsewhere). Pure-ish: `now`/`load1`/`ncpu` are injectable so the gate
    is testable without real processes/load.
    """
    if force:
        return None
    active = dream_active_sessions(kdir, now=now)
    if active:
        return "agentware loop session active: %s" % ", ".join(active)
    if load1 is None:
        try:
            load1 = os.getloadavg()[0]
        except (OSError, AttributeError):
            load1 = None
    if ncpu is None:
        ncpu = os.cpu_count() or 1
    return dream_load_skip_reason(load1, ncpu)


def _dream_perf():
    return time.perf_counter()


def _dream_file_fp(path):
    """sha256 of a file's bytes, or None if absent. For cache-delta detection."""
    import hashlib  # stdlib, lazy
    try:
        with open(path, "rb") as f:
            return hashlib.sha256(f.read()).hexdigest()
    except OSError:
        return None


def _dream_capture(fn, *a, **k):
    """Call `fn` with stdout/stderr captured; return (rc, stdout_text)."""
    import io          # stdlib, lazy
    import contextlib  # stdlib, lazy
    buf, errbuf = io.StringIO(), io.StringIO()
    with contextlib.redirect_stdout(buf), contextlib.redirect_stderr(errbuf):
        rc = fn(*a, **k)
    return rc, buf.getvalue()


def _dream_step_index_rebuild(kdir, dry_run):
    """Step a — refresh derived caches via rebuild_kb (the SOLE cache writer)."""
    if dry_run:
        return {"status": "planned",
                "would": "index rebuild (index.json + rosters + FEATURES + BM25 cache)"}
    idx, bm = os.path.join(kdir, INDEX_REL), os.path.join(kdir, BM25_CACHE_REL)
    before = (_dream_file_fp(idx), _dream_file_fp(bm))
    data, rosters, errors = rebuild_kb(kdir)
    if errors:
        return {"status": "error", "errors": errors}
    after = (_dream_file_fp(idx), _dream_file_fp(bm))
    return {"status": "ok", "entries": len(data["entries"]),
            "rosters": len(rosters),
            "index_changed": before[0] != after[0],
            "bm25_changed": before[1] != after[1]}


def _dream_step_bench_redact(kdir, dry_run):
    """Step b — scrub operator HOME from the ledger gold_path (only mutation)."""
    ledger = os.path.join(kdir, HISTORY_REL)
    if dry_run:
        return {"status": "planned", "would": "bench redact (scrub gold_path)"}
    if not os.path.isfile(ledger):
        return {"status": "skipped", "reason": "no ledger"}
    before = _dream_file_fp(ledger)
    total, changed = redact_ledger_gold_paths(ledger)
    try:
        rows = _read_ledger(ledger)
        scorecard = os.path.join(os.path.dirname(ledger),
                                 os.path.basename(SCORECARD_REL))
        with open(scorecard, "w", encoding="utf-8") as f:
            f.write(render_scorecard(rows))
    except OSError:
        pass
    return {"status": "ok", "rows": total, "scrubbed": changed,
            "ledger_changed": before != _dream_file_fp(ledger)}


def _dream_step_audit(kdir, dry_run):
    """Step c — health check. Mirrors `audit --with-tests`; the suite-shell is
    skipped under the nested-unittest guard so the cycle never recurses."""
    with_tests = os.environ.get("AGENTWARE_NESTED_UNITTEST") != "1"
    if dry_run:
        return {"status": "planned",
                "would": "audit%s" % (" --with-tests" if with_tests else "")}
    ns = argparse.Namespace(format="json", with_tests=with_tests, stale=False,
                            max_age_days=120)
    rc, out = _dream_capture(cmd_audit, ns)
    failed = []
    try:
        payload = json.loads(out)
        failed = sorted(c["name"] for c in payload.get("checks", [])
                        if not c.get("ok"))
    except ValueError:
        pass
    return {"status": "ok" if rc == 0 else "fail", "audit_ok": rc == 0,
            "with_tests": with_tests, "failed_checks": ",".join(failed) or "-"}


def _dream_step_eval_record(kdir, dry_run):
    """Step d — append ONE reliability row (eval --record), then redact it."""
    gold = os.path.join(kdir, "benchmarks", "recall-gold.json")
    if dry_run:
        return {"status": "planned",
                "would": "eval --strategy bm25 --record, then bench redact"}
    if not os.path.isfile(gold):
        return {"status": "skipped", "reason": "no gold set"}
    ledger = os.path.join(kdir, HISTORY_REL)
    before = len(_read_ledger(ledger)) if os.path.isfile(ledger) else 0
    ns = argparse.Namespace(
        format="json", gold=None, suite=None, dataset=None, limit=None,
        top_k=5, strategy="bm25", ablate=False, baseline="tag", treatment="bm25",
        record=True, gate=False, ab=False, tolerance=0.02, as_of=None,
        acr_gate=False, acr_margin=ACR_GATE_MARGIN, acr_alpha=ACR_GATE_ALPHA)
    rc, out = _dream_capture(cmd_eval, ns)
    reliability = None
    try:
        reliability = (json.loads(out).get("recorded") or {}).get("reliability")
    except ValueError:
        pass
    after = len(_read_ledger(ledger)) if os.path.isfile(ledger) else 0
    redact = _dream_step_bench_redact(kdir, dry_run=False)
    return {"status": "ok" if rc == 0 else "fail",
            "rows_added": after - before, "reliability": reliability,
            "post_redact_scrubbed": redact.get("scrubbed", 0)}


def _dream_step_detect_report(kdir, dry_run):
    """Step e — DETECT-AND-REPORT only (Phase 1): stale/duplicate learnings +
    unpromoted markers across work/*/worklog.md. READ-ONLY (INV-2): never
    promotes, deletes, or merges (that is Phase 2)."""
    if dry_run:
        return {"status": "planned",
                "would": "audit --stale + worklog scan (REPORT only, no mutation)"}
    data, err = load_index(kdir)
    if err is not None:
        return {"status": "error", "errors": [err]}
    report = build_stale_report(kdir, data, 120)
    unpromoted, scanned = 0, 0
    work = os.path.join(kdir, "work")
    if os.path.isdir(work):
        for feat in sorted(os.listdir(work)):
            wl = os.path.join(work, feat, "worklog.md")
            if os.path.isfile(wl):
                scanned += 1
                up, _tot = scan_worklog(wl, kdir, data)
                unpromoted += len(up)
    return {"status": "ok", "stale": len(report["stale"]),
            "duplicates": len(report["conflicts"]),
            "worklogs_scanned": scanned, "unpromoted_markers": unpromoted}


def _dream_step_kb_git(kdir, dry_run):
    """Step f — nightly backup: kb-git commit (+ optional push), gated on
    autocommit. A non-tracked KB / autocommit OFF / no upstream degrades to a
    clean no-op. NEVER stages the package repo (the helper refuses, C-3)."""
    if resolve_kb_autocommit() != "1":
        return {"status": "skipped", "reason": "kb autocommit OFF"}
    if not git_is_work_tree(kdir):
        return {"status": "skipped", "reason": "KB not a git work tree"}
    if dry_run:
        return {"status": "planned", "would": "kb-git commit (+ optional push)"}
    head0 = _git(kdir, "rev-parse", "HEAD")
    sha0 = head0.stdout.strip() if head0.returncode == 0 else None
    ns = argparse.Namespace(path=None, tag="dream", type="chore", message=None)
    rc, _out = _dream_capture(cmd_kb_git_commit, ns)
    head1 = _git(kdir, "rev-parse", "HEAD")
    sha1 = head1.stdout.strip() if head1.returncode == 0 else None
    committed = bool(sha1) and sha1 != sha0
    result = {"status": "ok" if rc == 0 else "fail", "committed": committed,
              "sha": sha1[:9] if committed else "-"}
    if committed and git_has_upstream(kdir):
        push_ns = argparse.Namespace(path=None, on_prose_conflict="abort",
                                     max_retries=3, format="text")
        prc, _ = _dream_capture(cmd_kb_git_push, push_ns)
        result["pushed"] = prc == 0
    else:
        result["pushed"] = False
    return result


DREAM_STEP_FUNCS = (
    ("a", "index-rebuild", _dream_step_index_rebuild),
    ("b", "bench-redact", _dream_step_bench_redact),
    ("c", "audit", _dream_step_audit),
    ("d", "eval-record", _dream_step_eval_record),
    ("e", "detect-report", _dream_step_detect_report),
    ("f", "kb-git-commit", _dream_step_kb_git),
)


def _dream_parse_steps(raw):
    """Parse --steps 'a,c,f' into an ordered validated subset. Returns
    (steps_list, None) or (None, error)."""
    valid = [s for s, _, _ in DREAM_STEP_FUNCS]
    if not raw:
        return valid, None
    want = {t.strip().lower() for t in raw.split(",") if t.strip()}
    bad = sorted(t for t in want if t not in set(valid))
    if bad:
        return None, ("unknown dream step(s): %s (valid: %s)"
                      % (", ".join(bad), ", ".join(valid)))
    return [s for s in valid if s in want], None


def _dream_step_summary(r):
    """Stable ' k=v k=v' for the journal/text output (sorted keys; metadata out)."""
    skip = {"step", "label", "status"}
    parts = ["%s=%s" % (k, r[k]) for k in sorted(r) if k not in skip]
    return ("  " + " ".join(parts)) if parts else ""


def _dream_render_journal_entry(cycle):
    """Deterministic, diff-friendly journal entry (fixed field order)."""
    lines = ["## dream %s" % cycle["started"], "",
             "- finished: %s" % cycle["finished"],
             "- duration_s: %s" % cycle["duration_s"],
             "- force: %s" % cycle["force"]]
    for r in cycle["steps"]:
        lines.append("- step %s (%s): %s%s"
                     % (r["step"], r["label"], r["status"], _dream_step_summary(r)))
    lines.append("")
    return "\n".join(lines) + "\n"


def _dream_write_journal(kdir, cycle):
    """Append one entry to logs/dream-journal.md (gitignored; best-effort)."""
    try:
        path = os.path.join(kdir, DREAM_JOURNAL_REL)
        os.makedirs(os.path.dirname(path), exist_ok=True)
        new = not os.path.exists(path)
        with open(path, "a", encoding="utf-8") as f:
            if new:
                f.write("# Dream Journal\n\n> Deterministic append-only "
                        "maintenance log (machine-local; gitignored via logs/). "
                        "One entry per cycle.\n\n")
            f.write(_dream_render_journal_entry(cycle))
    except OSError:
        pass


def _dream_emit_metric(kdir, cycle):
    """Rule-7 observability: ONE `dream` event to logs/metrics.jsonl. Best-effort
    + read-only w.r.t. the KB/index; a write failure never blocks (mirrors the
    ingestion-event shape: sorted-keys append)."""
    try:
        rec = {"event": "dream", "ts": cycle["started"],
               "finished": cycle["finished"], "duration_s": cycle["duration_s"],
               "force": cycle["force"],
               "steps": [{"step": r["step"], "status": r["status"],
                          "duration_s": r["duration_s"]} for r in cycle["steps"]]}
        logs = os.path.join(kdir, "logs")
        os.makedirs(logs, exist_ok=True)
        with open(os.path.join(logs, "metrics.jsonl"), "a",
                  encoding="utf-8") as f:
            f.write(json.dumps(rec, ensure_ascii=False, sort_keys=True) + "\n")
    except OSError:
        pass


def _dream_output(cycle, as_json, dry_run):
    """Render the cycle result; return the process exit code (0 unless a step
    failed/errored — a SKIP is not a failure)."""
    if as_json:
        json.dump(cycle, sys.stdout, ensure_ascii=False, indent=2, sort_keys=True)
        sys.stdout.write("\n")
    else:
        print("DREAM %s%s" % ("(dry-run) " if dry_run else "", cycle["started"]))
        for r in cycle["steps"]:
            print("  [%s] %s (%s)%s" % (r["status"], r["step"], r["label"],
                                        _dream_step_summary(r)))
        print("  duration_s: %s" % cycle["duration_s"])
    ok = all(r["status"] in ("ok", "skipped", "planned") for r in cycle["steps"])
    return 0 if ok else 1


def _dream_skip_output(kind, reason, as_json):
    """Render a skipped cycle (idle-gate or lock). Mutates NOTHING. rc 0."""
    if as_json:
        json.dump({"event": "dream", "skipped": True, "skip_kind": kind,
                   "skip_reason": reason, "ts": utc_now_iso()},
                  sys.stdout, ensure_ascii=False, indent=2, sort_keys=True)
        sys.stdout.write("\n")
    else:
        print("DREAM SKIPPED (%s): %s" % (kind, reason))
    return 0


def cmd_dream(args):
    """Run ONE deterministic, idle-gated KB-maintenance cycle (Phase 1).

    Orchestrates the sanctioned writers in fixed order a-f; each step is
    idempotent + skippable (--steps). --dry-run reports the plan and mutates
    NOTHING. The idle-gate skips (with a logged reason) when a loop session is
    active or load is high (bypass with --force); the concurrency lock is ALWAYS
    honored. Non-interactive (R-SHELL-01).
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    as_json = getattr(args, "format", "text") == "json"

    if getattr(args, "install_schedule", False):
        return _dream_install_schedule(kdir, as_json)
    if getattr(args, "uninstall_schedule", False):
        return _dream_uninstall_schedule(as_json)

    dry_run = getattr(args, "dry_run", False)
    force = getattr(args, "force", False)
    steps, err = _dream_parse_steps(getattr(args, "steps", None))
    if err:
        sys.stderr.write("agentware: %s\n" % err)
        return 2

    def _run_cycle():
        started, wall0 = utc_now_iso(), _dream_perf()
        results = []
        for s, label, fn in DREAM_STEP_FUNCS:
            if s not in steps:
                continue
            t0 = _dream_perf()
            try:
                r = fn(kdir, dry_run)
            except Exception as exc:   # one bad step never aborts the cycle
                r = {"status": "error", "error": "%s: %s" % (type(exc).__name__, exc)}
            r["step"], r["label"] = s, label
            r["duration_s"] = round(_dream_perf() - t0, 4)
            results.append(r)
        return {"event": "dream", "started": started, "finished": utc_now_iso(),
                "duration_s": round(_dream_perf() - wall0, 4), "dry_run": dry_run,
                "force": force, "skipped": False, "steps": results}

    # --dry-run: pure report — no lock, no idle-gate writes, no journal/metric.
    if dry_run:
        return _dream_output(_run_cycle(), as_json, True)

    # Idle-gate FIRST (reads only) so an active-session skip mutates nothing.
    skip = dream_idle_skip_reason(kdir, force=force)
    if skip:
        return _dream_skip_output("idle-gate", skip, as_json)

    # Single-writer concurrency lock (honored even with --force).
    acquired, info = dream_acquire_lock(kdir)
    if not acquired:
        return _dream_skip_output("lock", info, as_json)
    try:
        if os.environ.get("AGENTWARE_NESTED_UNITTEST") != "1":
            try:
                os.nice(DREAM_NICE)   # low priority; best-effort
            except (OSError, AttributeError):
                pass
        cycle = _run_cycle()
        _dream_write_journal(kdir, cycle)
        _dream_emit_metric(kdir, cycle)
        return _dream_output(cycle, as_json, False)
    finally:
        dream_release_lock(kdir)


def _dream_last_cycle_ts(kdir):
    """Timestamp (ISO 'Z') of the most recent dream from logs/metrics.jsonl, or
    None. Read-only; tolerant of a missing/garbled log."""
    path = os.path.join(kdir, "logs", "metrics.jsonl")
    last = None
    try:
        with open(path, "r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line or '"event": "dream"' not in line and \
                        '"event":"dream"' not in line:
                    continue
                try:
                    rec = json.loads(line)
                except ValueError:
                    continue
                if rec.get("event") == "dream" and rec.get("ts"):
                    last = rec["ts"]
    except OSError:
        return None
    return last


def _dream_age_hours(ts):
    """Hours between an ISO 'Z' timestamp and now (UTC), or None if unparseable."""
    try:
        when = datetime.datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ").replace(
            tzinfo=datetime.timezone.utc)
    except (ValueError, TypeError):
        return None
    return (datetime.datetime.now(datetime.timezone.utc) - when).total_seconds() / 3600.0


def _audit_dream_health_check(kdir):
    """Rule-7 last-dream freshness. INERT when dream is OFF (the opt-in default);
    when ON it FAILs if no cycle ran yet or the last one is stale (> DREAM_STALE_
    HOURS). Read-only (reads logs/metrics.jsonl only)."""
    if resolve_dream() != "1":
        return {"name": "dream_health", "ok": True,
                "details": ["inert: dream mode OFF (opt-in; enable with "
                            "`scripts/agentware config --set-dream on`)"]}
    last = _dream_last_cycle_ts(kdir)
    if last is None:
        return {"name": "dream_health", "ok": False,
                "details": ["dream is ON but no cycle has run yet — run "
                            "`scripts/agentware dream` or install the schedule"]}
    age = _dream_age_hours(last)
    if age is not None and age > DREAM_STALE_HOURS:
        return {"name": "dream_health", "ok": False,
                "details": ["last dream %s is stale (%.1fh > %dh budget)"
                            % (last, age, DREAM_STALE_HOURS)]}
    return {"name": "dream_health", "ok": True,
            "details": ["fresh: last dream %s" % last]}


# --- Dream scheduler installer (Task 10; OS-agnostic, opt-in) -----------------
# The PORTABLE artifact is the `dream` command. The installer is a thin, fully
# non-interactive wrapper that writes ONLY into the operator's HOME (launchd on
# macOS, a crontab fragment elsewhere) so it is testable under a patched HOME and
# never mutates the package. Default OFF: nothing is installed unless the operator
# opts in (`config --set-dream on` + a schedule, then `dream --install-schedule`).
DREAM_LAUNCHD_LABEL = "com.agentware.dream"
DREAM_CRON_REL = os.path.join(".agentware", "dream.cron")


def _dream_cli_path():
    """Absolute path to this CLI (the schedule invokes it directly)."""
    return os.path.join(REPO_ROOT, "scripts", "agentware")


def _dream_schedule_hm(schedule):
    """(hour, minute) ints from an HH:MM or 5-field cron token, or None.

    For a cron expression, uses the first two fields when both are plain integers
    (minute, hour); a wildcard/range/list yields None (launchd needs concretes)."""
    m = re.match(r"^([01]?\d|2[0-3]):([0-5]\d)$", schedule or "")
    if m:
        return int(m.group(1)), int(m.group(2))
    fields = (schedule or "").split()
    if len(fields) == 5 and fields[0].isdigit() and fields[1].isdigit():
        return int(fields[1]), int(fields[0])
    return None


def _dream_launchd_plist(schedule, cli_path):
    """Deterministic LaunchAgent plist string for a nightly low-priority dream."""
    hm = _dream_schedule_hm(schedule)
    hour, minute = hm if hm else (3, 0)
    return (
        '<?xml version="1.0" encoding="UTF-8"?>\n'
        '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" '
        '"http://www.apple.com/DTDs/PropertyList-1.0.dtd">\n'
        '<plist version="1.0">\n'
        '<dict>\n'
        '  <key>Label</key>\n  <string>%s</string>\n'
        '  <key>ProgramArguments</key>\n'
        '  <array>\n'
        '    <string>/usr/bin/nice</string>\n'
        '    <string>-n</string>\n    <string>%d</string>\n'
        '    <string>%s</string>\n'
        '    <string>dream</string>\n'
        '  </array>\n'
        '  <key>StartCalendarInterval</key>\n'
        '  <dict>\n'
        '    <key>Hour</key>\n    <integer>%d</integer>\n'
        '    <key>Minute</key>\n    <integer>%d</integer>\n'
        '  </dict>\n'
        '  <key>RunAtLoad</key>\n  <false/>\n'
        '</dict>\n</plist>\n'
        % (DREAM_LAUNCHD_LABEL, DREAM_NICE, cli_path, hour, minute))


def _dream_cron_line(schedule, cli_path):
    """Deterministic crontab line for a nightly low-priority dream."""
    fields = (schedule or "").split()
    if len(fields) == 5:
        spec = " ".join(fields)
    else:
        hm = _dream_schedule_hm(schedule) or (0, 3)  # (minute_src) -> rebuild
        hour, minute = hm
        spec = "%d %d * * *" % (minute, hour)
    return "%s nice -n %d %s dream >/dev/null 2>&1\n" % (
        spec, DREAM_NICE, cli_path)


def _dream_launchd_plist_path():
    return os.path.join(os.path.expanduser("~"), "Library", "LaunchAgents",
                        "%s.plist" % DREAM_LAUNCHD_LABEL)


def _dream_install_schedule(kdir, as_json):
    """Install the nightly schedule into the operator's HOME (opt-in). Requires
    dream ON + a configured schedule. macOS -> launchd plist; else -> crontab
    fragment. Fully non-interactive; writes ONLY under HOME."""
    if resolve_dream() != "1":
        sys.stderr.write("agentware: dream is OFF — enable it first "
                         "(`scripts/agentware config --set-dream on`).\n")
        return 2
    schedule = resolve_dream_schedule()
    if not schedule:
        sys.stderr.write("agentware: no dream schedule configured "
                         "(`scripts/agentware config --set-dream-schedule HH:MM`).\n")
        return 2
    cli = _dream_cli_path()
    if sys.platform == "darwin":
        path = _dream_launchd_plist_path()
        content = _dream_launchd_plist(schedule, cli)
        platform = "launchd"
    else:
        path = os.path.join(os.path.expanduser("~"), DREAM_CRON_REL)
        content = _dream_cron_line(schedule, cli)
        platform = "cron"
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w", encoding="utf-8") as f:
            f.write(content)
    except OSError as exc:
        sys.stderr.write("agentware: could not write schedule %s: %s\n" % (path, exc))
        return 1
    # Best-effort activation (skipped under the test guard; never fatal).
    if os.environ.get("AGENTWARE_NESTED_UNITTEST") != "1":
        try:
            if platform == "launchd":
                subprocess.run(["launchctl", "load", "-w", path],
                               stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                               check=False)
            else:
                existing = subprocess.run(["crontab", "-l"], stdout=subprocess.PIPE,
                                          stderr=subprocess.PIPE, check=False)
                base = existing.stdout.decode("utf-8", "replace") \
                    if existing.returncode == 0 else ""
                base = "".join(l for l in base.splitlines(keepends=True)
                               if "agentware" not in l or "dream" not in l)
                subprocess.run(["crontab", "-"], input=(base + content).encode(),
                               stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                               check=False)
        except (OSError, ValueError):
            pass
    if as_json:
        json.dump({"ok": True, "platform": platform, "path": path,
                   "schedule": schedule}, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("DREAM schedule installed (%s): %s @ %s" % (platform, path, schedule))
    return 0


def _dream_uninstall_schedule(as_json):
    """Remove an installed schedule from HOME (idempotent; clean no-op if absent)."""
    if sys.platform == "darwin":
        path, platform = _dream_launchd_plist_path(), "launchd"
    else:
        path = os.path.join(os.path.expanduser("~"), DREAM_CRON_REL)
        platform = "cron"
    removed = False
    if os.path.isfile(path):
        if os.environ.get("AGENTWARE_NESTED_UNITTEST") != "1":
            try:
                if platform == "launchd":
                    subprocess.run(["launchctl", "unload", "-w", path],
                                   stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                                   check=False)
            except OSError:
                pass
        try:
            os.remove(path)
            removed = True
        except OSError:
            pass
    if as_json:
        json.dump({"ok": True, "platform": platform, "path": path,
                   "removed": removed}, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("DREAM schedule %s (%s): %s"
              % ("removed" if removed else "not present", platform, path))
    return 0


def build_parser():
    fmt_parent = argparse.ArgumentParser(add_help=False)
    fmt_parent.add_argument("--format", choices=("text", "json"), default="text",
                            help="output format (default: text)")

    parser = argparse.ArgumentParser(
        prog="agentware",
        parents=[fmt_parent],
        description="Deterministic CLI toolkit for an agentware workspace.")
    sub = parser.add_subparsers(dest="command", metavar="<command>")
    sub.required = True

    # init -------------------------------------------------------------------
    p_init = sub.add_parser(
        "init", parents=[fmt_parent],
        help="scaffold the external knowledge dir + seed index + write config")
    p_init.add_argument("--knowledge-dir", required=True, dest="knowledge_dir",
                        help="absolute or ~ path to store this operator's knowledge")
    p_init.set_defaults(func=cmd_init)

    # config -----------------------------------------------------------------
    p_cfg = sub.add_parser(
        "config", parents=[fmt_parent], help="show the resolved knowledge dir")
    p_cfg.add_argument("--knowledge-dir-only", action="store_true",
                       dest="knowledge_dir_only",
                       help="print only the bare path (for shell consumers)")
    p_cfg.add_argument("--kb-autocommit-only", action="store_true",
                       dest="kb_autocommit_only",
                       help="print only the resolved KB-autocommit setting (1/0)")
    p_cfg.add_argument("--set-autocommit", dest="set_autocommit",
                       metavar="on|off",
                       help="persist the KB-autocommit setting to "
                            "~/.agentware/config.env (env still overrides per-run)")
    p_cfg.add_argument("--retrieval-mode-only", action="store_true",
                       dest="retrieval_mode_only",
                       help="print only the resolved EFFECTIVE retrieval mode "
                            "(deterministic|semantic) for shell consumers")
    p_cfg.add_argument("--set-mode", dest="set_mode",
                       metavar="deterministic|semantic",
                       help="persist the retrieval mode to ~/.agentware/config.env "
                            "(Mode A deterministic / Mode B semantic; env still "
                            "overrides per-run)")
    # --- SETTINGS_AW (260627-semantic-embedding-settings) ----------------
    p_cfg.add_argument("--set-retrieval", dest="set_retrieval",
                       metavar="bm25|semantic",
                       help="SETTINGS_AW alias for --set-mode "
                            "(bm25=Mode A deterministic / semantic=Mode B); "
                            "persisted to ~/.agentware/config.env")
    p_cfg.add_argument("--set-embedder", dest="set_embedder",
                       metavar="DOTTED_NAME|PATH",
                       help="persist the LOCAL embedder backend spec (dotted module "
                            "name e.g. agentware_embedder_fastembed, or a path to a "
                            ".py backend) to ~/.agentware/config.env")
    p_cfg.add_argument("--embedder-only", action="store_true",
                       dest="embedder_only",
                       help="print only the resolved embedder backend spec "
                            "(empty if unset) for shell consumers")
    p_cfg.add_argument("--set-embed-model", dest="set_embed_model",
                       metavar="MODEL_ID",
                       help="persist the embedding model id (e.g. "
                            "BAAI/bge-small-en-v1.5) to ~/.agentware/config.env")
    p_cfg.add_argument("--embed-model-only", action="store_true",
                       dest="embed_model_only",
                       help="print only the resolved embedding model id for "
                            "shell consumers")
    p_cfg.add_argument("--kb-mode-only", action="store_true",
                       dest="kb_mode_only",
                       help="print only the resolved workspace KB mode "
                            "(power|team) for shell consumers (onboarding)")
    p_cfg.add_argument("--set-kb-mode", dest="set_kb_mode",
                       metavar="power|team",
                       help="persist the workspace KB mode to ~/.agentware/config.env "
                            "(power=solo local KB / team=shared git KB; distinct "
                            "from the retrieval --set-mode; env overrides per-run)")
    p_cfg.add_argument("--user-handle-only", action="store_true",
                       dest="user_handle_only",
                       help="print only the resolved per-user provenance handle "
                            "(empty if unset)")
    p_cfg.add_argument("--set-user-handle", dest="set_user_handle",
                       metavar="HANDLE",
                       help="persist the per-user provenance handle to "
                            "~/.agentware/config.env (stamped as `author` on "
                            "entries this user creates in a shared team KB)")
    p_cfg.add_argument("--record-onboarding", action="store_true",
                       dest="record_onboarding",
                       help="append one onboarding event {mode,user_handle} to "
                            "<kdir>/logs/metrics.jsonl (gitignored observability)")
    # --- dream mode (260627-dream-mode) ----------------------------------
    p_cfg.add_argument("--dream-only", action="store_true", dest="dream_only",
                       help="print only the resolved dream setting (on|off) for "
                            "shell consumers (the scheduler installer + idle-gate)")
    p_cfg.add_argument("--set-dream", dest="set_dream", metavar="on|off",
                       help="persist the dream-mode opt-in to "
                            "~/.agentware/config.env (default OFF; env still "
                            "overrides per-run)")
    p_cfg.add_argument("--dream-schedule-only", action="store_true",
                       dest="dream_schedule_only",
                       help="print only the resolved dream schedule token "
                            "(empty if unset) for shell consumers")
    p_cfg.add_argument("--set-dream-schedule", dest="set_dream_schedule",
                       metavar="HH:MM|CRON",
                       help="persist the nightly dream schedule (a 24h HH:MM token "
                            "or a 5-field cron expression) to ~/.agentware/config.env")
    p_cfg.set_defaults(func=cmd_config)

    # attach -----------------------------------------------------------------
    p_attach = sub.add_parser(
        "attach", parents=[fmt_parent],
        help="validate (and optionally --migrate) a candidate repo for adoption "
             "as the shared KB (team-mode onboarding)")
    p_attach.add_argument("--path", required=True,
                          help="path to the candidate KB repo to validate")
    p_attach.add_argument("--migrate", action="store_true",
                          help="idempotently fill missing structure first "
                               "(never clobbers existing data), then validate")
    p_attach.set_defaults(func=cmd_attach)

    # index ------------------------------------------------------------------
    p_index = sub.add_parser("index", help="manage the knowledge index.json")
    index_sub = p_index.add_subparsers(dest="index_command", metavar="<subcommand>")
    index_sub.required = True

    p_add = index_sub.add_parser(
        "add", parents=[fmt_parent], help="register a new entry in index.json")
    p_add.add_argument("--id", required=True, help="unique entry id")
    p_add.add_argument("--title", required=True, help="human-readable title")
    p_add.add_argument("--category", required=True,
                       help="one of: %s" % ", ".join(CATEGORIES))
    p_add.add_argument("--path", required=True,
                       help="knowledge-dir-relative path (must exist)")
    p_add.add_argument("--tags", required=True, help="comma-separated tags")
    p_add.add_argument("--summary", required=True, help="one-line summary")
    p_add.add_argument("--created", default=None, help="YYYY-MM-DD (default: today)")
    p_add.add_argument("--last-verified", default=None,
                       help="YYYY-MM-DD freshness date (default: == created)")
    p_add.set_defaults(func=cmd_index_add)

    p_rm = index_sub.add_parser(
        "remove", parents=[fmt_parent], help="unregister an entry from index.json")
    p_rm.add_argument("--id", required=True, help="id of the entry to remove")
    p_rm.set_defaults(func=cmd_index_remove)

    p_val = index_sub.add_parser(
        "validate", parents=[fmt_parent], help="validate index.json integrity")
    p_val.set_defaults(func=cmd_index_validate)

    p_sync = index_sub.add_parser(
        "sync", parents=[fmt_parent], help="report (or --fix) unindexed *.md files")
    p_sync.add_argument("--fix", action="store_true",
                        help="add missing entries instead of just reporting")
    p_sync.set_defaults(func=cmd_index_sync)

    p_migrate = index_sub.add_parser(
        "migrate-frontmatter", parents=[fmt_parent],
        help="one-time: backfill YAML frontmatter into every indexed entry file")
    p_migrate.set_defaults(func=cmd_index_migrate)

    p_rebuild = index_sub.add_parser(
        "rebuild", parents=[fmt_parent],
        help="regenerate index.json + rosters + FEATURES.md from entry frontmatter")
    p_rebuild.set_defaults(func=cmd_index_rebuild)

    # query ------------------------------------------------------------------
    p_query = sub.add_parser(
        "query", parents=[fmt_parent], help="look up entries (O(1) by id/path/tag)")
    q_group = p_query.add_mutually_exclusive_group(required=True)
    q_group.add_argument("--id", help="look up a single entry by id")
    q_group.add_argument("--path", help="look up a single entry by path")
    q_group.add_argument("--category", help="list all entries in a category")
    q_group.add_argument("--tag", help="list all entries carrying a tag")
    q_group.add_argument("--depends-on", dest="depends_on",
                         help="forward closure: entries the given id depends on")
    q_group.add_argument("--impact",
                         help="reverse closure: entries that depend on the given id")
    q_group.add_argument("--relates",
                         help="direct graph neighbors of the given id (both directions)")
    p_query.add_argument("--depth", type=int, default=1,
                         help="traversal hops for graph queries (default 1; 0 = full closure)")
    p_query.set_defaults(func=cmd_query)

    # learn ------------------------------------------------------------------
    p_learn = sub.add_parser(
        "learn", parents=[fmt_parent], help="create + register a learning file")
    p_learn.add_argument("--topic", required=True, help="filename stem under learnings/")
    p_learn.add_argument("--summary", required=True, help="one-line summary")
    p_learn.add_argument("--tags", required=True, help="comma-separated tags")
    p_learn.add_argument("--content", required=True,
                         help="learning body, or '-' to read from stdin")
    p_learn.add_argument("--author", default=None,
                         help="optional provenance author handle (default: the "
                              "per-user handle if set, else the operator handle). "
                              "For shared/team KBs.")
    p_learn.add_argument("--source", default=None,
                         help="optional provenance source: user|agent|imported "
                              "(default: agent). Feeds the ACR source_weight prior.")
    p_learn.set_defaults(func=cmd_learn)

    # decide -----------------------------------------------------------------
    p_decide = sub.add_parser(
        "decide", parents=[fmt_parent],
        help="record + register an autonomous decision (R-AUTO-03)")
    p_decide.add_argument("--topic", required=True,
                          help="hyphenated slug; filename stem under decisions/")
    p_decide.add_argument("--summary", required=True, help="one-line summary")
    p_decide.add_argument("--options", required=True,
                          help="options that were weighed")
    p_decide.add_argument("--choice", required=True, help="the option chosen")
    p_decide.add_argument("--rationale", required=True,
                          help="why this choice, in-scope per R-AUTO-01")
    p_decide.add_argument("--reversible", required=True,
                          help="how reversible the decision is")
    p_decide.add_argument("--tags", default=None,
                          help="comma-separated extra tags ('decision' auto-added)")
    p_decide.set_defaults(func=cmd_decide)

    # ingest -----------------------------------------------------------------
    p_ingest = sub.add_parser(
        "ingest", parents=[fmt_parent],
        help="deterministic curated capture from a LOCAL source artifact "
             "(dry-run by default; --commit registers a reviewed subset)")
    p_ingest.add_argument("--source", required=True, choices=INGEST_SOURCES,
                          help="source adapter: %s" % " | ".join(INGEST_SOURCES))
    p_ingest.add_argument("--path", required=True,
                          help="LOCAL docs dir or github-issues JSON export "
                               "(agentware NEVER fetches the network)")
    p_ingest.add_argument("--tags", default=None,
                          help="extra comma-separated tags applied to every "
                               "candidate")
    p_ingest.add_argument("--only", default=None,
                          help="comma-separated topic slugs to commit "
                               "(the reviewed subset; default: all valid)")
    p_ingest.add_argument("--commit", action="store_true",
                          help="register the selected candidates with "
                               "source: imported (default: dry-run, registers "
                               "nothing)")
    p_ingest.set_defaults(func=cmd_ingest)

    # features ---------------------------------------------------------------
    p_feat = sub.add_parser(
        "features", parents=[fmt_parent],
        help="regenerate FEATURES.md from the knowledge index.json")
    p_feat.set_defaults(func=cmd_features)

    # worklog ----------------------------------------------------------------
    p_wl = sub.add_parser("worklog", help="worklog utilities")
    wl_sub = p_wl.add_subparsers(dest="worklog_command", metavar="<subcommand>")
    wl_sub.required = True
    p_scan = wl_sub.add_parser(
        "scan", parents=[fmt_parent],
        help="find unpromoted '> LEARNED:' markers in a worklog")
    p_scan.add_argument("--path", required=True, help="path to a worklog.md")
    p_scan.set_defaults(func=cmd_worklog_scan)

    # audit ------------------------------------------------------------------
    p_audit = sub.add_parser(
        "audit", parents=[fmt_parent], help="run all consistency checks in one pass")
    p_audit.add_argument(
        "--with-tests", action="store_true",
        help="also run the unittest suite (tests/) and fail the audit on failure")
    p_audit.add_argument(
        "--stale", action="store_true",
        help="report aged volatile entries + near-duplicate/conflict pairs (advisory)")
    p_audit.add_argument(
        "--max-age-days", type=int, default=120, dest="max_age_days",
        help="staleness window in days for --stale (default: 120)")
    p_audit.set_defaults(func=cmd_audit)

    # recall -----------------------------------------------------------------
    p_recall = sub.add_parser(
        "recall", parents=[fmt_parent],
        help="deterministic BM25 ranked retrieval, token-budgeted")
    p_recall.add_argument("query", help="free-text query to rank KB entries against")
    p_recall.add_argument("--top-k", type=int, default=5, dest="top_k",
                          help="max entries to return before budgeting (default: 5)")
    p_recall.add_argument("--token-budget", type=int, default=1500,
                          dest="token_budget",
                          help="trim so cumulative est. tokens <= budget (default: 1500)")
    p_recall.add_argument("--category", default=None,
                          help="restrict ranking to a single category")
    p_recall.add_argument("--strategy", choices=("bm25", "bm25+acr"),
                          default=None,
                          help="ranking strategy (default: the gated default — "
                               "bm25+acr iff the recorded ACR win gate passed, "
                               "else bm25; bm25+acr applies the ACR "
                               "provenance+freshness prior over BM25)")
    p_recall.add_argument("--acr", action="store_const", const="bm25+acr",
                          dest="strategy",
                          help="shorthand for --strategy bm25+acr (opt into the "
                               "ACR re-rank; reorders within the BM25 set only)")
    p_recall.add_argument("--as-of", default=None, dest="as_of",
                          help="YYYY-MM-DD date for ACR freshness decay "
                               "(default: today; PIN it for reproducible runs)")
    p_recall.set_defaults(func=cmd_recall)

    # mcp --------------------------------------------------------------------
    p_mcp = sub.add_parser(
        "mcp", help="read-only Model Context Protocol server over the KB (stdio)")
    mcp_sub = p_mcp.add_subparsers(dest="mcp_command", metavar="<subcommand>")
    mcp_sub.required = True
    p_mcp_serve = mcp_sub.add_parser(
        "serve",
        help="speak MCP (JSON-RPC 2.0) over stdio; exposes read-only recall+query")
    p_mcp_serve.set_defaults(func=cmd_mcp)

    # eval -------------------------------------------------------------------
    p_eval = sub.add_parser(
        "eval", parents=[fmt_parent],
        help="benchmark recall over a gold set (Recall@k, precision@k, nDCG@k, MRR)")
    p_eval.add_argument(
        "--gold", default=None,
        help="path to gold set JSON (default: <kdir>/benchmarks/recall-gold.json)")
    p_eval.add_argument(
        "--suite", choices=("longmemeval", "gold-fixture"), default=None,
        help="run a benchmark suite instead of the own gold set. "
             "'longmemeval' scores the requested --strategy on LongMemEval-S at "
             "SESSION granularity (Recall@k headline k=5, per-category, "
             "abstention reported separately). 'gold-fixture' scores a tiny "
             "FROZEN synthetic corpus shipped with the package (no operator "
             "data) for a DRIFT-FREE absolute gate. Strategy-agnostic.")
    p_eval.add_argument(
        "--dataset", default=None,
        help="path to the LongMemEval-S JSON for --suite longmemeval (default: "
             "<kdir>/benchmarks/longmemeval/longmemeval_s_cleaned.json)")
    p_eval.add_argument(
        "--limit", type=int, default=None,
        help="score only the first N questions of a --suite run "
             "(dev/testing; default: all)")
    p_eval.add_argument("--top-k", type=int, default=5, dest="top_k",
                        help="cutoff k for @k metrics (default: 5)")
    p_eval.add_argument("--strategy",
                        choices=("tag", "bm25", "bm25+acr", "bm25+embed"),
                        default="tag",
                        help="retrieval strategy to score (default: tag baseline; "
                             "bm25+acr applies the ACR prior over BM25; bm25+embed "
                             "fuses BM25 + local embeddings via RRF, falling back "
                             "to bm25 with no local embedder)")
    p_eval.add_argument("--ablate", action="store_true",
                        help="run the gold set through both --baseline and "
                             "--treatment strategies and report the per-metric lift")
    p_eval.add_argument("--baseline",
                        choices=("tag", "bm25", "bm25+acr", "bm25+embed"),
                        default="tag",
                        help="baseline strategy for --ablate (default: tag). "
                             "Use bm25 to ablate the ACR prior (bm25 vs bm25+acr) "
                             "or the embed lift (bm25 vs bm25+embed)")
    p_eval.add_argument("--treatment",
                        choices=("tag", "bm25", "bm25+acr", "bm25+embed"),
                        default="bm25",
                        help="treatment strategy for --ablate (default: bm25). "
                             "Use bm25+acr to measure the ACR lift, or bm25+embed "
                             "to measure the hybrid embedding lift over plain BM25")
    p_eval.add_argument("--record", action="store_true",
                        help="append one immutable commit+UTC-date-stamped row "
                             "(with a 0-100 reliability score) to "
                             "<kdir>/benchmarks/history.jsonl (append-only)")
    p_eval.add_argument("--gate", action="store_true",
                        help="compare this run to the best prior comparable "
                             "ledger row and EXIT NON-ZERO on a regression "
                             "beyond --tolerance (implies --record; seeds + "
                             "passes when there is no prior history)")
    p_eval.add_argument("--ab", action="store_true",
                        help="clean-HEAD A/B gate: score the working-tree CLI and "
                             "the git-HEAD CLI (extracted to a temp file via "
                             "`git show HEAD:scripts/agentware`, read-only) over "
                             "the SAME corpus and PASS iff working >= head - "
                             "tolerance. Isolates THIS diff's recall effect from "
                             "live-KB corpus drift; emits both numbers + the delta "
                             "in --format json. Unavailable HEAD ⇒ passes.")
    p_eval.add_argument("--tolerance", type=float, default=0.02,
                        help="max allowed drop per headline metric before --gate "
                             "fails (default: 0.02; reliability uses x100 points)")
    p_eval.add_argument("--as-of", default=None, dest="as_of",
                        help="YYYY-MM-DD date for ACR freshness decay "
                             "(default: today; PINNED for reproducible benchmarks)")
    p_eval.add_argument("--acr-gate", action="store_true", dest="acr_gate",
                        help="run the bm25-vs-bm25+acr ablation at --as-of and "
                             "apply the deterministic 5-part ACR win gate (nDCG "
                             "margin + paired t-test + win-rate + no-harm "
                             "guardrails + age-stratified no-regression); EXIT "
                             "NON-ZERO on FAIL. Distinct from --gate.")
    p_eval.add_argument("--acr-margin", type=float, default=ACR_GATE_MARGIN,
                        dest="acr_margin",
                        help="min mean nDCG@k lift for the ACR-gate primary "
                             "check (default: %g)" % ACR_GATE_MARGIN)
    p_eval.add_argument("--acr-alpha", type=float, default=ACR_GATE_ALPHA,
                        dest="acr_alpha",
                        help="paired t-test two-tailed significance level for "
                             "the ACR gate (default: %g; table supports 0.05, "
                             "0.01)" % ACR_GATE_ALPHA)
    p_eval.set_defaults(func=cmd_eval)

    # bench ------------------------------------------------------------------
    p_bench = sub.add_parser("bench", help="benchmark scorecard utilities")
    bench_sub = p_bench.add_subparsers(dest="bench_command", metavar="<subcommand>")
    bench_sub.required = True
    p_score = bench_sub.add_parser(
        "scorecard",
        help="regenerate benchmarks/SCORECARD.md trend table from history.jsonl")
    p_score.set_defaults(func=cmd_bench)
    p_redact = bench_sub.add_parser(
        "redact",
        help="scrub operator HOME from ledger gold_path (PII redaction; the ONLY "
             "sanctioned mutation of the append-only ledger)")
    p_redact.add_argument(
        "path", nargs="?", default=None,
        help="ledger file to scrub (default: <knowledge-dir>/benchmarks/history.jsonl)")
    p_redact.set_defaults(func=cmd_bench_redact)

    # metrics ----------------------------------------------------------------
    p_metrics = sub.add_parser(
        "metrics", parents=[fmt_parent],
        help="execution observability over session transcripts (read-only)")
    p_metrics.add_argument("--session", default=None,
                           help="restrict to a single session id")
    p_metrics.add_argument("--feature", default=None,
                           help="sessions whose transcript references the feature")
    p_metrics.add_argument("--since", default=None,
                           help="only sessions starting on/after YYYY-MM-DD")
    p_metrics.add_argument("--prices", default=None,
                           help="path to a JSON price table ($ per 1M tokens, "
                                "keyed by model-id substring) overriding the "
                                "built-in default cost rates")
    p_metrics.add_argument("--context-window", dest="context_window",
                           type=int, default=None,
                           help="model context-window size (tokens) the "
                                "context-tax truncation-risk is measured "
                                "against (default 200000)")
    p_metrics.set_defaults(func=cmd_metrics)

    # dashboard --------------------------------------------------------------
    p_dash = sub.add_parser(
        "dashboard",
        help="serve the read-only observability dashboard (localhost-only)")
    p_dash.add_argument("--port", type=int, default=8765,
                        help="port to bind (default: 8765)")
    p_dash.add_argument("--host", default="127.0.0.1",
                        help="loopback host to bind (default: 127.0.0.1)")
    p_dash.add_argument("--no-open", dest="no_open", action="store_true",
                        help="do not open a browser window")
    p_dash.set_defaults(func=cmd_dashboard)

    # dream ------------------------------------------------------------------
    p_dream = sub.add_parser(
        "dream", parents=[fmt_parent],
        help="run ONE deterministic, idle-gated KB-maintenance cycle (Phase 1)")
    p_dream.add_argument(
        "--dry-run", action="store_true", dest="dry_run",
        help="report the ordered step plan; mutate NOTHING")
    p_dream.add_argument(
        "--steps", default=None, metavar="a,b,…",
        help="run only this comma-separated subset of steps a-f "
             "(a index-rebuild, b bench-redact, c audit, d eval-record, "
             "e detect-report, f kb-git-commit)")
    p_dream.add_argument(
        "--force", action="store_true",
        help="bypass the idle-gate for a manual run (the concurrency lock is "
             "STILL honored)")
    p_dream.add_argument(
        "--install-schedule", action="store_true", dest="install_schedule",
        help="install the nightly schedule into HOME (launchd/cron) — requires "
             "dream ON + a configured --set-dream-schedule")
    p_dream.add_argument(
        "--uninstall-schedule", action="store_true", dest="uninstall_schedule",
        help="remove an installed nightly schedule (idempotent)")
    p_dream.set_defaults(func=cmd_dream)

    # kb-git -----------------------------------------------------------------
    p_kbgit = sub.add_parser(
        "kb-git", help="knowledge-base git sync (detection, commit, pull/push)")
    kbgit_sub = p_kbgit.add_subparsers(dest="kb_git_command", metavar="<subcommand>")
    kbgit_sub.required = True
    p_kbstatus = kbgit_sub.add_parser(
        "status", parents=[fmt_parent],
        help="report is_work_tree / has_upstream / is_clean for the KB repo")
    p_kbstatus.add_argument(
        "--path", default=None,
        help="repo dir to inspect (default: the resolved knowledge dir)")
    p_kbstatus.set_defaults(func=cmd_kb_git_status)

    p_kbcommit = kbgit_sub.add_parser(
        "commit",
        help="stage + commit ONLY the KB repo as one feat|chore(tag): commit")
    p_kbcommit.add_argument(
        "--path", default=None,
        help="KB repo dir to commit (default: the resolved knowledge dir)")
    p_kbcommit.add_argument(
        "--tag", default=None,
        help="commit scope tag (sanitized to [a-z0-9._-]; default: kb)")
    p_kbcommit.add_argument(
        "--type", choices=("feat", "chore"), default="chore",
        help="conventional-commit type (default: chore)")
    p_kbcommit.add_argument(
        "--message", default=None,
        help="commit summary (default: deterministic changed-dirs summary)")
    p_kbcommit.set_defaults(func=cmd_kb_git_commit)

    p_kbpull = kbgit_sub.add_parser(
        "pull",
        help="fast-forward the KB repo from upstream at a safe point (no-op "
             "when dirty / offline / no upstream)")
    p_kbpull.add_argument(
        "--path", default=None,
        help="KB repo dir to pull (default: the resolved knowledge dir)")
    p_kbpull.set_defaults(func=cmd_kb_git_pull)

    p_kbpush = kbgit_sub.add_parser(
        "push",
        help="push KB commits to upstream, auto-resolving derived-file "
             "conflicts via index rebuild (no-op when offline / no upstream)")
    p_kbpush.add_argument(
        "--path", default=None,
        help="KB repo dir to push (default: the resolved knowledge dir)")
    p_kbpush.add_argument(
        "--on-prose-conflict", dest="on_prose_conflict",
        choices=("abort", "pause"), default="abort",
        help="same-entry (non-derived) conflict disposition: 'abort' fails loud "
             "(default); 'pause' leaves the rebase in progress + lists the "
             "conflicted entry files (rc 3) for the MERGE_PROMPT")
    p_kbpush.add_argument(
        "--max-retries", dest="max_retries", type=int, default=3,
        help="bounded pull→resolve→push retries on a re-push race before "
             "failing loud (default: 3)")
    p_kbpush.set_defaults(func=cmd_kb_git_push)

    p_kbcont = kbgit_sub.add_parser(
        "merge-continue",
        help="continue a paused prose-merge rebase after the entry files were "
             "reconciled, rebuild derived files, then push")
    p_kbcont.add_argument(
        "--path", default=None,
        help="KB repo dir to continue (default: the resolved knowledge dir)")
    p_kbcont.set_defaults(func=cmd_kb_git_merge_continue)

    # steering ---------------------------------------------------------------
    p_steer = sub.add_parser("steering", help="Deterministic Steering Format tooling")
    steer_sub = p_steer.add_subparsers(dest="steering_command", metavar="<subcommand>")
    steer_sub.required = True
    p_lint = steer_sub.add_parser(
        "lint", parents=[fmt_parent], help="enforce DSF on always-loaded steering")
    p_lint.set_defaults(func=cmd_steering_lint)

    # plan -------------------------------------------------------------------
    p_plan = sub.add_parser("plan", help="feature-plan structural tooling")
    plan_sub = p_plan.add_subparsers(dest="plan_command", metavar="<subcommand>")
    plan_sub.required = True
    p_plan_lint = plan_sub.add_parser(
        "lint", parents=[fmt_parent],
        help="lint a feature plan against the R1–R9 structural contract")
    p_plan_lint.add_argument("--path", required=True, help="path to a plan.md")
    p_plan_lint.add_argument(
        "--strict", action="store_true",
        help="treat the R9 autonomy rule as a hard failure (used by the loop "
             "pre-hook so a non-autonomous plan aborts before the run)")
    p_plan_lint.set_defaults(func=cmd_plan_lint)

    p_plan_new = plan_sub.add_parser(
        "new", parents=[fmt_parent],
        help="scaffold a lint-passing plan.md (seeds the mandatory [e2e]+[kb] pair)")
    p_plan_new.add_argument("feature", help="feature slug; dir under work/")
    p_plan_new.add_argument("--title", required=True, help="human plan title")
    p_plan_new.add_argument("--max-iterations", type=int, default=30,
                            dest="max_iterations", help="loop iteration budget")
    p_plan_new.add_argument("--self-extension", action="store_true",
                            dest="self_extension",
                            help="seed the R-PKG-03 self-extension warning block")
    p_plan_new.add_argument("--force", action="store_true",
                            help="overwrite an existing plan.md")
    p_plan_new.set_defaults(func=cmd_plan_new)

    p_plan_add = plan_sub.add_parser(
        "add-task", parents=[fmt_parent],
        help="insert a task before the trailing [e2e]+[kb] pair and renumber")
    p_plan_add.add_argument("feature", help="feature slug; dir under work/")
    p_plan_add.add_argument("description", help="task description")
    p_plan_add.add_argument("--verify", default=None, help="the *Verify:* command")
    p_plan_add.add_argument("--e2e", action="store_true",
                            help="tag this as an additional [e2e] task")
    p_plan_add.add_argument("--kb", action="store_true",
                            help="tag this as an additional [kb] task")
    p_plan_add.set_defaults(func=cmd_plan_add_task)

    p_plan_status = plan_sub.add_parser(
        "set-status", parents=[fmt_parent],
        help="flip a task marker (todo|wip|done) in place, line-local")
    p_plan_status.add_argument("feature", help="feature slug; dir under work/")
    p_plan_status.add_argument("number", type=int, help="task number to flip")
    p_plan_status.add_argument("status", choices=("todo", "wip", "done"),
                               help="new status")
    p_plan_status.set_defaults(func=cmd_plan_set_status)

    # fanout -----------------------------------------------------------------
    p_fanout = sub.add_parser(
        "fanout",
        help="parallel-lane orchestration (isolated worktrees + gated merge queue)")
    fanout_sub = p_fanout.add_subparsers(
        dest="fanout_command", metavar="<subcommand>")
    fanout_sub.required = True

    p_fan_spin = fanout_sub.add_parser(
        "spin-up", parents=[fmt_parent],
        help="provision N isolated lanes (package + KB worktrees + env file)")
    p_fan_spin.add_argument("features", nargs="+", help="feature slug(s)")
    p_fan_spin.add_argument("--base", default=None,
                            help="package base ref for feat/<f> (default: HEAD)")
    p_fan_spin.add_argument("--kb-base", default=None, dest="kb_base",
                            help="KB base ref for kb/<f> (default: --base)")
    p_fan_spin.add_argument("--repo", default=None,
                            help="package repo (default: this agentware repo)")
    p_fan_spin.add_argument("--kb-repo", default=None, dest="kb_repo",
                            help="KB repo (default: the resolved knowledge dir)")
    p_fan_spin.add_argument("--dry-run", action="store_true", dest="dry_run",
                            help="print the plan; write nothing")
    p_fan_spin.set_defaults(func=cmd_fanout_spin_up)

    p_fan_list = fanout_sub.add_parser(
        "list", parents=[fmt_parent],
        help="report each active lane's branch, KB path, and loop outcome")
    p_fan_list.set_defaults(func=cmd_fanout_list)

    p_fan_mp = fanout_sub.add_parser(
        "merge-policy", parents=[fmt_parent],
        help="install the idempotent merge=union .gitattributes in the KB repo")
    p_fan_mp.add_argument("--kb", default=None,
                          help="KB repo dir (default: the resolved knowledge dir)")
    p_fan_mp.set_defaults(func=cmd_fanout_merge_policy)

    p_fan_mq = fanout_sub.add_parser(
        "merge-queue", parents=[fmt_parent],
        help="serially integrate finished lanes onto an integration branch (gated)")
    p_fan_mq.add_argument("features", nargs="*",
                          help="lanes to integrate (default: all registered lanes)")
    p_fan_mq.add_argument("--repo", default=None,
                          help="package repo (default: this agentware repo)")
    p_fan_mq.add_argument("--kb-repo", default=None, dest="kb_repo",
                          help="integration KB repo (default: resolved knowledge dir)")
    p_fan_mq.add_argument("--integration-branch", default=None,
                          dest="integration_branch",
                          help="integration branch name (default: integration)")
    p_fan_mq.add_argument("--base", default=None,
                          help="base ref to create the package integration branch")
    p_fan_mq.add_argument("--kb-base", default=None, dest="kb_base",
                          help="base ref to create the KB integration branch")
    p_fan_mq.add_argument("--gate", action="append", default=None,
                          help="post-merge gate command (repeatable; overrides "
                               "the default steering+eval+test gates)")
    p_fan_mq.add_argument("--no-gates", action="store_true", dest="no_gates",
                          help="skip the post-merge gates")
    p_fan_mq.add_argument("--dry-run", action="store_true", dest="dry_run",
                          help="print the plan; integrate nothing")
    p_fan_mq.set_defaults(func=cmd_fanout_merge_queue)

    p_fan_td = fanout_sub.add_parser(
        "teardown", parents=[fmt_parent],
        help="remove merged lanes' worktrees + branches (refuses unmerged/dirty)")
    p_fan_td.add_argument("features", nargs="+", help="lane(s) to tear down")
    p_fan_td.add_argument("--repo", default=None,
                          help="package repo (default: this agentware repo)")
    p_fan_td.add_argument("--kb-repo", default=None, dest="kb_repo",
                          help="KB repo (default: the resolved knowledge dir)")
    p_fan_td.add_argument("--integration-branch", default=None,
                          dest="integration_branch",
                          help="integration branch for the merged check (default: integration)")
    p_fan_td.add_argument("--force", action="store_true",
                          help="remove even unmerged/dirty lanes (R-GIT-02 override)")
    p_fan_td.add_argument("--dry-run", action="store_true", dest="dry_run",
                          help="print what would be removed; remove nothing")
    p_fan_td.set_defaults(func=cmd_fanout_teardown)

    return parser


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
