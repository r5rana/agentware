#!/usr/bin/env python3
"""agentware — deterministic CLI toolkit for an agentware workspace.

The LLM decides WHAT to do; this toolkit does it correctly. It is the ONLY
writer of structured data (the knowledge index.json, FEATURES.md, learning
files).

agentware ships ZERO personal data. The knowledge base lives at a user-chosen
directory OUTSIDE this repo, resolved (in order) from:

  1. the AGENTWARE_KNOWLEDGE_DIR environment variable, then
  2. the AGENTWARE_KNOWLEDGE_DIR=... line in ~/.agentware/config.env, then
  3. (legacy) the same line in <repo>/.agentware/config.env

Run `scripts/agentware init --knowledge-dir <path>` once to create the
directory structure, seed an empty index, and write the config file. Every
other knowledge command resolves the directory automatically. All paths stored
in the index are RELATIVE to the knowledge directory so the index stays
portable.
"""

import argparse
import datetime
import glob
import json
import math
import os
import re
import shutil
import subprocess
import sys
import time

# --- Repo + knowledge-dir resolution ----------------------------------------
# Repo root = the parent of the scripts/ dir that holds this file. Computed from
# __file__ so the toolkit works regardless of the caller's cwd.
REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
# The config pointer lives in the user's HOME by default so the orchestrator
# package itself stays pristine (read-only) across projects. A repo-local config
# is honoured as a legacy/override fallback. `init` always writes HOME_CONFIG.
HOME_CONFIG = os.path.join(os.path.expanduser("~"), ".agentware", "config.env")
REPO_CONFIG = os.path.join(REPO_ROOT, ".agentware", "config.env")
CONFIG_PATHS = (HOME_CONFIG, REPO_CONFIG)
CONFIG_KEY = "AGENTWARE_KNOWLEDGE_DIR"

# KB auto-commit+push setting (feature 260625-kb-autocommit-default). Resolution
# precedence: the AGENTWARE_KB_AUTOCOMMIT env var -> config.env -> default ON.
# The resolved value is '1' (on) or '0' (off); the loop still only ACTS when the
# KB is a git work tree with an upstream (a non-tracked KB stays a clean no-op).
AUTOCOMMIT_KEY = "AGENTWARE_KB_AUTOCOMMIT"
AUTOCOMMIT_DEFAULT = "1"
_AUTOCOMMIT_OFF_TOKENS = ("0", "off", "no", "false", "disable", "disabled")
_AUTOCOMMIT_ON_TOKENS = ("1", "on", "yes", "true", "enable", "enabled")

# Knowledge-dir-relative locations (joined with the resolved knowledge dir).
INDEX_REL = "index.json"
LEARNINGS_REL = "learnings"
FEATURES_REL = "FEATURES.md"
SENTINEL_REL = ".initialized"
LOGS_SESSIONS_REL = os.path.join("logs", "sessions")
GITIGNORE_REL = ".gitignore"

# The KB .gitignore `init` scaffolds. `logs/` holds full session transcripts and
# is local-only: with KB autocommit ON by default, every run would otherwise
# commit+push transcripts to the remote (bloat + an unwanted disclosure for a
# security-first operator). Ignoring + untracking `logs/` keeps autocommit to
# KNOWLEDGE only (learnings, index, scorecard, MAIN) — never transcripts.
KB_GITIGNORE_MARKER = "logs/"
KB_GITIGNORE_CONTENT = (
    "# agentware knowledge base — ignored paths (scaffolded by `agentware init`)\n"
    "# Session transcripts/logs are local-only: NEVER committed or pushed. KB\n"
    "# autocommit only ever versions knowledge (learnings, index, scorecard, MAIN).\n"
    "logs/\n"
    "\n"
    "# OS / editor / tooling noise\n"
    ".DS_Store\n"
    "__pycache__/\n"
)

# Indexed knowledge categories scaffolded by `init` inside the knowledge dir.
KNOWLEDGE_SUBDIRS = ("learnings", "projects", "configurations", "prompts",
                     "references", "skills")

# Non-indexed dirs `init` also scaffolds in the knowledge dir: per-feature work
# artifacts (plans/worklogs/state) and append-only session logs. These hold the
# operator's project work + audit trail OUTSIDE the orchestrator package so the
# package stays read-only across projects.
NON_INDEXED_DIRS = ("work", "logs", os.path.join("logs", "sessions"))

# Single source of truth for knowledge categories. The index holds the USER's
# knowledge only — framework artifacts (skills, steering, the toolkit) ship with
# the repo and are documented in README/FEATURES, not in the per-user index.
CATEGORIES = (
    "learnings",
    "projects",
    "configurations",
    "prompts",
    "references",
    "skills",
)

# Files that are intentionally NEVER indexed (structural / generated). `index
# sync` must not report these as gaps, otherwise the report is pure noise.
SYNC_EXCLUDE_BASENAMES = ("MAIN.md", "FEATURES.md", "README.md")

# Maps a knowledge subdir to the canonical category + id prefix `index sync
# --fix` assigns to a newly discovered file.
SYNC_CATEGORY_RULES = (
    ("learnings/", "learnings", "learn"),
    ("projects/", "projects", "project"),
    ("configurations/", "configurations", "config"),
    ("prompts/", "prompts", "prompt"),
    ("references/", "references", "ref"),
    ("skills/", "skills", "skill"),
)

# --- Steering (Deterministic Steering Format) lint config --------------------
# These operate on the IN-REPO always-loaded steering, which is framework and
# ships with the clone — unrelated to the external knowledge dir.

# Allowed directive verbs for Deterministic Steering Format (DSF-2).
DSF_VERBS = ("MUST", "NEVER", "ALWAYS", "RUN", "ASK", "STOP", "READ", "IF")

# Banned hedge words for always-loaded steering (DSF-5).
DSF_BANNED_WORDS = (
    "should", "try", "consider", "ideally", "generally",
    "usually", "maybe", "prefer", "when possible", "as needed",
)

# Total character budget for always-loaded steering (DSF-budget).
STEERING_CHAR_BUDGET = 15000

# Always-loaded steering set under Claude Code: `CLAUDE.md` is auto-loaded and
# imports `@AGENTS.md` plus the files in `steering/`. The linter lints all of
# them so the always-on layer can never drift out of the Deterministic Steering
# Format. (The `@`-import lines in CLAUDE.md are bare paths, not bullets, so they
# are not treated as rules.)
STEERING_EXPLICIT = ("CLAUDE.md", "AGENTS.md")
STEERING_GLOB = os.path.join(REPO_ROOT, "steering", "*.md")

# DSF-6: every rule bullet carries a stable rule ID like R-KB-01.
DSF_RULE_ID_RE = re.compile(r"R-[A-Z]+-\d+")
# A lintable rule line is a markdown bullet (`-` or `*`). Numbered lists,
# headings, tables, blockquotes, code fences and prose are NOT rules.
DSF_BULLET_RE = re.compile(r"^\s*[-*]\s+(.+)$")

# Required fields every index entry must carry.
REQUIRED_FIELDS = ("id", "title", "category", "path", "tags", "summary")


# --- Knowledge-dir resolution ------------------------------------------------
def resolve_knowledge_dir():
    """Resolve the knowledge directory, or return None if unconfigured.

    Precedence: AGENTWARE_KNOWLEDGE_DIR env var, then the config.env file.
    Always returns an absolute, user-expanded path.
    """
    env = os.environ.get(CONFIG_KEY)
    if env and env.strip():
        return os.path.abspath(os.path.expanduser(env.strip()))
    for cfg in CONFIG_PATHS:
        if not os.path.isfile(cfg):
            continue
        try:
            with open(cfg, "r", encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if line.startswith("#") or "=" not in line:
                        continue
                    key, _, val = line.partition("=")
                    if key.strip() == CONFIG_KEY:
                        val = val.strip().strip('"').strip("'")
                        if val:
                            return os.path.abspath(os.path.expanduser(val))
        except OSError:
            continue
    return None


def _read_config_key(key):
    """Read KEY=VALUE from the first config.env that defines it (None if absent).

    Mirrors resolve_knowledge_dir's file precedence (HOME then REPO). Values may
    be quoted; surrounding quotes are stripped.
    """
    for cfg in CONFIG_PATHS:
        if not os.path.isfile(cfg):
            continue
        try:
            with open(cfg, "r", encoding="utf-8") as f:
                for line in f:
                    s = line.strip()
                    if s.startswith("#") or "=" not in s:
                        continue
                    k, _, val = s.partition("=")
                    if k.strip() == key:
                        return val.strip().strip('"').strip("'")
        except OSError:
            continue
    return None


def _parse_autocommit(raw):
    """Map a raw setting to '1'/'0', or None if empty/unset.

    Honors the "anything that isn't an explicit off-token is ON" contract so an
    unrecognized non-empty value never silently disables autocommit.
    """
    if raw is None:
        return None
    v = raw.strip().strip('"').strip("'").lower()
    if not v:
        return None
    return "0" if v in _AUTOCOMMIT_OFF_TOKENS else "1"


def _parse_autocommit_strict(raw):
    """Strict parse for `config --set-autocommit`: only recognized tokens.

    Returns '1'/'0' for known on/off tokens, else None (caller errors out).
    """
    v = (raw or "").strip().strip('"').strip("'").lower()
    if v in _AUTOCOMMIT_OFF_TOKENS:
        return "0"
    if v in _AUTOCOMMIT_ON_TOKENS:
        return "1"
    return None


def resolve_kb_autocommit():
    """Resolve the effective KB-autocommit setting as '1' (on) or '0' (off).

    Precedence: AGENTWARE_KB_AUTOCOMMIT env var -> config.env -> default ON.
    This is the SINGLE source of truth read by agentware.sh
    (`config --kb-autocommit-only`).
    """
    env = _parse_autocommit(os.environ.get(AUTOCOMMIT_KEY))
    if env is not None:
        return env
    cfg = _parse_autocommit(_read_config_key(AUTOCOMMIT_KEY))
    if cfg is not None:
        return cfg
    return AUTOCOMMIT_DEFAULT


def require_knowledge_dir():
    """Resolve the knowledge dir or print a uniform error and return None."""
    kdir = resolve_knowledge_dir()
    if not kdir:
        sys.stderr.write(
            "agentware: knowledge directory is not configured.\n"
            "  Run: scripts/agentware init --knowledge-dir <path>\n"
            "  Or set the AGENTWARE_KNOWLEDGE_DIR environment variable.\n")
        return None
    if not os.path.isdir(kdir):
        sys.stderr.write(
            "agentware: configured knowledge directory does not exist: %s\n"
            "  Run: scripts/agentware init --knowledge-dir %s\n" % (kdir, kdir))
        return None
    return kdir


def index_path(kdir):
    return os.path.join(kdir, INDEX_REL)


def features_path(kdir):
    return os.path.join(kdir, FEATURES_REL)


def learnings_dir(kdir):
    return os.path.join(kdir, LEARNINGS_REL)


# --- Shared index helpers ----------------------------------------------------
def load_index(kdir):
    """Load <kdir>/index.json. Returns (data, error)."""
    path = index_path(kdir)
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except FileNotFoundError:
        return None, "index file not found: %s (run 'agentware init')" % path
    except json.JSONDecodeError as exc:
        return None, "invalid JSON in %s: %s" % (path, exc)
    return data, None


def save_index(kdir, data):
    """Write <kdir>/index.json canonically (2-space indent, trailing newline)."""
    with open(index_path(kdir), "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
        f.write("\n")


def _today():
    import datetime
    return datetime.date.today().isoformat()


def _is_valid_date(s):
    """True iff `s` is a strict YYYY-MM-DD calendar date (stdlib only)."""
    if not isinstance(s, str):
        return False
    import datetime
    try:
        datetime.date.fromisoformat(s)
    except ValueError:
        return False
    # fromisoformat is lenient about some forms across versions; pin the shape.
    return bool(re.match(r"^\d{4}-\d{2}-\d{2}$", s))


def entry_last_verified(entry):
    """Effective freshness date for an entry.

    Back-compat: entries without an explicit `last_verified` are treated as
    `last_verified == created` (R-FAIL-08 freshness without a forced migration).
    """
    if not isinstance(entry, dict):
        return None
    lv = entry.get("last_verified")
    if isinstance(lv, str) and lv:
        return lv
    return entry.get("created")


def _entry_key(entry):
    return (entry.get("category") or "", entry.get("id") or "")


def insert_entry_sorted(entries, entry):
    """Insert `entry` at its (category, id) sorted slot (insertion-only)."""
    key = _entry_key(entry)
    for i, existing in enumerate(entries):
        if _entry_key(existing) > key:
            entries.insert(i, entry)
            return
    entries.append(entry)


def add_tags_to_map(tags_map, entry_id, tag_list):
    for t in tag_list:
        bucket = tags_map.get(t)
        if bucket is None:
            tags_map[t] = [entry_id]
        elif entry_id not in bucket:
            bucket.append(entry_id)


def remove_tags_from_map(tags_map, entry_id):
    for t in list(tags_map.keys()):
        bucket = tags_map.get(t)
        if isinstance(bucket, list) and entry_id in bucket:
            bucket[:] = [i for i in bucket if i != entry_id]
            if not bucket:
                del tags_map[t]


def parse_tags(raw):
    out = []
    for part in (raw or "").split(","):
        t = part.strip()
        if t and t not in out:
            out.append(t)
    return out


def validate_index(kdir, data):
    """Return a list of error strings for the index data (empty == valid).

    All entry paths are interpreted RELATIVE to the knowledge dir.
    """
    errors = []
    if not isinstance(data, dict):
        return ["index root is not a JSON object"]

    entries = data.get("entries")
    tags = data.get("tags")
    if not isinstance(entries, list):
        errors.append("'entries' is missing or not a list")
        entries = []
    if not isinstance(tags, dict):
        errors.append("'tags' is missing or not an object")
        tags = {}

    seen_ids = {}
    seen_paths = {}

    for i, entry in enumerate(entries):
        if not isinstance(entry, dict):
            errors.append("entry #%d is not an object" % i)
            continue
        eid = entry.get("id")
        label = eid if eid else "#%d" % i

        for field in REQUIRED_FIELDS:
            if field not in entry:
                errors.append("entry '%s' missing required field '%s'" % (label, field))

        cat = entry.get("category")
        if cat is not None and cat not in CATEGORIES:
            errors.append("entry '%s' has invalid category '%s'" % (label, cat))

        path = entry.get("path")
        if path:
            if not os.path.exists(os.path.join(kdir, path)):
                errors.append("entry '%s' path does not exist: %s" % (label, path))
            if path in seen_paths:
                errors.append("duplicate path '%s' (entries '%s' and '%s')"
                              % (path, seen_paths[path], label))
            else:
                seen_paths[path] = label

        if eid:
            if eid in seen_ids:
                errors.append("duplicate id '%s'" % eid)
            else:
                seen_ids[eid] = entry

        etags = entry.get("tags")
        if etags is not None and not isinstance(etags, list):
            errors.append("entry '%s' tags is not a list" % label)

        # Optional `last_verified` (freshness). Back-compat: absent is fine
        # (treated as == created). When present it MUST be a YYYY-MM-DD date.
        lv = entry.get("last_verified")
        if lv is not None and not _is_valid_date(lv):
            errors.append("entry '%s' last_verified is not YYYY-MM-DD: %r"
                          % (label, lv))

    # Tag map bidirectional consistency: entry.tags -> tags map.
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        eid = entry.get("id")
        etags = entry.get("tags")
        if not isinstance(etags, list):
            continue
        for t in etags:
            ids = tags.get(t)
            if not isinstance(ids, list) or eid not in ids:
                errors.append("tag map missing id '%s' under tag '%s'" % (eid, t))

    # Tag map bidirectional consistency: tags map -> entry.tags.
    for t, ids in tags.items():
        if not isinstance(ids, list):
            errors.append("tag '%s' is not a list" % t)
            continue
        if len(ids) == 0:
            errors.append("tag '%s' has an empty entry list" % t)
        for eid in ids:
            entry = seen_ids.get(eid)
            if entry is None:
                errors.append("tag '%s' references unknown id '%s'" % (t, eid))
            elif t not in (entry.get("tags") or []):
                errors.append("entry '%s' does not list tag '%s' (back-ref mismatch)"
                              % (eid, t))

    return errors


def _do_add(kdir, data, eid, title, category, path, tag_list, summary,
            created=None, last_verified=None):
    """Shared add core. Validates BEFORE mutating; returns (entry, error)."""
    entries = data.setdefault("entries", [])
    tags_map = data.setdefault("tags", {})

    if category not in CATEGORIES:
        return None, "invalid category '%s' (allowed: %s)" % (
            category, ", ".join(CATEGORIES))
    if not os.path.exists(os.path.join(kdir, path)):
        return None, "path does not exist (relative to knowledge dir): %s" % path
    if any(e.get("id") == eid for e in entries):
        return None, "duplicate id '%s'" % eid
    if any(e.get("path") == path for e in entries):
        return None, "path already indexed: %s" % path
    if created is not None and not _is_valid_date(created):
        return None, "created is not YYYY-MM-DD: %r" % created
    if last_verified is not None and not _is_valid_date(last_verified):
        return None, "last_verified is not YYYY-MM-DD: %r" % last_verified

    entry = {
        "id": eid,
        "title": title,
        "category": category,
        "path": path,
        "tags": tag_list,
        "created": created or _today(),
        "summary": summary,
    }
    # Optional freshness field: store ONLY when explicitly provided so the 36
    # legacy entries stay byte-stable (absent == created via entry_last_verified).
    if last_verified is not None:
        entry["last_verified"] = last_verified
    insert_entry_sorted(entries, entry)
    add_tags_to_map(tags_map, eid, tag_list)
    return entry, None


def indexed_paths(data):
    return {e.get("path") for e in (data.get("entries") or [])
            if isinstance(e, dict) and e.get("path")}


def _is_sync_candidate(path):
    """True if `path` (knowledge-dir-relative) is an indexable *.md gap."""
    p = path.replace(os.sep, "/")
    base = os.path.basename(p)
    parts = p.split("/")
    if base in SYNC_EXCLUDE_BASENAMES:
        return False
    if "templates" in parts:
        return False
    # Section roster `<section>/index.md` (exactly 2 parts) is a human roster.
    if base == "index.md" and len(parts) == 2:
        return False
    return True


def scan_unindexed(kdir, data):
    """Return sorted unindexed indexable *.md files (knowledge-dir-relative)."""
    have = indexed_paths(data)
    found = []
    for sub in KNOWLEDGE_SUBDIRS:
        d = os.path.join(kdir, sub)
        if not os.path.isdir(d):
            continue
        for root, _dirs, files in os.walk(d):
            for fn in files:
                if not fn.endswith(".md"):
                    continue
                rel = os.path.relpath(os.path.join(root, fn), kdir).replace(os.sep, "/")
                if rel in have:
                    continue
                if _is_sync_candidate(rel):
                    found.append(rel)
    return sorted(set(found))


def _infer_category(path):
    p = path.replace(os.sep, "/")
    for prefix, category, _id_prefix in SYNC_CATEGORY_RULES:
        if p.startswith(prefix):
            return category
    return "references"


def _suggest_id(path):
    p = path.replace(os.sep, "/")
    category = _infer_category(p)
    id_prefix = "ref"
    for prefix, cat, ip in SYNC_CATEGORY_RULES:
        if cat == category:
            id_prefix = ip
            break
    stem = p[:-3] if p.endswith(".md") else p
    base = os.path.basename(stem)
    if base in ("SKILL", "index"):
        base = os.path.basename(os.path.dirname(stem))
    slug = re.sub(r"[^a-z0-9]+", "-", base.lower()).strip("-")
    return "%s-%s" % (id_prefix, slug)


def _suggest_title(path):
    eid = _suggest_id(path)
    parts = eid.split("-")[1:] or eid.split("-")
    return " ".join(w.capitalize() for w in parts)


# --- init / config -----------------------------------------------------------
_CONFIG_HEADER = (
    "# agentware config — machine-specific, points at this operator's",
    "# EXTERNAL knowledge base so the orchestrator package stays read-only.",
)


def _set_config_value(key, value):
    """Upsert KEY=VALUE in HOME_CONFIG, preserving every other line.

    Creates the file (with the standard header) if absent. Replaces the FIRST
    existing definition of KEY and drops any later duplicates, so the setting is
    written exactly once. Kept in HOME (not the repo) so the package stays pristine.
    """
    os.makedirs(os.path.dirname(HOME_CONFIG), exist_ok=True)
    if os.path.isfile(HOME_CONFIG):
        with open(HOME_CONFIG, "r", encoding="utf-8") as f:
            lines = f.read().splitlines()
    else:
        lines = list(_CONFIG_HEADER)
    out, replaced = [], False
    for line in lines:
        s = line.strip()
        if not s.startswith("#") and "=" in s and s.partition("=")[0].strip() == key:
            if not replaced:
                out.append("%s=%s" % (key, value))
                replaced = True
            # else: drop the duplicate definition
        else:
            out.append(line)
    if not replaced:
        out.append("%s=%s" % (key, value))
    with open(HOME_CONFIG, "w", encoding="utf-8") as f:
        f.write("\n".join(out) + "\n")


def _write_config(kdir):
    """Pin the knowledge dir in ~/.agentware/config.env (preserving other keys).

    Kept in HOME (not the repo) so the orchestrator package stays pristine.
    """
    _set_config_value(CONFIG_KEY, kdir)


def _ensure_kb_gitignore(kdir):
    """Ensure the KB `.gitignore` exists and ignores `logs/` (transcripts).

    Idempotent: creates the file with the standard content if absent; if a
    `.gitignore` already exists but has no `logs/` rule, appends one (so an
    existing KB scaffolded before this rule still gets transcripts excluded).
    Returns 'created' | 'appended' | 'kept' describing what it did.
    """
    path = os.path.join(kdir, GITIGNORE_REL)
    if not os.path.exists(path):
        with open(path, "w", encoding="utf-8") as f:
            f.write(KB_GITIGNORE_CONTENT)
        return "created"
    with open(path, "r", encoding="utf-8") as f:
        existing = f.read()
    # A bare `logs/` line (ignoring surrounding whitespace) means it's covered.
    has_rule = any(ln.strip().rstrip("/") == "logs"
                   for ln in existing.splitlines())
    if has_rule:
        return "kept"
    sep = "" if existing.endswith("\n") or existing == "" else "\n"
    with open(path, "a", encoding="utf-8") as f:
        f.write(sep + "\n# Session transcripts/logs are local-only "
                "(added by agentware).\n" + KB_GITIGNORE_MARKER + "\n")
    return "appended"


def cmd_init(args):
    """Scaffold the external knowledge dir + seed an empty index + write config.

    Idempotent: re-running against an existing dir leaves entries intact and
    only fills in any missing structure. Does NOT write the .initialized
    sentinel — onboarding writes that after the interview.
    """
    kdir = os.path.abspath(os.path.expanduser(args.knowledge_dir))
    as_json = getattr(args, "format", "text") == "json"

    # KNOWLEDGE_SUBDIRS are indexed knowledge categories; NON_INDEXED_DIRS are
    # the operator's work artifacts (plans/worklogs) and append-only logs that
    # the orchestrator writes here INSTEAD of into the package.
    created_dirs = []
    for sub in ("",) + KNOWLEDGE_SUBDIRS + NON_INDEXED_DIRS:
        d = os.path.join(kdir, sub) if sub else kdir
        if not os.path.isdir(d):
            os.makedirs(d, exist_ok=True)
            created_dirs.append(d)

    # Seed an empty valid index only if absent (never clobber real data).
    ipath = index_path(kdir)
    seeded = False
    if not os.path.exists(ipath):
        save_index(kdir, {"entries": [], "tags": {}})
        seeded = True

    # Drop a category roster placeholder so each subdir is browsable.
    for sub in KNOWLEDGE_SUBDIRS:
        roster = os.path.join(kdir, sub, "index.md")
        if not os.path.exists(roster):
            with open(roster, "w", encoding="utf-8") as f:
                f.write("# %s\n\n_Index of %s. Entries are registered in "
                        "`../index.json` via `scripts/agentware`._\n"
                        % (sub.capitalize(), sub))

    # Install the entry templates INTO the operator's dir so their working
    # instance is self-contained and they never have to reach back into the
    # package to scaffold a learning / project / skill entry.
    installed_templates = []
    src_templates = os.path.join(REPO_ROOT, "templates")
    dst_templates = os.path.join(kdir, "templates")
    if os.path.isdir(src_templates):
        os.makedirs(dst_templates, exist_ok=True)
        for fn in sorted(os.listdir(src_templates)):
            if not fn.endswith(".md"):
                continue
            dst = os.path.join(dst_templates, fn)
            if not os.path.exists(dst):
                shutil.copyfile(os.path.join(src_templates, fn), dst)
                installed_templates.append(fn)

    # Scaffold the KB .gitignore so transcripts (logs/) are never committed/pushed
    # once autocommit is ON by default.
    gitignore_action = _ensure_kb_gitignore(kdir)

    _write_config(kdir)

    if as_json:
        json.dump({"ok": True, "knowledge_dir": kdir, "seeded_index": seeded,
                   "created_dirs": created_dirs, "installed_templates": installed_templates,
                   "gitignore": gitignore_action, "config": HOME_CONFIG},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("INITIALIZED knowledge dir: %s" % kdir)
        print("  index:  %s%s" % (ipath, " (seeded)" if seeded else " (kept)"))
        print("  config: %s" % HOME_CONFIG)
        print("  work:   %s/work/<feature>/   logs: %s/logs/" % (kdir, kdir))
        print("  .gitignore: %s (logs/ excluded — transcripts never committed)"
              % gitignore_action)
        if installed_templates:
            print("  templates installed: %s" % ", ".join(installed_templates))
        print("Next: run onboarding (.claude/skills/onboarding/SKILL.md) to "
              "personalize MAIN.md and write the .initialized sentinel.")
    return 0


def cmd_config(args):
    """Show resolved config; optionally set/print the KB-autocommit setting.

    Exit 1 if the knowledge dir is unconfigured (for the default/dir views).
    `--set-autocommit` and `--kb-autocommit-only` never require a knowledge dir.
    """
    as_json = getattr(args, "format", "text") == "json"

    # --set-autocommit on|off: persist to ~/.agentware/config.env, then report.
    set_val = getattr(args, "set_autocommit", None)
    if set_val is not None:
        norm = _parse_autocommit_strict(set_val)
        if norm is None:
            sys.stderr.write(
                "agentware: invalid --set-autocommit value %r (use on|off|1|0|yes|no)\n"
                % set_val)
            return 2
        _set_config_value(AUTOCOMMIT_KEY, norm)
        if as_json:
            json.dump({"ok": True, "kb_autocommit": norm, "config": HOME_CONFIG},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            print("Set %s=%s in %s (KB autocommit %s)"
                  % (AUTOCOMMIT_KEY, norm, HOME_CONFIG,
                     "ON" if norm == "1" else "OFF"))
        return 0

    # --kb-autocommit-only: bare resolved setting for shell consumers (the loop).
    if getattr(args, "kb_autocommit_only", False):
        print(resolve_kb_autocommit())
        return 0

    kdir = resolve_knowledge_dir()
    autocommit = resolve_kb_autocommit()
    initialized = bool(kdir) and os.path.isfile(os.path.join(kdir, SENTINEL_REL))
    if as_json:
        json.dump({"knowledge_dir": kdir, "configured": bool(kdir),
                   "initialized": initialized, "kb_autocommit": autocommit},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return 0 if kdir else 1
    if getattr(args, "knowledge_dir_only", False):
        # Bare path for shell consumers (hooks). Empty output if unconfigured.
        if kdir:
            print(kdir)
        return 0 if kdir else 1
    if kdir:
        print("knowledge_dir: %s" % kdir)
        print("initialized:   %s" % ("yes" if initialized else "no"))
        print("kb_autocommit: %s" % ("on" if autocommit == "1" else "off"))
        return 0
    print("knowledge_dir: <unconfigured>")
    print("kb_autocommit: %s" % ("on" if autocommit == "1" else "off"))
    return 1


# --- index / query / learn / features / worklog ------------------------------
def cmd_index_add(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    entry, add_err = _do_add(
        kdir, data, args.id, args.title, args.category, args.path,
        parse_tags(args.tags), args.summary, args.created,
        getattr(args, "last_verified", None))
    if add_err is not None:
        sys.stderr.write("agentware: %s\n" % add_err)
        return 1

    # Ensure the registered (pre-existing) file is frontmatter-complete: if it
    # lacks a frontmatter block, prepend one built from the entry + defaults so
    # the file remains the rebuildable source of truth (C-1). Never overwrite an
    # existing block (idempotent); never edit the body.
    backfilled = ensure_entry_frontmatter(kdir, entry)

    save_index(kdir, data)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "added": entry, "frontmatter_backfilled": backfilled},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("ADDED entry '%s' (category=%s, path=%s)%s"
              % (args.id, args.category, args.path,
                 " [frontmatter backfilled]" if backfilled else ""))
    return 0


def cmd_index_remove(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    entries = data.setdefault("entries", [])
    tags_map = data.setdefault("tags", {})
    match = next((e for e in entries if e.get("id") == args.id), None)
    if match is None:
        sys.stderr.write("agentware: id not found: %s\n" % args.id)
        return 1

    entries[:] = [e for e in entries if e.get("id") != args.id]
    remove_tags_from_map(tags_map, args.id)
    save_index(kdir, data)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "removed": match}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("REMOVED entry '%s' (file on disk left untouched)" % args.id)
    return 0


def cmd_index_validate(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    errors = [err] if err is not None else validate_index(kdir, data)
    ok = len(errors) == 0
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": ok, "errors": errors}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        if ok:
            print("VALIDATION PASSED: index.json is consistent.")
        else:
            print("VALIDATION FAILED (%d error(s)):" % len(errors))
            for e in errors:
                print(" -", e)
    return 0 if ok else 1


def cmd_index_sync(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    candidates = scan_unindexed(kdir, data)
    as_json = getattr(args, "format", "text") == "json"

    if not args.fix:
        report = [{"path": p, "suggested_id": _suggest_id(p),
                   "suggested_category": _infer_category(p)} for p in candidates]
        if as_json:
            json.dump({"unindexed": report, "count": len(report)},
                      sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
        else:
            if not report:
                print("SYNC: no unindexed *.md files in the knowledge dir.")
            else:
                print("SYNC: %d unindexed *.md file(s) (dry-run; pass --fix):"
                      % len(report))
                for r in report:
                    print("  %s  ->  id=%s category=%s"
                          % (r["path"], r["suggested_id"], r["suggested_category"]))
        return 0

    added, failures = [], []
    interactive = sys.stdin.isatty()
    for path in candidates:
        category = _infer_category(path)
        eid = _suggest_id(path)
        title = _suggest_title(path)
        if interactive:
            tags_in = input("tags for %s (comma-sep) [%s]: " % (path, category)).strip() \
                or category
            summary_in = input("summary for %s [%s]: " % (path, title)).strip() \
                or title
        else:
            tags_in = category
            summary_in = title
        entry, add_err = _do_add(
            kdir, data, eid, title, category, path, parse_tags(tags_in), summary_in)
        if add_err is not None:
            failures.append({"path": path, "error": add_err})
        else:
            added.append(entry)

    if added:
        save_index(kdir, data)
    if as_json:
        json.dump({"ok": not failures, "added": added, "failures": failures},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        for e in added:
            print("ADDED entry '%s' (category=%s, path=%s)"
                  % (e["id"], e["category"], e["path"]))
        for f in failures:
            sys.stderr.write("agentware: could not add %s: %s\n"
                             % (f["path"], f["error"]))
        if not added and not failures:
            print("SYNC: nothing to fix; all *.md files already indexed.")
    return 1 if failures else 0


def cmd_index_migrate(args):
    """One-time backfill: prepend frontmatter to every indexed entry file.

    Bootstraps the rebuildable source of truth (C-1): each entry's `.md` gets a
    frontmatter block derived from its `index.json` row + defaults
    (author=operator handle, source=agent, last_verified=created). PREPEND only —
    bodies are never edited. Idempotent: a file that already carries frontmatter
    is skipped, so re-running is a no-op (reports 0 changed).
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    author = _operator_handle(kdir)
    migrated, skipped, missing = [], [], []
    for entry in data.get("entries") or []:
        if not isinstance(entry, dict):
            continue
        rel = entry.get("path")
        if not rel or not os.path.exists(os.path.join(kdir, rel)):
            missing.append(rel)
            continue
        if ensure_entry_frontmatter(kdir, entry, author=author,
                                    source=DEFAULT_ENTRY_SOURCE):
            migrated.append(rel)
        else:
            skipped.append(rel)

    as_json = getattr(args, "format", "text") == "json"
    if as_json:
        json.dump({"ok": not missing, "migrated": migrated, "skipped": skipped,
                   "missing": missing, "migrated_count": len(migrated),
                   "skipped_count": len(skipped)},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("MIGRATE: %d file(s) gained frontmatter, %d already had it."
              % (len(migrated), len(skipped)))
        for p in migrated:
            print("  + %s" % p)
        for p in missing:
            sys.stderr.write("agentware: indexed path missing on disk: %s\n" % p)
    return 1 if missing else 0


def scan_entry_files(kdir):
    """All indexable entry *.md paths (knowledge-dir-relative), sorted.

    Same candidate rule as `index sync` (2-part `<section>/index.md` rosters and
    structural files are excluded), but WITHOUT the already-indexed filter — this
    is the full set of files `index rebuild` derives the index from.
    """
    found = []
    for sub in KNOWLEDGE_SUBDIRS:
        d = os.path.join(kdir, sub)
        if not os.path.isdir(d):
            continue
        for root, _dirs, files in os.walk(d):
            for fn in files:
                if not fn.endswith(".md"):
                    continue
                rel = os.path.relpath(os.path.join(root, fn), kdir).replace(os.sep, "/")
                if _is_sync_candidate(rel):
                    found.append(rel)
    return sorted(set(found))


def build_index_from_frontmatter(kdir):
    """Reconstruct the index dict from per-entry frontmatter alone.

    Returns (data, errors). Deterministic: entries are (category, id)-sorted and
    the tags map is rebuilt from that stable order, so identical inputs yield
    byte-identical output (C-2). `path` is derived from each file's location;
    every other column comes from its frontmatter (C-1).
    """
    entries, errors = [], []
    for rel in scan_entry_files(kdir):
        fm = read_entry_frontmatter(os.path.join(kdir, rel))
        eid = fm.get("id")
        if not eid:
            errors.append("missing frontmatter id (un-migrated?): %s" % rel)
            continue
        category = fm.get("category") or _infer_category(rel)
        created = fm.get("created") or _today()
        row = {
            "id": eid,
            "title": fm.get("title") or "",
            "category": category,
            "path": rel,
            "tags": list(fm.get("tags") or []),
            "created": created,
            "summary": fm.get("summary") or "",
            "last_verified": fm.get("last_verified") or created,
        }
        insert_entry_sorted(entries, row)
    tags_map = {}
    for e in entries:
        add_tags_to_map(tags_map, e["id"], e["tags"])
    return {"entries": entries, "tags": tags_map}, errors


def _roster_link(sub, rel_path):
    """Subdir-relative link target for a roster row (e.g. projects/x/index.md -> x/index.md)."""
    prefix = sub + "/"
    return rel_path[len(prefix):] if rel_path.startswith(prefix) else rel_path


def _render_roster(sub, entries):
    """Deterministic, derived `<sub>/index.md` roster (regenerated by rebuild)."""
    rows = [e for e in entries if e.get("category") == sub]
    out = ["# %s\n" % sub.capitalize(),
           "> Auto-generated roster — DO NOT edit. Source of truth is each entry's "
           "frontmatter; regenerate with `scripts/agentware index rebuild`.\n"]
    if not rows:
        out.append("_No entries yet._\n")
    else:
        out.append("| Title | Path | Summary |")
        out.append("|-------|------|---------|")
        for e in rows:
            link = _roster_link(sub, e.get("path") or "")
            out.append("| **%s** | [%s](%s) | %s |"
                       % (e.get("title") or "", link, link, e.get("summary") or ""))
        out.append("")
    return "\n".join(out) + "\n"


def rebuild_kb(kdir):
    """Regenerate index.json + rosters + FEATURES.md from frontmatter at `kdir`.

    Path-parameterized core of `index rebuild` so callers (the CLI command AND
    the git-sync push resolver, Task 4.1) can rebuild ANY knowledge dir — e.g. a
    throwaway clone mid-rebase — not just the resolved operator KB. Returns
    `(data, rosters, errors)`: on any frontmatter/validation error `data` is None,
    `errors` is the non-empty reason list, and NOTHING is written (the caller
    decides how to surface the failure). Deterministic + idempotent (C-1/C-2).
    """
    data, errors = build_index_from_frontmatter(kdir)
    if errors:
        return None, [], errors
    verrs = validate_index(kdir, data)
    if verrs:
        return None, [], ["rebuild produced an invalid index: %s" % e
                          for e in verrs]

    save_index(kdir, data)
    rosters = []
    for sub in KNOWLEDGE_SUBDIRS:
        d = os.path.join(kdir, sub)
        if not os.path.isdir(d):
            continue
        with open(os.path.join(d, "index.md"), "w", encoding="utf-8") as f:
            f.write(_render_roster(sub, data["entries"]))
        rosters.append("%s/index.md" % sub)
    with open(features_path(kdir), "w", encoding="utf-8") as f:
        f.write(_render_features(data))
    return data, rosters, []


def cmd_index_rebuild(args):
    """Regenerate index.json + `<sub>/index.md` rosters + FEATURES.md from frontmatter.

    The index is a DERIVED cache: this reconstructs it from the per-entry markdown
    frontmatter alone (C-1), deterministically and idempotently (C-2). It is the
    conflict-safe resolver for the derived files — never hand-edit them (C-3).
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, rosters, errors = rebuild_kb(kdir)
    if errors:
        for e in errors:
            sys.stderr.write("agentware: rebuild: %s\n" % e)
        return 1

    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "entries": len(data["entries"]),
                   "rosters": rosters, "features": features_path(kdir)},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("REBUILT index.json (%d entries) + %d roster(s) + FEATURES.md "
              "from frontmatter." % (len(data["entries"]), len(rosters)))
    return 0


def cmd_query(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    entries = data.get("entries") or []
    tags_map = data.get("tags") or {}
    by_id, by_path = {}, {}
    for e in entries:
        if not isinstance(e, dict):
            continue
        eid = e.get("id")
        if eid is not None and eid not in by_id:
            by_id[eid] = e
        path = e.get("path")
        if path is not None and path not in by_path:
            by_path[path] = e

    results = []
    if args.id is not None:
        hit = by_id.get(args.id)
        if hit is not None:
            results = [hit]
    elif args.path is not None:
        hit = by_path.get(args.path)
        if hit is not None:
            results = [hit]
    elif args.tag is not None:
        for eid in tags_map.get(args.tag, []):
            hit = by_id.get(eid)
            if hit is not None:
                results.append(hit)
    elif args.category is not None:
        results = [e for e in entries
                   if isinstance(e, dict) and e.get("category") == args.category]

    json.dump(results, sys.stdout, ensure_ascii=False, indent=2)
    sys.stdout.write("\n")
    return 0


def _topic_to_title(topic):
    words = re.split(r"[^a-zA-Z0-9]+", topic)
    return " ".join(w.capitalize() for w in words if w) or topic


# --- Entry frontmatter (machine-readable source of truth) --------------------
# Per-entry `.md` files carry a leading YAML frontmatter block that is the SOURCE
# OF TRUTH for the index. `index.json` is a DERIVED cache (`index rebuild`
# reconstructs it from frontmatter alone). The format is a RESTRICTED,
# deterministic YAML subset (C-5): a block delimited by `---` lines holding flat
# `key: value` scalars plus one inline list (`tags: [a, b]`). Emit + parse are
# hand-rolled, stdlib only — NO PyYAML (preserves the zero-dependency moat).

# Canonical field order in every emitted block.
FRONTMATTER_FIELDS = ("id", "title", "category", "tags", "created",
                      "summary", "author", "source", "last_verified")
# The index columns derivable from frontmatter (tags handled separately).
_FM_INDEX_SCALARS = ("id", "title", "category", "created", "summary")

DEFAULT_ENTRY_SOURCE = "agent"


def _operator_handle(kdir):
    """Best-effort operator handle for the `author` default. Stdlib only.

    Parses `**Handle**:` (then `**Operator**:`) out of the KB MAIN.md. Falls back
    to 'operator' so the writer never blocks on a missing profile.
    """
    try:
        with open(os.path.join(kdir, "MAIN.md"), "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return "operator"
    for pat in (r"\*\*Handle\*\*:\s*([^\s·|]+)", r"\*\*Operator\*\*:\s*([^\s·|]+)"):
        m = re.search(pat, text)
        if m:
            return m.group(1).strip()
    return "operator"


# --- Personal-data leak guard (R-LOC-03) -------------------------------------
# Directories NEVER scanned for operator identity: VCS metadata, the machine-
# local config (it legitimately stores the KB path, which contains HOME),
# spawn/prompt logs, caches, and vendored deps. This mirrors .gitignore so the
# guard only ever inspects what the package actually ships/pushes.
PERSONAL_SCAN_EXCLUDE_DIRS = (
    ".git", ".agentware", ".agentware-logs", "__pycache__",
    ".venv", "node_modules", ".idea", ".vscode",
)
# Generic / fallback handles that are NOT personal data. Scanning for these
# would match framework prose everywhere; "operator" is also the _operator_handle
# fallback. Compared case-insensitively.
_GENERIC_HANDLES = ("operator", "user", "handle", "admin")
# Email-shaped token, used to lift an operator email out of MAIN.md if present.
_EMAIL_RE = re.compile(r"[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}")


def _operator_email(kdir):
    """Best-effort operator email parsed from the KB MAIN.md, or None.

    Reads the LIVE profile at runtime (hardcodes nothing). Returns the first
    email-shaped token found in MAIN.md, else None.
    """
    try:
        with open(os.path.join(kdir, "MAIN.md"), "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return None
    m = _EMAIL_RE.search(text)
    return m.group(0) if m else None


def operator_identity_strings(kdir):
    """Resolve the LIVE operator identity to the set of literal strings whose
    presence in the package tree would be a personal-data leak (R-LOC-03).

    Resolved entirely at runtime — hardcodes nothing — so the package still ships
    zero personal data. Sources: the handle (MAIN.md/config), the email (MAIN.md,
    if present), and the operator HOME path. Generic/fallback handles are dropped
    (they would match framework prose), as are tokens shorter than 3 chars.
    """
    strings = set()
    handle = _operator_handle(kdir)
    if handle and handle.lower() not in _GENERIC_HANDLES:
        strings.add(handle)
    email = _operator_email(kdir)
    if email:
        strings.add(email)
    home = os.path.expanduser("~")
    if home and home not in ("", "/", "~"):
        strings.add(home)
    return {s for s in strings if len(s) >= 3}


def _package_files(root):
    """Yield (abspath, relpath) for the files that make up the package at `root`.

    Prefers `git ls-files` so the guard inspects EXACTLY what the package
    ships/pushes — which naturally excludes machine-local, gitignored files
    (e.g. `.claude/settings.local.json`, `.agentware/`, `.agentware-logs/`,
    caches). Falls back to a pruned filesystem walk when `root` is not a git work
    tree (e.g. the unit-test temp dirs).
    """
    try:
        proc = subprocess.run(
            ["git", "-C", root, "ls-files", "-z"],
            stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        if proc.returncode == 0:
            for rel in proc.stdout.decode("utf-8", "replace").split("\0"):
                if rel:
                    yield os.path.join(root, rel), rel
            return
    except OSError:
        pass
    kdir = resolve_knowledge_dir()
    kdir_abs = os.path.abspath(kdir) if kdir else None
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [
            d for d in dirnames
            if d not in PERSONAL_SCAN_EXCLUDE_DIRS
            and not (kdir_abs and os.path.abspath(
                os.path.join(dirpath, d)) == kdir_abs)
        ]
        for name in filenames:
            fpath = os.path.join(dirpath, name)
            yield fpath, os.path.relpath(fpath, root)


def scan_personal_data(root, needles):
    """Scan the package's files under `root` for any of the literal `needles`.

    Returns a sorted list of human-readable hit strings (empty list == clean).
    Inspects only what the package ships (see `_package_files`) and silently
    skips non-text/binary files (decode errors). Read-only (INV-2).
    """
    needles = [n for n in (needles or []) if n]
    if not needles:
        return []
    hits = []
    for fpath, rel in _package_files(root):
        try:
            with open(fpath, "r", encoding="utf-8") as f:
                lines = f.readlines()
        except (OSError, UnicodeDecodeError):
            continue
        for i, line in enumerate(lines, 1):
            for n in needles:
                if n in line:
                    hits.append(
                        "%s:%d leaks operator identity %r" % (rel, i, n))
    hits.sort()
    return hits


def _fm_needs_quote(s):
    """True iff a scalar string must be double-quoted to survive round-trip."""
    if s == "":
        return True
    if s != s.strip():
        return True
    if s[0] in "\"'[]{}>|*&!#%@`,?:-":
        return True
    # A colon or hash mid-value can change YAML meaning; quote to be safe.
    return ":" in s or "#" in s


def _fm_quote(s):
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def _fm_emit_scalar(value):
    s = "" if value is None else str(value)
    return _fm_quote(s) if _fm_needs_quote(s) else s


def _fm_emit_tag(t):
    t = "" if t is None else str(t)
    if t == "" or t != t.strip() or any(c in t for c in ',[]"\' '):
        return _fm_quote(t)
    return t


def render_frontmatter(fields):
    """Emit the restricted-YAML frontmatter block (including `---` delimiters)."""
    lines = ["---"]
    for k in FRONTMATTER_FIELDS:
        if k == "tags":
            tags = fields.get("tags") or []
            lines.append("tags: [%s]" % ", ".join(_fm_emit_tag(t) for t in tags))
        else:
            lines.append("%s: %s" % (k, _fm_emit_scalar(fields.get(k))))
    lines.append("---")
    return "\n".join(lines) + "\n"


def _fm_parse_scalar(raw):
    raw = raw.strip()
    if len(raw) >= 2 and raw[0] == '"' and raw[-1] == '"':
        return raw[1:-1].replace('\\"', '"').replace("\\\\", "\\")
    return raw


def _fm_split_inline_list(s):
    """Split an inline list body on commas not inside double quotes."""
    parts, buf, in_q, esc = [], [], False, False
    for ch in s:
        if esc:
            buf.append(ch)
            esc = False
            continue
        if ch == "\\" and in_q:
            buf.append(ch)
            esc = True
            continue
        if ch == '"':
            in_q = not in_q
            buf.append(ch)
            continue
        if ch == "," and not in_q:
            parts.append("".join(buf))
            buf = []
            continue
        buf.append(ch)
    parts.append("".join(buf))
    return parts


def _fm_parse_tags(raw):
    raw = raw.strip()
    if raw.startswith("[") and raw.endswith("]"):
        raw = raw[1:-1]
    out = []
    for p in _fm_split_inline_list(raw):
        if p.strip() == "":
            continue
        out.append(_fm_parse_scalar(p))
    return out


def split_frontmatter(text):
    """Return (fields_dict_or_None, body_text).

    Recognizes a frontmatter block ONLY when the file's first line is exactly
    `---` and a closing `---` follows. Otherwise returns (None, text) so legacy
    files and bodies that merely contain `---` horizontal rules are untouched.
    """
    lines = text.split("\n")
    if not lines or lines[0].strip() != "---":
        return None, text
    close = None
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            close = i
            break
    if close is None:
        return None, text
    fields = {}
    for ln in lines[1:close]:
        if not ln.strip() or ":" not in ln:
            continue
        key, _, val = ln.partition(":")
        key = key.strip()
        if key == "tags":
            fields["tags"] = _fm_parse_tags(val)
        elif key in FRONTMATTER_FIELDS:
            fields[key] = _fm_parse_scalar(val)
    return fields, "\n".join(lines[close + 1:])


def strip_frontmatter(text):
    """Body text with any leading frontmatter block removed (lossless tail)."""
    fields, body = split_frontmatter(text)
    if fields is None:
        return text
    return body.lstrip("\n")


_LEGACY_CREATED_RE = re.compile(r">\s*\*\*Created\*\*:\s*(\S+)")
_LEGACY_CATEGORY_RE = re.compile(r">\s*\*\*Category\*\*:\s*(\S+)")
_LEGACY_TAGS_RE = re.compile(r">\s*\*\*Tags\*\*:\s*(.+)")


def _parse_legacy_header(text):
    """Best-effort extraction from a legacy blockquote-only entry (pre-migration).

    Returns whatever it can (title/created/category/tags) so callers degrade
    gracefully before the one-time migration runs.
    """
    out = {}
    m = re.search(r"^#\s+(.+?)\s*$", text, re.M)
    if m:
        out["title"] = m.group(1).strip()
    m = _LEGACY_CREATED_RE.search(text)
    if m:
        out["created"] = m.group(1).strip()
    m = _LEGACY_CATEGORY_RE.search(text)
    if m:
        out["category"] = m.group(1).strip()
    m = _LEGACY_TAGS_RE.search(text)
    if m:
        tags = re.findall(r"`([^`]+)`", m.group(1))
        if tags:
            out["tags"] = tags
    return out


def read_entry_frontmatter(path):
    """Parse an entry file's frontmatter into a dict (possibly partial).

    If the file carries a real frontmatter block, return its parsed fields.
    Otherwise tolerate a legacy blockquote-only file and return what it can.
    Returns {} on any read error.
    """
    try:
        with open(path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return {}
    fields, _ = split_frontmatter(text)
    if fields is not None:
        return fields
    return _parse_legacy_header(text)


def build_entry_frontmatter(entry, kdir, author=None,
                            source=DEFAULT_ENTRY_SOURCE, last_verified=None):
    """Build the 9-field frontmatter dict for an index entry + defaults."""
    created = entry.get("created") or _today()
    return {
        "id": entry.get("id") or "",
        "title": entry.get("title") or "",
        "category": entry.get("category") or "",
        "tags": list(entry.get("tags") or []),
        "created": created,
        "summary": entry.get("summary") or "",
        "author": author if author is not None else _operator_handle(kdir),
        "source": source,
        "last_verified": last_verified or entry.get("last_verified") or created,
    }


def ensure_entry_frontmatter(kdir, entry, author=None,
                             source=DEFAULT_ENTRY_SOURCE):
    """Prepend a frontmatter block to `entry`'s file iff it lacks one.

    Idempotent: a file that already carries a frontmatter block is left untouched
    (returns False). PREPEND only — never edits the body. Returns True if it wrote
    a block. The block is derived from the index `entry` row + defaults so the
    file becomes the rebuildable source of truth (C-1, C-3).
    """
    rel = entry.get("path")
    if not rel:
        return False
    abs_path = os.path.join(kdir, rel)
    try:
        with open(abs_path, "r", encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return False
    existing, _ = split_frontmatter(text)
    if existing is not None:
        return False
    fm = build_entry_frontmatter(entry, kdir, author=author, source=source)
    with open(abs_path, "w", encoding="utf-8") as f:
        f.write(render_frontmatter(fm) + text)
    return True


def _render_learning(fields, body):
    """Render a learning entry: machine frontmatter + human header + body.

    `fields` is the 9-field frontmatter dict (source of truth); the human
    blockquote header below it is for readability and is regenerated from the
    same fields, so the two never drift.
    """
    tag_list = fields.get("tags") or []
    tags_str = ", ".join("`%s`" % t for t in tag_list) if tag_list else "_(none)_"
    return (
        "%s"
        "# %s\n\n"
        "> **Created**: %s  \n"
        "> **Tags**: %s  \n"
        "> **Category**: %s\n\n"
        "---\n\n"
        "%s\n\n"
        "---\n\n"
        "[← Back to Learnings](./index.md) | [← Back to Main](../MAIN.md)\n"
        % (render_frontmatter(fields), fields.get("title") or "",
           fields.get("created") or "", tags_str,
           fields.get("category") or "learnings", body.rstrip("\n"))
    )


def cmd_learn(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    topic = (args.topic or "").strip()
    if not topic:
        sys.stderr.write("agentware: --topic must not be empty\n")
        return 1

    body = sys.stdin.read() if args.content == "-" else args.content
    if not (body or "").strip():
        sys.stderr.write("agentware: --content must not be empty\n")
        return 1

    eid = "learn-%s" % topic
    rel_path = "%s/%s.md" % (LEARNINGS_REL, topic)
    abs_path = os.path.join(kdir, rel_path)
    tag_list = parse_tags(args.tags)
    title = _topic_to_title(topic)
    created = _today()

    entries = data.get("entries") or []
    if any(e.get("id") == eid for e in entries):
        sys.stderr.write("agentware: duplicate id '%s'\n" % eid)
        return 1
    if any(e.get("path") == rel_path for e in entries):
        sys.stderr.write("agentware: path already indexed: %s\n" % rel_path)
        return 1
    if os.path.exists(abs_path):
        sys.stderr.write(
            "agentware: learning file already exists (refusing to overwrite): %s\n"
            % abs_path)
        return 1

    fm = build_entry_frontmatter(
        {"id": eid, "title": title, "category": "learnings", "tags": tag_list,
         "created": created, "summary": args.summary},
        kdir, source=DEFAULT_ENTRY_SOURCE)
    os.makedirs(learnings_dir(kdir), exist_ok=True)
    with open(abs_path, "w", encoding="utf-8") as f:
        f.write(_render_learning(fm, body))

    entry, add_err = _do_add(
        kdir, data, eid, title, "learnings", rel_path, tag_list, args.summary, created)
    if add_err is not None:
        try:
            os.remove(abs_path)
        except OSError:
            pass
        sys.stderr.write("agentware: %s\n" % add_err)
        return 1

    save_index(kdir, data)
    if getattr(args, "format", "text") == "json":
        json.dump({"ok": True, "learning": entry}, sys.stdout,
                  ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("LEARNED entry '%s' -> %s (registered in index)" % (eid, abs_path))
    return 0


def _render_features(data):
    markdown = "# Knowledge Base — Features & Capabilities\n\n"
    markdown += ("> **NOTICE:** Auto-generated from this knowledge base's "
                 "`index.json` by `scripts/agentware features`. Do not edit "
                 "manually.\n\n")
    categories = {}
    for entry in data.get("entries", []):
        cat = entry.get("category", "uncategorized")
        categories.setdefault(cat, []).append(entry)
    for cat in sorted(categories.keys()):
        pretty_cat = cat.replace("_", " ").title()
        markdown += "## %s\n\n" % pretty_cat
        markdown += "| Title | Path | Summary |\n"
        markdown += "|-------|------|---------|\n"
        for entry in categories[cat]:
            title = entry.get("title", "")
            path = entry.get("path", "")
            summary = entry.get("summary", "")
            markdown += "| **%s** | `[%s](%s)` | %s |\n" % (title, path, path, summary)
        markdown += "\n"
    if not categories:
        markdown += "_No entries yet. Capture knowledge with " \
                    "`scripts/agentware learn ...`._\n"
    return markdown


def cmd_features(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1
    content = _render_features(data)
    with open(features_path(kdir), "w", encoding="utf-8") as f:
        f.write(content)
    if getattr(args, "format", "text") == "json":
        cat_count = len({e.get("category", "uncategorized")
                         for e in data.get("entries", [])})
        json.dump({"ok": True, "path": features_path(kdir),
                   "entries": len(data.get("entries", [])), "categories": cat_count},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("Successfully generated %s" % features_path(kdir))
    return 0


LEARNED_RE = re.compile(r"^\s*>?\s*LEARNED:\s*(.*?)\s*$")


def _slugify(text):
    return re.sub(r"[^a-z0-9]+", "-", (text or "").lower()).strip("-")


def learning_stems(kdir, data):
    stems = set()
    for e in (data.get("entries") or []):
        if not isinstance(e, dict) or e.get("category") != "learnings":
            continue
        base = os.path.basename(e.get("path") or "")
        if base.endswith(".md"):
            stems.add(base[:-3].lower())
        eid = e.get("id") or ""
        if eid.startswith("learn-"):
            stems.add(eid[len("learn-"):].lower())
    ldir = learnings_dir(kdir)
    if os.path.isdir(ldir):
        for fn in os.listdir(ldir):
            if fn.endswith(".md") and fn != "index.md":
                stems.add(fn[:-3].lower())
    return {s for s in stems if s}


def _is_promoted(marker_text, stems):
    slug = _slugify(marker_text)
    if not slug:
        return False
    for stem in stems:
        if slug == stem or stem in slug or slug in stem:
            return True
    return False


def scan_worklog(path, kdir, data):
    stems = learning_stems(kdir, data)
    unpromoted, total = [], 0
    with open(path, "r", encoding="utf-8") as f:
        for lineno, line in enumerate(f, start=1):
            m = LEARNED_RE.match(line)
            if not m:
                continue
            text = m.group(1).strip()
            if not text:
                continue
            total += 1
            if not _is_promoted(text, stems):
                unpromoted.append({"line": lineno, "text": text})
    return unpromoted, total


def cmd_worklog_scan(args):
    if not os.path.isfile(args.path):
        sys.stderr.write("agentware: worklog not found: %s\n" % args.path)
        return 1
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    unpromoted, total = scan_worklog(args.path, kdir, data)
    ok = len(unpromoted) == 0
    if getattr(args, "format", "text") == "json":
        json.dump({"unpromoted": unpromoted, "total": total},
                  sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        if ok:
            print("WORKLOG SCAN PASSED: %d LEARNED marker(s), all promoted." % total)
        else:
            print("WORKLOG SCAN FAILED: %d of %d LEARNED marker(s) unpromoted:"
                  % (len(unpromoted), total))
            for item in unpromoted:
                print("  line %d: %s" % (item["line"], item["text"]))
    return 0 if ok else 1


# --- Audit -------------------------------------------------------------------
def tag_consistency_errors(data):
    errors = []
    entries = data.get("entries") or []
    tags = data.get("tags") or {}
    by_id = {e.get("id"): e for e in entries
             if isinstance(e, dict) and e.get("id")}
    for e in entries:
        if not isinstance(e, dict):
            continue
        eid = e.get("id")
        for t in (e.get("tags") or []):
            ids = tags.get(t)
            if not isinstance(ids, list) or eid not in ids:
                errors.append("tag map missing id '%s' under tag '%s'" % (eid, t))
    for t, ids in tags.items():
        if not isinstance(ids, list):
            errors.append("tag '%s' is not a list" % t)
            continue
        if not ids:
            errors.append("tag '%s' has an empty entry list" % t)
        for eid in ids:
            entry = by_id.get(eid)
            if entry is None:
                errors.append("tag '%s' references unknown id '%s'" % (t, eid))
            elif t not in (entry.get("tags") or []):
                errors.append("entry '%s' missing back-ref for tag '%s'" % (eid, t))
    return errors


def template_conformance_errors(kdir, data):
    errors = []
    ldir = learnings_dir(kdir)
    if os.path.isdir(ldir):
        for fn in sorted(os.listdir(ldir)):
            if not fn.endswith(".md") or fn == "index.md":
                continue
            fp = os.path.join(ldir, fn)
            try:
                with open(fp, "r", encoding="utf-8") as f:
                    text = f.read()
            except OSError as exc:
                errors.append("cannot read %s: %s" % (fp, exc))
                continue
            if not re.search(r"(?m)^#\s+\S", text):
                errors.append("learning '%s' missing H1 title" % fp)

    projects_dir = os.path.join(kdir, "projects")
    if os.path.isdir(projects_dir):
        for name in sorted(os.listdir(projects_dir)):
            d = os.path.join(projects_dir, name)
            if not os.path.isdir(d):
                continue
            fp = os.path.join(d, "index.md")
            if not os.path.isfile(fp):
                errors.append("project '%s' missing index.md" % name)
                continue
            with open(fp, "r", encoding="utf-8") as f:
                text = f.read()
            if not re.search(r"(?m)^#\s+\S", text):
                errors.append("project index '%s' missing H1 title" % fp)
    return errors


def orphaned_learning_errors(kdir, data):
    errors = []
    have = indexed_paths(data)
    ldir = learnings_dir(kdir)
    if os.path.isdir(ldir):
        for fn in sorted(os.listdir(ldir)):
            if not fn.endswith(".md") or fn == "index.md":
                continue
            rel = "%s/%s" % (LEARNINGS_REL, fn)
            if rel not in have:
                errors.append("orphaned learning (on disk, not indexed): %s" % rel)
    return errors


# --- Retrieval & evaluation (deterministic, stdlib-only) ---------------------
# INV-1: ranking is hand-rolled, stdlib-only — NO LLM, NO embeddings, NO network,
# NO wall-clock in scoring. INV-2: read-only — never mutates index.json or KB.
# The tokenizer here is the SINGLE shared tokenizer reused by the BM25 `recall`
# engine (Phase 1) so the baseline (tag) and ranked (bm25) paths stay comparable.

# Fixed, documented tokenizer: lowercase, split on non-alphanumeric runs, no
# stemming (v1). Pure stdlib; deterministic for identical input.
_TOKEN_RE = re.compile(r"[a-z0-9]+")


def tokenize(text):
    """Lowercase + split on non-alphanumeric. Returns a list of tokens."""
    return _TOKEN_RE.findall((text or "").lower())


def estimate_tokens(text):
    """Documented heuristic: ~4 characters per token (context-budget estimate)."""
    return (len(text or "") + 3) // 4


def _read_entry_body(kdir, entry):
    """Read an entry's markdown body (read-only, best-effort). '' on any error.

    Strips any leading machine frontmatter block so the BM25 corpus sees only the
    human body — keeping recall/eval byte-identical to the pre-frontmatter corpus
    (the index already contributes title/summary/tags separately).
    """
    rel = entry.get("path")
    if not rel:
        return ""
    try:
        with open(os.path.join(kdir, rel), "r", encoding="utf-8") as f:
            return strip_frontmatter(f.read())
    except OSError:
        return ""


def build_corpus(kdir, data):
    """Return [(entry, doc_text), ...] for every dict entry, in index order.

    doc_text = title + summary + tags + file body. Read-only; this is the shared
    corpus builder for both the tag baseline (footprint) and BM25 recall (Phase 1).
    """
    corpus = []
    for e in data.get("entries") or []:
        if not isinstance(e, dict):
            continue
        parts = [
            e.get("title") or "",
            e.get("summary") or "",
            " ".join(e.get("tags") or []),
            _read_entry_body(kdir, e),
        ]
        corpus.append((e, "\n".join(parts)))
    return corpus


def retrieve_tag(kdir, data, query, top_k=None):
    """Baseline strategy: map a free-text query onto the EXACT-tag `query` path.

    Tokenize the query, union the exact-tag hits for each token that is a known
    tag, and rank entries by (# matching query tokens) desc, then `created` desc,
    then `id` asc. Deterministic and tokenizer-stable so the baseline reproduces.
    `kdir` is accepted for a uniform strategy signature (unused here).
    """
    tags_map = data.get("tags") or {}
    by_id = {}
    for e in data.get("entries") or []:
        if isinstance(e, dict) and e.get("id") is not None:
            by_id.setdefault(e.get("id"), e)

    counts = {}
    for tok in set(tokenize(query)):
        for eid in tags_map.get(tok, []):
            counts[eid] = counts.get(eid, 0) + 1

    ranked = list(counts.keys())
    # Stable multi-pass sort, lowest priority first → highest priority last.
    ranked.sort(key=lambda eid: eid)                                      # id asc
    ranked.sort(key=lambda eid: by_id.get(eid, {}).get("created") or "",  # created
                reverse=True)                                            # desc
    ranked.sort(key=lambda eid: counts[eid], reverse=True)               # matches desc
    return ranked if top_k is None else ranked[:top_k]


# --- BM25 deterministic ranking (Phase 1) ------------------------------------
# Fixed, documented Okapi BM25 parameters. Pinned for determinism; identical
# inputs yield byte-identical ordering (INV-1). No embeddings, no network.
_BM25_K1 = 1.5
_BM25_B = 0.75


def _bm25_index(corpus):
    """Build a BM25 index from [(entry, doc_text), ...] in corpus order.

    Returns (docs, df, avgdl): `docs` is [(entry, term_freqs, doc_len), ...] in
    corpus order, `df` maps term -> number of docs containing it, `avgdl` is the
    mean document length in tokens. Pure stdlib; deterministic.
    """
    docs = []
    df = {}
    total_len = 0
    for entry, text in corpus:
        toks = tokenize(text)
        tf = {}
        for t in toks:
            tf[t] = tf.get(t, 0) + 1
        docs.append((entry, tf, len(toks)))
        total_len += len(toks)
        for t in tf:
            df[t] = df.get(t, 0) + 1
    avgdl = (total_len / len(docs)) if docs else 0.0
    return docs, df, avgdl


def bm25_scores(corpus, query_tokens):
    """Return [(entry, score), ...] in corpus order, scored by Okapi BM25.

    idf = ln(1 + (N - df + 0.5)/(df + 0.5)) (always positive). Term contribution
    saturates via k1 and is length-normalized via b. Deterministic for identical
    input; a doc sharing no query term scores exactly 0.0.
    """
    docs, df, avgdl = _bm25_index(corpus)
    n = len(docs)
    q_terms = set(query_tokens)
    idf = {}
    for t in q_terms:
        n_t = df.get(t, 0)
        idf[t] = math.log(1.0 + (n - n_t + 0.5) / (n_t + 0.5))
    results = []
    for entry, tf, dl in docs:
        score = 0.0
        for t in q_terms:
            f = tf.get(t, 0)
            if f == 0:
                continue
            norm = 1.0 - _BM25_B + _BM25_B * (dl / avgdl if avgdl else 0.0)
            denom = f + _BM25_K1 * norm
            score += idf[t] * (f * (_BM25_K1 + 1.0)) / denom
        results.append((entry, score))
    return results


def retrieve_bm25(kdir, data, query, top_k=None):
    """BM25 recall strategy over title+summary+tags+body. Returns ranked ids.

    Deterministic ordering: score desc -> created desc -> id asc. Only entries
    with a positive score (sharing >=1 query term) are returned. Read-only
    (INV-2); no network/LLM/embeddings (INV-1, INV-6).
    """
    corpus = build_corpus(kdir, data)
    scored = [(e, s) for (e, s) in bm25_scores(corpus, tokenize(query)) if s > 0.0]
    # Stable multi-pass sort: lowest priority first, highest priority last.
    scored.sort(key=lambda es: es[0].get("id") or "")                       # id asc
    scored.sort(key=lambda es: es[0].get("created") or "", reverse=True)    # created desc
    scored.sort(key=lambda es: es[1], reverse=True)                         # score desc
    ids = [e.get("id") for (e, _s) in scored]
    return ids if top_k is None else ids[:top_k]


def recall_ranked(kdir, data, query, top_k=None, category=None):
    """Deterministic BM25 recall returning [(entry, score, doc_text), ...].

    Reuses the shared `build_corpus` + `bm25_scores` so ordering is byte-identical
    to `retrieve_bm25`: score desc -> created desc -> id asc, positive scores only.
    An optional `category` restricts the corpus BEFORE scoring. Read-only (INV-2);
    no network/LLM/embeddings (INV-1, INV-6). `doc_text` is the entry's full
    corpus document (title+summary+tags+body) for token-footprint estimation.
    """
    corpus = build_corpus(kdir, data)
    if category:
        corpus = [(e, t) for (e, t) in corpus if e.get("category") == category]
    text_by_id = {e.get("id"): t for (e, t) in corpus}
    scored = [(e, s) for (e, s) in bm25_scores(corpus, tokenize(query)) if s > 0.0]
    # Stable multi-pass sort: lowest priority first, highest priority last.
    scored.sort(key=lambda es: es[0].get("id") or "")                       # id asc
    scored.sort(key=lambda es: es[0].get("created") or "", reverse=True)    # created desc
    scored.sort(key=lambda es: es[1], reverse=True)                         # score desc
    if top_k is not None:
        scored = scored[:top_k]
    return [(e, s, text_by_id.get(e.get("id"), "")) for (e, s) in scored]


def retrieve(kdir, data, query, strategy, top_k=None):
    """Dispatch to a retrieval strategy. Returns a ranked list of entry ids.

    'tag'  — the legacy exact-tag baseline (available from day one).
    'bm25' — the deterministic BM25 recall engine (provided by Phase 1 as the
             module-level `retrieve_bm25`); errors clearly until that lands.
    """
    if strategy == "tag":
        return retrieve_tag(kdir, data, query, top_k)
    if strategy == "bm25":
        fn = globals().get("retrieve_bm25")
        if fn is None:
            raise NotImplementedError(
                "the 'bm25' strategy requires the recall engine (Phase 1); "
                "use --strategy tag for the baseline")
        return fn(kdir, data, query, top_k)
    raise ValueError("unknown retrieval strategy: %s" % strategy)


# --- Ranking metrics (hand-computable, exact) --------------------------------
def recall_at_k(ranked, relevant, k):
    """|relevant ∩ top-k| / |relevant|. 0.0 when there are no relevant items."""
    relevant = set(relevant)
    if not relevant:
        return 0.0
    hits = sum(1 for r in ranked[:k] if r in relevant)
    return hits / len(relevant)


def precision_at_k(ranked, relevant, k):
    """|relevant ∩ top-k| / k (standard precision@k; k is the denominator)."""
    if k <= 0:
        return 0.0
    relevant = set(relevant)
    hits = sum(1 for r in ranked[:k] if r in relevant)
    return hits / k


def _dcg(ranked, relevant, k):
    relevant = set(relevant)
    total = 0.0
    for i, r in enumerate(ranked[:k]):
        if r in relevant:
            total += 1.0 / math.log2(i + 2)  # gain 1, discount log2(rank+1)
    return total


def ndcg_at_k(ranked, relevant, k):
    """Binary-gain nDCG@k = DCG@k / ideal-DCG@k. 0.0 when ideal DCG is 0."""
    relevant = set(relevant)
    ideal_hits = min(len(relevant), k)
    idcg = sum(1.0 / math.log2(i + 2) for i in range(ideal_hits))
    if idcg == 0:
        return 0.0
    return _dcg(ranked, relevant, k) / idcg


def reciprocal_rank(ranked, relevant):
    """1 / (rank of first relevant item) over the FULL ranking; 0.0 if none."""
    relevant = set(relevant)
    for i, r in enumerate(ranked):
        if r in relevant:
            return 1.0 / (i + 1)
    return 0.0


def _median(values):
    """Deterministic p50: middle of an odd list, mean of the two middles else."""
    if not values:
        return 0.0
    s = sorted(values)
    n = len(s)
    mid = n // 2
    if n % 2:
        return float(s[mid])
    return (s[mid - 1] + s[mid]) / 2.0


def load_gold(path):
    """Load a gold set: list of {query, expected_ids[]}. Returns (items, error)."""
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
    except FileNotFoundError:
        return None, "gold set not found: %s" % path
    except json.JSONDecodeError as exc:
        return None, "invalid JSON in gold set %s: %s" % (path, exc)
    if not isinstance(data, list):
        return None, "gold set must be a JSON list of {query, expected_ids}"
    items = []
    for i, row in enumerate(data):
        if not isinstance(row, dict):
            return None, "gold entry #%d is not an object" % i
        q = row.get("query")
        exp = row.get("expected_ids")
        if not isinstance(q, str) or not q.strip():
            return None, "gold entry #%d missing a non-empty 'query'" % i
        if not isinstance(exp, list) or not exp:
            return None, "gold entry #%d missing a non-empty 'expected_ids' list" % i
        items.append({"query": q, "expected_ids": [str(x) for x in exp]})
    if not items:
        return None, "gold set is empty"
    return items, None


def evaluate(kdir, data, gold, strategy, top_k):
    """Run the gold set through a strategy and compute graded metrics.

    Returns a dict with aggregate `metrics` + `per_query` rows. Read-only.
    Latency uses time.perf_counter and is the ONLY non-deterministic field; the
    ranking itself is deterministic (INV-1).
    """
    docs_by_id = {e.get("id"): doc for e, doc in build_corpus(kdir, data)}
    per_query = []
    recalls, precisions, ndcgs, rrs, latencies, footprints = [], [], [], [], [], []
    for row in gold:
        query = row["query"]
        relevant = set(row["expected_ids"])
        t0 = time.perf_counter()
        ranked = retrieve(kdir, data, query, strategy, top_k=None)
        latency_ms = (time.perf_counter() - t0) * 1000.0
        topk = ranked[:top_k]
        rec = recall_at_k(ranked, relevant, top_k)
        prec = precision_at_k(ranked, relevant, top_k)
        nd = ndcg_at_k(ranked, relevant, top_k)
        rr = reciprocal_rank(ranked, relevant)
        footprint = sum(estimate_tokens(docs_by_id.get(eid, "")) for eid in topk)
        recalls.append(rec)
        precisions.append(prec)
        ndcgs.append(nd)
        rrs.append(rr)
        latencies.append(latency_ms)
        footprints.append(footprint)
        per_query.append({
            "query": query,
            "expected_ids": sorted(relevant),
            "ranked": topk,
            "recall_at_k": rec,
            "precision_at_k": prec,
            "ndcg_at_k": nd,
            "reciprocal_rank": rr,
            "latency_ms": latency_ms,
            "context_tokens": footprint,
        })
    n = len(gold)
    mean = lambda xs: (sum(xs) / len(xs)) if xs else 0.0
    return {
        "strategy": strategy,
        "top_k": top_k,
        "num_queries": n,
        "metrics": {
            "recall_at_k": mean(recalls),
            "precision_at_k": mean(precisions),
            "ndcg_at_k": mean(ndcgs),
            "mrr": mean(rrs),
            "latency_ms_mean": mean(latencies),
            "latency_ms_p50": _median(latencies),
            "context_tokens_mean": mean(footprints),
        },
        "per_query": per_query,
    }


_ABLATE_METRIC_KEYS = (
    "recall_at_k", "precision_at_k", "ndcg_at_k", "mrr",
    "latency_ms_mean", "latency_ms_p50", "context_tokens_mean",
)


def evaluate_ablation(kdir, data, gold, top_k, baseline="tag", treatment="bm25"):
    """Run the SAME gold set through two strategies and report the per-metric lift.

    Proof-of-lift instrument (Phase 3.2): scores the legacy tag-only baseline and
    the new BM25 treatment over identical queries, then reports `treatment -
    baseline` for every headline metric. Read-only (INV-2); ranking is
    deterministic (INV-1) so the delta is reproducible (latency excepted).
    """
    base = evaluate(kdir, data, gold, baseline, top_k)
    treat = evaluate(kdir, data, gold, treatment, top_k)
    delta = {}
    for key in _ABLATE_METRIC_KEYS:
        delta[key] = treat["metrics"][key] - base["metrics"][key]
    return {
        "mode": "ablate",
        "top_k": top_k,
        "num_queries": len(gold),
        "baseline": baseline,
        "treatment": treatment,
        "strategies": {
            baseline: base["metrics"],
            treatment: treat["metrics"],
        },
        "delta": delta,
        "per_query": {
            baseline: base["per_query"],
            treatment: treat["per_query"],
        },
    }


# --- Benchmark ledger (Phase 3B.1): append-only, commit + date-stamped ------
# Every package update records ONE immutable row keyed by (commit SHA, UTC run
# timestamp) to <kdir>/benchmarks/history.jsonl. Rows are NEVER edited or
# removed — `--record` only ever opens the file in append mode. SCORECARD.md
# (Phase 3B.3) is the only regenerated, derived view over these rows.

HISTORY_REL = os.path.join("benchmarks", "history.jsonl")
LEDGER_SCHEMA = "agentware-bench/v1"


def _git_capture(argv, env=None):
    """Run a read-only git command in REPO_ROOT; return stripped stdout or ''."""
    try:
        proc = subprocess.run(
            ["git"] + argv, cwd=REPO_ROOT,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True, env=env)
    except OSError:
        return ""
    return proc.stdout.strip() if proc.returncode == 0 else ""


def git_info():
    """Read-only snapshot of HEAD: short SHA, subject, UTC commit date, dirtiness.

    Degrades gracefully (commit='unknown', empty strings) outside a git repo so
    `--record` never fails just because git is missing. Never mutates anything.
    """
    utc_env = dict(os.environ)
    utc_env["TZ"] = "UTC"
    commit = _git_capture(["rev-parse", "--short", "HEAD"]) or "unknown"
    subject = _git_capture(["log", "-1", "--pretty=%s"])
    committed = _git_capture(
        ["log", "-1", "--date=iso-strict-local", "--pretty=%cd"], env=utc_env)
    dirty = bool(_git_capture(["status", "--porcelain"]))
    return {"commit": commit, "subject": subject,
            "committed": committed, "dirty": dirty}


def utc_now_iso():
    """Current UTC timestamp as ISO-8601 'Z' string. Metadata only (not scoring)."""
    return datetime.datetime.now(datetime.timezone.utc).strftime(
        "%Y-%m-%dT%H:%M:%SZ")


def _record_test_passrate():
    """Shell the unittest suite once and return (pass_rate, ran, failed).

    Recursion guard: the unittest suite itself exercises `eval --record`; if we
    are already inside a suite run (AGENTWARE_NESTED_UNITTEST=1) we return
    (None, 0, 0) instead of spawning the suite again. pass_rate is None when not
    measured. Pure stdlib subprocess (INV-6). Read-only.
    """
    if os.environ.get("AGENTWARE_NESTED_UNITTEST") == "1":
        return None, 0, 0
    env = dict(os.environ)
    env["AGENTWARE_NESTED_UNITTEST"] = "1"
    tests_dir = os.path.join(REPO_ROOT, "tests")
    if not os.path.isdir(tests_dir):
        return None, 0, 0
    try:
        proc = subprocess.run(
            [sys.executable, "-m", "unittest", "discover", "-s", "tests"],
            cwd=REPO_ROOT, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True, env=env)
    except OSError:
        return None, 0, 0
    err = proc.stderr or ""
    rm = re.search(r"Ran (\d+) test", err)
    ran = int(rm.group(1)) if rm else 0
    fm = re.search(r"failures=(\d+)", err)
    em = re.search(r"errors=(\d+)", err)
    failed = (int(fm.group(1)) if fm else 0) + (int(em.group(1)) if em else 0)
    if ran == 0:
        return None, 0, 0
    return (ran - failed) / ran, ran, failed


def _determinism_check(kdir, data, gold, top_k):
    """Score the bm25 path twice over the gold set; True iff ranking is identical.

    Operationalizes INV-1 as a recorded boolean: identical inputs -> identical
    ordering. Latency is excluded (the only non-deterministic field). Read-only.
    """
    a = evaluate(kdir, data, gold, "bm25", top_k)["per_query"]
    b = evaluate(kdir, data, gold, "bm25", top_k)["per_query"]
    return [q["ranked"] for q in a] == [q["ranked"] for q in b]


def compute_reliability(recall_at_k, test_pass_rate, index_ok, determinism_ok):
    """Composite 0-100 reliability score (documented formula).

    Weighted blend (weights sum to 1.0): Recall@k 0.40, unittest pass-rate 0.30,
    index validate clean 0.15, determinism check 0.15. When test_pass_rate is
    None (not measured, e.g. nested run) its component is dropped and the
    remaining weights are renormalized so the score stays in [0, 100].
    """
    comps = [(0.40, max(0.0, min(1.0, recall_at_k)))]
    if test_pass_rate is not None:
        comps.append((0.30, max(0.0, min(1.0, test_pass_rate))))
    comps.append((0.15, 1.0 if index_ok else 0.0))
    comps.append((0.15, 1.0 if determinism_ok else 0.0))
    total_w = sum(w for w, _ in comps)
    if total_w <= 0:
        return 0.0
    return round(100.0 * sum(w * v for w, v in comps) / total_w, 2)


def build_ledger_row(result, git_meta, run_ts, checks):
    """Assemble one immutable ledger row from an eval/ablate result. Pure.

    Deterministic given its inputs (the only volatile values — run_ts, latency,
    git state — are injected by the caller), so tests can build + serialize a row
    byte-identically. `checks` carries test_pass_rate / index_validate_ok /
    determinism_ok / tests_ran / tests_failed.
    """
    mode = result.get("mode", "eval")
    if mode == "ablate":
        treatment = result["treatment"]
        metrics = result["strategies"][treatment]
        strategy = treatment
        ablation = {
            "baseline": result["baseline"],
            "treatment": treatment,
            "delta": result["delta"],
        }
    else:
        metrics = result["metrics"]
        strategy = result.get("strategy", "bm25")
        ablation = None
    recall = metrics.get("recall_at_k", 0.0)
    reliability = compute_reliability(
        recall, checks.get("test_pass_rate"),
        checks.get("index_validate_ok", False),
        checks.get("determinism_ok", False))
    return {
        "schema": LEDGER_SCHEMA,
        "run": run_ts,
        "commit": git_meta.get("commit", "unknown"),
        "committed": git_meta.get("committed", ""),
        "subject": git_meta.get("subject", ""),
        "dirty": git_meta.get("dirty", False),
        "mode": mode,
        "strategy": strategy,
        "top_k": result.get("top_k"),
        "num_queries": result.get("num_queries"),
        "gold_path": result.get("gold_path"),
        "metrics": metrics,
        "ablation": ablation,
        "checks": checks,
        "reliability": reliability,
    }


def append_ledger_row(path, row):
    """Append ONE JSON line to the ledger. APPEND-ONLY — never rewrites a row.

    Opens strictly in append mode ('a'), so existing rows are byte-immutable;
    re-recording at the same commit adds a NEW row (distinct run timestamp). Keys
    are sorted so a fixed row serializes byte-identically. Returns the line.
    """
    parent = os.path.dirname(path)
    if parent:
        os.makedirs(parent, exist_ok=True)
    line = json.dumps(row, ensure_ascii=False, sort_keys=True)
    with open(path, "a", encoding="utf-8") as f:
        f.write(line + "\n")
    return line


def record_ledger(kdir, data, gold, gold_path, result, top_k):
    """Gather volatile state (git, UTC ts, test pass-rate, validate, determinism),
    build a row, and append it. Returns the row. Read-only w.r.t. the KB."""
    pass_rate, ran, failed = _record_test_passrate()
    checks = {
        "test_pass_rate": pass_rate,
        "tests_ran": ran,
        "tests_failed": failed,
        "index_validate_ok": not validate_index(kdir, data),
        "determinism_ok": _determinism_check(kdir, data, gold, top_k),
    }
    row = build_ledger_row(result, git_info(), utc_now_iso(), checks)
    append_ledger_row(os.path.join(kdir, HISTORY_REL), row)
    return row


# --- Regression gate (Phase 3B.2) -------------------------------------------
# `eval --gate [--tolerance T]` compares the current run to the BEST prior
# comparable ledger row (same retrieval strategy) and EXITS NON-ZERO if any
# headline quality metric or the reliability score regresses beyond tolerance.
# This is the INV-7 enforcement: every package update is benchmarked and a
# regression cannot ship. A first-ever run (no comparable history) PASSES and
# seeds the baseline. The gate ALWAYS records (append-only) so the ledger grows
# on every gated run; it reads the prior rows BEFORE appending the new one so the
# fresh row never compares against itself.

# Higher-is-better quality metrics that the gate protects. Latency/ctx-token
# footprint are deliberately NOT gated as hard failures (they are reported and
# trended in the scorecard) so a benign latency jitter never fails a build.
GATE_METRICS = ("recall_at_k", "precision_at_k", "ndcg_at_k", "mrr")


def _read_ledger(path):
    """Read all rows from the append-only ledger; tolerate blanks/bad lines.

    Read-only (INV-2): only ever opens the file for reading. Returns [] when the
    file does not exist (first-ever run).
    """
    rows = []
    if not os.path.isfile(path):
        return rows
    with open(path, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rows.append(json.loads(line))
            except ValueError:
                continue
    return rows


def gate_baseline(rows, strategy):
    """Best-seen value per gated metric + reliability among COMPARABLE rows.

    Comparable = rows recorded with the same retrieval `strategy` (apples to
    apples: a bm25 run is never gated against a tag-only baseline). The baseline
    is the MAX of each metric across all prior comparable rows, so a run can
    never silently drop below any earlier peak. Returns None when there is no
    comparable history (first-ever run for this strategy -> gate seeds + passes).
    """
    comparable = [r for r in rows if r.get("strategy") == strategy]
    if not comparable:
        return None
    base = {}
    for key in GATE_METRICS:
        vals = [r.get("metrics", {}).get(key) for r in comparable]
        vals = [v for v in vals if isinstance(v, (int, float))]
        if vals:
            base[key] = max(vals)
    rels = [r.get("reliability") for r in comparable
            if isinstance(r.get("reliability"), (int, float))]
    if rels:
        base["reliability"] = max(rels)
    return base


def evaluate_gate(metrics, reliability, baseline, tolerance):
    """Decide pass/fail vs a baseline. Returns (passed, regressions).

    Each gated metric must stay within `tolerance` of the best prior value
    (current >= best - tolerance). Reliability is a 0-100 score, so its
    allowance is `tolerance * 100` points. `baseline is None` => first run =>
    pass with no regressions (caller marks it seeded). `regressions` is a list of
    (metric, baseline_value, current_value) for every metric that dropped too far.
    """
    if baseline is None:
        return True, []
    regressions = []
    for key in GATE_METRICS:
        if key not in baseline:
            continue
        cur = metrics.get(key)
        if not isinstance(cur, (int, float)):
            continue
        if cur < baseline[key] - tolerance:
            regressions.append((key, baseline[key], cur))
    if "reliability" in baseline and isinstance(reliability, (int, float)):
        if reliability < baseline["reliability"] - tolerance * 100.0:
            regressions.append(
                ("reliability", baseline["reliability"], reliability))
    return (len(regressions) == 0), regressions


def _record_and_gate(args, kdir, data, gold, gold_path, result):
    """Apply --record / --gate to a computed eval result.

    --gate implies --record (every gated run appends an immutable row). Reads the
    prior ledger BEFORE appending so the new row never compares against itself.
    Returns (recorded_or_None, gate_or_None); attaches `recorded`/`gate` to
    `result` for the JSON output.
    """
    want_gate = getattr(args, "gate", False)
    if not (getattr(args, "record", False) or want_gate):
        return None, None
    ledger_path = os.path.join(kdir, HISTORY_REL)
    prior_rows = _read_ledger(ledger_path) if want_gate else None
    recorded = record_ledger(kdir, data, gold, gold_path, result, args.top_k)
    result["recorded"] = {
        "path": ledger_path, "commit": recorded["commit"],
        "run": recorded["run"], "reliability": recorded["reliability"],
    }
    gate = None
    if want_gate:
        baseline = gate_baseline(prior_rows, recorded["strategy"])
        passed, regressions = evaluate_gate(
            recorded["metrics"], recorded["reliability"],
            baseline, args.tolerance)
        gate = {
            "passed": passed,
            "tolerance": args.tolerance,
            "strategy": recorded["strategy"],
            "seeded": baseline is None,
            "baseline": baseline,
            "regressions": [
                {"metric": m, "baseline": b, "current": c}
                for m, b, c in regressions
            ],
        }
        result["gate"] = gate
    return recorded, gate


def _gate_exit(gate):
    """Exit code for a gate result: non-zero (1) only on a real regression."""
    return 0 if (gate is None or gate["passed"]) else 1


def _print_gate(gate):
    """Human-readable gate verdict for text format."""
    if gate is None:
        return
    if gate["seeded"]:
        print("  gate: PASS (seeded baseline; no prior %s history)"
              % gate["strategy"])
        return
    if gate["passed"]:
        print("  gate: PASS (no regression beyond tolerance %.4f)"
              % gate["tolerance"])
        return
    print("  gate: FAIL (regression beyond tolerance %.4f)" % gate["tolerance"])
    for r in gate["regressions"]:
        print("    %-16s best=%.4f  current=%.4f  drop=%.4f" % (
            r["metric"], r["baseline"], r["current"],
            r["baseline"] - r["current"]))


# --- Scorecard (Phase 3B.3): derived trend VIEW over the ledger --------------
# `bench scorecard` regenerates <kdir>/benchmarks/SCORECARD.md from the
# append-only history.jsonl: a commit + date stamped trend table (newest run
# first) plus the latest ablation delta. The ledger stays the immutable system
# of record; SCORECARD.md is the only regenerated, human-readable VIEW. Pure
# given its rows (no wall-clock, no git) so the same ledger always renders the
# same markdown.

SCORECARD_REL = os.path.join("benchmarks", "SCORECARD.md")

_SCORECARD_COLS = ("Run (UTC)", "Commit", "Committed (UTC)", "Strategy", "Mode",
                   "Recall@5", "nDCG@5", "MRR", "p50 ms", "ctx-tok",
                   "Reliability")


def _fmt_cell(value, fmt):
    """Format a numeric ledger cell, or an em-dash when missing/non-numeric."""
    return (fmt % value) if isinstance(value, (int, float)) else "—"


def render_scorecard(rows):
    """Render the append-only ledger rows as a Markdown trend table (newest run
    first) plus the latest ablation delta. Pure: deterministic given `rows`, so
    it is a faithful VIEW over the immutable ledger. Returns the markdown text.
    """
    head = "# agentware Recall / Benchmark Scorecard\n"
    intro = (
        "> Derived VIEW over the append-only benchmark ledger "
        "(`benchmarks/history.jsonl`). Regenerate with "
        "`scripts/agentware bench scorecard`. Newest run first; the ledger "
        "itself is immutable (one row per commit + run-timestamp).\n")
    if not rows:
        return "%s\n%s\n_No benchmark runs recorded yet._\n" % (head, intro)
    ordered = sorted(rows, key=lambda r: r.get("run", ""), reverse=True)
    lines = [head, intro, ""]
    lines.append("| " + " | ".join(_SCORECARD_COLS) + " |")
    lines.append("| " + " | ".join("---" for _ in _SCORECARD_COLS) + " |")
    for r in ordered:
        m = r.get("metrics", {}) or {}
        cells = [
            r.get("run") or "—",
            "`%s`" % (r.get("commit") or "—"),
            r.get("committed") or "—",
            r.get("strategy") or "—",
            r.get("mode") or "—",
            _fmt_cell(m.get("recall_at_k"), "%.4f"),
            _fmt_cell(m.get("ndcg_at_k"), "%.4f"),
            _fmt_cell(m.get("mrr"), "%.4f"),
            _fmt_cell(m.get("latency_ms_p50"), "%.3f"),
            _fmt_cell(m.get("context_tokens_mean"), "%.1f"),
            _fmt_cell(r.get("reliability"), "%.2f"),
        ]
        lines.append("| " + " | ".join(cells) + " |")
    abl_rows = [r for r in ordered if r.get("ablation")]
    if abl_rows:
        a = abl_rows[0]
        abl = a["ablation"]
        delta = abl.get("delta", {}) or {}
        lines.append("")
        lines.append(
            "## Latest ablation delta (%s vs %s) — commit `%s`, run %s"
            % (abl.get("treatment", "?"), abl.get("baseline", "?"),
               a.get("commit", "?"), a.get("run", "?")))
        lines.append("")
        lines.append("| Metric | Delta |")
        lines.append("| --- | --- |")
        for label, key in (("Recall@k", "recall_at_k"),
                           ("Precision@k", "precision_at_k"),
                           ("nDCG@k", "ndcg_at_k"), ("MRR", "mrr")):
            v = delta.get(key)
            cell = ("%+.4f" % v) if isinstance(v, (int, float)) else "—"
            lines.append("| %s | %s |" % (label, cell))
    return "\n".join(lines) + "\n"


def write_scorecard(kdir):
    """Read the ledger and (over)write SCORECARD.md as a derived VIEW. Returns
    (path, row_count). The ledger is read-only here; only the derived markdown
    view is regenerated."""
    rows = _read_ledger(os.path.join(kdir, HISTORY_REL))
    text = render_scorecard(rows)
    path = os.path.join(kdir, SCORECARD_REL)
    parent = os.path.dirname(path)
    if parent:
        os.makedirs(parent, exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write(text)
    return path, len(rows)


def cmd_bench(args):
    """`bench scorecard` regenerates benchmarks/SCORECARD.md from history.jsonl."""
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    path, n = write_scorecard(kdir)
    print("bench scorecard: wrote %s (%d ledger row%s)" % (
        path, n, "" if n == 1 else "s"))
    return 0


def cmd_eval(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1

    gold_path = args.gold or os.path.join(kdir, "benchmarks", "recall-gold.json")
    gold, gerr = load_gold(gold_path)
    if gerr is not None:
        sys.stderr.write("agentware: %s\n" % gerr)
        return 1

    if args.top_k <= 0:
        sys.stderr.write("agentware: --top-k must be a positive integer\n")
        return 1

    if getattr(args, "ablate", False):
        try:
            result = evaluate_ablation(kdir, data, gold, args.top_k)
        except NotImplementedError as exc:
            sys.stderr.write("agentware: %s\n" % exc)
            return 2
        result["gold_path"] = gold_path
        recorded, gate = _record_and_gate(args, kdir, data, gold, gold_path, result)
        if args.format == "json":
            json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
            sys.stdout.write("\n")
            return _gate_exit(gate)
        k = result["top_k"]
        base, treat = result["baseline"], result["treatment"]
        bm, tm = result["strategies"][base], result["strategies"][treat]
        d = result["delta"]
        print("eval --ablate: %s (baseline) vs %s  top_k=%d  queries=%d" % (
            base, treat, k, result["num_queries"]))
        print("  gold: %s" % gold_path)
        labels = [
            ("Recall@%d" % k, "recall_at_k"),
            ("Precision@%d" % k, "precision_at_k"),
            ("nDCG@%d" % k, "ndcg_at_k"),
            ("MRR", "mrr"),
            ("latency_ms_mean", "latency_ms_mean"),
            ("latency_ms_p50", "latency_ms_p50"),
            ("ctx_tokens_mean", "context_tokens_mean"),
        ]
        print("  %-16s %12s %12s %12s" % ("metric", base, treat, "delta"))
        for label, key in labels:
            print("  %-16s %12.4f %12.4f %+12.4f" % (
                label, bm[key], tm[key], d[key]))
        if recorded is not None:
            print("  recorded: %s  commit=%s  reliability=%.2f  run=%s" % (
                os.path.join(kdir, HISTORY_REL), recorded["commit"],
                recorded["reliability"], recorded["run"]))
        _print_gate(gate)
        return _gate_exit(gate)

    try:
        result = evaluate(kdir, data, gold, args.strategy, args.top_k)
    except NotImplementedError as exc:
        sys.stderr.write("agentware: %s\n" % exc)
        return 2
    result["gold_path"] = gold_path
    recorded, gate = _record_and_gate(args, kdir, data, gold, gold_path, result)

    if args.format == "json":
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return _gate_exit(gate)

    m = result["metrics"]
    k = result["top_k"]
    print("eval: strategy=%s  top_k=%d  queries=%d" % (
        result["strategy"], k, result["num_queries"]))
    print("  gold: %s" % gold_path)
    print("  Recall@%d     : %.4f" % (k, m["recall_at_k"]))
    print("  Precision@%d  : %.4f" % (k, m["precision_at_k"]))
    print("  nDCG@%d       : %.4f" % (k, m["ndcg_at_k"]))
    print("  MRR           : %.4f" % m["mrr"])
    print("  latency (ms)  : mean=%.3f  p50=%.3f" % (
        m["latency_ms_mean"], m["latency_ms_p50"]))
    print("  ctx tokens    : mean=%.1f" % m["context_tokens_mean"])
    if recorded is not None:
        print("  recorded: %s  commit=%s  reliability=%.2f  run=%s" % (
            os.path.join(kdir, HISTORY_REL), recorded["commit"],
            recorded["reliability"], recorded["run"]))
    _print_gate(gate)
    return _gate_exit(gate)


def cmd_recall(args):
    """Deterministic BM25 ranked retrieval, token-budgeted (replaces MAIN.md dump).

    Returns the highest-ranked entries (id, path, score, summary) trimmed so the
    cumulative estimated token footprint stays <= --token-budget. The greedy pass
    walks ranked order and STOPS at the first entry that would exceed the budget,
    preserving rank order (INV-5: reduce injected context, never increase it).
    Read-only (INV-2). --format json emits a stable schema for the loop.
    """
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    data, err = load_index(kdir)
    if err is not None:
        sys.stderr.write("agentware: %s\n" % err)
        return 1
    if args.top_k < 0:
        sys.stderr.write("agentware: --top-k must be >= 0\n")
        return 1
    if args.token_budget < 0:
        sys.stderr.write("agentware: --token-budget must be >= 0\n")
        return 1

    ranked = recall_ranked(kdir, data, args.query, top_k=args.top_k,
                           category=args.category)
    results = []
    used = 0
    for entry, score, doc_text in ranked:
        cost = estimate_tokens(doc_text)
        if used + cost > args.token_budget:
            break  # budget exhausted; keep rank order, drop the rest
        used += cost
        results.append({
            "id": entry.get("id"),
            "path": entry.get("path"),
            "category": entry.get("category"),
            "score": round(score, 6),
            "summary": entry.get("summary") or "",
            "estimated_tokens": cost,
        })

    if args.format == "json":
        payload = {
            "query": args.query,
            "strategy": "bm25",
            "top_k": args.top_k,
            "token_budget": args.token_budget,
            "category": args.category,
            "context_tokens": used,
            "count": len(results),
            "results": results,
        }
        json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return 0

    print("recall: query=%r  strategy=bm25  top_k=%d  budget=%d  -> %d entr%s (~%d tokens)"
          % (args.query, args.top_k, args.token_budget, len(results),
             "y" if len(results) == 1 else "ies", used))
    if args.category:
        print("  category: %s" % args.category)
    for r in results:
        print("  [%.4f] %s" % (r["score"], r["id"]))
        print("    %s" % r["path"])
        if r["summary"]:
            print("    %s" % r["summary"])
    return 0


# --- metrics (execution observability over session transcripts) -------------
# Token-usage keys live at message.usage on assistant lines. We sum exactly the
# four canonical keys (NOT cache_read/cache_creation) per the transcript format.
_USAGE_KEYS = (
    "input_tokens",
    "output_tokens",
    "cache_creation_input_tokens",
    "cache_read_input_tokens",
)


def logs_sessions_dir(kdir):
    return os.path.join(kdir, LOGS_SESSIONS_REL)


def _parse_iso(ts):
    """Parse an ISO-8601 timestamp (tolerating a trailing 'Z') to a datetime.

    Returns None on anything unparseable so a single malformed line can never
    crash the parser (transcripts mix control lines that lack timestamps)."""
    if not isinstance(ts, str) or not ts:
        return None
    import datetime
    try:
        return datetime.datetime.fromisoformat(ts.replace("Z", "+00:00"))
    except ValueError:
        return None


def _empty_usage():
    return {k: 0 for k in _USAGE_KEYS}


def aggregate_jsonl(path):
    """Aggregate ONE JSONL transcript file (read-only).

    Returns a dict with: turns (count of assistant lines), usage (summed token
    keys), tools (tool_use name -> count), tool_calls (total), ts_first/ts_last
    (raw ISO strings among lines that HAVE a timestamp), lines (parsed),
    malformed (count of unparseable lines). Tolerates missing files, malformed
    JSON, and lines whose `type` is not assistant/user.
    """
    agg = {
        "turns": 0,
        "usage": _empty_usage(),
        "tools": {},
        "tool_calls": 0,
        "ts_first": None,
        "ts_last": None,
        "_first_dt": None,
        "_last_dt": None,
        "lines": 0,
        "malformed": 0,
    }
    try:
        f = open(path, "r", encoding="utf-8")
    except (FileNotFoundError, IsADirectoryError, OSError):
        return agg
    with f:
        for raw in f:
            raw = raw.strip()
            if not raw:
                continue
            agg["lines"] += 1
            try:
                obj = json.loads(raw)
            except (ValueError, TypeError):
                agg["malformed"] += 1
                continue
            if not isinstance(obj, dict):
                agg["malformed"] += 1
                continue

            dt = _parse_iso(obj.get("timestamp"))
            if dt is not None:
                if agg["_first_dt"] is None or dt < agg["_first_dt"]:
                    agg["_first_dt"] = dt
                    agg["ts_first"] = obj.get("timestamp")
                if agg["_last_dt"] is None or dt > agg["_last_dt"]:
                    agg["_last_dt"] = dt
                    agg["ts_last"] = obj.get("timestamp")

            if obj.get("type") != "assistant":
                continue
            agg["turns"] += 1
            message = obj.get("message")
            if not isinstance(message, dict):
                continue
            usage = message.get("usage")
            if isinstance(usage, dict):
                for k in _USAGE_KEYS:
                    v = usage.get(k)
                    if isinstance(v, (int, float)) and not isinstance(v, bool):
                        agg["usage"][k] += int(v)
            content = message.get("content")
            if isinstance(content, list):
                for item in content:
                    if isinstance(item, dict) and item.get("type") == "tool_use":
                        name = item.get("name") or "<unknown>"
                        agg["tools"][name] = agg["tools"].get(name, 0) + 1
                        agg["tool_calls"] += 1
    return agg


def _merge_usage(into, other):
    for k in _USAGE_KEYS:
        into[k] += other.get(k, 0)


def _merge_tools(into, other):
    for name, count in other.items():
        into[name] = into.get(name, 0) + count


def _duration_seconds(first_dt, last_dt):
    if first_dt is None or last_dt is None:
        return 0.0
    return max(0.0, (last_dt - first_dt).total_seconds())


def parse_session(session_dir):
    """Parse one session directory into a metrics row (read-only).

    Wall time is computed from main.jsonl's first->last timestamped line only.
    Token + tool totals fold in subagents/*.jsonl. subagent_count is the number
    of subagent transcript files. Returns None if there is no main.jsonl.
    """
    main_path = os.path.join(session_dir, "main.jsonl")
    if not os.path.isfile(main_path):
        return None
    main = aggregate_jsonl(main_path)

    usage = _empty_usage()
    _merge_usage(usage, main["usage"])
    tools = dict(main["tools"])
    tool_calls = main["tool_calls"]
    turns = main["turns"]

    sub_dir = os.path.join(session_dir, "subagents")
    subagent_files = []
    if os.path.isdir(sub_dir):
        subagent_files = sorted(
            n for n in os.listdir(sub_dir) if n.endswith(".jsonl"))
    sub_usage = _empty_usage()
    sub_tools = {}
    sub_turns = 0
    for name in subagent_files:
        sa = aggregate_jsonl(os.path.join(sub_dir, name))
        _merge_usage(usage, sa["usage"])
        _merge_usage(sub_usage, sa["usage"])
        _merge_tools(tools, sa["tools"])
        _merge_tools(sub_tools, sa["tools"])
        tool_calls += sa["tool_calls"]
        turns += sa["turns"]
        sub_turns += sa["turns"]

    duration = _duration_seconds(main["_first_dt"], main["_last_dt"])
    total_tokens = sum(usage[k] for k in _USAGE_KEYS)
    return {
        "session_id": os.path.basename(session_dir.rstrip(os.sep)),
        "turns": turns,
        "main_turns": main["turns"],
        "subagent_turns": sub_turns,
        "start": main["ts_first"],
        "end": main["ts_last"],
        "duration_seconds": round(duration, 3),
        "tokens": usage,
        "total_tokens": total_tokens,
        "subagent_tokens": sub_usage,
        "tools": tools,
        "tool_calls": tool_calls,
        "subagent_count": len(subagent_files),
        "malformed_lines": main["malformed"],
    }


def _session_feature_match(session_dir, feature):
    """True iff the session transcript references the feature (deterministic).

    A session 'belongs to' a feature when its main.jsonl mentions the feature
    work dir (work/<feature>) or the bare feature name. Pure substring scan over
    the raw transcript text — no parsing, fully deterministic.
    """
    main_path = os.path.join(session_dir, "main.jsonl")
    try:
        with open(main_path, "r", encoding="utf-8", errors="replace") as f:
            text = f.read()
    except (FileNotFoundError, IsADirectoryError, OSError):
        return False
    needles = (os.path.join("work", feature), feature)
    return any(n in text for n in needles)


def collect_sessions(kdir, session=None, feature=None, since=None):
    """Collect per-session metric rows, deterministically ordered.

    Filters: --session (exact id), --feature (transcript references feature),
    --since (session start date >= since, YYYY-MM-DD). Ordering is by start
    timestamp then session_id (rows lacking a start sort last) so output is
    byte-stable across runs.
    """
    root = logs_sessions_dir(kdir)
    rows = []
    if not os.path.isdir(root):
        return rows
    for name in sorted(os.listdir(root)):
        sdir = os.path.join(root, name)
        if not os.path.isdir(sdir):
            continue
        if session is not None and name != session:
            continue
        if feature is not None and not _session_feature_match(sdir, feature):
            continue
        row = parse_session(sdir)
        if row is None:
            continue
        if since is not None:
            start = row.get("start") or ""
            # Compare the YYYY-MM-DD date prefix lexically (ISO sorts correctly).
            if start[:10] < since:
                continue
        rows.append(row)
    rows.sort(key=lambda r: (r.get("start") is None, r.get("start") or "",
                             r.get("session_id") or ""))
    return rows


def aggregate_metrics(rows):
    """Aggregate per-session rows into feature/global totals."""
    usage = _empty_usage()
    tools = {}
    agg = {
        "session_count": len(rows),
        "turns": 0,
        "tool_calls": 0,
        "subagent_count": 0,
        "duration_seconds": 0.0,
        "tokens": usage,
        "total_tokens": 0,
        "tools": tools,
    }
    for r in rows:
        agg["turns"] += r["turns"]
        agg["tool_calls"] += r["tool_calls"]
        agg["subagent_count"] += r["subagent_count"]
        agg["duration_seconds"] += r["duration_seconds"]
        _merge_usage(usage, r["tokens"])
        _merge_tools(tools, r["tools"])
    agg["duration_seconds"] = round(agg["duration_seconds"], 3)
    agg["total_tokens"] = sum(usage[k] for k in _USAGE_KEYS)
    return agg


def _fmt_duration(seconds):
    seconds = int(round(seconds))
    h, rem = divmod(seconds, 3600)
    m, s = divmod(rem, 60)
    if h:
        return "%dh%02dm%02ds" % (h, m, s)
    if m:
        return "%dm%02ds" % (m, s)
    return "%ds" % s


def _print_metrics_text(rows, agg, flt):
    desc = []
    if flt.get("session"):
        desc.append("session=%s" % flt["session"])
    if flt.get("feature"):
        desc.append("feature=%s" % flt["feature"])
    if flt.get("since"):
        desc.append("since=%s" % flt["since"])
    print("metrics: %d session%s%s" % (
        len(rows), "" if len(rows) == 1 else "s",
        ("  (%s)" % ", ".join(desc)) if desc else ""))
    for r in rows:
        print("  %s  turns=%d  tools=%d  subagents=%d  tokens=%d  wall=%s"
              % (r["session_id"], r["turns"], r["tool_calls"],
                 r["subagent_count"], r["total_tokens"],
                 _fmt_duration(r["duration_seconds"])))
        if r["tools"]:
            parts = ", ".join("%s=%d" % (k, r["tools"][k])
                              for k in sorted(r["tools"]))
            print("    tool calls: %s" % parts)
    print("  ----")
    print("  TOTAL  sessions=%d  turns=%d  tools=%d  subagents=%d  tokens=%d  wall=%s"
          % (agg["session_count"], agg["turns"], agg["tool_calls"],
             agg["subagent_count"], agg["total_tokens"],
             _fmt_duration(agg["duration_seconds"])))
    u = agg["tokens"]
    print("    tokens: in=%d out=%d cache_creation=%d cache_read=%d"
          % (u["input_tokens"], u["output_tokens"],
             u["cache_creation_input_tokens"], u["cache_read_input_tokens"]))


def cmd_metrics(args):
    """Execution observability over session transcripts (READ-ONLY, INV-2).

    Parses logs/sessions/<sid>/main.jsonl (+ subagents/*.jsonl) for turn counts,
    wall time, token usage, tool-call counts and subagent counts. NEVER touches
    index.json or any KB file."""
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    since = getattr(args, "since", None)
    if since is not None and not _is_valid_date(since):
        sys.stderr.write("agentware: --since must be YYYY-MM-DD\n")
        return 1
    rows = collect_sessions(
        kdir, session=getattr(args, "session", None),
        feature=getattr(args, "feature", None), since=since)
    agg = aggregate_metrics(rows)
    flt = {"session": getattr(args, "session", None),
           "feature": getattr(args, "feature", None), "since": since}

    if args.format == "json":
        payload = {"filter": flt, "session_count": len(rows),
                   "sessions": rows, "aggregate": agg}
        json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
        return 0 if rows else 1

    if not rows:
        print("metrics: no matching sessions under %s"
              % logs_sessions_dir(kdir))
        return 1
    _print_metrics_text(rows, agg, flt)
    return 0


def _audit_steering_lint_check():
    result = lint_steering()
    details = []
    if not result["budget_ok"]:
        details.append("char budget exceeded: %d > %d" % (
            result["total_chars"], result["char_budget"]))
    for v in result["violations"]:
        details.append("%s %s:%d %s" % (v["rule"], v["file"], v["line"], v["text"]))
    for b in result["banned_words"]:
        details.append("DSF-5 %s:%d banned %r" % (b["file"], b["line"], b["word"]))
    return {
        "name": "steering_lint",
        "ok": result["ok"],
        "details": details or ["DSF-clean: %d/%d chars" % (
            result["total_chars"], result["char_budget"])],
    }


def _audit_tests_check():
    """Shell the stdlib unittest suite and report pass/fail as an audit check.

    Read-only, hermetic: the suite points the CLI at a synthetic temp KB via
    AGENTWARE_KNOWLEDGE_DIR (see tests/_fixtures.py), so it never touches the
    operator KB. subprocess is stdlib, so INV-6 (stdlib-only) holds.
    """
    tests_dir = os.path.join(REPO_ROOT, "tests")
    if not os.path.isdir(tests_dir):
        return {"name": "unittest", "ok": False,
                "details": ["tests/ directory not found at %s" % tests_dir]}
    try:
        proc = subprocess.run(
            [sys.executable, "-m", "unittest", "discover", "-s", "tests"],
            cwd=REPO_ROOT, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True)
    except OSError as exc:
        return {"name": "unittest", "ok": False,
                "details": ["could not launch unittest: %s" % exc]}
    ok = proc.returncode == 0
    lines = [ln for ln in (proc.stderr or "").splitlines() if ln.strip()]
    ran_line = next((ln for ln in lines if ln.startswith("Ran ")), "")
    details = [ran_line.strip() or ("unittest exit %d" % proc.returncode)]
    if not ok:
        details.extend(lines[-12:])
    return {"name": "unittest", "ok": ok, "details": details}


def _audit_gate_check(kdir):
    """Run the benchmark regression gate as the audit's INV-7 enforcement.

    Shells `eval --strategy bm25 --gate --format json` as an isolated subprocess
    (so it measures an honest reliability via its own test pass-rate and stays
    decoupled from this process), then regenerates SCORECARD.md from the freshly
    appended row. FAILS the audit on a beyond-tolerance regression (non-zero
    gate exit). A first-ever run seeds + passes. When no gold set exists yet the
    check is a soft pass (nothing to benchmark). Read-only w.r.t. index.json;
    only appends to the append-only ledger + regenerates the derived scorecard.
    """
    gold = os.path.join(kdir, "benchmarks", "recall-gold.json")
    if not os.path.isfile(gold):
        return {"name": "benchmark_gate", "ok": True,
                "details": ["no gold set at %s; skipped" % gold]}
    env = dict(os.environ)
    env["AGENTWARE_KNOWLEDGE_DIR"] = kdir
    try:
        proc = subprocess.run(
            [sys.executable, os.path.join(REPO_ROOT, "scripts", "agentware"),
             "eval", "--strategy", "bm25", "--gate", "--format", "json"],
            cwd=REPO_ROOT, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            universal_newlines=True, env=env)
    except OSError as exc:
        return {"name": "benchmark_gate", "ok": False,
                "details": ["could not launch eval --gate: %s" % exc]}
    ok = proc.returncode == 0
    details = []
    try:
        payload = json.loads(proc.stdout)
        g = payload.get("gate", {}) or {}
        rec = payload.get("recorded", {}) or {}
        if g.get("seeded"):
            details.append("seeded baseline (no prior bm25 history)")
        details.append("reliability=%.2f commit=%s tolerance=%.4f" % (
            rec.get("reliability", 0.0), rec.get("commit", "?"),
            g.get("tolerance", 0.0)))
        for r in g.get("regressions", []) or []:
            details.append("REGRESSION %s best=%.4f current=%.4f" % (
                r.get("metric"), r.get("baseline", 0.0), r.get("current", 0.0)))
    except ValueError:
        details.append("eval --gate exit %d" % proc.returncode)
        if not ok:
            details.extend((proc.stderr or "").splitlines()[-6:])
    try:
        write_scorecard(kdir)
    except OSError as exc:
        details.append("scorecard regen failed: %s" % exc)
    return {"name": "benchmark_gate", "ok": ok, "details": details}


def _audit_personal_data_check(kdir):
    """R-LOC-03 guard: the package must ship ZERO operator personal data.

    Resolves the LIVE operator identity (handle, email, HOME path) at runtime
    and scans the package tree (REPO_ROOT) for those exact strings. Hardcodes
    nothing, so the package still ships zero personal data. FAILS if any leak is
    present. Read-only.
    """
    needles = operator_identity_strings(kdir)
    hits = scan_personal_data(REPO_ROOT, needles)
    return {
        "name": "personal_data",
        "ok": not hits,
        "details": hits or [
            "clean: no operator identity in package tree "
            "(%d needle(s) checked)" % len(needles)],
    }


# --- Freshness & conflict detection (Phase 2.2) ------------------------------
# "Volatile" categories whose facts decay (R-FAIL-08): treat a point-in-time
# value as suspect once its last_verified is older than the staleness window.
VOLATILE_CATEGORIES = ("learnings", "configurations")
# Token-set Jaccard at/above this threshold flags a same-category pair as a
# possible duplicate/conflict. Reporting only; never auto-mutates the KB (INV-2).
_CONFLICT_JACCARD = 0.6


def stale_entries(data, max_age_days, today=None):
    """Return [(entry, age_days), ...] for volatile-category entries whose
    effective last_verified is older than max_age_days.

    Deterministic given `today` (defaults to the system date — reporting only,
    so wall-clock here is fine; INV-1 forbids wall-clock in RANKING, not in this
    advisory freshness report). Entries with no valid date are skipped. Ordering:
    oldest first, then id asc. Read-only (INV-2).
    """
    import datetime
    today = today or _today()
    try:
        today_d = datetime.date.fromisoformat(today)
    except ValueError:
        return []
    out = []
    for e in data.get("entries") or []:
        if not isinstance(e, dict):
            continue
        if (e.get("category") or "") not in VOLATILE_CATEGORIES:
            continue
        lv = entry_last_verified(e)
        if not _is_valid_date(lv):
            continue
        age = (today_d - datetime.date.fromisoformat(lv)).days
        if age > max_age_days:
            out.append((e, age))
    out.sort(key=lambda ea: ea[0].get("id") or "")          # id asc
    out.sort(key=lambda ea: ea[1], reverse=True)            # oldest first
    return out


def conflict_pairs(kdir, data, threshold=_CONFLICT_JACCARD):
    """Return [(entry_a, entry_b, jaccard), ...] for same-category entry pairs
    whose token-set Jaccard >= threshold (possible duplicate/conflict).

    Token sets come from the shared corpus document (title+summary+tags+body)
    via the same tokenizer BM25 uses, so flagging is deterministic and stable.
    Read-only (INV-2); reporting only — never auto-deletes/merges. Ordering:
    highest similarity first, then (id_a, id_b) asc.
    """
    corpus = build_corpus(kdir, data)
    items = [(e, set(tokenize(text))) for (e, text) in corpus]
    pairs = []
    for i in range(len(items)):
        ei, si = items[i]
        if not si:
            continue
        for j in range(i + 1, len(items)):
            ej, sj = items[j]
            if not sj:
                continue
            if (ei.get("category") or "") != (ej.get("category") or ""):
                continue
            union = si | sj
            if not union:
                continue
            jac = len(si & sj) / len(union)
            if jac >= threshold:
                pairs.append((ei, ej, round(jac, 6)))
    pairs.sort(key=lambda p: ((p[0].get("id") or ""), (p[1].get("id") or "")))
    pairs.sort(key=lambda p: p[2], reverse=True)            # most similar first
    return pairs


def build_stale_report(kdir, data, max_age_days):
    """Build the advisory staleness + conflict report dict. Reporting only."""
    stale = stale_entries(data, max_age_days)
    conflicts = conflict_pairs(kdir, data)
    return {
        "max_age_days": max_age_days,
        "volatile_categories": list(VOLATILE_CATEGORIES),
        "stale": [
            {"id": e.get("id"), "category": e.get("category"),
             "path": e.get("path"), "last_verified": entry_last_verified(e),
             "age_days": age}
            for (e, age) in stale
        ],
        "conflicts": [
            {"a": a.get("id"), "b": b.get("id"),
             "category": a.get("category"), "jaccard": jac}
            for (a, b, jac) in conflicts
        ],
    }


def _print_stale_report(report):
    print("STALE REPORT (advisory — reporting only, no mutation):")
    print("  window: last_verified older than %d day(s) in %s" % (
        report["max_age_days"], ", ".join(report["volatile_categories"])))
    if report["stale"]:
        print("  stale entries (%d):" % len(report["stale"]))
        for s in report["stale"]:
            print("    - %s [%s] last_verified=%s age=%dd" % (
                s["id"], s["category"], s["last_verified"], s["age_days"]))
    else:
        print("  stale entries: none")
    if report["conflicts"]:
        print("  possible duplicate/conflict pairs (%d, Jaccard >= %.2f):" % (
            len(report["conflicts"]), _CONFLICT_JACCARD))
        for c in report["conflicts"]:
            print("    - %s <-> %s [%s] jaccard=%.4f" % (
                c["a"], c["b"], c["category"], c["jaccard"]))
    else:
        print("  possible duplicate/conflict pairs: none")


def cmd_audit(args):
    kdir = require_knowledge_dir()
    if not kdir:
        return 1
    as_json = getattr(args, "format", "text") == "json"
    data, err = load_index(kdir)
    if err is not None:
        checks = [{"name": "index_validate", "ok": False, "details": [err]}]
    else:
        ve = validate_index(kdir, data)
        un = scan_unindexed(kdir, data)
        te = tag_consistency_errors(data)
        tce = template_conformance_errors(kdir, data)
        oe = orphaned_learning_errors(kdir, data)
        checks = [
            {"name": "index_validate", "ok": not ve, "details": ve},
            {"name": "filesystem_sync", "ok": not un, "details": un},
            {"name": "tag_consistency", "ok": not te, "details": te},
            {"name": "template_conformance", "ok": not tce, "details": tce},
            {"name": "orphaned_learnings", "ok": not oe, "details": oe},
            _audit_steering_lint_check(),
            _audit_personal_data_check(kdir),
        ]
    if getattr(args, "with_tests", False):
        checks.append(_audit_tests_check())
        if err is None:
            checks.append(_audit_gate_check(kdir))
    stale_report = None
    if getattr(args, "stale", False) and err is None:
        stale_report = build_stale_report(
            kdir, data, getattr(args, "max_age_days", 120))
    ok = all(c["ok"] for c in checks)
    if as_json:
        payload = {"ok": ok, "checks": checks}
        if stale_report is not None:
            payload["stale_report"] = stale_report
        json.dump(payload, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("AUDIT %s (%d check(s)):" % ("PASSED" if ok else "FAILED", len(checks)))
        for c in checks:
            print("  [%s] %s" % ("ok" if c["ok"] else "FAIL", c["name"]))
            if not c["ok"]:
                for d in c["details"]:
                    print("      - %s" % d)
        if stale_report is not None:
            _print_stale_report(stale_report)
    return 0 if ok else 1


# --- Steering DSF lint -------------------------------------------------------
def _steering_files():
    files = []
    for name in STEERING_EXPLICIT:
        p = os.path.join(REPO_ROOT, name)
        if os.path.exists(p):
            files.append(p)
    files.extend(sorted(glob.glob(STEERING_GLOB)))
    return files


def _iter_rule_lines(text):
    lines = text.splitlines()
    in_front = in_code = False
    for i, raw in enumerate(lines, 1):
        stripped = raw.strip()
        if i == 1 and stripped == "---":
            in_front = True
            continue
        if in_front:
            if stripped == "---":
                in_front = False
            continue
        if stripped.startswith("```"):
            in_code = not in_code
            continue
        if in_code:
            continue
        m = DSF_BULLET_RE.match(raw)
        if not m:
            continue
        body = m.group(1).strip()
        if body:
            yield i, body


def _first_token_verb(body):
    first = body.split()[0]
    return first.strip("*_`").rstrip(":.,")


def lint_steering():
    violations, banned_words = [], []
    total_chars = 0
    for path in _steering_files():
        try:
            text = open(path, "r", encoding="utf-8").read()
        except OSError as exc:
            violations.append({"rule": "DSF-read", "file": path,
                               "line": 0, "text": str(exc)})
            continue
        total_chars += len(text)
        for lineno, body in _iter_rule_lines(text):
            verb = _first_token_verb(body)
            if verb not in DSF_VERBS:
                violations.append({"rule": "DSF-2", "file": path, "line": lineno,
                                   "text": body})
            if not DSF_RULE_ID_RE.search(body):
                violations.append({"rule": "DSF-6", "file": path, "line": lineno,
                                   "text": body})
            low = body.lower()
            for w in DSF_BANNED_WORDS:
                if re.search(r"\b" + re.escape(w) + r"\b", low):
                    banned_words.append({"file": path, "line": lineno,
                                         "word": w, "text": body})
    budget_ok = total_chars <= STEERING_CHAR_BUDGET
    ok = (not violations) and (not banned_words) and budget_ok
    return {"ok": ok, "total_chars": total_chars, "char_budget": STEERING_CHAR_BUDGET,
            "budget_ok": budget_ok, "violations": violations,
            "banned_words": banned_words}


def cmd_steering_lint(args):
    result = lint_steering()
    as_json = getattr(args, "format", "text") == "json"
    if as_json:
        json.dump(result, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("STEERING LINT %s" % ("PASSED" if result["ok"] else "FAILED"))
        print("  chars: %d / %d (budget %s)" % (
            result["total_chars"], result["char_budget"],
            "ok" if result["budget_ok"] else "EXCEEDED"))
        for v in result["violations"]:
            print("  [%s] %s:%d  %s" % (v["rule"], v["file"], v["line"], v["text"]))
        for b in result["banned_words"]:
            print("  [DSF-5] %s:%d  banned %r in: %s" % (
                b["file"], b["line"], b["word"], b["text"]))
    return 0 if result["ok"] else 1


# --- KB git sync -------------------------------------------------------------
# Pure-git helpers for the conflict-safe knowledge-base sync (feature
# 260625-kb-git-sync). NO new dependency: shells the operator's `git` only. All
# helpers operate on an explicit directory so tests can drive throwaway temp
# repos (NEVER the operator's real $KDIR) and never raise on a non-repo dir.

def _git(target, *args, **kwargs):
    """Run `git -C <target> <args>`; return the CompletedProcess.

    Never raises on a non-zero exit (check=False); callers inspect returncode.
    Captures stdout/stderr as text. If the `git` binary is absent the
    FileNotFoundError is surfaced as a synthetic returncode 127 so callers can
    degrade to local-only (C-4) without crashing.
    """
    cmd = ["git", "-C", target] + [str(a) for a in args]
    try:
        return subprocess.run(
            cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            text=True, check=False, **kwargs)
    except FileNotFoundError:
        return subprocess.CompletedProcess(cmd, 127, "", "git: command not found")


def git_is_work_tree(target):
    """True iff `target` is inside a git work tree."""
    cp = _git(target, "rev-parse", "--is-inside-work-tree")
    return cp.returncode == 0 and cp.stdout.strip() == "true"


def git_has_upstream(target):
    """True iff the current branch has a configured upstream tracking branch.

    This is the precise precondition for a fast-forward pull / push: a bare
    remote alone is not enough — the branch must track an upstream (`@{u}`).
    """
    if not git_is_work_tree(target):
        return False
    cp = _git(target, "rev-parse", "--abbrev-ref",
              "--symbolic-full-name", "@{upstream}")
    return cp.returncode == 0 and bool(cp.stdout.strip())


def git_is_clean(target):
    """True iff the work tree has no staged/unstaged/untracked changes."""
    if not git_is_work_tree(target):
        return False
    cp = _git(target, "status", "--porcelain")
    return cp.returncode == 0 and cp.stdout.strip() == ""


def git_status(target):
    """Report the three KB git-state booleans as a dict.

    has_upstream / is_clean are forced False on a non-work-tree so the shape is
    always the same regardless of the target.
    """
    iwt = git_is_work_tree(target)
    return {
        "is_work_tree": iwt,
        "has_upstream": git_has_upstream(target) if iwt else False,
        "is_clean": git_is_clean(target) if iwt else False,
    }


def cmd_kb_git_status(args):
    """Print the KB git-state booleans (is_work_tree / has_upstream / is_clean).

    Targets the resolved knowledge dir by default; `--path` overrides it so the
    loop (and tests) can point at a throwaway repo. NEVER mutates anything.
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1
    st = git_status(target)
    if getattr(args, "format", "text") == "json":
        json.dump(st, sys.stdout, ensure_ascii=False, indent=2)
        sys.stdout.write("\n")
    else:
        print("is_work_tree: %s" % ("yes" if st["is_work_tree"] else "no"))
        print("has_upstream: %s" % ("yes" if st["has_upstream"] else "no"))
        print("is_clean:     %s" % ("yes" if st["is_clean"] else "no"))
    return 0


def git_toplevel(target):
    """Absolute path of `target`'s git work-tree root, or None if not a repo."""
    cp = _git(target, "rev-parse", "--show-toplevel")
    if cp.returncode != 0:
        return None
    top = cp.stdout.strip()
    return os.path.realpath(top) if top else None


def git_changed_paths(target):
    """Repo-relative paths with pending changes (staged, unstaged, untracked).

    Parses `status --porcelain` (machine-stable). Rename entries (`old -> new`)
    contribute the NEW path. Returns a de-duplicated, sorted list.
    """
    cp = _git(target, "status", "--porcelain")
    if cp.returncode != 0:
        return []
    paths = set()
    for line in cp.stdout.splitlines():
        if len(line) < 4:
            continue
        p = line[3:]
        if " -> " in p:  # rename / copy: take the destination
            p = p.split(" -> ", 1)[1]
        p = p.strip().strip('"')
        if p:
            paths.add(p)
    return sorted(paths)


def _sanitize_commit_tag(tag):
    """Lowercase + restrict a commit scope tag to [a-z0-9._-] (collapsed `-`)."""
    tag = (tag or "kb").strip().lower()
    tag = re.sub(r"[^a-z0-9._-]+", "-", tag).strip("-._")
    return tag or "kb"


# Conventional-commit subject the auto-commit must satisfy: feat|chore(scope): msg
COMMIT_MSG_RE = re.compile(r"^(feat|chore)\([a-z0-9._-]+\): .+")


def cmd_kb_git_commit(args):
    """Stage + commit ONLY the knowledge-base repo as one conventional commit.

    Deterministic, opt-in commit discipline (feature 260625-kb-git-sync, Task
    2.1). Scope is the KB repo ONLY (C-3): the helper operates with `git -C
    <target>` against a SEPARATE git repo and refuses if the target's work-tree
    root resolves to the agentware package repo, so the project/package can
    never be staged. No-ops (rc 0) on a non-tracked KB (C-4) or a clean tree.

    Message format is ENFORCED: `feat|chore(<tag>): <summary>`. The tag is
    derived deterministically (caller-supplied --tag, sanitized); when --message
    is omitted a deterministic summary of the changed top-level dirs is built.
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1

    # C-4: degrade to local-only (no failure) when the KB is not a git repo.
    if not git_is_work_tree(target):
        print("kb-git commit: %s is not a git work tree — skipping commit "
              "(local-only)." % target)
        return 0

    # C-3 scope guard: NEVER commit the agentware package repo. The KB is a
    # separate repo; if the target somehow resolves to this package's work-tree
    # root, refuse loudly rather than stage package/project files.
    top = git_toplevel(target)
    pkg_top = git_toplevel(REPO_ROOT)
    if top and pkg_top and top == pkg_top:
        sys.stderr.write(
            "kb-git commit: refusing — target resolves to the agentware "
            "package repo (%s); commits are scoped to the KB repo only "
            "(C-3).\n" % top)
        return 1

    changed = git_changed_paths(target)
    if not changed:
        print("kb-git commit: nothing to commit — work tree clean.")
        return 0

    tag = _sanitize_commit_tag(getattr(args, "tag", None))
    ctype = getattr(args, "type", None) or "chore"
    message = getattr(args, "message", None)
    if not message:
        tops = sorted({p.split("/", 1)[0] for p in changed})
        n = len(changed)
        message = "sync %s (%d file%s)" % (
            ", ".join(tops), n, "" if n == 1 else "s")

    subject = "%s(%s): %s" % (ctype, tag, message)
    if not COMMIT_MSG_RE.match(subject):
        sys.stderr.write(
            "kb-git commit: refusing — message '%s' does not match "
            "feat|chore(<tag>): <summary>.\n" % subject)
        return 1

    # Stage ONLY this repo (git -C <target> scopes the add to <target>'s repo).
    add = _git(target, "add", "-A")
    if add.returncode != 0:
        sys.stderr.write("kb-git commit: git add failed: %s\n" % add.stderr.strip())
        return 1

    commit = _git(target, "commit", "-m", subject)
    if commit.returncode != 0:
        sys.stderr.write("kb-git commit: git commit failed: %s\n"
                         % (commit.stderr.strip() or commit.stdout.strip()))
        return 1

    head = _git(target, "rev-parse", "HEAD").stdout.strip()
    print("kb-git commit: %s — %s" % (head[:9], subject))
    return 0


def git_pull_ff(target):
    """Fast-forward-only `git pull`; non-interactive (never prompts for input).

    Returns the CompletedProcess. `GIT_TERMINAL_PROMPT=0` makes an offline /
    auth-required fetch fail fast instead of hanging for credentials
    (R-SHELL-01), and `--ff-only` refuses to create a merge commit — a divergent
    upstream is reported as a non-zero exit the caller treats as a graceful skip
    (the push/rebase path, Phase 4, owns real divergence).
    """
    env = dict(os.environ)
    env["GIT_TERMINAL_PROMPT"] = "0"
    return _git(target, "pull", "--ff-only", env=env)


def cmd_kb_git_pull(args):
    """Fast-forward the KB repo from its upstream at a safe point.

    Pull cadence (feature 260625-kb-git-sync, Task 3.1): run at agent start and
    again right before a push. Preconditions — the target is a git work tree
    (C-4), has a configured upstream, and the tree is CLEAN (prior writes must be
    committed first; we NEVER pull onto uncommitted edits). Any unmet
    precondition, an offline fetch, or a non-fast-forward divergence is a
    graceful SKIP (rc 0 + a clear notice) — pulling NEVER blocks work. Beyond the
    fast-forward this mutates nothing.
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1

    # C-4: degrade to local-only (never block) when the KB is not a git repo.
    if not git_is_work_tree(target):
        print("kb-git pull: %s is not a git work tree — skipping pull "
              "(local-only)." % target)
        return 0

    if not git_has_upstream(target):
        print("kb-git pull: no upstream tracking branch — skipping pull "
              "(local-only).")
        return 0

    # Precondition: a clean tree. Prior writes must be committed first so a
    # fast-forward can never clobber or conflict with uncommitted edits.
    if not git_is_clean(target):
        print("kb-git pull: work tree has uncommitted changes — skipping pull "
              "(commit first; never pulling onto uncommitted writes).")
        return 0

    cp = git_pull_ff(target)
    if cp.returncode != 0:
        detail = [l for l in (cp.stderr or "").strip().splitlines() if l.strip()]
        first = detail[0] if detail else "fetch failed"
        print("kb-git pull: skipped — %s (offline or diverged; not blocking "
              "work)." % first)
        return 0

    out_lines = [l for l in (cp.stdout or "").strip().splitlines() if l.strip()]
    summary = out_lines[0] if out_lines else "up to date"
    print("kb-git pull: %s" % summary)
    return 0


def _is_derived_rel(rel):
    """True iff a KB-relative path is a DERIVED file regenerated by `index rebuild`.

    The derived set is exactly `index.json`, `FEATURES.md`, and each
    `<sub>/index.md` roster (sub in KNOWLEDGE_SUBDIRS). These are NEVER merged by
    hand or by an agent (C-1) — conflicts in them are resolved deterministically
    by rebuilding from the union of entry frontmatter.
    """
    rel = rel.strip().strip('"')
    if rel in ("index.json", "FEATURES.md"):
        return True
    parts = rel.split("/")
    return (len(parts) == 2 and parts[1] == "index.md"
            and parts[0] in KNOWLEDGE_SUBDIRS)


def git_unmerged_paths(target):
    """Repo-relative paths currently in a conflicted (unmerged) state, sorted."""
    cp = _git(target, "diff", "--name-only", "--diff-filter=U")
    if cp.returncode != 0:
        return []
    return sorted({l.strip().strip('"') for l in cp.stdout.splitlines()
                   if l.strip()})


def git_rebase_in_progress(target):
    """True iff a rebase is currently paused/in progress in `target`.

    Checks both git rebase backends (merge → `rebase-merge`, am → `rebase-apply`)
    via `rev-parse --git-path`, which respects worktrees. Used by the prose-merge
    path (Phase 5): `kb-git push --on-prose-conflict pause` leaves a rebase in
    progress for the MERGE_PROMPT, and `kb-git merge-continue` only proceeds when
    one is actually in progress.
    """
    for marker in ("rebase-merge", "rebase-apply"):
        cp = _git(target, "rev-parse", "--git-path", marker)
        if cp.returncode != 0:
            continue
        p = cp.stdout.strip()
        if not p:
            continue
        if not os.path.isabs(p):
            p = os.path.join(target, p)
        if os.path.isdir(p):
            return True
    return False


def file_has_conflict_markers(path):
    """True iff `path` still contains git conflict markers (`<<<<<<<`/`>>>>>>>`).

    Only the 7-angle-bracket markers are checked: they never occur in normal
    prose/markdown, so this avoids false positives on a `=======` setext heading
    or horizontal rule. The nothing-lost prose merge (Phase 5) refuses to continue
    a rebase while any reconciled entry file still carries an unresolved marker.
    """
    try:
        with open(path, encoding="utf-8", errors="replace") as f:
            for line in f:
                if line.startswith("<<<<<<<") or line.startswith(">>>>>>>"):
                    return True
    except OSError:
        return False
    return False


def _git_noninteractive_env():
    """Env that makes git fail fast instead of prompting (stdin/editor/creds)."""
    env = dict(os.environ)
    env["GIT_TERMINAL_PROMPT"] = "0"  # never prompt for credentials (R-SHELL-01)
    env["GIT_EDITOR"] = "true"        # never open an editor (rebase --continue)
    return env


def git_push(target):
    """`git push` to the upstream; non-interactive. Returns the CompletedProcess."""
    return _git(target, "push", env=_git_noninteractive_env())


def _push_was_rejected(cp):
    """True iff a non-zero push failed because the upstream moved (non-fast-forward).

    Distinguishes a resolvable rejection (rebase + retry) from an offline / auth /
    network failure (graceful skip, C-4). Matches git's stable wording.
    """
    blob = ((cp.stderr or "") + (cp.stdout or "")).lower()
    return ("rejected" in blob or "non-fast-forward" in blob
            or "fetch first" in blob or "updates were rejected" in blob)


# Distinct return code for a re-push RACE (upstream moved again between our
# resolve and our push). It is recoverable — `kb_git_push_synced` retries the
# whole pull→resolve→push up to a bounded cap (C-2) — so it is kept separate from
# a fail-loud rc 1. Never surfaced to a CLI caller: the wrapper maps an exhausted
# race to a plain rc 1.
RC_REPUSH_RACE = 4


def git_entry_ids_at_ref(target, ref):
    """Set of entry frontmatter IDs present at a git ref's tree, or None.

    Lists the tree at `ref` WITHOUT a checkout (`git ls-tree -r`), keeps only
    indexable entry files (the same `<sub>/…md` candidate rule as
    `scan_entry_files`, minus the `<sub>/index.md` rosters), reads each blob via
    `git show <ref>:<path>`, and parses its frontmatter `id`. Returns None when
    `ref` does not resolve, so the nothing-lost gate can SKIP an unavailable
    parent (e.g. `@{upstream}` during a detached-HEAD rebase) rather than
    mis-count it as empty. Pure git — no new dependency (C-5).
    """
    ls = _git(target, "ls-tree", "-r", "--name-only", ref)
    if ls.returncode != 0:
        return None
    ids = set()
    for rel in ls.stdout.splitlines():
        rel = rel.strip().strip('"')
        if not rel.endswith(".md"):
            continue
        parts = rel.split("/")
        if parts[0] not in KNOWLEDGE_SUBDIRS:
            continue
        if not _is_sync_candidate(rel):
            continue
        show = _git(target, "show", "%s:%s" % (ref, rel))
        if show.returncode != 0:
            continue
        fields, _body = split_frontmatter(show.stdout)
        if fields and fields.get("id"):
            ids.add(fields["id"])
    return ids


def kb_entry_ids(target):
    """Set of entry frontmatter IDs in the WORKING TREE at `target`.

    The same enumeration the index derives from (`scan_entry_files` +
    `read_entry_frontmatter`); used by the nothing-lost gate to compute the
    MERGED entry-ID set after a resolution.
    """
    ids = set()
    for rel in scan_entry_files(target):
        fm = read_entry_frontmatter(os.path.join(target, rel))
        if fm.get("id"):
            ids.add(fm["id"])
    return ids


def kb_nothing_lost_gate(target, parent_refs):
    """Mechanical "nothing lost" gate after a merge resolution (C-2).

    Runs ON the resolved work tree, BEFORE the network push, so a lossy or
    invalid merge is REJECTED before it can reach the remote:

      1. index rebuild → index validate: re-derive the index from frontmatter
         (`build_index_from_frontmatter`, read-only — writes nothing) and validate
         it. Any frontmatter / validation error fails the gate.
      2. entry-ID superset check: the merged entry-ID set MUST be a SUPERSET of
         the UNION of every resolvable parent's entry-ID set. A parent ref that
         does not resolve is skipped (not counted as empty). If any id was dropped
         the gate fails.

    Returns (ok, note). The caller aborts/leaves the rebase and fails loud on a
    False result — no silent loss. Deterministic, no agent, no new dependency.
    """
    data, errors = build_index_from_frontmatter(target)
    if errors:
        return False, ("nothing-lost gate: invalid frontmatter after merge: %s"
                       % "; ".join(errors))
    verrs = validate_index(target, data)
    if verrs:
        return False, ("nothing-lost gate: index invalid after merge: %s"
                       % "; ".join(verrs))

    merged = {e.get("id") for e in data["entries"] if e.get("id")}
    union = set()
    for ref in parent_refs:
        if not ref:
            continue
        pids = git_entry_ids_at_ref(target, ref)
        if pids is None:
            continue  # parent ref unavailable (e.g. detached @{upstream}) — skip
        union |= pids
    dropped = union - merged
    if dropped:
        return False, ("nothing-lost gate: merge would DROP entry id(s): %s — "
                       "merged set is not a superset of the parents (C-2 abort)"
                       % ", ".join(sorted(dropped)))
    return True, ("nothing-lost gate: ok (%d merged id(s) ⊇ %d parent id(s))"
                  % (len(merged), len(union)))


def _git_upstream_name(target):
    """The current branch's upstream ref name (e.g. `origin/main`), or "".

    Resolved while ON the branch (before any rebase detaches HEAD) so the
    nothing-lost gate can reference the upstream parent by a concrete name that
    still resolves mid-rebase.
    """
    cp = _git(target, "rev-parse", "--abbrev-ref",
              "--symbolic-full-name", "@{upstream}")
    return cp.stdout.strip() if cp.returncode == 0 else ""


def kb_git_push_once(target, on_prose_conflict="abort"):
    """One push attempt with deterministic derived-file conflict resolution.

    Returns (rc, note). rc 0 == pushed or a graceful no-op skip (C-4); rc 1 ==
    fail loud; rc 3 == paused on a prose conflict (only when
    `on_prose_conflict == "pause"`) with the rebase LEFT IN PROGRESS for the
    MERGE_PROMPT — `note` is `"PROSE_CONFLICT\n<rel>\n<rel>..."`. The flow:

      1. push → success: done.
      2. push rejected (upstream moved) → `pull --rebase`.
         - rebase clean → push again.
         - rebase conflicts ONLY in derived files → rebuild from the entry union
           (`rebuild_kb`, C-1, NO agent), stage, `rebase --continue`, push.
         - any conflict in a NON-derived (entry) file → same-entry prose case:
           * on_prose_conflict == "abort" (default): `rebase --abort` + fail loud
             rc 1 (preserves the deterministic, agent-free push contract).
           * on_prose_conflict == "pause" (Phase 5): leave the rebase in progress
             and return rc 3 + the conflicted entry-file list, so the loop can
             reconcile them with the curated MERGE_PROMPT (agentware-execution)
             and then run `kb-git merge-continue`. NO agent is invoked here.
      3. push failed for any other reason (offline/auth) → graceful skip (C-4).

    Every conflict RESOLUTION is verified by the nothing-lost gate (C-2) BEFORE
    the resulting commit is pushed: a lossy or invalid merge aborts the rebase
    and fails loud rather than reaching the remote. A re-push race returns
    RC_REPUSH_RACE so `kb_git_push_synced` can retry within a bounded cap.
    """
    # Captured ON the branch (before any rebase detaches HEAD) so the nothing-lost
    # gate can name the upstream parent with a ref that still resolves mid-rebase.
    upstream_name = _git_upstream_name(target)

    push = git_push(target)
    if push.returncode == 0:
        out = (push.stderr or push.stdout or "").strip().splitlines()
        return 0, "pushed%s" % ((" — " + out[-1]) if out else "")

    if not _push_was_rejected(push):
        first = (push.stderr or "push failed").strip().splitlines()
        return 0, "skipped — %s (offline or no access; not blocking work)" % (
            first[0] if first else "push failed")

    # Upstream moved: rebase our local commits on top of it, resolving any
    # derived-file conflicts deterministically.
    env = _git_noninteractive_env()
    rebase = _git(target, "pull", "--rebase", env=env)
    if rebase.returncode == 0:
        push2 = git_push(target)
        if push2.returncode == 0:
            return 0, "pushed (after fast-forward rebase)"
        # A conflict-free rebase replays every commit verbatim (no synthesized
        # content) so there is nothing for the gate to catch; a rejection here is
        # purely a re-push race for the bounded retry.
        return (RC_REPUSH_RACE,
                "push still rejected after clean rebase (re-push race)")

    unmerged = git_unmerged_paths(target)
    if not unmerged:
        _git(target, "rebase", "--abort", env=env)
        first = (rebase.stderr or "rebase failed").strip().splitlines()
        return 1, "rebase failed: %s" % (first[0] if first else "unknown")

    non_derived = [p for p in unmerged if not _is_derived_rel(p)]
    if non_derived:
        # Same-entry prose conflict — the deterministic path stops here (C-1: an
        # agent NEVER merges via this engine). Two dispositions:
        if on_prose_conflict == "pause":
            # Phase 5: leave the rebase in progress for the curated MERGE_PROMPT.
            # The loop reconciles these entry files via agentware-execution, then
            # calls `kb-git merge-continue` (which rebuilds the derived files).
            return 3, "PROSE_CONFLICT\n" + "\n".join(non_derived)
        # Default: abort cleanly and fail loud rather than touch entry files.
        _git(target, "rebase", "--abort", env=env)
        return 1, ("conflict in non-derived file(s) %s — needs prose merge "
                   "(not auto-resolvable here)" % ", ".join(non_derived))

    # All conflicts are in derived files: regenerate them from the union of
    # entry frontmatter (the entry files themselves merged cleanly). NO agent.
    data, _rosters, errors = rebuild_kb(target)
    if errors:
        _git(target, "rebase", "--abort", env=env)
        return 1, "rebuild during merge failed: %s" % "; ".join(errors)

    add = _git(target, "add", "-A")
    if add.returncode != 0:
        _git(target, "rebase", "--abort", env=env)
        return 1, "git add failed during merge: %s" % add.stderr.strip()

    # Nothing-lost gate (C-2): the resolved (mid-rebase) work tree must rebuild to
    # a valid index whose entry-ID set is a superset of BOTH parents. Fail loud +
    # abort the rebase BEFORE the push if anything was dropped — no silent loss.
    ok, gnote = kb_nothing_lost_gate(target, ["ORIG_HEAD", upstream_name])
    if not ok:
        _git(target, "rebase", "--abort", env=env)
        return 1, gnote

    cont = _git(target, "rebase", "--continue", env=env)
    if cont.returncode != 0:
        _git(target, "rebase", "--abort", env=env)
        first = (cont.stderr or "rebase --continue failed").strip().splitlines()
        return 1, "rebase --continue failed: %s" % (first[0] if first else "")

    push3 = git_push(target)
    if push3.returncode == 0:
        return 0, "pushed (derived files auto-resolved via index rebuild)"
    return (RC_REPUSH_RACE,
            "push rejected after deterministic resolve (re-push race)")


def kb_git_push_synced(target, on_prose_conflict="abort", max_retries=3):
    """`kb_git_push_once` wrapped in a bounded pull→resolve→push retry (C-2).

    Each attempt runs a full `kb_git_push_once` (which itself pulls/rebases and
    resolves derived-file conflicts under the nothing-lost gate). When the upstream
    moves AGAIN between our resolve and our push (`RC_REPUSH_RACE`), we retry the
    whole cycle up to `max_retries` times, then FAIL LOUD (rc 1) — never an
    unbounded loop. Any other disposition (pushed rc 0, graceful skip rc 0, prose
    pause rc 3, fail-loud rc 1) returns immediately. The race sentinel is internal
    and is mapped to a plain rc 1 on exhaustion so callers see a normal failure.
    """
    attempts = max(1, max_retries)
    last_note = "no attempt"
    for attempt in range(1, attempts + 1):
        rc, note = kb_git_push_once(target, on_prose_conflict=on_prose_conflict)
        if rc != RC_REPUSH_RACE:
            return rc, note
        last_note = note  # race — pull/resolve/push again on the next iteration
    return 1, ("push failed after %d re-push race retries: %s (upstream keeps "
               "moving — try again)" % (attempts, last_note))


def cmd_kb_git_push(args):
    """Push KB commits to upstream, auto-resolving derived-file conflicts.

    Git-sync push (feature 260625-kb-git-sync, Task 4.1). Preconditions: the
    target is a git work tree (C-4) with a configured upstream, and is NOT the
    agentware package repo (C-3). A push rejected by a moved upstream is resolved
    by rebasing and regenerating the DERIVED files (`index.json`, rosters,
    `FEATURES.md`) from the entry union via `index rebuild` — never by an agent
    (C-1). Offline / no-upstream / non-repo are graceful rc-0 skips (never block).
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1

    # C-4: degrade to local-only (never block) when the KB is not a git repo.
    if not git_is_work_tree(target):
        print("kb-git push: %s is not a git work tree — skipping push "
              "(local-only)." % target)
        return 0

    # C-3 scope guard: NEVER push the agentware package repo.
    top = git_toplevel(target)
    pkg_top = git_toplevel(REPO_ROOT)
    if top and pkg_top and top == pkg_top:
        sys.stderr.write(
            "kb-git push: refusing — target resolves to the agentware package "
            "repo (%s); sync is scoped to the KB repo only (C-3).\n" % top)
        return 1

    if not git_has_upstream(target):
        print("kb-git push: no upstream tracking branch — skipping push "
              "(local-only).")
        return 0

    mode = getattr(args, "on_prose_conflict", "abort")
    retries = getattr(args, "max_retries", 3) or 3
    rc, note = kb_git_push_synced(target, on_prose_conflict=mode,
                                  max_retries=retries)

    if rc == 3 and note.startswith("PROSE_CONFLICT"):
        # Paused on a same-entry prose conflict (Phase 5). Emit the conflicted
        # entry paths on stdout (one per line) so the loop can feed them to the
        # MERGE_PROMPT; the human note goes to stderr. The rebase is LEFT IN
        # PROGRESS — the loop reconciles, then runs `kb-git merge-continue`.
        files = [l for l in note.splitlines()[1:] if l.strip()]
        for f in files:
            print(f)
        sys.stderr.write(
            "kb-git push: prose conflict in %d entry file(s) — rebase left in "
            "progress; reconcile via the MERGE_PROMPT, then run "
            "`kb-git merge-continue`.\n" % len(files))
        return 3

    stream = sys.stdout if rc == 0 else sys.stderr
    stream.write("kb-git push: %s\n" % note)
    return rc


def kb_git_merge_continue(target):
    """Finish a prose-merge rebase after the agent reconciled the entry files.

    Phase 5 second half. Preconditions: a rebase is in progress (left by
    `kb-git push --on-prose-conflict pause`) and the conflicted ENTRY files have
    been reconciled in the work tree (both sides' facts retained, no conflict
    markers). Deterministic, C-1/C-2:

      1. Require a rebase in progress (else nothing to continue).
      2. Refuse if any reconciled entry file still carries conflict markers — the
         prose merge is incomplete (do NOT continue, do NOT abort: the partial
         work is preserved for another reconciliation pass).
      3. Stage the reconciled entry files, then UNCONDITIONALLY rebuild the
         DERIVED files (`index.json`, rosters, `FEATURES.md`) from the entry
         frontmatter union (`rebuild_kb`) — so even if the agent touched a derived
         file it is overwritten with the canonical regenerated content (C-1).
      4. `rebase --continue`, then push.

    Returns (rc, note). rc 0 == pushed; rc 1 == fail loud (the rebase is left in
    place for inspection, never silently aborted).
    """
    env = _git_noninteractive_env()
    if not git_rebase_in_progress(target):
        return 1, "no rebase in progress — nothing to continue"

    unmerged = git_unmerged_paths(target)
    entry_unmerged = [p for p in unmerged if not _is_derived_rel(p)]
    for rel in entry_unmerged:
        if file_has_conflict_markers(os.path.join(target, rel)):
            return 1, ("unresolved conflict markers remain in %s — prose merge "
                       "incomplete (not continuing; rebase left in place)" % rel)

    # Stage the agent-reconciled entry files (C-1: derived files are NEVER
    # hand-merged — they are regenerated below).
    if entry_unmerged:
        add = _git(target, "add", "--", *entry_unmerged)
        if add.returncode != 0:
            return 1, "git add (entry files) failed: %s" % add.stderr.strip()

    # Regenerate the DERIVED files from the reconciled entry union — never merged.
    data, _rosters, errors = rebuild_kb(target)
    if errors:
        return 1, "rebuild after prose merge failed: %s" % "; ".join(errors)

    add2 = _git(target, "add", "-A")
    if add2.returncode != 0:
        return 1, "git add (derived) failed: %s" % add2.stderr.strip()

    # Nothing-lost gate (C-2): the reconciled (mid-rebase) work tree must rebuild
    # to a valid index whose entry-ID set is a superset of BOTH parents. On
    # failure leave the rebase in place (never silently abort — the partial work
    # is preserved for another reconciliation pass) and fail loud BEFORE the push.
    ok, gnote = kb_nothing_lost_gate(target, ["ORIG_HEAD", "@{upstream}"])
    if not ok:
        return 1, gnote

    cont = _git(target, "rebase", "--continue", env=env)
    if cont.returncode != 0:
        first = (cont.stderr or "rebase --continue failed").strip().splitlines()
        return 1, "rebase --continue failed: %s" % (first[0] if first else "")

    push = git_push(target)
    if push.returncode == 0:
        return 0, "pushed (prose conflict reconciled; derived files rebuilt)"
    return 1, "push rejected after prose merge (re-push race)"


def cmd_kb_git_merge_continue(args):
    """Continue a paused prose-merge rebase, then push (feature 260625-kb-git-sync).

    Runs after the curated MERGE_PROMPT reconciled the conflicted entry markdown.
    Same scope guards as push: a non-repo target is a graceful no-op (C-4), and
    the agentware package repo is refused (C-3). The derived files are always
    rebuilt from frontmatter, never hand-merged (C-1).
    """
    override = getattr(args, "path", None)
    if override:
        target = os.path.abspath(os.path.expanduser(override))
    else:
        target = require_knowledge_dir()
        if not target:
            return 1

    # C-4: degrade to local-only (never block) when the KB is not a git repo.
    if not git_is_work_tree(target):
        print("kb-git merge-continue: %s is not a git work tree — nothing to "
              "continue (local-only)." % target)
        return 0

    # C-3 scope guard: NEVER operate on the agentware package repo.
    top = git_toplevel(target)
    pkg_top = git_toplevel(REPO_ROOT)
    if top and pkg_top and top == pkg_top:
        sys.stderr.write(
            "kb-git merge-continue: refusing — target resolves to the agentware "
            "package repo (%s); sync is scoped to the KB repo only (C-3).\n" % top)
        return 1

    rc, note = kb_git_merge_continue(target)
    stream = sys.stdout if rc == 0 else sys.stderr
    stream.write("kb-git merge-continue: %s\n" % note)
    return rc


# --- Parser construction -----------------------------------------------------
def build_parser():
    fmt_parent = argparse.ArgumentParser(add_help=False)
    fmt_parent.add_argument("--format", choices=("text", "json"), default="text",
                            help="output format (default: text)")

    parser = argparse.ArgumentParser(
        prog="agentware",
        parents=[fmt_parent],
        description="Deterministic CLI toolkit for an agentware workspace.")
    sub = parser.add_subparsers(dest="command", metavar="<command>")
    sub.required = True

    # init -------------------------------------------------------------------
    p_init = sub.add_parser(
        "init", parents=[fmt_parent],
        help="scaffold the external knowledge dir + seed index + write config")
    p_init.add_argument("--knowledge-dir", required=True, dest="knowledge_dir",
                        help="absolute or ~ path to store this operator's knowledge")
    p_init.set_defaults(func=cmd_init)

    # config -----------------------------------------------------------------
    p_cfg = sub.add_parser(
        "config", parents=[fmt_parent], help="show the resolved knowledge dir")
    p_cfg.add_argument("--knowledge-dir-only", action="store_true",
                       dest="knowledge_dir_only",
                       help="print only the bare path (for shell consumers)")
    p_cfg.add_argument("--kb-autocommit-only", action="store_true",
                       dest="kb_autocommit_only",
                       help="print only the resolved KB-autocommit setting (1/0)")
    p_cfg.add_argument("--set-autocommit", dest="set_autocommit",
                       metavar="on|off",
                       help="persist the KB-autocommit setting to "
                            "~/.agentware/config.env (env still overrides per-run)")
    p_cfg.set_defaults(func=cmd_config)

    # index ------------------------------------------------------------------
    p_index = sub.add_parser("index", help="manage the knowledge index.json")
    index_sub = p_index.add_subparsers(dest="index_command", metavar="<subcommand>")
    index_sub.required = True

    p_add = index_sub.add_parser(
        "add", parents=[fmt_parent], help="register a new entry in index.json")
    p_add.add_argument("--id", required=True, help="unique entry id")
    p_add.add_argument("--title", required=True, help="human-readable title")
    p_add.add_argument("--category", required=True,
                       help="one of: %s" % ", ".join(CATEGORIES))
    p_add.add_argument("--path", required=True,
                       help="knowledge-dir-relative path (must exist)")
    p_add.add_argument("--tags", required=True, help="comma-separated tags")
    p_add.add_argument("--summary", required=True, help="one-line summary")
    p_add.add_argument("--created", default=None, help="YYYY-MM-DD (default: today)")
    p_add.add_argument("--last-verified", default=None,
                       help="YYYY-MM-DD freshness date (default: == created)")
    p_add.set_defaults(func=cmd_index_add)

    p_rm = index_sub.add_parser(
        "remove", parents=[fmt_parent], help="unregister an entry from index.json")
    p_rm.add_argument("--id", required=True, help="id of the entry to remove")
    p_rm.set_defaults(func=cmd_index_remove)

    p_val = index_sub.add_parser(
        "validate", parents=[fmt_parent], help="validate index.json integrity")
    p_val.set_defaults(func=cmd_index_validate)

    p_sync = index_sub.add_parser(
        "sync", parents=[fmt_parent], help="report (or --fix) unindexed *.md files")
    p_sync.add_argument("--fix", action="store_true",
                        help="add missing entries instead of just reporting")
    p_sync.set_defaults(func=cmd_index_sync)

    p_migrate = index_sub.add_parser(
        "migrate-frontmatter", parents=[fmt_parent],
        help="one-time: backfill YAML frontmatter into every indexed entry file")
    p_migrate.set_defaults(func=cmd_index_migrate)

    p_rebuild = index_sub.add_parser(
        "rebuild", parents=[fmt_parent],
        help="regenerate index.json + rosters + FEATURES.md from entry frontmatter")
    p_rebuild.set_defaults(func=cmd_index_rebuild)

    # query ------------------------------------------------------------------
    p_query = sub.add_parser(
        "query", parents=[fmt_parent], help="look up entries (O(1) by id/path/tag)")
    q_group = p_query.add_mutually_exclusive_group(required=True)
    q_group.add_argument("--id", help="look up a single entry by id")
    q_group.add_argument("--path", help="look up a single entry by path")
    q_group.add_argument("--category", help="list all entries in a category")
    q_group.add_argument("--tag", help="list all entries carrying a tag")
    p_query.set_defaults(func=cmd_query)

    # learn ------------------------------------------------------------------
    p_learn = sub.add_parser(
        "learn", parents=[fmt_parent], help="create + register a learning file")
    p_learn.add_argument("--topic", required=True, help="filename stem under learnings/")
    p_learn.add_argument("--summary", required=True, help="one-line summary")
    p_learn.add_argument("--tags", required=True, help="comma-separated tags")
    p_learn.add_argument("--content", required=True,
                         help="learning body, or '-' to read from stdin")
    p_learn.set_defaults(func=cmd_learn)

    # features ---------------------------------------------------------------
    p_feat = sub.add_parser(
        "features", parents=[fmt_parent],
        help="regenerate FEATURES.md from the knowledge index.json")
    p_feat.set_defaults(func=cmd_features)

    # worklog ----------------------------------------------------------------
    p_wl = sub.add_parser("worklog", help="worklog utilities")
    wl_sub = p_wl.add_subparsers(dest="worklog_command", metavar="<subcommand>")
    wl_sub.required = True
    p_scan = wl_sub.add_parser(
        "scan", parents=[fmt_parent],
        help="find unpromoted '> LEARNED:' markers in a worklog")
    p_scan.add_argument("--path", required=True, help="path to a worklog.md")
    p_scan.set_defaults(func=cmd_worklog_scan)

    # audit ------------------------------------------------------------------
    p_audit = sub.add_parser(
        "audit", parents=[fmt_parent], help="run all consistency checks in one pass")
    p_audit.add_argument(
        "--with-tests", action="store_true",
        help="also run the unittest suite (tests/) and fail the audit on failure")
    p_audit.add_argument(
        "--stale", action="store_true",
        help="report aged volatile entries + near-duplicate/conflict pairs (advisory)")
    p_audit.add_argument(
        "--max-age-days", type=int, default=120, dest="max_age_days",
        help="staleness window in days for --stale (default: 120)")
    p_audit.set_defaults(func=cmd_audit)

    # recall -----------------------------------------------------------------
    p_recall = sub.add_parser(
        "recall", parents=[fmt_parent],
        help="deterministic BM25 ranked retrieval, token-budgeted")
    p_recall.add_argument("query", help="free-text query to rank KB entries against")
    p_recall.add_argument("--top-k", type=int, default=5, dest="top_k",
                          help="max entries to return before budgeting (default: 5)")
    p_recall.add_argument("--token-budget", type=int, default=1500,
                          dest="token_budget",
                          help="trim so cumulative est. tokens <= budget (default: 1500)")
    p_recall.add_argument("--category", default=None,
                          help="restrict ranking to a single category")
    p_recall.set_defaults(func=cmd_recall)

    # eval -------------------------------------------------------------------
    p_eval = sub.add_parser(
        "eval", parents=[fmt_parent],
        help="benchmark recall over a gold set (Recall@k, precision@k, nDCG@k, MRR)")
    p_eval.add_argument(
        "--gold", default=None,
        help="path to gold set JSON (default: <kdir>/benchmarks/recall-gold.json)")
    p_eval.add_argument("--top-k", type=int, default=5, dest="top_k",
                        help="cutoff k for @k metrics (default: 5)")
    p_eval.add_argument("--strategy", choices=("tag", "bm25"), default="tag",
                        help="retrieval strategy to score (default: tag baseline)")
    p_eval.add_argument("--ablate", action="store_true",
                        help="run the gold set through both tag (baseline) and "
                             "bm25 (treatment) and report the per-metric lift")
    p_eval.add_argument("--record", action="store_true",
                        help="append one immutable commit+UTC-date-stamped row "
                             "(with a 0-100 reliability score) to "
                             "<kdir>/benchmarks/history.jsonl (append-only)")
    p_eval.add_argument("--gate", action="store_true",
                        help="compare this run to the best prior comparable "
                             "ledger row and EXIT NON-ZERO on a regression "
                             "beyond --tolerance (implies --record; seeds + "
                             "passes when there is no prior history)")
    p_eval.add_argument("--tolerance", type=float, default=0.02,
                        help="max allowed drop per headline metric before --gate "
                             "fails (default: 0.02; reliability uses x100 points)")
    p_eval.set_defaults(func=cmd_eval)

    # bench ------------------------------------------------------------------
    p_bench = sub.add_parser("bench", help="benchmark scorecard utilities")
    bench_sub = p_bench.add_subparsers(dest="bench_command", metavar="<subcommand>")
    bench_sub.required = True
    p_score = bench_sub.add_parser(
        "scorecard",
        help="regenerate benchmarks/SCORECARD.md trend table from history.jsonl")
    p_score.set_defaults(func=cmd_bench)

    # metrics ----------------------------------------------------------------
    p_metrics = sub.add_parser(
        "metrics", parents=[fmt_parent],
        help="execution observability over session transcripts (read-only)")
    p_metrics.add_argument("--session", default=None,
                           help="restrict to a single session id")
    p_metrics.add_argument("--feature", default=None,
                           help="sessions whose transcript references the feature")
    p_metrics.add_argument("--since", default=None,
                           help="only sessions starting on/after YYYY-MM-DD")
    p_metrics.set_defaults(func=cmd_metrics)

    # kb-git -----------------------------------------------------------------
    p_kbgit = sub.add_parser(
        "kb-git", help="knowledge-base git sync (detection, commit, pull/push)")
    kbgit_sub = p_kbgit.add_subparsers(dest="kb_git_command", metavar="<subcommand>")
    kbgit_sub.required = True
    p_kbstatus = kbgit_sub.add_parser(
        "status", parents=[fmt_parent],
        help="report is_work_tree / has_upstream / is_clean for the KB repo")
    p_kbstatus.add_argument(
        "--path", default=None,
        help="repo dir to inspect (default: the resolved knowledge dir)")
    p_kbstatus.set_defaults(func=cmd_kb_git_status)

    p_kbcommit = kbgit_sub.add_parser(
        "commit",
        help="stage + commit ONLY the KB repo as one feat|chore(tag): commit")
    p_kbcommit.add_argument(
        "--path", default=None,
        help="KB repo dir to commit (default: the resolved knowledge dir)")
    p_kbcommit.add_argument(
        "--tag", default=None,
        help="commit scope tag (sanitized to [a-z0-9._-]; default: kb)")
    p_kbcommit.add_argument(
        "--type", choices=("feat", "chore"), default="chore",
        help="conventional-commit type (default: chore)")
    p_kbcommit.add_argument(
        "--message", default=None,
        help="commit summary (default: deterministic changed-dirs summary)")
    p_kbcommit.set_defaults(func=cmd_kb_git_commit)

    p_kbpull = kbgit_sub.add_parser(
        "pull",
        help="fast-forward the KB repo from upstream at a safe point (no-op "
             "when dirty / offline / no upstream)")
    p_kbpull.add_argument(
        "--path", default=None,
        help="KB repo dir to pull (default: the resolved knowledge dir)")
    p_kbpull.set_defaults(func=cmd_kb_git_pull)

    p_kbpush = kbgit_sub.add_parser(
        "push",
        help="push KB commits to upstream, auto-resolving derived-file "
             "conflicts via index rebuild (no-op when offline / no upstream)")
    p_kbpush.add_argument(
        "--path", default=None,
        help="KB repo dir to push (default: the resolved knowledge dir)")
    p_kbpush.add_argument(
        "--on-prose-conflict", dest="on_prose_conflict",
        choices=("abort", "pause"), default="abort",
        help="same-entry (non-derived) conflict disposition: 'abort' fails loud "
             "(default); 'pause' leaves the rebase in progress + lists the "
             "conflicted entry files (rc 3) for the MERGE_PROMPT")
    p_kbpush.add_argument(
        "--max-retries", dest="max_retries", type=int, default=3,
        help="bounded pull→resolve→push retries on a re-push race before "
             "failing loud (default: 3)")
    p_kbpush.set_defaults(func=cmd_kb_git_push)

    p_kbcont = kbgit_sub.add_parser(
        "merge-continue",
        help="continue a paused prose-merge rebase after the entry files were "
             "reconciled, rebuild derived files, then push")
    p_kbcont.add_argument(
        "--path", default=None,
        help="KB repo dir to continue (default: the resolved knowledge dir)")
    p_kbcont.set_defaults(func=cmd_kb_git_merge_continue)

    # steering ---------------------------------------------------------------
    p_steer = sub.add_parser("steering", help="Deterministic Steering Format tooling")
    steer_sub = p_steer.add_subparsers(dest="steering_command", metavar="<subcommand>")
    steer_sub.required = True
    p_lint = steer_sub.add_parser(
        "lint", parents=[fmt_parent], help="enforce DSF on always-loaded steering")
    p_lint.set_defaults(func=cmd_steering_lint)

    return parser


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
